  <% if flash[:error] %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <%= flash[:error] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center mb-4">
<!--    <h1 class="mb-0">Establecimientos</h1>-->
    <% if current_user.administrador? %>

      <%= link_to select_affiliate_establishments_path, class: "btn btn-primary btn-lg" do %>
        <i class="fa-solid fa-plus"></i> Nuevo
      <% end %>
    <% end %>

    <% if current_user.afiliado? %>

      <%= link_to choose_type_establishments_path, class: "btn btn-primary btn-lg" do %>
        <i class="fa-solid fa-plus"></i> Nuevo
      <% end %>
    <% end %>
  </div>

  <%#= form_tag establishments_path, method: :get, class: "mb-4" do %>
<!--    <div class="input-group">-->
      <%#= text_field_tag :search, params[:search], class: "form-control", placeholder: "Buscar establecimiento..." %>
<!--      <button class="btn btn-outline-primary" type="submit">-->
<!--        <i class="fa-solid fa-magnifying-glass"></i>-->
<!--      </button>-->
<!--    </div>-->
  <%# end %>

  <%# Vista según el rol del usuario %>
  <% if current_user.administrador? %>
    <%= render "table_view", establishments: @establishments %>
  <% elsif current_user.afiliado? %>
    <%= render "card_view", establishments: @establishments %>
  <% elsif current_user.turista? %>
    <%= render "catalog_view", establishments: @establishments %>
  <% end %>
