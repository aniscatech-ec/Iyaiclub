<!-- app/views/establishments/show.html.erb -->

<h1><%= @establishment.name %></h1>

<p>
  <strong>Descripción:</strong><br>
  <%= @establishment.description %>
</p>

<p>
  <strong>Categoría:</strong> <%= @establishment.category.humanize %>
</p>

<p>
  <strong>Afiliado:</strong> <%= @establishment.user.email %>
</p>

<h3>Imágenes</h3>
<% if @establishment.images.attached? %>
  <div style="display: flex; flex-wrap: wrap; gap: 10px;">
    <% @establishment.images.each do |image| %>
      <%= image_tag image.variant(resize_to_limit: [300, 300]), style: "border-radius: 8px;" %>
    <% end %>
  </div>
<% else %>
  <p>No hay imágenes disponibles.</p>
<% end %>

<%= link_to "Editar", edit_establishment_path(@establishment), class: "btn btn-primary" %> |
<%= link_to "Volver", establishments_path, class: "btn btn-secondary" %>
