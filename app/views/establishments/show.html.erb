<!-- Sección 6: Políticas de precios -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">6. Políticas de precios y beneficios</div>
  <div class="card-body">
    <p><strong>Moneda:</strong> <%= @establishment.pricing_policy&.currency %></p>
    <p><strong>Comisión servicio:</strong> <%= @establishment.pricing_policy&.service_fee %></p>
    <p><strong>Descuento máximo:</strong> <%= @establishment.pricing_policy&.max_discount %></p>
    <p><strong>Políticas de reembolso:</strong></p>

      <% if @establishment.pricing_policy %>
      <ul>

        <% @establishment.pricing_policy.refund_policy_array.each do |policy| %>
          <li><%= policy %></li>
        <% end %>
      </ul>

      <% else %>
        <div class="alert alert-info">No hay politicas de reembolso registradas para este establecimiento.</div>

      <% end %>
      <%# Array(@establishment.pricing_policy.refund_policy).each do |policy| %>


  </div>
</div>

<!-- Sección 7: Métodos de pago -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">7. Métodos de pago (<%= @establishment.payment_methods.size %>)</div>
  <div class="card-body">
    <ul class="list-group">
      <% @establishment.payment_methods.each do |pm| %>
        <li class="list-group-item">
          <strong><%= pm.method_type %></strong>
          <% if pm.bank_name.present? %> - Banco: <%= pm.bank_name %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>

<!-- Sección 8: Verificación -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">8. Verificación</div>
  <div class="card-body">
    <% if @establishment.verification %>
      <% v = @establishment.verification %>
      <p><strong>Documento
        identidad:</strong> <%= link_to "Ver", url_for(v.identity_document), target: "_blank" if v.identity_document.attached? %>
      </p>
      <p><strong>Documento
        propiedad:</strong> <%= link_to "Ver", url_for(v.property_document), target: "_blank" if v.property_document.attached? %>
      </p>
      <p>
        <strong>Selfie:</strong> <%= image_tag v.selfie.variant(resize_to_limit: [150, 150]), class: "img-thumbnail" if v.selfie.attached? %>
      </p>
    <% else %>
      <p class="text-muted">No se han subido documentos de verificación.</p>
    <% end %>
  </div>
</div>

<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">9. Declaración de información</div>
  <div class="card-body">
    <%= check_box_tag "confirmed", "1", @establishment.confirmed, class: "form-check-input", disabled: true %>
    <%= @establishment.confirmed ? "Sí" : "No" %>
  </div>
</div>

<div class="card mb-4 shadow-sm border-primary">
  <div class="card-header bg-primary text-white fw-bold d-flex justify-content-between align-items-center">
    <span>10. Escapadas de Momento (Getaways)</span>
    <span class="badge bg-light text-primary rounded-pill"><%= @establishment.getaways.count %></span>
  </div>
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <p class="mb-0 text-muted">Gestione las escapadas que ofrece este establecimiento.</p>
      <%= link_to "Ir al módulo completo", establishment_getaways_path(@establishment), class: "btn btn-outline-primary btn-sm" %>
    </div>
    
    <% if @establishment.getaways.any? %>
      <div class="row">
        <% @establishment.getaways.limit(3).each do |getaway| %>
          <div class="col-md-4 mb-2">
            <div class="card h-100 bg-light">
              <div class="card-body p-3">
                <h6 class="fw-bold text-primary mb-1"><%= getaway.subcategory&.titleize %></h6>
                <p class="mb-1 fw-bold fs-5"><%= number_to_currency(getaway.entry_price) %></p>
                <p class="small text-truncate mb-2"><%= getaway.recommendations %></p>
                <div class="d-flex justify-content-between mt-auto">
                  <%= link_to "Detalles", getaway_path(getaway), class: "btn btn-sm btn-outline-secondary" %>
                  <%= link_to "Editar", edit_getaway_path(getaway), class: "btn btn-sm btn-outline-info" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <% if @establishment.getaways.count > 3 %>
        <p class="text-center mt-3 mb-0">
          <%= link_to "Ver las #{@establishment.getaways.count - 3} escapadas restantes", establishment_getaways_path(@establishment), class: "text-decoration-none" %>
        </p>
      <% end %>
    <% else %>
      <div class="alert alert-secondary py-2 mb-0">No hay escapadas registradas en este establecimiento.</div>
    <% end %>
    
    <hr>
    <div class="">
      <%= link_to "+ Crear Nueva Escapada", new_establishment_getaway_path(@establishment), class: "btn btn-success" %>
    </div>
  </div>
</div>

<div class="card mb-4 shadow-sm border-info">
  <div class="card-header bg-info text-dark fw-bold d-flex justify-content-between align-items-center">
    <span>11. Hospedajes Disponibles (Lodgings)</span>
    <span class="badge bg-white text-info border border-info rounded-pill"><%= @establishment.lodgings.count %></span>
  </div>
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <p class="mb-0 text-muted">Gestione los espacios de hospedaje para este establecimiento.</p>
      <%= link_to "Ir al módulo completo", establishment_lodgings_path(@establishment), class: "btn btn-outline-info btn-sm" %>
    </div>
    
    <% if @establishment.lodgings.any? %>
      <div class="row">
        <% @establishment.lodgings.limit(3).each do |lodging| %>
          <div class="col-md-4 mb-2">
            <div class="card h-100 bg-light">
              <div class="card-body p-3">
                <h6 class="fw-bold text-info mb-1"><i class="bi bi-house-door"></i> <%= lodging.lodging_type&.titleize %></h6>
                <p class="mb-1 fw-bold fs-5 text-dark"><%= number_to_currency(lodging.price_per_night) %> / n</p>
                <div class="small text-muted mb-3">
                  <span class="d-block">In: <%= lodging.check_in_time&.strftime("%H:%M") || "N/A" %></span>
                  <span class="d-block">Out: <%= lodging.check_out_time&.strftime("%H:%M") || "N/A" %></span>
                </div>
                <div class="d-flex justify-content-between mt-auto">
                  <%= link_to "Detalles", lodging_path(lodging), class: "btn btn-sm btn-outline-secondary" %>
                  <%= link_to "Editar", edit_lodging_path(lodging), class: "btn btn-sm btn-outline-warning" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <% if @establishment.lodgings.count > 3 %>
        <p class="text-center mt-3 mb-0">
          <%= link_to "Ver los #{@establishment.lodgings.count - 3} hospedajes restantes", establishment_lodgings_path(@establishment), class: "text-decoration-none text-info" %>
        </p>
      <% end %>
    <% else %>
      <div class="alert alert-secondary py-2 mb-0">No hay hospedajes registrados en este establecimiento.</div>
    <% end %>
    
    <hr>
    <div class="">
      <%= link_to "+ Agregar Hospedaje", new_establishment_lodging_path(@establishment), class: "btn btn-info text-white fw-bold" %>
    </div>
  </div>
</div>
