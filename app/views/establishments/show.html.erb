<script>
    document.addEventListener("turbo:load", () => {
        const calendar = document.getElementById("availability-calendar")
        if (calendar) {
            flatpickr(calendar, {
                inline: true,
                dateFormat: "d/m/Y",
                defaultDate: JSON.parse(calendar.dataset.dates),
                enable: JSON.parse(calendar.dataset.enabled),
                disable: JSON.parse(calendar.dataset.disabled),
                locale: Spanish
            })
        }
    })

</script>
<h2 class="mb-4">Resumen del Establecimiento - <%= @establishment.id %></h2>

<!-- Sección 1: Datos legales -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">1. Datos legales y de contacto</div>
  <div class="card-body">
    <p><strong>Razón social:</strong> <%= @establishment.legal_info&.business_name %></p>
    <p><strong>Representante legal:</strong> <%= @establishment.legal_info&.legal_representative %></p>
    <p><strong>Documento:</strong> <%= @establishment.legal_info&.document_type %>
      - <%= @establishment.legal_info&.document_number %></p>
    <p><strong>Email de contacto:</strong> <%= @establishment.legal_info&.contact_email %></p>
    <p><strong>Teléfono:</strong> <%= @establishment.legal_info&.contact_phone %></p>
  </div>
</div>

<!-- Sección 2: Perfil -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">2. Perfil del establecimiento</div>
  <div class="card-body">
    <p><strong>Nombre público:</strong> <%= @establishment.name %></p>
    <p><strong>Descripción corta:</strong> <%= @establishment.short_description %></p>
    <p><strong>Descripción larga:</strong> <%= @establishment.long_description %></p>
    <p><strong>Categoría:</strong> <%= @establishment.category %></p>
    <p><strong>Amenities:</strong> (<%= @establishment.amenities.count %>)</p>
    <ul>
      <% @establishment.amenities.each do |amenity| %>
        <li><%= amenity.name %></li>
      <% end %>
    </ul>

    <!--    <p><strong>Políticas:</strong> <%#= @establishment.policies %></p>-->

    <p><strong>Políticas:</strong></p>
    <p>
      <strong>Check-in:</strong> <%= @establishment.check_in_time.strftime("%I:%M %p") if @establishment.check_in_time %>
    </p>
    <p>
      <strong>Check-out:</strong> <%= @establishment.check_out_time.strftime("%I:%M %p") if @establishment.check_out_time %>
    </p>

    <ul>
      <% @establishment.policies_array.each do |policy| %>
        <li><%= policy %></li>
      <% end %>
    </ul>

  </div>
</div>

<!-- Sección 3: Ubicación -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">3. Ubicación</div>
  <div class="card-body">
    <p><strong>Dirección:</strong> <%= @establishment.address %></p>
    <p><strong>País:</strong> <%= @establishment.country.name if @establishment.country %></p>
    <p><strong>Provincia:</strong> <%= @establishment.province.name if @establishment.province %></p>
    <p><strong>Ciudad:</strong> <%= @establishment.city.name if @establishment.city %></p>
    <p><strong>Instrucciones:</strong> <%= @establishment.arrival_instructions %></p>
    <p><strong>Latitud:</strong> <%= @establishment.latitude %></p>
    <p><strong>Longitud:</strong> <%= @establishment.longitude %></p>
  </div>
</div>

<!-- Sección 4: Galería -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">4. Galería (<%= @establishment.galleries.count %>)</div>
  <div class="card-body">
    <% @establishment.galleries.each do |gallery| %>
      <h6><%= gallery.name %> <%= gallery.gallery_images.count %></h6>
      <div class="d-flex flex-wrap">
        <% gallery.gallery_images.each do |gi| %>
          <%= gi.video_url %>
          <% if gi.file.attached? %>
            <%= image_tag gi.file.variant(resize_to_limit: [150, 150]), class: "img-thumbnail me-2 mb-2" %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
  <h2>Video del establecimiento</h2>
  <% if @establishment.video.attached? %>
    <%= video_tag url_for(@establishment.video),
                  controls: true,
                  preload: "metadata",
                  class: "w-100 rounded shadow mb-3" %>
  <% elsif @establishment.video_url.present? %>

    <%= embed_video_tag_from_url(@establishment.video_url) %>

  <% end %>
</div>

<!-- Sección 5: Unidades -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">5. Unidades / Habitaciones (<%= @establishment.units.count %>)</div>
  <div class="card-body">
    <table class="table table-sm table-bordered">
      <thead>
      <tr>
        <th>Tipo</th>
        <th>Capacidad</th>
        <th>Camas</th>
        <th>Precio base</th>
      </tr>
      </thead>
      <tbody>
      <% @establishment.units.each do |unit| %>
        <tr>
          <td><%= unit.unit_type %></td>
          <td><%= unit.capacity %></td>
          <!--          <td><%#= unit.beds %></td>-->
          <td><%= number_to_currency(unit.base_price) %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>


<h2 class="mb-4">Unidades registradas</h2>

<% if @establishment.units.any? %>
  <% @establishment.units.each do |unit| %>
    <div class="card mb-4 shadow-sm">
      <div class="card-header bg-light">
        <h5 class="mb-0">
          <%= unit.unit_type.presence || "Unidad sin nombre" %>
        </h5>
      </div>

      <div class="card-body">
        <p><strong>Capacidad:</strong> <%= unit.capacity || "No especificada" %> personas</p>
        <p><strong>Distribución de camas:</strong>
          <% if unit.bed_configuration.present? %>
            <%= unit.bed_configuration.map { |k, v| "#{v} #{k}" }.join(", ") %>
          <% else %>
            No especificada
          <% end %>
        </p>
        <p><strong>Precio base:</strong>
          $<%= unit.base_price || "No definido" %> / noche
        </p>
      </div>

      <!-- Tarifas -->
      <% if unit.unit_prices.any? %>
        <div class="card-body border-top">
          <h6>Tarifas por temporada</h6>
          <ul class="list-group list-group-flush">
            <% unit.unit_prices.each do |price| %>
              <li class="list-group-item d-flex justify-content-between">
                <span><%= price.season.capitalize %></span>
                <span>$<%= price.price %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>


      <!--      <h3>Disponibilidad (próximos 30 días)</h3>-->

      <!--      <table class="table table-bordered text-center">-->
      <!--        <thead class="table-light">-->
      <!--        <tr>-->
      <!--          <th>Fecha</th>-->
      <!--          <th>Estado</th>-->
      <!--        </tr>-->
      <!--        </thead>-->
      <!--        <tbody>-->
      <%# (Date.today..Date.today+30).each do |day| %>
      <%# availability = unit.unit_availabilities.find_by(date: day) %>
      <!--          <tr>-->
      <!--            <td><%#= day.strftime("%d/%m/%Y") %></td>-->
      <!--            <td>-->
      <%# if availability.present? %>
      <%#= availability.available ? "✅ Disponible" : "❌ No disponible" %>
      <%# else %>
      <!--                <span class="text-muted">Sin registro</span>-->
      <%# end %>
      <!--            </td>-->
      <!--          </tr>-->
      <%# end %>
      <!--        </tbody>-->
      <!--      </table>-->


      <!-- Disponibilidad -->
      <h3>Disponibilidad</h3>

      <div class="card-body border-top"
           data-controller="fullcalendar"
           data-fullcalendar-events-value='<%= raw unit.unit_availabilities.map { |a|
             { title: a.available ? "✅ Disponible" : "❌ No disponible",
               start: a.date,
               color: a.available ? "green" : "red" }
           }.to_json %>'>
      </div>


    </div>
  <% end %>
<% else %>
  <div class="alert alert-info">No hay unidades registradas para este establecimiento.</div>
<% end %>

<!-- Sección 6: Políticas de precios -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">6. Políticas de precios y beneficios</div>
  <div class="card-body">
    <p><strong>Moneda:</strong> <%= @establishment.pricing_policy&.currency %></p>
    <p><strong>Comisión servicio:</strong> <%= @establishment.pricing_policy&.service_fee %></p>
    <p><strong>Descuento máximo:</strong> <%= @establishment.pricing_policy&.max_discount %></p>
    <p><strong>Políticas de reembolso:</strong></p>

    <ul>
      <% Array(@establishment.pricing_policy.refund_policy).each do |policy| %>
        <li><%= policy %></li>
      <% end %>
    </ul>


  </div>
</div>

<!-- Sección 7: Métodos de pago -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">7. Métodos de pago (<%= @establishment.payment_methods.count %>)</div>
  <div class="card-body">
    <ul class="list-group">
      <% @establishment.payment_methods.each do |pm| %>
        <li class="list-group-item">
          <strong><%= pm.method_type %></strong>
          <% if pm.bank_name.present? %> - Banco: <%= pm.bank_name %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>

<!-- Sección 8: Verificación -->
<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">8. Verificación</div>
  <div class="card-body">
    <% if @establishment.verification %>
      <% v = @establishment.verification %>
      <p><strong>Documento
        identidad:</strong> <%= link_to "Ver", url_for(v.identity_document), target: "_blank" if v.identity_document.attached? %>
      </p>
      <p><strong>Documento
        propiedad:</strong> <%= link_to "Ver", url_for(v.property_document), target: "_blank" if v.property_document.attached? %>
      </p>
      <p>
        <strong>Selfie:</strong> <%= image_tag v.selfie.variant(resize_to_limit: [150, 150]), class: "img-thumbnail" if v.selfie.attached? %>
      </p>
    <% else %>
      <p class="text-muted">No se han subido documentos de verificación.</p>
    <% end %>
  </div>
</div>

<div class="card mb-4 shadow-sm">
  <div class="card-header fw-bold">9. Declaración de información</div>
  <div class="card-body">
    <%= check_box_tag "confirmed", "1", @establishment.confirmed, class: "form-check-input", disabled: true %>
    <%= @establishment.confirmed ? "Sí" : "No" %>
  </div>
</div>
