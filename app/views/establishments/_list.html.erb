<% if establishments.any? %>
  <div id="establishments-list">
    <div class="row">
      <% establishments.each do |est| %>
        <div class="col-12 col-md-6 col-xl-4 mb-4">
          <%= link_to est, class: "text-decoration-none text-dark" do %>
            <div class="card establishment-card shadow-sm border-0 h-100 rounded-4 overflow-hidden transition-all">

              <!-- Imagen principal -->
              <div class="position-relative">
                <% if est.galleries.any? && est.galleries.first.gallery_images.any? %>
                  <% first_image = est.galleries.first.gallery_images.first.file %>
                  <%= image_tag first_image, class: "card-img-top establishment-image", height: 200 if first_image.attached? %>
                <% else %>
                  <%= image_tag "logo-ant.jpg", class: "card-img-top establishment-image", height: 200 %>
                <% end %>

                <!-- Badge de categoría -->
                <div class="position-absolute top-0 start-0 p-2">
                  <% if est.category == "hotel" %>
                    <span class="badge bg-primary bg-opacity-90 text-white fs-7">
                      <i class="bi bi-building me-1"></i>Hotel
                    </span>
                  <% elsif est.category == "restaurant" %>
                    <span class="badge bg-success bg-opacity-90 text-white fs-7">
                      <i class="bi bi-utensils me-1"></i>Restaurante
                    </span>
                  <% else %>
                    <span class="badge bg-secondary bg-opacity-90 text-white fs-7">
                      <i class="bi bi-shop me-1"></i><%= est.category&.humanize || "Establecimiento" %>
                    </span>
                  <% end %>
                </div>

                <!-- Precio por noche -->
                <div class="position-absolute bottom-0 end-0 m-2">
                  <span class="badge bg-dark bg-opacity-75 text-white fs-6">
                    $<%= est.price_per_night %>
                  </span>
                </div>
              </div>

              <div class="card-body p-3">
                <!-- Información principal -->
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h6 class="fw-bold text-dark mb-0 flex-grow-1 me-2"><%= est.name %></h6>
                  <span class="badge bg-success"><%= est.category %></span>
                </div>

                <!-- Ubicación -->
                <div class="d-flex align-items-center mb-3">
                  <i class="bi bi-geo-alt text-muted me-2"></i>
                  <small class="text-muted">
                    <%= est.city&.name || "Ciudad no definida" %>,
                    <%= est.city&.province&.name || "Provincia no definida" %>
                  </small>
                </div>

                <!-- Precio -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <span class="fw-bold text-primary">$<%= est.price_per_night %>/noche</span>
                  <small class="text-muted">Precio promedio</small>
                </div>

                <!-- Comodidades -->
                <div class="amenities-preview">
                  <div class="d-flex flex-wrap gap-1">
                    <% est.amenities.limit(4).each do |amenity| %>
                      <span class="badge bg-light text-dark border small">
                        <i class="bi bi-check-circle text-success me-1"></i><%= amenity.name %>
                      </span>
                    <% end %>

                    <% if est.amenities.size > 4 %>
                      <span class="badge bg-secondary bg-opacity-10 text-secondary border-0 small">
                        +<%= est.amenities.size - 4 %> más
                      </span>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Paginación -->
    <div class="col-12 mt-4">
      <%= paginate establishments%>
    </div>
  </div>
<% else %>
  <div class="col-12 text-center my-5 py-5">
    <div class="text-muted">
      <i class="bi bi-shop display-4 opacity-50"></i>
      <h5 class="mt-3 fw-semibold">No se encontraron establecimientos</h5>
      <p class="mb-0 text-muted">Intenta ajustar los filtros de búsqueda</p>
    </div>
  </div>
<% end %>

<style>
    .establishment-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid rgba(0,0,0,0.08);
    }

    .establishment-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
    }

    .establishment-image {
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .establishment-card:hover .establishment-image {
        transform: scale(1.03);
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .fs-7 {
        font-size: 0.8rem;
    }
</style>