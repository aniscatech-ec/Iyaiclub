<div class="row">
  <% establishments.each do |est| %>
    <div class="col-md-2 mx-2">
      <div class="card h-100 shadow-sm d-flex flex-column">

        <!-- Carrusel de imágenes de la primera galería -->
        <% first_gallery = est.galleries.first %>
        <% if first_gallery && first_gallery.gallery_images.any? %>
          <div id="carouselEstablishment<%= est.id %>" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
              <% first_gallery.gallery_images.each_with_index do |gi, index| %>
                <% if gi.file.attached? %>
                  <div class="carousel-item <%= 'active' if index == 0 %>">

                    <div class="d-flex justify-content-center">
                      <%= image_tag gi.file, height: 200,alt: est.name, class: "d-block w-100" %>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>

            <% if first_gallery.gallery_images.size > 1 %>
              <button class="carousel-control-prev" type="button" data-bs-target="#carouselEstablishment<%= est.id %>" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Anterior</span>
              </button>
              <button class="carousel-control-next" type="button" data-bs-target="#carouselEstablishment<%= est.id %>" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Siguiente</span>
              </button>
            <% end %>
          </div>
        <% else %>
        <% end %>

        <div class="card-body d-flex flex-column">
          <!-- Nombre -->
          <h5 class="card-title"><%= est.name %></h5>

          <!-- Ciudad / País -->
<!--          <p class="text-muted mb-2"><i class="bi bi-geo-alt"></i> <%#= est.city.name.presence || "-" %>, <%#= est.country.name.presence || "-" %></p>-->

          <!-- Comodidades -->
          <p class="mb-2">
            <% est.amenities.limit(3).each do |amenity| %>
              <span class="badge bg-secondary"><%= amenity.name %></span>
            <% end %>
          </p>

          <!-- Botón Ver más -->
          <%= link_to "Ver más", est, class: "btn btn-primary mt-auto w-100" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
