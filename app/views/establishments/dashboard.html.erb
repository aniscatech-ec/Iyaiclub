<div class="container-fluid">
  <div class="row">
    <!-- Sidebar de pasos -->
    <div class="col-md-3">
      <div class="list-group mb-4">
        <% steps = [:legal_info, :perfil, :ubicacion, :galeria, :unidades, :politicas, :pagos, :verificacion, :revision] %>
        <% steps.each_with_index do |s, i| %>
          <% step_completed = case s
                              when :legal_info then @establishment.legal_info.present?
                              when :perfil then @establishment.short_description.present?
                              when :ubicacion then @establishment.address.present?
                              when :galeria then @establishment.galleries.any?
                              when :unidades then @establishment.units.any?
                              when :politicas then @establishment.pricing_policy.present?
                              when :pagos then @establishment.payment_methods.any?
                              when :verificacion then @establishment.verification.present?
                              when :revision then @establishment.confirmed
                              end %>

          <%= link_to "#{i+1}. #{s.to_s.humanize} #{step_completed ? '✅' : '❌'}",
                      establishment_establishment_step_path(@establishment, s),
                      class: "list-group-item list-group-item-action" %>
        <% end %>

      </div>
    </div>

    <!-- Contenido del dashboard -->
    <div class="col-md-9">
      <h2 class="mb-4">Resumen del Establecimiento - <%= @establishment.id %></h2>

      <!-- Datos legales -->
      <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          1. Datos legales y de contacto
          <%= link_to "Editar",
                      establishment_establishment_step_path(@establishment, :legal_info, edit_mode: true),
                      class: "btn btn-sm btn-warning" %>
        </div>
        <div class="card-body">
          <p><strong>Razón social:</strong> <%= @establishment.legal_info&.business_name %></p>
          <p><strong>Representante legal:</strong> <%= @establishment.legal_info&.legal_representative %></p>
          <p><strong>Documento:</strong> <%= @establishment.legal_info&.document_type %> - <%= @establishment.legal_info&.document_number %></p>
          <p><strong>Email:</strong> <%= @establishment.legal_info&.contact_email %></p>
          <p><strong>Teléfono:</strong> <%= @establishment.legal_info&.contact_phone %></p>
        </div>
      </div>

      <!-- Perfil -->
      <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          2. Perfil del establecimiento
          <%#= link_to "Editar", wizard_path(:perfil, establishment_id: @establishment.id), class: "btn btn-sm btn-primary" %>
          <%= link_to "Editar",
                      establishment_establishment_step_path(@establishment, :perfil, edit_mode: true),
                      class: "btn btn-sm btn-warning" %>
        </div>
        <div class="card-body">
          <p><strong>Nombre público:</strong> <%= @establishment.name %></p>
          <p><strong>Descripción corta:</strong> <%= @establishment.short_description %></p>
          <p><strong>Descripción larga:</strong> <%= @establishment.long_description %></p>
          <p><strong>Categoría:</strong> <%= @establishment.category %></p>
          <p><strong>Amenities:</strong></p>
          <ul>
            <% @establishment.amenities.each do |amenity| %>
              <li><%= amenity.name %></li>
            <% end %>
          </ul>
          <p><strong>Check-in:</strong> <%= @establishment.check_in_time.strftime("%I:%M %p") if @establishment.check_in_time %></p>
          <p><strong>Check-out:</strong> <%= @establishment.check_out_time.strftime("%I:%M %p") if @establishment.check_out_time %></p>
        </div>
      </div>

      <!-- Ubicación -->
      <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          3. Ubicación
          <%#= link_to "Editar", wizard_path(:ubicacion, establishment_id: @establishment.id), class: "btn btn-sm btn-primary" %>
          <%= link_to "Editar",
                      establishment_establishment_step_path(@establishment, :ubicacion),
                      class: "btn btn-sm btn-primary" %>
        </div>
        <div class="card-body">
          <p><strong>Dirección:</strong> <%= @establishment.address %></p>
          <p><strong>País:</strong> <%= @establishment.country&.name %></p>
          <p><strong>Provincia:</strong> <%= @establishment.province&.name %></p>
          <p><strong>Ciudad:</strong> <%= @establishment.city&.name %></p>
          <p><strong>Instrucciones:</strong> <%= @establishment.arrival_instructions %></p>
        </div>
      </div>

      <!-- Galería -->
      <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          4. Galería (<%= @establishment.galleries.count %>)
          <%#= link_to "Editar", wizard_path(:galeria, establishment_id: @establishment.id), class: "btn btn-sm btn-primary" %>
          <%= link_to "Editar",
                      establishment_establishment_step_path(@establishment, :galeria, edit_mode: true),
                      class: "btn btn-sm btn-primary" %>
        </div>
        <div class="card-body">
          <% @establishment.galleries.each do |gallery| %>
            <h6><%= gallery.name %> (<%= gallery.gallery_images.count %> imágenes)</h6>
            <div class="d-flex flex-wrap mb-3">
              <% gallery.gallery_images.each do |gi| %>
                <% if gi.file.attached? %>
                  <%= image_tag gi.file.variant(resize_to_limit: [150,150]), class: "img-thumbnail me-2 mb-2" %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Unidades -->
      <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          5. Unidades / Habitaciones (<%= @establishment.units.count %>)
          <%#= link_to "Editar", wizard_path(:unidades, establishment_id: @establishment.id), class: "btn btn-sm btn-primary" %>
          <%= link_to "Editar",
                      establishment_establishment_step_path(@establishment, :unidades, edit_mode: true),
                      class: "btn btn-sm btn-warning" %>
        </div>
        <div class="card-body">
          <table class="table table-sm table-bordered">
            <thead>
            <tr>
              <th>Tipo</th>
              <th>Capacidad</th>
              <th>Camas</th>
              <th>Precio base</th>
            </tr>
            </thead>
            <tbody>
            <% @establishment.units.each do |unit| %>
              <tr>
                <td><%= unit.unit_type %></td>
                <td><%= unit.capacity %></td>
<!--                <td><%#= unit.beds %></td>-->
                <td><%= number_to_currency(unit.base_price) %></td>
              </tr>
            <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Políticas -->
      <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          6. Políticas de precios y beneficios
          <%#= link_to "Editar", wizard_path(:politicas, establishment_id: @establishment.id), class: "btn btn-sm btn-primary" %>
          <%= link_to "Editar",
                      establishment_establishment_step_path(@establishment, :politicas),
                      class: "btn btn-sm btn-primary" %>
        </div>
        <div class="card-body">
          <p><strong>Moneda:</strong> <%= @establishment.pricing_policy&.currency %></p>
          <p><strong>Comisión servicio:</strong> <%= @establishment.pricing_policy&.service_fee %></p>
          <p><strong>Descuento máximo:</strong> <%= @establishment.pricing_policy&.max_discount %></p>
          <p><strong>Políticas de reembolso:</strong></p>
          <ul>
            <% Array(@establishment.pricing_policy&.refund_policy).each do |policy| %>
              <li><%= policy %></li>
            <% end %>
          </ul>
        </div>
      </div>

      <!-- Pagos -->
      <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          7. Métodos de pago (<%= @establishment.payment_methods.count %>)
          <%#= link_to "Editar", wizard_path(:pagos, establishment_id: @establishment.id), class: "btn btn-sm btn-primary" %>
          <%= link_to "Editar",
                      establishment_establishment_step_path(@establishment, :pagos),
                      class: "btn btn-sm btn-primary" %>
        </div>
        <div class="card-body">
          <ul class="list-group">
            <% @establishment.payment_methods.each do |pm| %>
              <li class="list-group-item"><strong><%= pm.method_type %></strong> <%= pm.bank_name.present? ? "- Banco: #{pm.bank_name}" : "" %></li>
            <% end %>
          </ul>
        </div>
      </div>

      <!-- Verificación -->
      <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          8. Verificación
          <%#= link_to "Editar", wizard_path(:verificacion, establishment_id: @establishment.id), class: "btn btn-sm btn-primary" %>
          <%= link_to "Editar",
                      establishment_establishment_step_path(@establishment, :verificacion),
                      class: "btn btn-sm btn-primary" %>
        </div>
        <div class="card-body">
          <% if @establishment.verification %>
            <% v = @establishment.verification %>
            <p><strong>Documento identidad:</strong> <%= link_to "Ver", url_for(v.identity_document), target: "_blank" if v.identity_document.attached? %></p>
            <p><strong>Documento propiedad:</strong> <%= link_to "Ver", url_for(v.property_document), target: "_blank" if v.property_document.attached? %></p>
            <p><strong>Selfie:</strong> <%= image_tag v.selfie.variant(resize_to_limit: [150,150]), class: "img-thumbnail" if v.selfie.attached? %></p>
          <% else %>
            <p class="text-muted">No se han subido documentos de verificación.</p>
          <% end %>
        </div>
      </div>

      <!-- Revisión -->
      <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          9. Declaración de información
          <%#= link_to "Editar", wizard_path(:revision, establishment_id: @establishment.id), class: "btn btn-sm btn-primary" %>
          <%= link_to "Editar",
                      establishment_establishment_step_path(@establishment, :revision),
                      class: "btn btn-sm btn-primary" %>
        </div>
        <div class="card-body">
          <%= check_box_tag "confirmed", "1", @establishment.confirmed, class: "form-check-input", disabled: true %>
          <%= @establishment.confirmed ? "Sí" : "No" %>
        </div>
      </div>
    </div>
  </div>
</div>
