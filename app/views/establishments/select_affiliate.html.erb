<style>
    .transition-card {
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .transition-card:hover {
        transform: translateY(-6px) scale(1.02);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        border: 1px solid #0d6efd;
    }

    .transition-card:active {
        transform: scale(0.98);
    }

</style>
<div class="container py-4" data-controller="affiliate">
  <h2 class="h4 mb-3">Selecciona un Afiliado</h2>

  <!-- Barra de búsqueda -->
  <div class="mb-3">
    <input type="text"
           id="affiliate-search"
           class="form-control"
           placeholder="Buscar por nombre, email o teléfono..."
           data-affiliate-target="search"
           data-action="input->affiliate#filter">
  </div>

  <!-- Lista de afiliados como cards -->
  <div class="row g-3">
    <% @affiliates.each do |affiliate| %>
      <div class="col-md-4 affiliate-card"
           role="button"
           tabindex="0"
           data-affiliate-target="card"
           data-action="click->affiliate#select"
           data-id="<%= affiliate.id %>"
           data-name="<%= affiliate.name.downcase %>"
           data-email="<%= affiliate.email.downcase %>"
           data-phone="<%= affiliate.phone.to_s.downcase %>"
           data-url="<%= choose_type_establishments_path(user_id: affiliate.id) %>">

      <div class="card h-100 shadow-sm transition-card">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= affiliate.name %></h5>
            <p class="card-text mb-1"><strong>Email:</strong> <%= affiliate.email %></p>
            <p class="card-text mb-1"><strong>Teléfono:</strong> <%= affiliate.phone %></p>
            <p class="card-text mb-3">
              <strong>Ciudad:</strong> <%= affiliate.city&.name %>,
              <strong>País:</strong> <%= affiliate.country&.name %>
            </p>
<!--            <span class="btn btn-outline-primary mt-auto">Seleccionar</span>-->
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
