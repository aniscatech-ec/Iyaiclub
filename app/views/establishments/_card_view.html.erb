<div class="establishments-grid">
  <% establishments.each do |est| %>
    <div class="establishment-card <%= est.current_subscription ? 'active' : 'inactive' %>">
      <!-- Header con estado de suscripción -->
      <div class="card-header">
        <div class="status-badge <%= est.current_subscription ? 'status-active' : 'status-inactive' %>">
          <i class="fas fa-<%= est.current_subscription ? 'check-circle' : 'exclamation-circle' %> me-2"></i>
          <%= est.current_subscription ? 'Suscripción Activa' : 'Sin Suscripción' %>
        </div>
        <div class="subscription-indicator">
          <div class="indicator <%= est.current_subscription ? 'indicator-active' : 'indicator-inactive' %>"></div>
        </div>
      </div>

      <!-- Información principal -->
      <div class="card-content">
        <div class="establishment-info">
          <h3 class="establishment-name">
            <i class="fas fa-building me-2"></i>
            <%= est.name %>
          </h3>

          <div class="user-info">
            <div class="info-item">
              <div class="info-icon">
                <i class="fas fa-user"></i>
              </div>
              <div class="info-content">
                <span class="info-label">Usuario</span>
                <span class="info-value"><%= est.user.name %></span>
              </div>
            </div>

            <div class="info-item">
              <div class="info-icon">
                <i class="fas fa-id-card"></i>
              </div>
              <div class="info-content">
                <span class="info-label">ID</span>
                <span class="info-value">#<%= est.user_id %></span>
              </div>
            </div>

            <div class="info-item">
              <div class="info-icon">
                <i class="fas fa-user-tag"></i>
              </div>
              <div class="info-content">
                <span class="info-label">Rol</span>
                <span class="info-value role-<%= est.user.role %>"><%= est.user.role %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Acciones -->
      <div class="card-actions">
        <%= link_to est, class: "btn-action btn-view" do %>
          <i class="fas fa-eye"></i>
          <span>Ver</span>
        <% end %>

        <%= link_to edit_establishment_path(est), class: "btn-action btn-edit" do %>
          <i class="fas fa-edit"></i>
          <span>Editar</span>
        <% end %>

        <%= link_to est, data: { turbo_method: :delete, turbo_confirm: "¿Estás seguro de eliminar este establecimiento?" }, class: "btn-action btn-delete" do %>
          <i class="fas fa-trash"></i>
          <span>Eliminar</span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<style>
    :root {
        --primary-color: #3b82f6;
        --success-color: #10b981;
        --warning-color: #f59e0b;
        --danger-color: #ef4444;
        --info-color: #06b6d4;
        --gray-100: #f8fafc;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --border-radius: 12px;
        --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        --transition: all 0.3s ease;
    }

    .establishments-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
        padding: 1rem 0;
    }

    .establishment-card {
        background: white;
        border-radius: var(--border-radius);
        box-shadow: var(--shadow);
        transition: var(--transition);
        overflow: hidden;
        border: 1px solid var(--gray-200);
        position: relative;
    }

    .establishment-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-hover);
    }

    .establishment-card.active {
        border-left: 4px solid var(--success-color);
    }

    .establishment-card.inactive {
        border-left: 4px solid var(--danger-color);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        background: var(--gray-100);
        border-bottom: 1px solid var(--gray-200);
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.375rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-active {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success-color);
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .status-inactive {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger-color);
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .subscription-indicator {
        display: flex;
        align-items: center;
    }

    .indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    .indicator-active {
        background: var(--success-color);
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    }

    .indicator-inactive {
        background: var(--danger-color);
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
    }

    @keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
        }
        70% {
            box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
        }
    }

    .card-content {
        padding: 1.5rem 1.25rem;
    }

    .establishment-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--gray-800);
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
    }

    .establishment-name i {
        color: var(--primary-color);
        font-size: 1.1rem;
    }

    .user-info {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .info-icon {
        width: 32px;
        height: 32px;
        background: var(--gray-100);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gray-600);
        font-size: 0.875rem;
    }

    .info-content {
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .info-label {
        font-size: 0.75rem;
        color: var(--gray-600);
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .info-value {
        font-size: 0.9rem;
        color: var(--gray-800);
        font-weight: 500;
    }

    .role-admin {
        color: var(--danger-color);
        font-weight: 600;
    }

    .role-user {
        color: var(--primary-color);
        font-weight: 600;
    }

    .role-manager {
        color: var(--warning-color);
        font-weight: 600;
    }

    .card-actions {
        display: flex;
        padding: 1rem 1.25rem;
        background: var(--gray-100);
        border-top: 1px solid var(--gray-200);
        gap: 0.5rem;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: var(--transition);
        flex: 1;
        border: 1px solid transparent;
    }

    .btn-action:hover {
        transform: translateY(-1px);
        text-decoration: none;
    }

    .btn-view {
        background: rgba(6, 182, 212, 0.1);
        color: var(--info-color);
        border-color: rgba(6, 182, 212, 0.2);
    }

    .btn-view:hover {
        background: var(--info-color);
        color: white;
        box-shadow: 0 4px 12px rgba(6, 182, 212, 0.3);
    }

    .btn-edit {
        background: rgba(245, 158, 11, 0.1);
        color: var(--warning-color);
        border-color: rgba(245, 158, 11, 0.2);
    }

    .btn-edit:hover {
        background: var(--warning-color);
        color: white;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
    }

    .btn-delete {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger-color);
        border-color: rgba(239, 68, 68, 0.2);
    }

    .btn-delete:hover {
        background: var(--danger-color);
        color: white;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    }

    /* Estados vacíos */
    .establishments-grid:empty::before {
        content: "No hay establecimientos registrados";
        display: block;
        text-align: center;
        padding: 3rem;
        color: var(--gray-600);
        font-size: 1.1rem;
        background: var(--gray-100);
        border-radius: var(--border-radius);
        border: 2px dashed var(--gray-300);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .establishments-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .card-header {
            padding: 0.875rem 1rem;
        }

        .card-content {
            padding: 1.25rem 1rem;
        }

        .card-actions {
            padding: 0.875rem 1rem;
            flex-direction: column;
        }

        .btn-action {
            padding: 0.625rem;
        }
    }

    @media (max-width: 480px) {
        .establishments-grid {
            grid-template-columns: 1fr;
        }

        .establishment-name {
            font-size: 1.1rem;
        }

        .info-item {
            gap: 0.5rem;
        }
    }
</style>