<style>
    /* Variables CSS para consistencia */
    :root {
        --primary-color: #2d5016;
        --secondary-color: #4a7c3a;
        --accent-color: #8db596;
        --light-bg: #f8f9fa;
        --dark-text: #333;
        --shadow: 0 4px 12px rgba(0,0,0,0.1);
        --shadow-hover: 0 8px 25px rgba(0,0,0,0.15);
    }

    /* Hero Section Mejorada */
    .hero-section {
        position: relative;
        overflow: hidden;
    }

    .hero-carousel {
        height: 85vh;
        min-height: 600px;
    }

    .hero-carousel .carousel-item {
        transition: transform 1.2s ease-in-out;
    }

    .hero-carousel img {
        object-fit: cover;
        height: 100%;
        width: 100%;
        filter: brightness(0.8);
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
        z-index: 1;
    }

    .hero-content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 10;
        width: 100%;
        max-width: 900px;
        text-align: center;
    }

    /* TEXTO COMPLETAMENTE CORREGIDO */
    .hero-title {
        /*font-size: 4rem;*/
        font-weight: 800;
        margin-bottom: 1.5rem;
        color: #ffffff;
        text-shadow:
                0 2px 4px rgba(0,0,0,0.8),
                0 4px 12px rgba(0,0,0,0.6),
                0 8px 24px rgba(0,0,0,0.4);
        line-height: 1.1;
        letter-spacing: -0.5px;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .hero-subtitle {
        font-size: 1.5rem;
        margin-bottom: 2.5rem;
        color: #ffffff;
        text-shadow:
                0 1px 3px rgba(0,0,0,0.8),
                0 2px 6px rgba(0,0,0,0.6);
        font-weight: 600;
        line-height: 1.4;
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
        opacity: 0.95;
    }

    .search-container {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: var(--shadow-hover);
        border: 1px solid rgba(255,255,255,0.2);
    }

    /* Categorías Mejoradas */
    .categories-section {
        background: linear-gradient(135deg, var(--light-bg) 0%, #fff 100%);
        position: relative;
        overflow: hidden;
    }

    .categories-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.3;
    }

    .category-card {
        background: white;
        border-radius: 16px;
        padding: 2rem 1rem;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 2px solid transparent;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .category-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
        transition: left 0.6s;
    }

    .category-card:hover::before {
        left: 100%;
    }

    .category-card:hover {
        transform: translateY(-10px) scale(1.03);
        box-shadow: var(--shadow-hover);
        border-color: var(--accent-color);
    }

    .category-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1rem;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2rem;
        transition: all 0.3s ease;
    }

    .category-card:hover .category-icon {
        transform: scale(1.1) rotate(5deg);
        background: linear-gradient(135deg, var(--secondary-color), var(--accent-color));
    }

    /* Destinos Populares Mejorados */
    .destinos-section {
        background: white;
        position: relative;
    }

    .section-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
        display: inline-block;
    }

    .section-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 4px;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        border-radius: 2px;
    }

    .destination-card {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: all 0.4s ease;
        position: relative;
        height: 300px;
    }

    .destination-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: var(--shadow-hover);
    }

    .destination-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 2rem 1.5rem 1.5rem;
        background: linear-gradient(transparent, rgba(0,0,0,0.9));
        color: white;
        transform: translateY(10px);
        transition: all 0.3s ease;
    }

    .destination-card:hover .destination-overlay {
        transform: translateY(0);
        padding-bottom: 2rem;
    }

    .destination-stats {
        background: var(--primary-color);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        display: inline-block;
        margin-top: 0.5rem;
        transition: all 0.3s ease;
    }

    .destination-card:hover .destination-stats {
        background: var(--accent-color);
        transform: scale(1.05);
    }

    /* Carrusel de Recomendados Mejorado */
    .recommendations-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        position: relative;
    }

    .recommendation-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: all 0.3s ease;
        height: 100%;
    }

    .recommendation-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-hover);
    }

    .recommendation-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: var(--primary-color);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 15px;
        font-size: 0.8rem;
        font-weight: 600;
        z-index: 2;
    }

    .rating-stars {
        color: #ffc107;
        font-size: 1.1rem;
    }

    .carousel-control-custom {
        width: 50px;
        height: 50px;
        background: var(--primary-color);
        border-radius: 50%;
        opacity: 0.9;
        top: 50%;
        transform: translateY(-50%);
    }

    .carousel-control-custom:hover {
        background: var(--secondary-color);
        opacity: 1;
    }

    /* Sabores y Experiencias Mejorado */
    .experiences-section {
        background: white;
    }

    .experience-card {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: all 0.4s ease;
        position: relative;
    }

    .experience-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-hover);
    }

    .experience-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 2rem;
        background: linear-gradient(transparent, rgba(0,0,0,0.8));
        color: white;
    }

    /* Beneficios Mejorados */
    .benefits-section {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
        color: white;
        position: relative;
        overflow: hidden;
    }

    .benefits-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .benefit-item {
        padding: 2rem;
        text-align: center;
        transition: all 0.3s ease;
        border-radius: 15px;
    }

    .benefit-item:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-5px);
    }

    .benefit-icon {
        font-size: 3.5rem;
        margin-bottom: 1.5rem;
        color: var(--accent-color);
        transition: all 0.3s ease;
    }

    .benefit-item:hover .benefit-icon {
        transform: scale(1.2) rotate(5deg);
        color: white;
    }

    /* Nuevas Secciones */
    .stats-section {
        background: white;
        padding: 4rem 0;
    }

    .stat-item {
        text-align: center;
        padding: 2rem;
    }

    .stat-number {
        font-size: 3rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
        line-height: 1;
    }

    .stat-label {
        color: var(--dark-text);
        font-weight: 600;
        margin-top: 0.5rem;
    }

    .testimonials-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .testimonial-card {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        box-shadow: var(--shadow);
        margin: 1rem;
        position: relative;
    }

    .testimonial-card::before {
        content: '"';
        font-size: 5rem;
        color: var(--accent-color);
        position: absolute;
        top: -1rem;
        left: 1rem;
        opacity: 0.3;
        font-family: Georgia, serif;
    }

    .testimonial-text {
        font-style: italic;
        margin-bottom: 1.5rem;
        position: relative;
        z-index: 1;
    }

    .testimonial-author {
        font-weight: 600;
        color: var(--primary-color);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem;
        }

        .hero-carousel {
            height: 70vh;
            min-height: 500px;
        }

        .section-title {
            font-size: 2rem;
        }

        .category-icon {
            width: 60px;
            height: 60px;
            font-size: 1.5rem;
        }
    }
</style>

<!-- Hero Section Rediseñada -->
<section class="hero-section">
  <div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel" data-bs-interval="5000">
    <div class="carousel-inner">
      <div class="carousel-item active">
        <%= image_tag "quito.jpg", class: "d-block w-100", alt: "Quito - Ciudad de los Andes" %>
        <div class="hero-overlay"></div>
      </div>

      <div class="carousel-item">
        <%= image_tag "cuenca.jpg", class: "d-block w-100", alt: "Cuenca - Patrimonio Cultural" %>
        <div class="hero-overlay"></div>
      </div>

      <div class="carousel-item">
        <%= image_tag "guayaquil.webp", class: "d-block w-100", alt: "Guayaquil - Perla del Pacífico" %>
        <div class="hero-overlay"></div>
      </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Anterior</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Siguiente</span>
    </button>
  </div>

  <div class="hero-content px-3">
    <h1 class="hero-title">Descubre Ecuador con IyaiClub</h1>
    <p class="hero-subtitle">Encuentra los mejores establecimientos, experiencias únicas y vive aventuras inolvidables</p>

    <div class="search-container">
      <%= render "shared/search_hotels" %>
    </div>
  </div>
</section>

<!-- Modal Comodidades -->
<%= render "shared/amenities_modal" %>

<!-- Estadísticas -->
<section class="stats-section">
  <div class="container">
    <div class="row text-center">
      <div class="col-md-3 col-6 stat-item">
        <span class="stat-number">500+</span>
        <span class="stat-label">Establecimientos</span>
      </div>
      <div class="col-md-3 col-6 stat-item">
        <span class="stat-number">50+</span>
        <span class="stat-label">Ciudades</span>
      </div>
      <div class="col-md-3 col-6 stat-item">
        <span class="stat-number">10k+</span>
        <span class="stat-label">Clientes Satisfechos</span>
      </div>
      <div class="col-md-3 col-6 stat-item">
        <span class="stat-number">95%</span>
        <span class="stat-label">Rating Positivo</span>
      </div>
    </div>
  </div>
</section>

<!-- Categorías Rediseñadas -->
<section class="categories py-5">
  <div class="container">


    <!-- Título -->
    <h2 class="text-center fw-bold mb-4">Encuentra exactamente lo que buscas para tu próxima aventura</h2>

    <!-- Grid de categorías -->
    <div class="ms-2 me-2">
      <div class="row row-cols-1 row-cols-md-6 g-4">

        <div class="col-6 col-md-2">
          <%= link_to establishments_path, class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
            <i class="bi bi-building icon"></i>
            <h5 class="mt-3">Establecimientos</h5>
          <% end %>
        </div>

        <div class="col-6 col-md-2">
          <%= link_to hotels_path, class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
            <i class="bi bi-building icon"></i>
            <h5 class="mt-3">Hoteles</h5>
          <% end %>
        </div>

        <div class="col-6 col-md-2">
          <%= link_to restaurants_path, class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
            <i class="bi bi-building icon"></i>
            <h5 class="mt-3">Restaurantes</h5>
          <% end %>
        </div>

        <div class="col-6 col-md-2">
          <%= link_to "#", class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
            <i class="bi bi-bus-front icon"></i>
            <h5 class="mt-3">Transporte</h5>
          <% end %>
        </div>


        <div class="col-6 col-md-2">
          <%= link_to "#", class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
            <i class="bi bi-geo-alt icon"></i>
            <h5 class="mt-3">Agencias de Viaje</h5>
          <% end %>
        </div>


        <div class="col-6 col-md-2">
          <%= link_to "#", class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
            <i class="bi bi-balloon-heart icon"></i>
            <h5 class="mt-3">Escapadas de Momento</h5>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- Destinos Populares Rediseñados -->
<section class="destinos-section py-5">
  <div class="container">
    <h2 class="section-title text-center mb-5">Destinos Populares</h2>
    <div class="row g-4">
      <% ["Quito", "Cuenca", "Guayaquil", "Galapagos"].each do |city| %>
        <div class="col-md-3 col-6">
          <%= link_to establishments_path(city: city), class: "text-decoration-none" do %>
            <div class="destination-card">
              <%= image_tag "#{city.downcase}.jpg", class: "w-100 h-100", style: "object-fit: cover;", alt: "Destino #{city}" %>
              <div class="destination-overlay">
                <h5 class="fw-bold mb-2"><%= city %></h5>
                <span class="destination-stats">
                  +<%= Establishment.where(city: City.find_by(name: city)).count %> lugares
                </span>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Recomendados Rediseñados -->
<section class="recommendations-section py-5">
  <div class="container">
    <h2 class="section-title text-center mb-5">Recomendados para Ti</h2>

    <div id="recommendedCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
      <div class="carousel-inner">
        <% establishments = Establishment.order("RAND()").limit(12).to_a %>
        <% establishments.each_slice(3).with_index do |group, index| %>
          <div class="carousel-item <%= 'active' if index.zero? %>">
            <div class="row g-4">
              <% group.each do |est| %>
                <div class="col-md-4">
                  <%= link_to establishment_path(est), class: "text-decoration-none text-dark" do %>
                    <div class="recommendation-card position-relative">
                      <span class="recommendation-badge">Popular</span>
                      <% image_src = if est.galleries.any? && est.galleries.first.gallery_images.any? && est.galleries.first.gallery_images.first.file.attached?
                                       est.galleries.first.gallery_images.first.file
                                     else
                                       "logo.jpeg"
                                     end %>
                      <%= image_tag image_src, class: "card-img-top", style: "height: 200px; object-fit: cover;", alt: est.name %>
                      <div class="card-body p-3">
                        <h6 class="card-title fw-bold mb-1"><%= est.name %></h6>
                        <p class="text-muted small mb-1"><%= est.category.humanize %></p>
                        <p class="text-muted small mb-2">
                          <i class="bi bi-geo-alt"></i> <%= est.city&.name || "Ubicación desconocida" %>
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                          <span class="rating-stars">⭐⭐⭐⭐☆</span>
                          <small class="text-muted">4.2/5</small>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <button class="carousel-control-prev carousel-control-custom" type="button" data-bs-target="#recommendedCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Anterior</span>
      </button>
      <button class="carousel-control-next carousel-control-custom" type="button" data-bs-target="#recommendedCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Siguiente</span>
      </button>
    </div>
  </div>
</section>

<!-- Testimonios -->
<section class="testimonials-section py-5">
  <div class="container">
    <h2 class="section-title text-center mb-5">Lo que Dicen Nuestros Viajeros</h2>
    <div class="row">
      <div class="col-md-4">
        <div class="testimonial-card">
          <p class="testimonial-text">"Encontré los mejores hoteles gracias a IyaiClub. La experiencia de reserva fue increíblemente fácil y rápida."</p>
          <p class="testimonial-author">- María González</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="testimonial-card">
          <p class="testimonial-text">"Las recomendaciones personalizadas me ayudaron a descubrir lugares que nunca hubiera encontrado por mi cuenta."</p>
          <p class="testimonial-author">- Carlos Mendoza</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="testimonial-card">
          <p class="testimonial-text">"La atención al cliente es excepcional. Resolvieron todas mis dudas rápidamente y con mucha amabilidad."</p>
          <p class="testimonial-author">- Ana López</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Sabores y Experiencias Rediseñados -->
<section class="experiences-section py-5">
  <div class="container text-center">
    <h2 class="section-title mb-4">Sabores y Experiencias Únicas</h2>
    <p class="text-muted mb-5 fs-5">Descubre la auténtica esencia de Ecuador a través de su gastronomía y aventuras</p>
    <div class="row g-4">
      <div class="col-md-6">
        <div class="experience-card">
          <%= image_tag "restaurante.jpg", class: "w-100", style: "height: 300px; object-fit: cover;", alt: "Gastronomía ecuatoriana" %>
          <div class="experience-overlay">
            <h4 class="fw-bold">Gastronomía Auténtica</h4>
            <p class="mb-0">Descubre los sabores tradicionales en cada rincón del país</p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="experience-card">
          <%= image_tag "aventura.jpg", class: "w-100", style: "height: 300px; object-fit: cover;", alt: "Aventuras en Ecuador" %>
          <div class="experience-overlay">
            <h4 class="fw-bold">Aventuras Inolvidables</h4>
            <p class="mb-0">Desde la selva hasta los Andes, experiencias que marcarán tu vida</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Beneficios Rediseñados -->
<section class="benefits-section py-5">
  <div class="container">
    <h2 class="text-center text-white mb-5 display-5 fw-bold">¿Por Qué Elegir IyaiClub?</h2>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="benefit-item">
          <i class="bi bi-shield-check benefit-icon"></i>
          <h4 class="text-white fw-bold">Reservas 100% Seguras</h4>
          <p class="text-white-50">Tu información y pagos protegidos con encriptación de última generación</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="benefit-item">
          <i class="bi bi-lightning-charge benefit-icon"></i>
          <h4 class="text-white fw-bold">Confirmación Inmediata</h4>
          <p class="text-white-50">Recibe tu confirmación al instante con actualizaciones en tiempo real</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="benefit-item">
          <i class="bi bi-star-fill benefit-icon"></i>
          <h4 class="text-white fw-bold">Reseñas Verificadas</h4>
          <p class="text-white-50">Opiniones reales de viajeros que han vivido la experiencia</p>
        </div>
      </div>
    </div>
  </div>
</section>