<h2>Editar Galería: <%= @gallery.name %></h2>

<%= form_with(model: [@gallery.establishment, @gallery], local: true, html: { multipart: true, data: { controller: "gallery-edit" } }) do |f| %>
  <div class="mb-3">
    <%= f.label :name, "Nombre de la galería" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <h4 class="mt-4">Imágenes</h4>

  <!-- Contenedor principal -->
  <div id="gallery-images-container"
       class="d-flex flex-wrap gap-3"
       data-gallery-edit-target="container"
       data-next-index="<%= @gallery.gallery_images.size %>">

    <% @gallery.gallery_images.each_with_index do |img, i| %>
      <div class="gallery-image border rounded p-3 mb-3 position-relative text-center">
        <% if img.file.attached? %>
          <%= image_tag img.file.variant(resize_to_limit: [150, 150]),
                        class: "preview-img rounded mb-2 d-block mx-auto" %>
          <%= link_to "x", [@gallery.establishment, @gallery, img], data: {
            turbo_method: :delete,
            turbo_confirm: "¿Seguro que deseas eliminar esta imagen?" },
                      class: "btn btn-sm btn-danger position-absolute top-0 end-0 m-1 rounded-circle" %>
        <% end %>

        <input type="hidden" name="gallery[gallery_images_attributes][<%= i %>][id]" value="<%= img.id %>">
        <input type="file" name="gallery[gallery_images_attributes][<%= i %>][file]" accept="image/*" class="form-control form-control-sm">

<!--        <div class="form-check mt-2">-->
<!--          <input type="checkbox"-->
<!--                 name="gallery[gallery_images_attributes][<%#= i %>][_destroy]"-->
<!--                 value="1"-->
<!--                 id="destroy_<%#= i %>"-->
<!--                 class="form-check-input">-->
<!--          <label for="destroy_<%#= i %>" class="form-check-label">Eliminar</label>-->
<!--        </div>-->
      </div>
    <% end %>
  </div>

  <div class="mt-3">
    <button type="button" class="btn btn-outline-primary" data-action="click->gallery-edit#addImages">
      Agregar imágenes
    </button>
  </div>

  <%= f.submit "Guardar cambios", class: "btn btn-success mt-4" %>
<% end %>

<%= link_to "Volver", establishment_gallery_path(@gallery.establishment, @gallery), class: "btn btn-secondary mt-3" %>

<!-- 🖼️ Estilos -->
<style>
    .gallery-image img.preview-img {
        width: 150px !important;
        height: 150px !important;
        object-fit: cover;
        display: block;
        border-radius: 8px;
        margin-bottom: 0.5rem;
    }

    #gallery-images-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .gallery-image {
        flex: 0 0 calc(25% - 1rem);
        box-sizing: border-box;
    }

    @media (max-width: 992px) {
        .gallery-image { flex: 0 0 calc(33.333% - 1rem); }
    }

    @media (max-width: 768px) {
        .gallery-image { flex: 0 0 calc(50% - 1rem); }
    }

    @media (max-width: 480px) {
        .gallery-image { flex: 0 0 100%; }
    }
</style>
