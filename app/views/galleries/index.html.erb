<h2>Galerías de <%= @establishment.name %></h2>

<% @establishment.galleries.each do |gallery| %>
  <div class="card mb-4 shadow-sm border-0 rounded-3">

    <!-- Header con el nombre y botón a la galería -->
    <div class="card-header d-flex justify-content-between align-items-center bg-light">
      <%= link_to gallery.name,
                  establishment_gallery_path(@establishment, gallery),
                  class: "btn btn-sm btn-info" %>
    </div>

    <!-- Contenedor de imágenes -->
    <div class="card-body d-flex flex-wrap gap-3">
      <% gallery.gallery_images.each do |img| %>
        <div class="gallery-image border rounded p-2 position-relative text-center"
             data-controller="cover-selector"
             data-cover-selector-url-value="<%= set_cover_establishment_gallery_gallery_image_path(@establishment, gallery, img) %>"
             data-cover-selector-id-value="<%= img.id %>">

          <% if img.file.attached? %>
            <%= image_tag img.file.variant(resize_to_limit: [150, 150]),
                          class: "rounded mb-2 d-block mx-auto" %>
          <% end %>

          <button type="button"
                  class="btn btn-sm <%= img.is_cover? ? 'btn-warning' : 'btn-outline-secondary' %>"
                  data-action="click->cover-selector#setCover">
            <%= img.is_cover? ? "⭐ Portada" : "Marcar portada" %>
          </button>

        </div>
      <% end %>
    </div>

  </div>
<% end %>
