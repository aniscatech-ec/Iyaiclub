<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white fw-bold">
          <i class="bi bi-calendar-check me-2"></i> Detalle de reserva #<%= @booking.id %>
        </div>
        <div class="card-body">

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0"><%= @hotel.establishment.name %></h5>
            <% badge_class = case @booking.status
                             when "pendiente" then "bg-warning text-dark"
                             when "confirmado" then "bg-success"
                             when "rechazado" then "bg-danger"
                             when "cancelado" then "bg-secondary"
                             else "bg-light text-dark"
                             end %>
            <span class="badge <%= badge_class %> fs-6"><%= @booking.status.capitalize %></span>
          </div>

          <hr>

          <div class="row">
            <div class="col-md-6 mb-3">
              <p class="text-muted mb-1">Huésped</p>
              <p class="fw-bold"><%= @booking.guest_name %></p>
            </div>
            <div class="col-md-6 mb-3">
              <p class="text-muted mb-1">Email</p>
              <p class="fw-bold"><%= @booking.guest_email %></p>
            </div>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <p class="text-muted mb-1">Huéspedes</p>
              <p class="fw-bold"><%= @booking.guest_count %></p>
            </div>
            <div class="col-md-4 mb-3">
              <p class="text-muted mb-1">Entrada</p>
              <p class="fw-bold"><%= @booking.start_date.strftime("%d/%m/%Y") %></p>
            </div>
            <div class="col-md-4 mb-3">
              <p class="text-muted mb-1">Salida</p>
              <p class="fw-bold"><%= @booking.end_date.strftime("%d/%m/%Y") %></p>
            </div>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <p class="text-muted mb-1">Noches</p>
              <p class="fw-bold"><%= @booking.total_nights %></p>
            </div>
            <div class="col-md-4 mb-3">
              <p class="text-muted mb-1">Habitación</p>
              <p class="fw-bold"><%= @booking.room&.name || @booking.unit&.unit_type.presence || "—" %></p>
            </div>
            <div class="col-md-4 mb-3">
              <p class="text-muted mb-1">Total</p>
              <p class="fw-bold fs-5 text-primary">
                $<%= number_with_precision(@booking.total_price || 0, precision: 2) %>
              </p>
            </div>
          </div>

          <%
            phone = @booking.establishment&.whatsapp.presence || @booking.establishment&.legal_info&.contact_phone
            room_name = @booking.room&.name || @booking.unit&.unit_type || "—"
            room_type = @booking.room&.room_type&.capitalize
            price_per_night = @booking.room&.price_per_night || @booking.unit&.base_price || 0
            wa_message = [
              "Hola, me comunico desde *Iyaiclub* respecto a mi reserva.",
              "",
              "*Reserva ##{@booking.id}*",
              "*Establecimiento:* #{@hotel.establishment.name}",
              "*Habitación:* #{room_name}#{room_type.present? ? " (#{room_type})" : ""}",
              "*Precio por noche:* $#{number_with_precision(price_per_night, precision: 2)}",
              "",
              "*Huésped:* #{@booking.guest_name}",
              "*Email:* #{@booking.guest_email}",
              "*Huéspedes:* #{@booking.guest_count}",
              "",
              "*Check-in:* #{@booking.start_date&.strftime("%d/%m/%Y")}",
              "*Check-out:* #{@booking.end_date&.strftime("%d/%m/%Y")}",
              "*Noches:* #{@booking.total_nights}",
              "*Total:* $#{number_with_precision(@booking.total_price || 0, precision: 2)}",
              "",
              "Quedo atento a su confirmación. Gracias."
            ].join("\n")
          %>
          <%= render "shared/whatsapp_button",
                     phone: phone,
                     message: wa_message %>

        </div>
      </div>

      <% if current_user.afiliado? || current_user.administrador? %>
        <div class="card shadow-sm border-0 mb-4">
          <div class="card-header bg-dark text-white fw-bold">
            <i class="bi bi-gear me-2"></i> Gestión de reserva
          </div>
          <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
              <% unless @booking.confirmado? %>
                <%= form_with(model: [@hotel, @booking], method: :patch, local: true, class: "d-inline") do |f| %>
                  <%= f.hidden_field :status, value: "confirmado" %>
                  <%= f.submit "Confirmar", class: "btn btn-success" %>
                <% end %>
              <% end %>

              <% unless @booking.rechazado? %>
                <%= form_with(model: [@hotel, @booking], method: :patch, local: true, class: "d-inline") do |f| %>
                  <%= f.hidden_field :status, value: "rechazado" %>
                  <%= f.submit "Rechazar", class: "btn btn-danger" %>
                <% end %>
              <% end %>

              <% unless @booking.cancelado? %>
                <%= form_with(model: [@hotel, @booking], method: :patch, local: true, class: "d-inline") do |f| %>
                  <%= f.hidden_field :status, value: "cancelado" %>
                  <%= f.submit "Cancelar", class: "btn btn-secondary" %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <div class="text-center">
        <%= link_to "Volver al hotel", hotel_path(@hotel), class: "btn btn-outline-secondary me-2" %>
        <%= link_to "Ver todas las reservas", hotel_bookings_path(@hotel), class: "btn btn-outline-primary" %>
      </div>

    </div>
  </div>
</div>
