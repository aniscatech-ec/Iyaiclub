<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white fw-bold">
          <i class="bi bi-calendar-check me-2"></i> Nueva reserva
        </div>
        <div class="card-body">

          <div class="alert alert-info">
            <strong><%= @hotel.establishment.name %></strong> —
            Habitación: <strong><%= @room.name %></strong>
            <% if @room.room_type.present? %>
              (<%= @room.room_type.capitalize %>)
            <% end %>
            (Capacidad: <%= @room.guest_capacity || 1 %> huéspedes)
            <br>
            Precio por noche: <strong>$<%= number_with_precision(@room.price_per_night, precision: 2) %></strong>
            <% if @room.quantity.present? && @room.quantity > 1 %>
              | Disponibles: <strong><%= @room.quantity %></strong>
            <% end %>
          </div>

          <%= form_with(model: [@hotel, @booking], local: true) do |f| %>
            <% if @booking.errors.any? %>
              <div class="alert alert-danger">
                <h6><%= pluralize(@booking.errors.count, "error") %> encontrados:</h6>
                <ul class="mb-0">
                  <% @booking.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <%= f.hidden_field :room_id, value: @room.id %>

            <div class="mb-3">
              <%= f.label :guest_name, "Nombre completo", class: "form-label" %>
              <%= f.text_field :guest_name, class: "form-control", placeholder: "Tu nombre completo", value: current_user.name %>
            </div>

            <div class="mb-3">
              <%= f.label :guest_email, "Correo electrónico", class: "form-label" %>
              <%= f.email_field :guest_email, class: "form-control", placeholder: "tu@email.com", value: current_user.email %>
            </div>

            <div class="mb-3">
              <%= f.label :guest_count, "Número de huéspedes", class: "form-label" %>
              <%= f.number_field :guest_count, class: "form-control", min: 1, max: @room.guest_capacity || 10 %>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.label :start_date, "Fecha de entrada", class: "form-label" %>
                <%= f.date_field :start_date, class: "form-control", min: Date.today %>
              </div>
              <div class="col-md-6 mb-3">
                <%= f.label :end_date, "Fecha de salida", class: "form-label" %>
                <%= f.date_field :end_date, class: "form-control", min: Date.tomorrow %>
              </div>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-3">
              <%= link_to "Cancelar", hotel_path(@hotel), class: "btn btn-outline-secondary" %>
              <%= f.submit "Solicitar reserva", class: "btn btn-primary" %>
            </div>
          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
