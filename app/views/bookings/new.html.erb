<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white fw-bold">
          <i class="bi bi-calendar-check me-2"></i> Nueva reserva
        </div>
        <div class="card-body">

          <% establishment_name = @hotel&.establishment&.name || @parent&.establishment&.name || "Establecimiento" %>
          <% bookable_name = @room&.name.presence || @unit&.name.presence || @unit&.unit_type.presence || @parent&.name.presence || "—" %>
          <% price_per_night = @room&.price_per_night || @unit&.base_price || (@parent.respond_to?(:price_per_night) ? @parent.price_per_night : nil) || (@parent.respond_to?(:price) ? @parent.price : nil) || 0 %>

          <div class="alert alert-info">
            <strong><%= establishment_name %></strong>
            <% if bookable_name.present? && bookable_name != "—" %>
              — <strong><%= bookable_name %></strong>
            <% end %>
            <% if price_per_night > 0 %>
              <br>Precio por noche: <strong>$<%= number_with_precision(price_per_night, precision: 2) %></strong>
            <% end %>
          </div>

          <%# Botón de beneficio exclusivo para alojamiento %>
          <% if user_signed_in? && current_user.turista? && current_user.can_request_lodging_benefit? %>
            <div class="alert border-warning rounded-3 d-flex flex-column flex-sm-row align-items-sm-center gap-3 mb-4"
                 style="background: rgba(255,193,7,0.08); border: 1.5px solid #ffc107 !important;">
              <div class="flex-grow-1">
                <div class="fw-bold text-warning mb-1">
                  <i class="fas fa-crown me-1"></i>
                  Beneficio <%= current_user.membership_display_name %> disponible
                </div>
                <div class="small text-muted">
                  Tienes <strong><%= current_user.remaining_free_nights %></strong>
                  noche(s) gratis este año. Solicita tu estadía sin costo y nosotros la coordinamos por ti.
                </div>
              </div>
              <% benefit_path = if @hotel
                                   new_turista_hotel_benefit_request_path(@hotel, benefit_type: "lodging")
                                 elsif @parent.is_a?(Lodging)
                                   new_turista_lodging_benefit_request_path(@parent, benefit_type: "lodging")
                                 end %>
              <% if benefit_path %>
                <%= link_to benefit_path, class: "btn btn-warning rounded-pill fw-bold flex-shrink-0" do %>
                  <i class="fas fa-crown me-1"></i> Usar mi beneficio
                <% end %>
              <% end %>
            </div>
          <% end %>

          <% if @hotel %>
            <%= form_with(model: [@hotel, @booking], local: true, data: { turbo: false }) do |f| %>
              <%= render "form", f: f, booking: @booking, room: @room %>
            <% end %>
          <% else %>
            <%= form_with(model: [@parent, @booking], local: true, data: { turbo: false }) do |f| %>
              <%= render "form", f: f, booking: @booking, room: nil %>
            <% end %>
          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
