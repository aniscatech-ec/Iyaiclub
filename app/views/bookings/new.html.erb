<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white fw-bold">
          <i class="bi bi-calendar-check me-2"></i> Nueva reserva
        </div>
        <div class="card-body">

          <% establishment_name = @hotel&.establishment&.name || @parent&.establishment&.name || "Establecimiento" %>
          <% bookable_name = @unit&.name.presence || @unit&.unit_type.presence || @parent&.name.presence || "—" %>
          <% price_per_night = @unit&.base_price || (@parent.respond_to?(:price_per_night) ? @parent.price_per_night : nil) || (@parent.respond_to?(:price) ? @parent.price : nil) || 0 %>

          <div class="alert alert-info">
            <strong><%= establishment_name %></strong>
            <% if bookable_name.present? && bookable_name != "—" %>
              — <strong><%= bookable_name %></strong>
            <% end %>
            <% if price_per_night > 0 %>
              <br>Precio por noche / entrada: <strong>$<%= number_with_precision(price_per_night, precision: 2) %></strong>
            <% end %>
          </div>

          <% if @hotel %>
            <%= form_with(model: [@hotel, @booking], local: true) do |f| %>
              <%= render "form", f: f, booking: @booking, unit: @unit %>
            <% end %>
          <% else %>
            <%= form_with(model: [@parent, @booking], local: true) do |f| %>
              <%= render "form", f: f, booking: @booking, unit: nil %>
            <% end %>
          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
