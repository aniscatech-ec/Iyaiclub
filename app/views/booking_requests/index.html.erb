<div class="container my-5">

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold text-primary mb-1">
        <i class="fas fa-inbox me-2"></i> Solicitudes de reserva
      </h1>
      <small class="text-muted">
        Leads recibidos desde WhatsApp y web
      </small>
    </div>
  </div>

  <% if @booking_requests.any? %>
    <div class="table-responsive">
      <table class="table table-hover align-middle shadow-sm">
        <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>Hotel</th>
          <th>Origen</th>
          <th>Usuario</th>
          <th>Estado</th>
          <th>Fecha</th>
          <th class="text-end">Acciones</th>
        </tr>
        </thead>

        <tbody>
        <% @booking_requests.each do |booking| %>
          <tr>
            <td class="fw-bold"><%= booking.id %></td>

            <td>
              <strong><%= booking.establishment.name %></strong><br>
              <small class="text-muted">
                ID: <%= booking.establishment.id %>
              </small>
            </td>

            <td>
              <% if booking.source == "whatsapp" %>
                  <span class="badge bg-success">
                    <i class="fab fa-whatsapp me-1"></i> WhatsApp
                  </span>
              <% else %>
                  <span class="badge bg-secondary">
                    <%= booking.source.capitalize %>
                  </span>
              <% end %>
            </td>

            <td>
              <% if booking.user.present? %>
                <%= booking.user.email %>
              <% else %>
                <em class="text-muted">Invitado</em>
              <% end %>
            </td>

            <td>
              <% case booking.status %>
              <% when "pending" %>
                <span class="badge bg-warning text-dark">Pendiente</span>
              <% when "contacted" %>
                <span class="badge bg-info">Contactado</span>
              <% when "closed" %>
                <span class="badge bg-success">Cerrado</span>
              <% else %>
                <span class="badge bg-secondary"><%= booking.status %></span>
              <% end %>
            </td>

            <td>
              <%= l booking.created_at, format: :short %>
            </td>

            <td class="text-end">
              <%= link_to booking_request_path(booking),
                          class: "btn btn-sm btn-outline-primary" do %>
                <i class="fas fa-eye"></i>
              <% end %>

              <%= link_to edit_booking_request_path(booking),
                          class: "btn btn-sm btn-outline-secondary ms-1" do %>
                <i class="fas fa-edit"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

  <% else %>
    <div class="alert alert-info">
      No hay solicitudes de reserva registradas todavía.
    </div>
  <% end %>

</div>
