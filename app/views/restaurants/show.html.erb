<% if user_signed_in? %>
  <% if current_user.administrador? %>
    <%= render "restaurants/show/show_admin", restaurant: @restaurant %>
  <% elsif current_user.afiliado? %>
    <%= render "restaurants/show/show_afiliado", restaurant: @restaurant %>
  <% elsif current_user.turista? %>
    <%= render "restaurants/show/show_turista", restaurant: @restaurant%>
  <% end %>
<% else %>
  <%= render "restaurants/show/show_turista", restaurant: @restaurant %>

<% end %>
