<% est = @restaurant.establishment %>
<%= render "shared/establishment_show_styles" %>

<div class="est-show-page">

  <!-- HERO -->
  <%= render "shared/establishment_hero",
             establishment: est,
             title: est.name,
             icon: "fa-utensils",
             badges: [
               { text: @restaurant.category&.humanize&.capitalize, color: "var(--brand-orange, #EB633B)", icon: "fa-store" },
               { text: @restaurant.cuisine_type&.humanize&.capitalize, color: "var(--brand-cofee, #88682B)", icon: "fa-drumstick-bite" }
             ] %>

  <!-- QUICK STATS -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
        <div class="mb-1" style="color: var(--brand-orange, #EB633B);"><i class="fas fa-chair fa-2x"></i></div>
        <div class="fw-bold fs-4"><%= @restaurant.total_tables || 0 %></div>
        <div class="small text-muted">Mesas</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
        <div class="mb-1" style="color: var(--brand-green, #3FBD02);"><i class="fas fa-check-circle fa-2x"></i></div>
        <div class="fw-bold fs-4"><%= @restaurant.available_tables || 0 %></div>
        <div class="small text-muted">Disponibles</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
        <div class="mb-1" style="color: var(--brand-cofee, #88682B);"><i class="fas fa-users fa-2x"></i></div>
        <div class="fw-bold fs-4"><%= @restaurant.total_capacity || 0 %></div>
        <div class="small text-muted">Capacidad</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
        <div class="text-primary mb-1"><i class="fas fa-book-open fa-2x"></i></div>
        <div class="fw-bold fs-4"><%= @restaurant.menus.count %></div>
        <div class="small text-muted">Menús</div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- COLUMNA PRINCIPAL -->
    <div class="col-12 col-lg-8">

      <!-- PERFIL -->
      <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-orange, #EB633B), #c94a28); color: white; border-radius: 0.5rem 0.5rem 0 0;">
          <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2"></i> Perfil del restaurante</h5>
        </div>
        <div class="card-body p-4">
          <div class="row g-3 mb-3">
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas fa-tag me-1"></i> Nombre</div>
                <div class="info-value"><%= est.name %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas fa-store me-1"></i> Categoría</div>
                <div class="info-value"><%= @restaurant.category&.humanize&.capitalize || "—" %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas fa-drumstick-bite me-1"></i> Tipo de cocina</div>
                <div class="info-value"><%= @restaurant.cuisine_type&.humanize&.capitalize || "—" %></div>
              </div>
            </div>
            <% if @restaurant.seats_per_table.present? %>
              <div class="col-sm-6">
                <div class="info-item">
                  <div class="info-label"><i class="fas fa-chair me-1"></i> Asientos por mesa</div>
                  <div class="info-value"><%= @restaurant.seats_per_table %></div>
                </div>
              </div>
            <% end %>
          </div>

          <% if est.short_description.present? %>
            <div class="mt-3">
              <div class="info-label"><i class="fas fa-align-left me-1"></i> Descripción corta</div>
              <p class="mb-0"><%= est.short_description %></p>
            </div>
          <% end %>

          <% if est.long_description.present? %>
            <div class="mt-3 pt-3 border-top">
              <div class="info-label"><i class="fas fa-file-alt me-1"></i> Descripción detallada</div>
              <div class="long-desc"><%= simple_format(est.long_description) %></div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- MENÚS -->
      <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, #e74c3c, #c0392b); color: white; border-radius: 0.5rem 0.5rem 0 0;">
          <h5 class="mb-0 fw-bold"><i class="fas fa-book-open me-2"></i> Menús</h5>
        </div>
        <div class="card-body p-4">
          <% if @restaurant.menus.any? %>
            <% @restaurant.menus.each_with_index do |menu, idx| %>
              <% if idx > 0 %><hr class="my-4"><% end %>
              <h5 class="fw-bold mb-3 pb-2 border-bottom" style="color: #e74c3c;">
                <i class="fas fa-utensils me-2"></i><%= menu.name %>
                <span class="badge bg-light text-dark ms-2"><%= menu.menu_items.size %> platos</span>
              </h5>
              <% if menu.menu_items.any? %>
                <div class="row g-3">
                  <% menu.menu_items.each do |item| %>
                    <div class="col-12 col-md-6">
                      <div class="card menu-item-card h-100 rounded-3">
                        <div class="card-body p-3 h-100 d-flex flex-column">
                          <% if item.photo.present? %>
                            <div class="mb-2 rounded-3 overflow-hidden" style="height: 140px;">
                              <img src="<%= item.photo %>"
                                   class="w-100 h-100"
                                   style="object-fit: cover;"
                                   alt="<%= item.name %>"
                                   onerror="this.parentElement.style.display='none'"
                                   loading="lazy">
                            </div>
                          <% end %>
                          <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="card-title fw-bold mb-0"><%= item.name %></h6>
                            <span class="menu-item-price ms-2 text-nowrap">
                              <%= number_to_currency(item.price) %>
                            </span>
                          </div>
                          <% if item.description.present? %>
                            <p class="card-text text-muted small mb-0 flex-grow-1"><%= item.description %></p>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="text-muted fst-italic ms-3">Este menú aún no tiene platos registrados.</p>
              <% end %>
            <% end %>
          <% else %>
            <div class="text-center py-4">
              <i class="fas fa-book-open fa-3x text-muted mb-2"></i>
              <p class="text-muted fst-italic mb-0">Este restaurante aún no ha publicado sus menús</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- GALERÍA -->
      <%= render "shared/establishment_gallery", establishment: est %>

      <!-- COMODIDADES -->
      <% if est.amenities.any? %>
        <div class="card border-0 shadow-sm rounded-3 mb-4">
          <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, #27ae60, #1e8449); color: white; border-radius: 0.5rem 0.5rem 0 0;">
            <h5 class="mb-0 fw-bold"><i class="fas fa-concierge-bell me-2"></i> Servicios del restaurante</h5>
          </div>
          <div class="card-body p-4">
            <div class="row g-2">
              <% est.amenities.each do |amenity| %>
                <div class="col-6 col-md-4">
                  <div class="amenity-pill d-flex align-items-center p-2 rounded-3">
                    <i class="fas fa-check-circle me-2" style="color: var(--brand-green, #3FBD02);"></i>
                    <span class="small"><%= amenity.name %></span>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

    </div>

    <!-- COLUMNA LATERAL -->
    <div class="col-12 col-lg-4">

      <!-- ACCIONES -->
      <div class="card border-0 shadow-sm rounded-3 mb-4 sticky-top-actions">
        <div class="card-body p-3">
          <div class="d-grid gap-2">
            <% if current_user&.administrador? || (current_user&.afiliado? && est.user_id == current_user.id) %>
              <%= link_to edit_restaurant_path(@restaurant), class: "btn btn-primary rounded-pill fw-semibold" do %>
                <i class="fas fa-edit me-1"></i> Editar restaurante
              <% end %>
            <% end %>

            <% phone = est.whatsapp.presence || est.legal_info&.contact_phone %>
            <% if phone.present? %>
              <a href="https://wa.me/<%= phone.to_s.gsub(/\D/, '') %>?text=<%= CGI.escape("Hola, estoy interesado en #{est.name}") %>"
                 target="_blank"
                 class="btn btn-success rounded-pill fw-semibold">
                <i class="fab fa-whatsapp me-1"></i> Contactar por WhatsApp
              </a>
            <% end %>

            <%= link_to restaurants_path, class: "btn btn-outline-secondary rounded-pill fw-semibold" do %>
              <i class="fas fa-arrow-left me-1"></i> Volver al listado
            <% end %>
          </div>
        </div>
      </div>

      <%= render "shared/establishment_sidebar", establishment: est %>

    </div>
  </div>
</div>
