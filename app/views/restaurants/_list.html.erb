<!-- app/views/restaurants/_list.html.erb -->
<div id="restaurants-list">
  <div class="row">
    <% if restaurants.any? %>
      <% restaurants.each do |restaurant| %>

        <%= render "restaurants/show/restaurant_card", restaurant: restaurant %>

      <% end %>

      <!-- Paginación -->
      <div class="col-12 mt-4">
        <%= paginate restaurants %>
      </div>
    <% else %>
      <div class="col-12 text-center my-5 py-5">
        <div class="text-muted">
          <i class="bi bi-search display-4 opacity-50"></i>
          <h5 class="mt-3 fw-semibold">No se encontraron restaurantes</h5>
          <p class="mb-0 text-muted">Intenta ajustar los filtros de búsqueda</p>
          <button class="btn btn-outline-primary mt-3 rounded-pill">
            <i class="bi bi-filter me-1"></i>Limpiar filtros
          </button>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
    .restaurant-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .restaurant-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15) !important;
    }

    .restaurant-image {
        object-fit: cover;
        transition: transform 0.3s ease;
        height: 200px;
    }

    .restaurant-card:hover .restaurant-image {
        transform: scale(1.03);
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .fs-7 {
        font-size: 0.8rem;
    }

    /* Efecto de brillo al hover */
    .restaurant-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        transform: translateX(-100%);
        transition: transform 0.6s;
        z-index: 1;
    }

    .restaurant-card:hover::before {
        transform: translateX(100%);
    }
</style>