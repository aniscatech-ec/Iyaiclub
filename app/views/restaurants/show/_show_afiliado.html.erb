            <div class="d-flex align-items-center">
              <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3"
                   style="width: 32px; height: 32px; font-size: 0.8rem;">CL</div>
              <div>
                <div class="fw-medium text-dark">Carlos López</div>
                <div class="text-muted small">7 reseñas</div>
              </div>
