          <div class="row align-items-end">
            <div class="col-12 col-lg-8">
              <h1 class="text-white display-5 fw-light mb-2">La Terraza Gourmet</h1>
              <div class="d-flex align-items-center text-white-80 mb-3 flex-wrap gap-3">
