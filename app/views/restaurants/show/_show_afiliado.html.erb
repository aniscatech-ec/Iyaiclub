               class="w-100 gallery-image rounded" alt="Comida">
        </div>
        <div class="col-6 col-md-3">
          <img src="https://images.unsplash.com/photo-1578474846511-04ba529f0b88?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
               class="w-100 gallery-image rounded" alt="Ambiente">
        </div>
        <div class="col-6 col-md-3">
          <div class="w-100 h-100 rounded bg-light d-flex align-items-center justify-content-center">
