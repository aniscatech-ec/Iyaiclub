                </div>
              </div>
            </div>
            <div class="col-12 col-sm-6">
              <div class="feature-item d-flex align-items-start">
                <i class="bi bi-wine-glass text-warning mt-1 me-3"></i>
                <div>
                  <div class="fw-medium text-dark mb-1">Bodega Seleccionada</div>
                  <div class="text-muted small">200+ etiquetas premium</div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Menú Destacado Mejorado -->
