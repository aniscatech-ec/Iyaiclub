                    <span class="text-dark">Todos</span>
                  </div>
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>

    <!-- Galería Minimalista -->
    <section class="gallery-section mt-5 pt-5 border-top">
      <h3 class="h5 fw-normal text-dark mb-4">Galería</h3>
      <div class="row g-3">
        <div class="col-6 col-md-3">
          <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
               class="w-100 gallery-image rounded" alt="Interior">
