                  </button>

                  <div class="text-center mt-3">
                    <small class="text-muted">
                      <i class="bi bi-shield-check me-1"></i>Reserva segura
                    </small>
                  </div>
                </form>
              </div>
            </div>
          </section>

          <!-- Contacto Rápido -->
          <section class="quick-contact">
            <div class="card border-light shadow-sm">
              <div class="card-body p-3">
                <div class="btn-group w-100" role="group">
                  <button class="btn btn-outline-dark">
                    <i class="bi bi-telephone"></i>
                  </button>
                  <button class="btn btn-outline-dark">
                    <i class="bi bi-whatsapp"></i>
                  </button>
                  <button class="btn btn-outline-dark">
                    <i class="bi bi-share"></i>
                  </button>
                  <button class="btn btn-outline-dark">
                    <i class="bi bi-heart"></i>
                  </button>
                </div>
              </div>
            </div>
          </section>

          <!-- Información Útil -->
          <section class="useful-info mt-4">
            <div class="card border-light shadow-sm">
              <div class="card-body">
                <h6 class="fw-medium text-dark mb-3">Información útil</h6>
                <div class="info-list">
                  <div class="info-item d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Tiempo promedio</span>
                    <span class="text-dark">1.5-2h</span>
                  </div>
                  <div class="info-item d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Cancelación</span>
