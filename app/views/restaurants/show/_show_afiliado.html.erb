</div>

<style>
    .hybrid-restaurant-show {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    .hero-container {
        border-radius: 0 0 1rem 1rem;
        overflow: hidden;
    }

    .hero-image {
        height: 400px;
        object-fit: cover;
    }

    .hero-content {
        background: linear-gradient(transparent 40%, rgba(0,0,0,0.7));
        padding-bottom: 2rem;
    }

    .rating-badge {
        background: rgba(255,255,255,0.2);
        padding: 4px 12px;
        border-radius: 20px;
        backdrop-filter: blur(10px);
    }

    .text-white-80 {
        color: rgba(255,255,255,0.8);
    }

    .cuisine-type, .price-range {
        padding: 4px 0;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #fff;
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }

    /* Cards de información */
    .info-card, .amenity-item {
        transition: all 0.3s ease;
        border: 1px solid #e9ecef !important;
    }

    .info-card:hover, .amenity-item:hover {
        transform: translateY(-2px);
        border-color: #dee2e6 !important;
    }

    /* Menú items */
    .menu-item {
        transition: border-color 0.3s ease;
    }

    .menu-item:hover {
        border-color: #dee2e6 !important;
    }

    /* Widget de reserva */
    .reservation-widget .card {
        border: 1px solid #e9ecef !important;
    }

    .reservation-form .form-control, .reservation-form .form-select {
        border-radius: 0.5rem;
    }

    /* Galería */
    .gallery-image {
        height: 200px;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .gallery-image:hover {
        transform: scale(1.02);
    }

    /* Reseñas */
    .review-card {
        transition: transform 0.3s ease;
        border: 1px solid #e9ecef !important;
    }

    .review-card:hover {
        transform: translateY(-2px);
    }

    /* Sidebar sticky */
    .sticky-sidebar {
        position: sticky;
        top: 2rem;
        z-index: 100;
    }

    /* Botones y elementos interactivos */
    .btn {
        transition: all 0.3s ease;
    }

    .btn-outline-dark:hover {
        background: #000;
        color: #fff;
    }

    /* Tipografía mejorada */
    .h5, .h6 {
        letter-spacing: -0.01em;
        font-weight: 400;
    }

    .fw-medium {
        font-weight: 500;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero-image {
            height: 300px;
        }

        .display-5 {
            font-size: 2rem;
        }

        .sticky-sidebar {
            position: static;
        }
    }

    /* Mejoras de espaciado */
    .section-spacing {
        margin-bottom: 3rem;
    }

    .border-top {
        border-color: #e9ecef !important;
    }
</style>