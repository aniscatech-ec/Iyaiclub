                <form class="reservation-form">
                  <div class="mb-3">
                    <label class="form-label small fw-medium text-muted">Fecha</label>
                    <input type="date" class="form-control border" value="2024-01-15">
                  </div>

                  <div class="row g-2 mb-3">
                    <div class="col-6">
                      <label class="form-label small fw-medium text-muted">Hora</label>
                      <select class="form-select border">
                        <option>19:00</option>
                        <option>19:30</option>
                        <option>20:00</option>
                        <option>20:30</option>
                      </select>
                    </div>
                    <div class="col-6">
                      <label class="form-label small fw-medium text-muted">Personas</label>
                      <select class="form-select border">
                        <option>2 personas</option>
                        <option>3 personas</option>
                        <option>4 personas</option>
                        <option>5 personas</option>
                      </select>
                    </div>
                  </div>

                  <div class="mb-3">
                    <label class="form-label small fw-medium text-muted">Tipo de mesa</label>
                    <select class="form-select border">
                      <option>Cualquier mesa</option>
                      <option>Terraza</option>
                      <option>Ventana</option>
                      <option>Privada</option>
                    </select>
                  </div>

                  <button type="submit" class="btn btn-dark w-100 py-3 fw-medium">
