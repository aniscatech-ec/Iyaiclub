<style>
    /* Variables CSS para restaurantes */
    :root {
        --primary-color: #c44536;
        --secondary-color: #e67e22;
        --accent-color: #f39c12;
        --light-bg: #fef9f7;
        --dark-text: #2c3e50;
        --shadow: 0 4px 12px rgba(0,0,0,0.1);
        --shadow-hover: 0 8px 25px rgba(0,0,0,0.15);
        --gradient-primary: linear-gradient(135deg, #c44536 0%, #e67e22 100%);
        --gradient-hero: linear-gradient(135deg, rgba(196, 69, 54, 0.85) 0%, rgba(0, 0, 0, 0.7) 100%);
    }

    /* ==================== Hero Section Restaurantes ==================== */
    .hero-section {
        position: relative;
        overflow: hidden;
        background: var(--gradient-hero), url('https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1800&q=80') center/cover no-repeat;
        min-height: 500px;
        display: flex;
        align-items: center;
        color: #fff;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        text-shadow: 0 4px 12px rgba(0,0,0,0.6);
        line-height: 1.1;
    }

    .hero-subtitle {
        font-size: 1.3rem;
        margin-bottom: 2.5rem;
        opacity: 0.95;
        text-shadow: 0 2px 8px rgba(0,0,0,0.4);
        font-weight: 400;
    }

    /* ==================== Search Card Restaurantes ==================== */
    .search-section {
        margin-top: -80px;
        position: relative;
        z-index: 10;
    }

    .search-card {
        background: rgba(255,255,255,0.98);
        backdrop-filter: blur(20px);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 20px 40px rgba(0,0,0,0.25);
        border: 1px solid rgba(255,255,255,0.3);
    }

    .search-form .form-label {
        font-weight: 600;
        color: var(--dark-text);
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .search-form .form-control {
        border-radius: 12px;
        border: 2px solid #e9ecef;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }

    .search-form .form-control:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 0.2rem rgba(196, 69, 54, 0.15);
    }

    /* Input con ícono */
    .input-icon {
        position: relative;
    }

    .input-icon i {
        position: absolute;
        top: 50%;
        left: 15px;
        transform: translateY(-50%);
        color: var(--primary-color);
        font-size: 1.1rem;
        z-index: 2;
    }

    .input-icon .form-control {
        padding-left: 45px;
    }

    /* Selectores de filtro */
    .filter-select {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        background: white;
        transition: all 0.3s ease;
        width: 100%;
        cursor: pointer;
    }

    .filter-select:focus {
        border-color: var(--primary-color);
        outline: none;
    }

    /* Botón buscar */
    .search-btn {
        background: var(--gradient-primary);
        border: none;
        border-radius: 12px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        height: 100%;
        color: white;
    }

    .search-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(196, 69, 54, 0.3);
    }

    /* ==================== Sección Restaurantes Destacados ==================== */
    .featured-section {
        padding: 4rem 0;
        background: var(--light-bg);
    }

    .section-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .section-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .section-subtitle {
        color: #6c757d;
        font-size: 1.1rem;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Tarjetas de restaurantes */
    .restaurant-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: all 0.4s ease;
        height: 100%;
        border: none;
        position: relative;
    }

    .restaurant-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-hover);
    }

    .restaurant-card-img {
        height: 200px;
        object-fit: cover;
        width: 100%;
    }

    .restaurant-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: var(--primary-color);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .restaurant-card-body {
        padding: 1.5rem;
    }

    .restaurant-card-title {
        font-weight: 700;
        margin-bottom: 0.5rem;
        font-size: 1.1rem;
        color: var(--dark-text);
    }

    .restaurant-card-cuisine {
        color: var(--primary-color);
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .restaurant-card-location {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .restaurant-rating {
        color: #ffc107;
        font-size: 0.9rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .restaurant-price {
        font-size: 0.9rem;
        color: #27ae60;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .restaurant-features {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .feature-tag {
        background: #f8f9fa;
        color: #6c757d;
        padding: 0.25rem 0.75rem;
        border-radius: 15px;
        font-size: 0.8rem;
        border: 1px solid #e9ecef;
    }

    .restaurant-btn {
        background: var(--gradient-primary);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
        width: 100%;
    }

    .restaurant-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(196, 69, 54, 0.3);
    }

    /* ==================== Categorías de Cocina ==================== */
    .cuisines-section {
        padding: 4rem 0;
        background: white;
    }

    .cuisine-card {
        background: white;
        border-radius: 16px;
        padding: 2rem 1rem;
        text-align: center;
        transition: all 0.4s ease;
        border: 2px solid transparent;
        box-shadow: var(--shadow);
        height: 100%;
        position: relative;
        overflow: hidden;
    }

    .cuisine-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-hover);
        border-color: var(--accent-color);
    }

    .cuisine-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1rem;
        background: var(--gradient-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2rem;
        transition: all 0.3s ease;
    }

    .cuisine-card:hover .cuisine-icon {
        transform: scale(1.1) rotate(5deg);
    }

    .cuisine-title {
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--dark-text);
    }

    .cuisine-count {
        color: #6c757d;
        font-size: 0.9rem;
    }

    /* ==================== Beneficios ==================== */
    .benefits-section {
        padding: 4rem 0;
        background: var(--gradient-primary);
        color: white;
        position: relative;
        overflow: hidden;
    }

    .benefits-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .benefit-item {
        text-align: center;
        padding: 2rem;
        transition: all 0.3s ease;
        border-radius: 15px;
        position: relative;
        z-index: 1;
    }

    .benefit-item:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-5px);
    }

    .benefit-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: var(--accent-color);
        transition: all 0.3s ease;
    }

    .benefit-item:hover .benefit-icon {
        background: rgba(255,255,255,0.2);
        transform: scale(1.1);
    }

    .benefit-title {
        font-weight: 600;
        margin-bottom: 1rem;
        font-size: 1.1rem;
    }

    .benefit-text {
        opacity: 0.9;
        font-size: 0.9rem;
        line-height: 1.5;
    }

    /* ==================== Zonas Populares ==================== */
    .locations-section {
        padding: 4rem 0;
        background: var(--light-bg);
    }

    .location-card {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: all 0.4s ease;
        position: relative;
        height: 200px;
    }

    .location-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-hover);
    }

    .location-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .location-card:hover .location-img {
        transform: scale(1.1);
    }

    .location-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 1.5rem;
        background: linear-gradient(transparent, rgba(0,0,0,0.8));
        color: white;
    }

    .location-name {
        font-weight: 600;
        margin-bottom: 0.25rem;
        font-size: 1.1rem;
    }

    .location-count {
        font-size: 0.9rem;
        opacity: 0.9;
    }

    /* ==================== Testimonios ==================== */
    .testimonials-section {
        padding: 4rem 0;
        background: white;
    }

    .testimonial-card {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        box-shadow: var(--shadow);
        transition: all 0.3s ease;
        position: relative;
        border: 1px solid #f1f3f4;
    }

    .testimonial-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-hover);
    }

    .testimonial-card::before {
        content: '"';
        font-size: 4rem;
        color: var(--accent-color);
        position: absolute;
        top: -0.5rem;
        left: 1rem;
        opacity: 0.3;
        font-family: Georgia, serif;
        line-height: 1;
    }

    .testimonial-text {
        font-style: italic;
        margin-bottom: 1.5rem;
        position: relative;
        z-index: 1;
        line-height: 1.6;
    }

    .testimonial-author {
        font-weight: 600;
        color: var(--primary-color);
        margin-bottom: 0.25rem;
    }

    .testimonial-restaurant {
        font-size: 0.85rem;
        color: #6c757d;
    }

    /* ==================== CTA Final ==================== */
    .cta-section {
        padding: 4rem 0;
        background: var(--gradient-primary);
        color: white;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .cta-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .cta-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .cta-subtitle {
        font-size: 1.2rem;
        margin-bottom: 2rem;
        opacity: 0.9;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .cta-btn {
        background: white;
        color: var(--primary-color);
        border: none;
        border-radius: 12px;
        padding: 1rem 2.5rem;
        font-weight: 600;
        font-size: 1.1rem;
        transition: all 0.3s ease;
    }

    .cta-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    /* ==================== Responsive ==================== */
    @media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem;
        }

        .hero-subtitle {
            font-size: 1.1rem;
        }

        .search-card {
            margin: 0 15px;
            padding: 1.5rem;
        }

        .section-title {
            font-size: 2rem;
        }

        .cta-title {
            font-size: 2rem;
        }

        .cta-subtitle {
            font-size: 1rem;
        }
    }

    @media (max-width: 576px) {
        .hero-section {
            min-height: 400px;
        }

        .hero-title {
            font-size: 2rem;
        }

        .search-section {
            margin-top: -60px;
        }
    }
</style>

<!-- ==================== Hero Section ==================== -->
<section class="hero-section">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">Descubre los mejores restaurantes</h1>
      <p class="hero-subtitle">Encuentra experiencias gastronómicas únicas, desde comida local hasta cocina internacional</p>
    </div>
  </div>
</section>

<!-- ==================== Search Section ==================== -->
<section class="search-section">
  <div class="container">
    <div class="search-card">
      <form action="/restaurants/search_results" method="get" class="search-form row g-3 align-items-end">
        <!-- Ubicación -->
        <div class="col-md-3">
          <label class="form-label">Ubicación</label>
          <div class="input-icon">
            <i class="bi bi-geo-alt"></i>
            <input type="text" name="city" class="form-control" placeholder="Ej: Quito, Centro...">
          </div>
        </div>

        <!-- Tipo de cocina -->
        <div class="col-md-3">
          <label class="form-label">Tipo de cocina</label>
          <select name="cuisine_type" class="filter-select">
            <option value="">Todas las cocinas</option>
            <option value="ecuatoriana">Ecuatoriana</option>
            <option value="internacional">Internacional</option>
            <option value="asiatica">Asiática</option>
            <option value="italiana">Italiana</option>
            <option value="mariscos">Mariscos</option>
            <option value="vegetariana">Vegetariana</option>
          </select>
        </div>

        <!-- Tipo de restaurante - NUEVO CAMPO -->
        <div class="col-md-3">
          <label class="form-label">Categoría</label>
          <select name="restaurant_type" class="filter-select">
            <option value="">Todas las categorías</option>
            <option value="Familiar" <%= "selected" if params[:restaurant_type] == "Familiar" %>>Familiar</option>
            <option value="Gourmet" <%= "selected" if params[:restaurant_type] == "Gourmet" %>>Gourmet</option>
            <option value="Bar" <%= "selected" if params[:restaurant_type] == "Bar" %>>Bar</option>
            <option value="Café" <%= "selected" if params[:restaurant_type] == "Café" %>>Café</option>
            <option value="Comida rápida" <%= "selected" if params[:restaurant_type] == "Comida rápida" %>>Comida rápida</option>
          </select>
        </div>

        <!-- Botón Buscar -->
        <div class="col-md-3 d-grid">
          <button type="submit" class="search-btn">
            <i class="bi bi-search me-2"></i> Buscar Restaurantes
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- ==================== Restaurantes Destacados ==================== -->
<section class="featured-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Restaurantes Destacados</h2>
      <p class="section-subtitle">Los lugares mejor calificados por nuestra comunidad</p>
    </div>
    <div class="row g-4">
      <% @restaurants.each do |restaurant| %>
        <div class="col-md-4">
          <div class="restaurant-card">
            <div class="position-relative">

              <% cover_image = restaurant.galleries.joins(:gallery_images).find_by(gallery_images: { is_cover: true })&.gallery_images&.find_by(is_cover: true)&.file %>

              <% if cover_image&.attached? %>
                <%= image_tag cover_image, class: "card-img-top hotel-image", height: 300 %>
              <% elsif restaurant.galleries.any? && restaurant.galleries.first.gallery_images.any? %>
                <% first_image = restaurant.galleries.first.gallery_images.first.file %>
                <%= image_tag first_image, class: "card-img-top hotel-image", height: 300 if first_image.attached? %>
              <% else %>
                <%= image_tag "hotel-placeholder.jpg", class: "card-img-top hotel-image", height: 300 %>
              <% end %>



              <%# if restaurant.images.attached? %>
                <%#= image_tag restaurant.images.first, class: "restaurant-card-img", alt: restaurant.establishment.name %>
              <%# else %>
<!--                <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=600&q=80" class="restaurant-card-img" alt="<%#= restaurant.establishment.name %>">-->
              <%# end %>
              <span class="restaurant-badge">Destacado</span>
            </div>
            <div class="restaurant-card-body">
              <h5 class="restaurant-card-title"><%= restaurant.establishment.name %></h5>
              <div class="restaurant-card-cuisine"><%= restaurant.restaurant_type&.humanize || "Cocina variada" %></div>
              <div class="restaurant-card-location">
                <i class="bi bi-geo-alt"></i>
                <%= restaurant.establishment.city&.name || "Ubicación no especificada" %>
              </div>
              <div class="restaurant-rating">
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-half"></i>
                <span>4.5</span>
              </div>
              <div class="restaurant-price">
                $$ • Abierto hasta 22:00
              </div>
              <div class="restaurant-features">
                <span class="feature-tag">WiFi</span>
                <span class="feature-tag">Reservas</span>
                <span class="feature-tag">Terraza</span>
              </div>
              <%= link_to "Ver Menú", restaurant_path(restaurant), class: "restaurant-btn" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ==================== Categorías de Cocina ==================== -->
<section class="cuisines-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Tipos de Cocina</h2>
      <p class="section-subtitle">Explora por tu tipo de comida favorita</p>
    </div>
    <div class="row g-4">
      <div class="col-6 col-md-3">
        <div class="cuisine-card">
          <div class="cuisine-icon">
            <i class="bi bi-egg-fried"></i>
          </div>
          <div class="cuisine-title">Ecuatoriana</div>
          <div class="cuisine-count"><%= Restaurant.where(cuisine_type: 'ecuatoriana').count %> restaurantes</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="cuisine-card">
          <div class="cuisine-icon">
            <i class="bi bi-globe"></i>
          </div>
          <div class="cuisine-title">Internacional</div>
          <div class="cuisine-count"><%= Restaurant.count %> opciones</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="cuisine-card">
          <div class="cuisine-icon">
            <i class="bi bi-bowl"></i>
          </div>
          <div class="cuisine-title">Asiática</div>
          <div class="cuisine-count"><%= Restaurant.count %> restaurantes</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="cuisine-card">
          <div class="cuisine-icon">
            <i class="bi bi-egg"></i>
          </div>
          <div class="cuisine-title">Italiana</div>
          <div class="cuisine-count"><%= Restaurant.count %> opciones</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== Beneficios ==================== -->
<section class="benefits-section">
  <div class="container">
    <div class="section-header">
      <h2 class="text-white">¿Por qué usar nuestra plataforma?</h2>
      <p class="text-white-50">La mejor manera de descubrir experiencias gastronómicas únicas</p>
    </div>
    <div class="row g-4">
      <div class="col-md-3">
        <div class="benefit-item">
          <div class="benefit-icon">
            <i class="bi bi-star"></i>
          </div>
          <h5 class="benefit-title">Reseñas Verificadas</h5>
          <p class="benefit-text">Opiniones reales de comensales que han visitado los restaurantes</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="benefit-item">
          <div class="benefit-icon">
            <i class="bi bi-camera"></i>
          </div>
          <h5 class="benefit-title">Fotos Reales</h5>
          <p class="benefit-text">Imágenes reales de los platos y ambientes de cada restaurante</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="benefit-item">
          <div class="benefit-icon">
            <i class="bi bi-clock"></i>
          </div>
          <h5 class="benefit-title">Horarios Actualizados</h5>
          <p class="benefit-text">Información precisa sobre horarios y disponibilidad</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="benefit-item">
          <div class="benefit-icon">
            <i class="bi bi-telephone"></i>
          </div>
          <h5 class="benefit-title">Reservas Fáciles</h5>
          <p class="benefit-text">Sistema simple para hacer reservas en tus restaurantes favoritos</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== Zonas Populares ==================== -->
<section class="locations-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Zonas Populares</h2>
      <p class="section-subtitle">Descubre restaurantes en las mejores ubicaciones</p>
    </div>
    <div class="row g-4">
      <div class="col-6 col-md-3">
        <div class="location-card">
          <img src="https://images.unsplash.com/photo-1565539549452-218826869b39?auto=format&fit=crop&w=600&q=80" class="location-img" alt="Centro Histórico">
          <div class="location-overlay">
            <h5 class="location-name">Centro Histórico</h5>
            <div class="location-count"><%= Restaurant.count %> restaurantes</div>
          </div>
        </div>
      </div>
