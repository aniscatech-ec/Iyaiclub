<div class="row">
  <% if restaurants.any? %>
    <% restaurants.each do |restaurant| %>
      <% can_modify = current_user&.administrador? ||
                      (current_user&.afiliado? && restaurant.establishment&.user_id == current_user.id) %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-0 rounded-3">
          <% if restaurant.establishment.galleries.any? && restaurant.establishment.galleries.first.gallery_images.any? %>
            <% first_image = restaurant.establishment.galleries.first.gallery_images.first.file %>
            <% if first_image.attached? %>
              <%= image_tag first_image.variant(resize_to_fill: [400, 200]),
                    class: "card-img-top rounded-top-3",
                    style: "height: 200px; object-fit: cover;",
                    loading: "lazy" %>
            <% end %>
          <% else %>
            <div class="card-img-top rounded-top-3 d-flex align-items-center justify-content-center" style="height: 200px; background: linear-gradient(135deg, #EB633B, #c94a28);">
              <i class="fas fa-utensils text-white fa-3x"></i>
            </div>
          <% end %>

          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="badge rounded-pill" style="background: #EB633B;">
                <%= restaurant.cuisine_type.presence&.humanize || "Sin categoría" %>
              </span>
            </div>
            <h5 class="card-title fw-bold"><%= restaurant.establishment.name %></h5>
            <p class="card-text text-muted small mb-2">
              <i class="fas fa-map-marker-alt me-1"></i>
              <%= restaurant.establishment.city&.name || "Ubicación no especificada" %>
            </p>
            <p class="card-text text-truncate small">
              <%= restaurant.establishment.short_description.presence || "Sin descripción" %>
            </p>
          </div>

          <div class="card-footer bg-transparent border-0 d-flex gap-2">
            <%= link_to restaurant_path(restaurant), class: "btn btn-outline-primary btn-sm flex-grow-1" do %>
              <i class="fas fa-eye me-1"></i> Ver
            <% end %>
            <% if can_modify %>
              <%= link_to edit_restaurant_path(restaurant), class: "btn btn-outline-secondary btn-sm" do %>
                <i class="fas fa-edit"></i>
              <% end %>
              <%= link_to restaurant_path(restaurant), data: { turbo_method: :delete, turbo_confirm: "¿Está seguro de eliminar este restaurante?" }, class: "btn btn-outline-danger btn-sm" do %>
                <i class="fa-solid fa-trash-can"></i>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="col-12">
      <div class="alert alert-info border-0 shadow-sm rounded-3">
        <i class="fas fa-info-circle me-2"></i>
        No hay restaurantes registrados aún.
      </div>
    </div>
  <% end %>
</div>
