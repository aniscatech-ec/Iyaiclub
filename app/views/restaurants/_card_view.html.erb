<div class="row">
  <% if restaurants.any? %>
    <% restaurants.each do |restaurant| %>
      <% est = restaurant.establishment %>
      <div class="col-12 col-md-6 col-lg-4 mb-4">
        <div class="card restaurant-card shadow-sm border-0 h-100 rounded-4 overflow-hidden transition-all">

          <!-- Imagen principal con badges superpuestos -->
          <div class="position-relative">
            <% cover_image = est.galleries.joins(:gallery_images).find_by(gallery_images: { is_cover: true })&.gallery_images&.find_by(is_cover: true)&.file %>

            <% if cover_image&.attached? %>
              <%= image_tag cover_image, class: "card-img-top restaurant-image", height: 300 %>
            <% elsif est.galleries.any? && est.galleries.first.gallery_images.any? %>
              <% first_image = est.galleries.first.gallery_images.first.file %>
              <%= image_tag first_image, class: "card-img-top restaurant-image", height: 300 if first_image.attached? %>
            <% else %>
              <%= image_tag "restaurant-placeholder.jpg", class: "card-img-top restaurant-image", height: 300 %>
            <% end %>

            <!-- Badges superpuestos -->
            <div class="position-absolute top-0 start-0 p-2">
              <span class="badge bg-success bg-opacity-90 text-white fs-7">
                <i class="bi bi-check-circle-fill me-1"></i>
                Activo
              </span>
            </div>
            <div class="position-absolute top-0 end-0 p-2">
              <span class="badge bg-info bg-opacity-90 text-white fs-7">
                <i class="bi bi-utensils me-1"></i>
                <%= restaurant.restaurant_type.present? ? restaurant.restaurant_type.humanize : "Restaurante" %>
              </span>
            </div>

            <!-- Precio promedio -->
            <div class="position-absolute bottom-0 end-0 m-2">
              <span class="badge bg-dark bg-opacity-75 text-white fs-6">
                $25-50
              </span>
            </div>
          </div>

          <div class="card-body p-3 d-flex flex-column">
            <!-- Información principal -->
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h6 class="fw-bold text-dark mb-0 flex-grow-1 me-2"><%= est.name %></h6>
              <div class="text-success">
                <i class="bi bi-star-fill"></i>
                <span class="fw-bold">4.2/5</span>
              </div>
            </div>

            <!-- Ubicación -->
            <div class="d-flex align-items-center mb-2">
              <i class="bi bi-geo-alt text-muted me-2"></i>
              <small class="text-muted">
                <%= est.city&.name || "Ciudad no definida" %>,
                <%= est.city&.province&.name || "Provincia no definida" %>
              </small>
            </div>

            <!-- Horario -->
            <div class="d-flex align-items-center mb-2">
              <i class="bi bi-clock text-muted me-2"></i>
              <small class="text-muted">
                11:00 - 23:00
              </small>
            </div>

            <!-- Contacto -->
            <div class="d-flex align-items-center mb-3">
              <i class="bi bi-telephone text-muted me-2"></i>
              <small class="text-muted">+1 234-567-8900</small>
            </div>

            <!-- Tipo de cocina y capacidad -->
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="badge bg-light text-dark border small">
                <i class="bi bi-egg-fried me-1"></i><%= restaurant.cuisine_type || "Internacional" %>
              </span>
              <span class="badge bg-primary bg-opacity-10 text-primary border-0 small">
                <i class="bi bi-people me-1"></i>50 personas
              </span>
            </div>

            <!-- Estadísticas del afiliado -->
            <div class="affiliate-stats border-top pt-2 mb-3">
              <div class="row small text-muted">
                <div class="col-6">
                  <i class="bi bi-calendar-check me-1"></i>
                  12 reservas hoy
                </div>
                <div class="col-6 text-end">
                  <i class="bi bi-cash-coin me-1"></i>
                  45 esta semana
                </div>
              </div>
            </div>

            <!-- Comodidades destacadas -->
            <div class="amenities-preview mb-3">
              <div class="d-flex flex-wrap gap-1">
                <% est.amenities.limit(3).each do |amenity| %>
                  <span class="badge bg-light text-dark border small">
                    <i class="bi bi-check-circle text-success me-1"></i><%= amenity.name %>
                  </span>
                <% end %>
                <% if est.amenities.empty? %>
                  <span class="badge bg-light text-dark border small">
                    <i class="bi bi-ban text-primary me-1"></i>No se han registrado comodidades
                  </span>
                <% end %>
              </div>
            </div>

            <!-- Acciones del afiliado - Se mantiene al fondo -->
            <div class="mt-auto">
              <div class="d-grid gap-2">

                <div class="btn-group w-100" role="group">
                  <%= link_to restaurant, class: "btn btn-info btn-sm" do %>
                    <i class="fa-solid fa-eye"></i>
                  <% end %>
                  <%= link_to edit_restaurant_path(restaurant), class: "btn btn-warning btn-sm" do %>
                    <i class="fa-solid fa-pen-to-square"></i>
                  <% end %>

                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="col-12 text-center my-5 py-5">
      <div class="text-muted">
        <i class="bi bi-utensils display-4 opacity-50"></i>
        <h5 class="mt-3 fw-semibold">No tienes restaurantes registrados</h5>
        <p class="mb-3 text-muted">Comienza agregando tu primer restaurante para gestionar reservas</p>
        <button class="btn btn-primary rounded-pill">
          <i class="bi bi-plus-circle me-2"></i>Registrar Primer Restaurante
        </button>
      </div>
    </div>
  <% end %>
</div>

