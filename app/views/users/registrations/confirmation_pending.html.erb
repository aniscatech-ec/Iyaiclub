<div class="container mt-5 mb-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow rounded-4 border-0 overflow-hidden">

        <!-- Encabezado con gradiente -->
        <div class="text-center py-5 px-4" style="background: linear-gradient(135deg, var(--brand-orange, #EB633B), #c94a28); color: white;">
          <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
               style="width: 90px; height: 90px; background: rgba(255,255,255,0.2); border: 3px solid rgba(255,255,255,0.4);">
            <i class="fas fa-envelope-open-text fa-3x"></i>
          </div>
          <h3 class="fw-bold mb-2">¡Revisa tu correo!</h3>
          <p class="mb-0 opacity-75">Te hemos enviado un enlace de verificación</p>
        </div>

        <div class="card-body p-4 p-md-5">

          <!-- Email destacado -->
          <div class="text-center mb-4">
            <p class="text-muted mb-2">Enviamos las instrucciones de confirmación a:</p>
            <div class="d-inline-block px-4 py-2 rounded-3 fw-bold"
                 style="background: #fff3ed; color: var(--brand-orange, #EB633B); border: 2px dashed var(--brand-orange, #EB633B);">
              <i class="fas fa-envelope me-2"></i><%= @email %>
            </div>
          </div>

          <!-- Pasos a seguir -->
          <div class="mb-4">
            <h6 class="fw-bold mb-3" style="color: var(--brand-cofee, #88682B);">
              <i class="fas fa-list-check me-2"></i> Qué hacer ahora
            </h6>
            <div class="d-flex mb-3">
              <div class="flex-shrink-0 me-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle fw-bold"
                     style="width: 32px; height: 32px; background: var(--brand-green, #3FBD02); color: white;">1</div>
              </div>
              <div>
                <strong class="d-block">Abre tu bandeja de entrada</strong>
                <small class="text-muted">Busca un correo de <strong>IyaiClub</strong></small>
              </div>
            </div>
            <div class="d-flex mb-3">
              <div class="flex-shrink-0 me-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle fw-bold"
                     style="width: 32px; height: 32px; background: var(--brand-green, #3FBD02); color: white;">2</div>
              </div>
              <div>
                <strong class="d-block">Haz clic en el enlace de verificación</strong>
                <small class="text-muted">El enlace te redirigirá automáticamente para activar tu cuenta</small>
              </div>
            </div>
            <div class="d-flex">
              <div class="flex-shrink-0 me-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle fw-bold"
                     style="width: 32px; height: 32px; background: var(--brand-green, #3FBD02); color: white;">3</div>
              </div>
              <div>
                <strong class="d-block">¡Listo! Inicia sesión</strong>
                <small class="text-muted">Una vez confirmada tu cuenta podrás acceder a todas las funciones</small>
              </div>
            </div>
          </div>

          <hr class="my-4">

          <!-- Mensaje de spam -->
          <div class="alert d-flex align-items-start mb-4" style="background: #fff9e6; border: 1px solid #ffd966; color: #7a5d00;">
            <i class="fas fa-exclamation-triangle me-2 mt-1"></i>
            <div class="small mb-0">
              <strong>¿No encuentras el correo?</strong> Revisa tu carpeta de <strong>Spam</strong> o
              <strong>Correo no deseado</strong>. A veces los mensajes de verificación terminan ahí.
            </div>
          </div>

          <!-- Acciones -->
          <div class="d-grid gap-2">
            <%= link_to new_user_confirmation_path, class: "btn btn-outline-primary rounded-pill fw-semibold" do %>
              <i class="fas fa-paper-plane me-1"></i> Reenviar correo de confirmación
            <% end %>
            <%= link_to new_user_session_path, class: "btn btn-link text-decoration-none" do %>
              <i class="fas fa-arrow-left me-1"></i> Volver al inicio de sesión
            <% end %>
          </div>

        </div>
      </div>

      <!-- Soporte -->
      <div class="text-center mt-4">
        <small class="text-muted">
          ¿Necesitas ayuda? <a href="mailto:soporte@iyaiclub.com" class="text-decoration-none fw-semibold" style="color: var(--brand-orange, #EB633B);">Contáctanos</a>
        </small>
      </div>
    </div>
  </div>
</div>
