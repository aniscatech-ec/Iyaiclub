<%= form_with(model: @custom_request, url: custom_requests_path, local: true,
              html: { data: { controller: "form-validation" } }) do |f| %>
  <% if @custom_request.errors.any? %>
    <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i>
      <strong><%= pluralize(@custom_request.errors.count, "error") %> encontrados:</strong>
      <ul class="mb-0 mt-2">
        <% @custom_request.errors.full_messages.each { |m| concat(content_tag(:li, m)) } %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <!-- ═══════════════ 1. DATOS DEL VIAJE ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header border-0 py-3"
         style="background: linear-gradient(135deg, var(--brand-orange, #EB633B), #c94a28); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-plane-departure me-2"></i> 1. Datos del viaje</h5>
    </div>
    <div class="card-body p-4">
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <%= f.label :destination, "Destino", class: "form-label fw-semibold required-field" %>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
            <%= f.text_field :destination, class: "form-control",
                             placeholder: "Ej: Quito, Galápagos, Baños...", required: true %>
          </div>
        </div>

        <div class="col-6 col-md-3">
          <%= f.label :start_date, "Fecha de inicio", class: "form-label fw-semibold required-field" %>
          <%= f.date_field :start_date, class: "form-control",
                           data: { controller: "flatpickr" }, required: true %>
        </div>
        <div class="col-6 col-md-3">
          <%= f.label :end_date, "Fecha de fin", class: "form-label fw-semibold required-field" %>
          <%= f.date_field :end_date, class: "form-control",
                           data: { controller: "flatpickr" }, required: true %>
        </div>

        <div class="col-6 col-md-3">
          <%= f.label :guests_count, "Nº de personas", class: "form-label fw-semibold required-field" %>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-users"></i></span>
            <%= f.number_field :guests_count, class: "form-control", min: 1, value: 1, required: true %>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <%= f.label :estimated_budget, "Presupuesto estimado ($)", class: "form-label fw-semibold" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :estimated_budget, class: "form-control", min: 0, step: 0.01 %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════ 2. TIPO DE EXPERIENCIA ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header border-0 py-3"
         style="background: linear-gradient(135deg, var(--brand-cofee, #88682B), #6b5320); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-star me-2"></i> 2. Tipo de experiencia</h5>
    </div>
    <div class="card-body p-4">
      <div class="row g-3">
        <% CustomRequest.experience_types.keys.each do |type| %>
          <div class="col-6 col-md-3">
            <%= f.radio_button :experience_type, type, class: "btn-check", id: "experience_#{type}", required: true %>
            <label class="btn btn-outline-warning w-100 h-100 d-flex flex-column align-items-center justify-content-center py-3 rounded-3"
                   for="experience_<%= type %>">
              <i class="<%= experience_type_icon(type) %> fa-2x mb-2"
                 style="color: <%= experience_type_color(type) %>;"></i>
              <span class="fw-semibold"><%= experience_type_label(type) %></span>
            </label>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- ═══════════════ 3. INTERESES ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header border-0 py-3"
         style="background: linear-gradient(135deg, #27ae60, #1e8449); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-heart me-2"></i> 3. Intereses</h5>
    </div>
    <div class="card-body p-4">
      <div class="row g-2">
        <% CustomRequest::INTERESTS.each do |key| %>
          <div class="col-6 col-md-4 col-lg-2">
            <%= check_box_tag "custom_request[interests][]", key,
                              @custom_request.interests&.include?(key),
                              class: "btn-check", id: "interest_#{key}" %>
            <label class="btn btn-outline-success w-100 d-flex flex-column align-items-center justify-content-center py-3 rounded-3"
                   for="interest_<%= key %>">
              <i class="<%= interest_icon(key) %> fa-lg mb-1"></i>
              <span class="small fw-semibold"><%= interest_label(key) %></span>
            </label>
          </div>
        <% end %>
      </div>
      <%= hidden_field_tag "custom_request[interests][]", "" %>
    </div>
  </div>

  <!-- ═══════════════ 4. PREFERENCIAS ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header border-0 py-3"
         style="background: linear-gradient(135deg, #8e44ad, #6c3483); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-concierge-bell me-2"></i> 4. Preferencias</h5>
    </div>
    <div class="card-body p-4">
      <div class="row g-2">
        <% CustomRequest::PREFERENCES.each do |key| %>
          <div class="col-6 col-md-3">
            <%= check_box_tag "custom_request[preferences][]", key,
                              @custom_request.preferences&.include?(key),
                              class: "btn-check", id: "preference_#{key}" %>
            <label class="btn btn-outline-primary w-100 d-flex flex-column align-items-center justify-content-center py-3 rounded-3"
                   for="preference_<%= key %>">
              <i class="<%= preference_icon(key) %> fa-lg mb-1"></i>
              <span class="small fw-semibold"><%= preference_label(key) %></span>
            </label>
          </div>
        <% end %>
      </div>
      <%= hidden_field_tag "custom_request[preferences][]", "" %>
    </div>
  </div>

  <!-- ═══════════════ 5. COMENTARIOS ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header border-0 py-3"
         style="background: linear-gradient(135deg, var(--brand-cofee-black, #7F5935), #5a3d1f); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-comment-dots me-2"></i> 5. Comentarios adicionales</h5>
    </div>
    <div class="card-body p-4">
      <%= f.text_area :comments, class: "form-control", rows: 4,
                      placeholder: "Cuéntanos cualquier detalle relevante para diseñar tu experiencia..." %>
    </div>
  </div>

  <div class="d-grid d-md-flex gap-2 justify-content-md-end">
    <%= link_to "Cancelar", :back, class: "btn btn-outline-secondary rounded-pill px-4" %>
    <%= f.submit "Enviar solicitud", class: "btn btn-warning rounded-pill px-4 fw-semibold" %>
  </div>
<% end %>
