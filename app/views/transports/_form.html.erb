<%= form_with(model: transport, local: true, html: { class: "transport-form", multipart: true, data: { controller: "form-validation" } }) do |form| %>
  <%= render_validation_errors(transport) %>

  <%= form.fields_for :establishment do |est| %>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header text-white fw-bold rounded-top-3" style="background: var(--brand-green);">
        <i class="fas fa-bus me-2"></i> 1. Información del transporte
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-12">
            <%= est.label :name, "Nombre del servicio", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-signature"></i></span>
              <%= est.text_field :name, class: "form-control", placeholder: "Nombre público del transporte", required: true %>
            </div>
          </div>

          <% if current_user.administrador? %>
            <div class="col-md-6">
              <%= est.label :user_id, "Afiliado responsable", class: "form-label fw-semibold" %>
              <%= est.collection_select :user_id, User.where(role: :afiliado).order(:name), :id, :email,
                  { prompt: "Seleccione un afiliado" }, class: "form-select" %>
            </div>
          <% end %>

          <div class="col-md-6">
            <%= form.label :transport_type, "Tipo de transporte", class: "form-label fw-semibold required-field" %>
            <%= form.select :transport_type,
                Transport::TRANSPORT_TYPES.map { |t| [t.humanize.capitalize, t] },
                { prompt: "Seleccione tipo" },
                class: "form-select",
                required: true,
                data: { action: "change->nested-form#toggleSubcategories" },
                id: "transport_type_select" %>
          </div>

          <div class="col-md-6">
            <%= form.label :subcategory, "Subcategoría", class: "form-label fw-semibold required-field" %>
            <%= form.select :subcategory,
                grouped_options_for_select(
                  {
                    "Terrestre" => Transport::TERRESTRIAL_SUBCATEGORIES.map { |s| [s.humanize.titleize, s] },
                    "Acuático" => Transport::AQUATIC_SUBCATEGORIES.map { |s| [s.humanize.titleize, s] }
                  },
                  transport.subcategory
                ),
                { prompt: "Seleccione subcategoría" },
                class: "form-select",
                required: true,
                id: "subcategory_select" %>
          </div>

          <div class="col-md-6">
            <%= est.label :status, "Estado", class: "form-label fw-semibold" %>
            <%= est.select :status, Establishment.statuses.keys.map { |s| [s.humanize.capitalize, s] },
                { prompt: "Seleccione estado" }, class: "form-select" %>
          </div>

          <div class="col-12">
            <%= est.label :description, "Descripción", class: "form-label fw-semibold" %>
            <%= est.text_area :description, class: "form-control", rows: 3, placeholder: "Descripción general del servicio de transporte" %>
          </div>

          <div class="col-md-6">
            <%= est.label :short_description, "Descripción corta", class: "form-label fw-semibold" %>
            <%= est.text_area :short_description, class: "form-control", rows: 2, placeholder: "Resumen breve" %>
          </div>

          <div class="col-md-6">
            <%= form.label :service_description, "Descripción del servicio", class: "form-label fw-semibold" %>
            <%= form.text_area :service_description, class: "form-control", rows: 2, placeholder: "Detalles específicos del servicio" %>
          </div>

          <div class="col-md-6">
            <%= form.label :capacity, "Capacidad (personas)", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-users"></i></span>
              <%= form.number_field :capacity, class: "form-control", placeholder: "0", min: 0 %>
            </div>
          </div>

          <div class="col-md-6">
            <%= form.label :price_range, "Rango de precios", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
              <%= form.text_field :price_range, class: "form-control", placeholder: "Ej: $5 - $25" %>
            </div>
          </div>

          <div class="col-md-6">
            <%= form.label :total_vehicles, "Total de vehiculos", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-car"></i></span>
              <%= form.number_field :total_vehicles, class: "form-control", min: 0, placeholder: "Ej: 10" %>
            </div>
          </div>

          <div class="col-md-6">
            <%= form.label :available_vehicles, "Vehiculos disponibles", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-check-circle"></i></span>
              <%= form.number_field :available_vehicles, class: "form-control", min: 0, placeholder: "Ej: 8" %>
            </div>
          </div>

          <div class="col-12">
            <%= form.label :routes, "Rutas o destinos principales", class: "form-label fw-semibold" %>
            <%= form.text_area :routes, class: "form-control", rows: 2, placeholder: "Ej: Cuenca - Guayaquil, Cuenca - Quito, Cuenca - Loja" %>
          </div>

          <div class="col-md-6">
            <%= form.label :service_frequency, "Frecuencia del servicio", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-sync-alt"></i></span>
              <%= form.text_field :service_frequency, class: "form-control", placeholder: "Ej: Cada 30 min, Diario, Semanal" %>
            </div>
          </div>

          <div class="col-md-6">
            <%= form.label :operating_area, "Zona de operacion", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-map"></i></span>
              <%= form.text_field :operating_area, class: "form-control", placeholder: "Ej: Azuay, Interurbano, Nacional" %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header text-white fw-bold rounded-top-3" style="background: var(--brand-orange);">
        <i class="fas fa-address-book me-2"></i> 2. Contacto
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <%= est.label :phone, "Teléfono", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-phone"></i></span>
              <%= est.telephone_field :phone, class: "form-control", placeholder: "Ej: 072123456", required: true %>
            </div>
          </div>

          <div class="col-md-6">
            <%= est.label :whatsapp, "WhatsApp", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fab fa-whatsapp text-success"></i></span>
              <%= est.telephone_field :whatsapp, class: "form-control", placeholder: "593991234567", required: true %>
            </div>
            <small class="text-muted">Con código de país, sin + ni espacios</small>
          </div>

          <div class="col-md-6">
            <%= est.label :email, "Correo electrónico", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-envelope"></i></span>
              <%= est.email_field :email, class: "form-control", placeholder: "correo@ejemplo.com", required: true %>
            </div>
          </div>

          <div class="col-md-6">
            <%= est.label :website, "Sitio web", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-globe"></i></span>
              <%= est.url_field :website, class: "form-control", placeholder: "https://www.ejemplo.com" %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header text-white fw-bold rounded-top-3" style="background: var(--brand-cofee);">
        <i class="fas fa-map-marker-alt me-2"></i> 3. Ubicación
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-12">
            <%= est.label :address, "Dirección", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-road"></i></span>
              <%= est.text_field :address, class: "form-control", placeholder: "Calle principal y secundaria", required: true %>
            </div>
          </div>

          <div class="col-md-4">
            <%= est.label :country_id, "País", class: "form-label fw-semibold required-field" %>
            <%= est.collection_select :country_id, Country.order(:name), :id, :name,
                { prompt: "Seleccione país" }, class: "form-select", required: true %>
          </div>

          <div class="col-md-4">
            <%= est.label :province_id, "Provincia", class: "form-label fw-semibold required-field" %>
            <%= est.collection_select :province_id, Province.order(:name), :id, :name,
                { prompt: "Seleccione provincia" }, class: "form-select", required: true %>
          </div>

          <div class="col-md-4">
            <%= est.label :city_id, "Ciudad", class: "form-label fw-semibold required-field" %>
            <%= est.collection_select :city_id, City.order(:name), :id, :name,
                { prompt: "Seleccione ciudad" }, class: "form-select", required: true %>
          </div>

          <div class="col-12">
            <%= est.label :arrival_instructions, "Instrucciones de llegada", class: "form-label fw-semibold" %>
            <%= est.text_area :arrival_instructions, class: "form-control", rows: 2, placeholder: "Cómo llegar a la terminal/oficina" %>
          </div>

          <div class="col-md-6">
            <%= est.label :latitude, "Latitud", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-map-pin"></i></span>
              <%= est.number_field :latitude, step: 0.000001, class: "form-control", placeholder: "Ej: -2.897086", required: true %>
            </div>
          </div>

          <div class="col-md-6">
            <%= est.label :longitude, "Longitud", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-map-pin"></i></span>
              <%= est.number_field :longitude, step: 0.000001, class: "form-control", placeholder: "Ej: -79.004653", required: true %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header bg-info text-white fw-bold rounded-top-3">
        <i class="fas fa-clock me-2"></i> 4. Horarios
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <%= est.label :opening_time, "Hora de inicio de servicio", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-door-open"></i></span>
              <%= est.time_field :opening_time, class: "form-control" %>
            </div>
          </div>

          <div class="col-md-6">
            <%= est.label :closing_time, "Hora de fin de servicio", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-door-closed"></i></span>
              <%= est.time_field :closing_time, class: "form-control" %>
            </div>
          </div>

          <div class="col-12">
            <%= est.label :policies, "Políticas del servicio", class: "form-label fw-semibold" %>
            <%= est.text_area :policies, class: "form-control", rows: 3, placeholder: "Políticas de cancelación, equipaje, normas..." %>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header bg-dark text-white fw-bold rounded-top-3">
        <i class="fas fa-file-contract me-2"></i> 5. Datos legales
      </div>
      <div class="card-body">
        <%= est.fields_for :legal_info do |li| %>
          <div class="row g-3">
            <div class="col-md-6">
              <%= li.label :business_name, "Razón social", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-building"></i></span>
                <%= li.text_field :business_name, class: "form-control", placeholder: "Nombre legal de la empresa", required: true %>
              </div>
            </div>

            <div class="col-md-6">
              <%= li.label :legal_representative, "Representante legal", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-user-tie"></i></span>
                <%= li.text_field :legal_representative, class: "form-control", placeholder: "Nombre completo", required: true %>
              </div>
            </div>

            <div class="col-md-6">
              <%= li.label :document_type, "Tipo de documento", class: "form-label fw-semibold required-field" %>
              <%= li.select :document_type, [["RUC", "RUC"], ["Cédula", "Cedula"], ["Pasaporte", "Pasaporte"]],
                  { prompt: "Seleccione" }, class: "form-select", required: true %>
            </div>

            <div class="col-md-6">
              <%= li.label :document_number, "Número de documento", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                <%= li.text_field :document_number, class: "form-control", placeholder: "Ej: 0102030405001", required: true %>
              </div>
            </div>

            <div class="col-md-6">
              <%= li.label :contact_email, "Email de contacto legal", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                <%= li.email_field :contact_email, class: "form-control", placeholder: "legal@empresa.com", required: true %>
              </div>
            </div>

            <div class="col-md-6">
              <%= li.label :contact_phone, "Teléfono de contacto legal", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                <%= li.telephone_field :contact_phone, class: "form-control", placeholder: "072123456", required: true %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  <% end %>

  <div class="card shadow-sm border-0 rounded-3 mb-4" id="vehicles-section">
    <div class="card-header text-white fw-bold rounded-top-3" style="background: var(--brand-green);">
      <i class="fas fa-car me-2"></i> 6. Vehículos
      <small class="fw-normal">(solo para Rentadoras — máx. 5)</small>
    </div>
    <div class="card-body" data-controller="nested-form">
      <template data-nested-form-target="template">
        <div class="nested-fields border rounded-3 p-3 mb-3" data-new-record="true">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold">Nombre del vehículo</label>
              <input type="text" name="transport[vehicles_attributes][NEW_RECORD][name]" class="form-control" placeholder="Ej: Toyota Hilux 2024">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Precio por día ($)</label>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                <input type="number" step="0.01" name="transport[vehicles_attributes][NEW_RECORD][price_per_day]" class="form-control" placeholder="0.00">
              </div>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Descripción</label>
              <textarea name="transport[vehicles_attributes][NEW_RECORD][description]" class="form-control" rows="2" placeholder="Características del vehículo"></textarea>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Condiciones de alquiler</label>
              <textarea name="transport[vehicles_attributes][NEW_RECORD][conditions]" class="form-control" rows="2" placeholder="Requisitos, depósito, seguro..."></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Foto</label>
              <input type="file" name="transport[vehicles_attributes][NEW_RECORD][photo]" class="form-control" accept="image/jpeg,image/png,image/webp">
            </div>
            <div class="col-md-6 d-flex align-items-end">
              <button type="button" class="btn btn-outline-danger" data-action="nested-form#remove">
                <i class="fas fa-trash me-1"></i> Eliminar vehículo
              </button>
            </div>
          </div>
        </div>
      </template>

      <div data-nested-form-target="target">
        <% transport.vehicles.each_with_index do |vehicle, index| %>
          <%= form.fields_for :vehicles, vehicle do |vf| %>
            <div class="nested-fields border rounded-3 p-3 mb-3">
              <div class="row g-3">
                <%= vf.hidden_field :id %>
                <div class="col-md-6">
                  <%= vf.label :name, "Nombre del vehículo", class: "form-label fw-semibold" %>
                  <%= vf.text_field :name, class: "form-control", placeholder: "Ej: Toyota Hilux 2024" %>
                </div>
                <div class="col-md-6">
                  <%= vf.label :price_per_day, "Precio por día ($)", class: "form-label fw-semibold" %>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                    <%= vf.number_field :price_per_day, step: 0.01, class: "form-control", placeholder: "0.00" %>
                  </div>
                </div>
                <div class="col-12">
                  <%= vf.label :description, "Descripción", class: "form-label fw-semibold" %>
                  <%= vf.text_area :description, class: "form-control", rows: 2, placeholder: "Características del vehículo" %>
                </div>
                <div class="col-12">
                  <%= vf.label :conditions, "Condiciones de alquiler", class: "form-label fw-semibold" %>
                  <%= vf.text_area :conditions, class: "form-control", rows: 2, placeholder: "Requisitos, depósito, seguro..." %>
                </div>
                <div class="col-md-6">
                  <%= vf.label :photo, "Foto", class: "form-label fw-semibold" %>
                  <% if vehicle.persisted? && vehicle.photo.attached? %>
                    <div class="mb-2">
                      <%= image_tag vehicle.photo.variant(resize_to_limit: [120, 80]), class: "img-thumbnail rounded shadow-sm", loading: "lazy" %>
                    </div>
                  <% end %>
                  <%= vf.file_field :photo, class: "form-control", accept: "image/jpeg,image/png,image/webp" %>
                </div>
                <div class="col-md-6 d-flex align-items-end">
                  <%= vf.hidden_field :_destroy, value: "0", id: "vehicle_destroy_#{index}" %>
                  <button type="button" class="btn btn-outline-danger" data-action="nested-form#remove"
                          onclick="document.getElementById('vehicle_destroy_<%= index %>').value = '1'; this.closest('.nested-fields').style.display = 'none';">
                    <i class="fas fa-trash me-1"></i> Eliminar vehículo
                  </button>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <button type="button" class="btn btn-outline-success" data-action="nested-form#add">
        <i class="fas fa-plus me-1"></i> Agregar vehículo
      </button>
    </div>
  </div>

  <div class="card shadow-sm border-0 rounded-3 mb-4">
    <div class="card-header bg-dark text-white fw-bold rounded-top-3">
      <i class="fas fa-images me-2"></i> 7. Imágenes
    </div>
    <div class="card-body">
      <%= form.fields_for :establishment do |est2| %>
        <% if transport.establishment&.images&.attached? %>
          <div class="mb-3">
            <label class="form-label fw-semibold text-muted">Imágenes actuales</label>
            <div class="d-flex flex-wrap gap-2">
              <% transport.establishment.images.each do |img| %>
                <div class="position-relative">
                  <%= image_tag img.variant(resize_to_limit: [120, 120]),
                      class: "img-thumbnail rounded shadow-sm",
                      style: "width: 120px; height: 80px; object-fit: cover;",
                      loading: "lazy" %>
                </div>
              <% end %>
            </div>
          </div>
          <hr>
        <% end %>
        <div class="mb-0">
          <%= est2.label :images, "Subir nuevas imágenes", class: "form-label fw-semibold" %>
          <%= est2.file_field :images, multiple: true, class: "form-control",
              accept: "image/jpeg,image/png,image/webp" %>
          <small class="text-muted">Puedes seleccionar varias imágenes (JPG, PNG, WEBP)</small>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm border-0 rounded-3 mb-4">
    <div class="card-header fw-bold rounded-top-3" style="background: var(--brand-green); color: white;">
      <i class="fas fa-concierge-bell me-2"></i> 8. Comodidades
    </div>
    <div class="card-body">
      <div class="row g-2">
        <% Amenity.with_attached_custom_icon.each do |amenity| %>
          <div class="col-6 col-md-4 col-lg-3">
            <div class="form-check p-3 border rounded-3 h-100 d-flex align-items-center"
                 style="cursor: pointer; transition: all 0.2s ease;"
                 onmouseover="this.style.borderColor='var(--brand-green)'; this.style.background='#f0fdf0';"
                 onmouseout="this.style.borderColor=''; this.style.background='';">
              <%= check_box_tag "transport[establishment_attributes][amenity_ids][]", amenity.id,
                  transport.establishment&.amenity_ids&.include?(amenity.id),
                  id: "amenity_#{amenity.id}",
                  class: "form-check-input me-2 flex-shrink-0" %>
              <%= label_tag "amenity_#{amenity.id}", amenity.name,
                  class: "form-check-label w-100",
                  style: "cursor: pointer;" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="d-flex flex-column flex-sm-row gap-3 mb-5">
    <button type="submit" class="gradient-btn btn-lg flex-grow-1 order-1 order-sm-1">
      <i class="fas fa-save me-2"></i> Guardar transporte
    </button>
    <%= link_to transport.persisted? ? transport_path(transport) : transports_path,
        class: "btn btn-outline-secondary btn-lg flex-grow-0 order-2 order-sm-2" do %>
      <i class="fas fa-times me-2"></i> Cancelar
    <% end %>
  </div>
<% end %>

<script>
    // Intentar múltiples eventos para asegurar que el script se ejecute
    function initLocationScript() {
        console.log("Inicializando script de ubicación para transporte");
        
        // ═══════════════ UBICACIÓN DINÁMICA ═══════════════
        const countrySelect = document.getElementById('establishment_country_id');
        const provinceSelect = document.getElementById('establishment_province_id');
        const citySelect = document.getElementById('establishment_city_id');

        console.log('Elementos encontrados:', { countrySelect, provinceSelect, citySelect });

        // Función para cargar provincias
        function loadProvinces(countryId) {
            console.log('Cargando provincias para país:', countryId);
            
            if (!countryId) {
                console.log('No hay país seleccionado');
                provinceSelect.innerHTML = '<option value="">Seleccione provincia</option>';
                citySelect.innerHTML = '<option value="">Seleccione ciudad</option>';
                return;
            }

            fetch(`/locations/provinces/${countryId}`)
                .then(response => {
                    console.log('Response status:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('Provincias recibidas:', data);
                    provinceSelect.innerHTML = '<option value="">Seleccione provincia</option>';
                    data.forEach(province => {
                        provinceSelect.innerHTML += `<option value="${province.id}">${province.name}</option>`;
                    });
                    citySelect.innerHTML = '<option value="">Seleccione ciudad</option>';
                })
                .catch(error => {
                    console.error('Error loading provinces:', error);
                    provinceSelect.innerHTML = '<option value="">Error al cargar provincias</option>';
                });
        }

        // Función para cargar ciudades
        function loadCities(provinceId) {
            console.log('Cargando ciudades para provincia:', provinceId);
            
            if (!provinceId) {
                citySelect.innerHTML = '<option value="">Seleccione ciudad</option>';
                return;
            }

            fetch(`/locations/cities/${provinceId}`)
                .then(response => {
                    console.log('Cities response status:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('Ciudades recibidas:', data);
                    citySelect.innerHTML = '<option value="">Seleccione ciudad</option>';
                    data.forEach(city => {
                        citySelect.innerHTML += `<option value="${city.id}">${city.name}</option>`;
                    });
                })
                .catch(error => {
                    console.error('Error loading cities:', error);
                    citySelect.innerHTML = '<option value="">Error al cargar ciudades</option>';
                });
        }

        // Event listeners
        if (countrySelect) {
            console.log('Country select encontrado:', countrySelect);
            countrySelect.addEventListener('change', function() {
                console.log('Cambio en país seleccionado:', this.value);
                loadProvinces(this.value);
            });

            // Cargar provincias si hay un país preseleccionado
            if (countrySelect.value) {
                console.log('País preseleccionado:', countrySelect.value);
                loadProvinces(countrySelect.value);
            }
        } else {
            console.log('No se encontró el select de país');
        }

        if (provinceSelect) {
            console.log('Province select encontrado:', provinceSelect);
            provinceSelect.addEventListener('change', function() {
                console.log('Cambio en provincia seleccionada:', this.value);
                loadCities(this.value);
            });
        } else {
            console.log('No se encontró el select de provincia');
        }
    }

    // Múltiples intentos para asegurar que el script se ejecute
    
    // Intentar inmediatamente
    initLocationScript();
    
    // Intentar con DOMContentLoaded
    document.addEventListener('DOMContentLoaded', initLocationScript);
    
    // Intentar con turbo:load
    document.addEventListener('turbo:load', initLocationScript);
    
    // Intentar después de un pequeño delay
    setTimeout(initLocationScript, 500);
</script>
