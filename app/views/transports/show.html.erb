<% est = @transport.establishment %>
<%= render "shared/establishment_show_styles" %>

<div class="est-show-page">

  <!-- HERO -->
  <%
    icon = @transport.aquatic? ? "fa-ship" : "fa-bus"
    type_color = @transport.aquatic? ? "#1e88e5" : "var(--brand-green, #3FBD02)"
  %>
  <%= render "shared/establishment_hero",
             establishment: est,
             title: est.name,
             icon: icon,
             badges: [
               { text: @transport.transport_type&.humanize&.capitalize, color: type_color, icon: (@transport.aquatic? ? "fa-water" : "fa-road") },
               { text: @transport.subcategory&.humanize&.titleize, color: "var(--brand-orange, #EB633B)", icon: "fa-layer-group" }
             ] %>

  <!-- QUICK STATS -->
  <div class="row g-3 mb-4">
    <% if @transport.capacity.present? && @transport.capacity > 0 %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
          <div class="mb-1" style="color: var(--brand-orange, #EB633B);"><i class="fas fa-users fa-2x"></i></div>
          <div class="fw-bold fs-4"><%= @transport.capacity %></div>
          <div class="small text-muted">Capacidad</div>
        </div>
      </div>
    <% end %>
    <% if @transport.total_vehicles.present? %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
          <div class="mb-1" style="color: var(--brand-cofee, #88682B);">
            <i class="fas <%= @transport.aquatic? ? 'fa-anchor' : 'fa-car' %> fa-2x"></i>
          </div>
          <div class="fw-bold fs-4"><%= @transport.total_vehicles %></div>
          <div class="small text-muted">Vehículos totales</div>
        </div>
      </div>
    <% end %>
    <% if @transport.available_vehicles.present? %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
          <div class="mb-1" style="color: var(--brand-green, #3FBD02);"><i class="fas fa-check-circle fa-2x"></i></div>
          <div class="fw-bold fs-4"><%= @transport.available_vehicles %></div>
          <div class="small text-muted">Disponibles</div>
        </div>
      </div>
    <% end %>
    <% if @transport.price_range.present? %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
          <div class="text-primary mb-1"><i class="fas fa-dollar-sign fa-2x"></i></div>
          <div class="fw-bold fs-6"><%= @transport.price_range %></div>
          <div class="small text-muted">Rango de precios</div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="row g-4">
    <!-- COLUMNA PRINCIPAL -->
    <div class="col-12 col-lg-8">

      <!-- PERFIL -->
      <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-orange, #EB633B), #c94a28); color: white; border-radius: 0.5rem 0.5rem 0 0;">
          <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2"></i> Perfil del servicio</h5>
        </div>
        <div class="card-body p-4">
          <div class="row g-3 mb-3">
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas fa-tag me-1"></i> Nombre</div>
                <div class="info-value"><%= est.name %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas <%= @transport.aquatic? ? 'fa-water' : 'fa-road' %> me-1"></i> Tipo de transporte</div>
                <div class="info-value"><%= @transport.transport_type&.humanize&.capitalize %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas fa-layer-group me-1"></i> Subcategoría</div>
                <div class="info-value"><%= @transport.subcategory&.humanize&.titleize %></div>
              </div>
            </div>
            <% if @transport.operating_area.present? %>
              <div class="col-sm-6">
                <div class="info-item">
                  <div class="info-label"><i class="fas fa-map me-1"></i> Área de operación</div>
                  <div class="info-value"><%= @transport.operating_area %></div>
                </div>
              </div>
            <% end %>
            <% if @transport.service_frequency.present? %>
              <div class="col-sm-6">
                <div class="info-item">
                  <div class="info-label"><i class="fas fa-sync-alt me-1"></i> Frecuencia del servicio</div>
                  <div class="info-value"><%= @transport.service_frequency %></div>
                </div>
              </div>
            <% end %>
          </div>

          <% if @transport.routes.present? %>
            <div class="mt-3 pt-3 border-top">
              <div class="info-label"><i class="fas fa-route me-1"></i> Rutas</div>
              <div class="long-desc"><%= simple_format(@transport.routes) %></div>
            </div>
          <% end %>

          <% if @transport.service_description.present? %>
            <div class="mt-3 pt-3 border-top">
              <div class="info-label"><i class="fas fa-align-left me-1"></i> Descripción del servicio</div>
              <div class="long-desc"><%= simple_format(@transport.service_description) %></div>
            </div>
          <% end %>

          <% if est.short_description.present? %>
            <div class="mt-3 pt-3 border-top">
              <div class="info-label"><i class="fas fa-align-left me-1"></i> Descripción corta</div>
              <p class="mb-0"><%= est.short_description %></p>
            </div>
          <% end %>

          <% if est.long_description.present? %>
            <div class="mt-3 pt-3 border-top">
              <div class="info-label"><i class="fas fa-file-alt me-1"></i> Descripción detallada</div>
              <div class="long-desc"><%= simple_format(est.long_description) %></div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- VEHÍCULOS (SOLO RENTADORAS) -->
      <% if @transport.rentadora? && @transport.vehicles.any? %>
        <div class="card border-0 shadow-sm rounded-3 mb-4">
          <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-green, #3FBD02), #2d8f01); color: white; border-radius: 0.5rem 0.5rem 0 0;">
            <h5 class="mb-0 fw-bold">
              <i class="fas fa-car me-2"></i> Vehículos disponibles
              <span class="badge bg-light text-dark ms-2"><%= @transport.vehicles.size %></span>
            </h5>
          </div>
          <div class="card-body p-4">
            <div class="row g-3">
              <% @transport.vehicles.each do |vehicle| %>
                <div class="col-12 col-md-6">
                  <div class="card unit-card h-100 rounded-3 border">
                    <% if vehicle.photo.attached? %>
                      <div class="overflow-hidden" style="height: 180px; border-radius: 0.5rem 0.5rem 0 0;">
                        <%= image_tag vehicle.photo.variant(resize_to_limit: [600, 400]),
                            class: "w-100 h-100",
                            style: "object-fit: cover;",
                            loading: "lazy" %>
                      </div>
                    <% else %>
                      <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px; border-radius: 0.5rem 0.5rem 0 0;">
                        <i class="fas fa-car fa-3x text-muted"></i>
                      </div>
                    <% end %>
                    <div class="card-body p-3">
                      <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title fw-bold mb-0"><%= vehicle.name %></h6>
                        <% if vehicle.price_per_day.present? %>
                          <span class="menu-item-price ms-2 text-nowrap">
                            $<%= number_with_precision(vehicle.price_per_day, precision: 2) %><small class="fw-normal">/día</small>
                          </span>
                        <% end %>
                      </div>
                      <% if vehicle.description.present? %>
                        <p class="card-text text-muted small mb-2"><%= vehicle.description %></p>
                      <% end %>
                      <% if vehicle.conditions.present? %>
                        <div class="small border-top pt-2">
                          <strong class="d-block mb-1" style="color: var(--brand-cofee, #88682B);">
                            <i class="fas fa-info-circle me-1"></i> Condiciones
                          </strong>
                          <span class="text-muted"><%= vehicle.conditions %></span>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- GALERÍA -->
      <%= render "shared/establishment_gallery", establishment: est %>

      <!-- COMODIDADES -->
      <% if est.amenities.any? %>
        <div class="card border-0 shadow-sm rounded-3 mb-4">
          <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, #27ae60, #1e8449); color: white; border-radius: 0.5rem 0.5rem 0 0;">
            <h5 class="mb-0 fw-bold"><i class="fas fa-concierge-bell me-2"></i> Comodidades del servicio</h5>
          </div>
          <div class="card-body p-4">
            <div class="row g-2">
              <% est.amenities.each do |amenity| %>
                <div class="col-6 col-md-4">
                  <div class="amenity-pill d-flex align-items-center p-2 rounded-3">
                    <i class="fas fa-check-circle me-2" style="color: var(--brand-green, #3FBD02);"></i>
                    <span class="small"><%= amenity.name %></span>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

    </div>

    <!-- COLUMNA LATERAL -->
    <div class="col-12 col-lg-4">

      <!-- ACCIONES -->
      <div class="card border-0 shadow-sm rounded-3 mb-4 sticky-top-actions">
        <div class="card-body p-3">
          <div class="d-grid gap-2">
            <% if current_user&.administrador? || (current_user&.afiliado? && est.user_id == current_user.id) %>
              <%= link_to edit_transport_path(@transport), class: "btn btn-primary rounded-pill fw-semibold" do %>
                <i class="fas fa-edit me-1"></i> Editar transporte
              <% end %>
            <% end %>

            <% phone = est.whatsapp.presence || est.legal_info&.contact_phone %>
            <% if phone.present? %>
              <a href="https://wa.me/<%= phone.to_s.gsub(/\D/, '') %>?text=<%= CGI.escape("Hola, me interesa el servicio de transporte #{est.name}") %>"
                 target="_blank"
                 class="btn btn-success rounded-pill fw-semibold">
                <i class="fab fa-whatsapp me-1"></i> Contactar por WhatsApp
              </a>
            <% end %>

            <%= link_to transports_path, class: "btn btn-outline-secondary rounded-pill fw-semibold" do %>
              <i class="fas fa-arrow-left me-1"></i> Volver al listado
            <% end %>
          </div>
        </div>
      </div>

      <%= render "shared/establishment_sidebar", establishment: est %>

    </div>
  </div>
</div>
