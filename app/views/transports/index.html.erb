<div class="container py-4">

  <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mb-4 gap-3">
    <div>
      <h2 class="fw-bold mb-1"><i class="fas fa-bus me-2" style="color: var(--brand-green);"></i> Transportes</h2>
      <p class="text-muted mb-0">Listado de servicios de transporte registrados</p>
    </div>
    <%= link_to new_transport_path, class: "gradient-btn text-decoration-none" do %>
      <i class="fas fa-plus me-1"></i> Nuevo transporte
    <% end %>
  </div>

  <% if @transports.any? %>
    <div class="table-responsive">
      <table class="table table-hover align-middle shadow-sm rounded-3 overflow-hidden">
        <thead style="background: var(--brand-green); color: white;">
          <tr>
            <th>Nombre</th>
            <th class="d-none d-md-table-cell">Tipo</th>
            <th class="d-none d-md-table-cell">Subcategoría</th>
            <th class="d-none d-lg-table-cell">Ciudad</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @transports.each do |transport| %>
            <tr>
              <td>
                <div class="d-flex align-items-center">
                  <div class="icon-bg rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 36px; height: 36px; min-width: 36px;">
                    <i class="fas fa-<%= transport.terrestrial? ? 'bus' : 'ship' %> text-white small"></i>
                  </div>
                  <div>
                    <strong><%= transport.establishment.name %></strong>
                    <small class="text-muted d-block d-md-none"><%= transport.subcategory&.humanize&.titleize %></small>
                  </div>
                </div>
              </td>
              <td class="d-none d-md-table-cell">
                <span class="badge rounded-pill" style="background: var(--brand-green);">
                  <%= transport.transport_type&.humanize&.capitalize %>
                </span>
              </td>
              <td class="d-none d-md-table-cell"><%= transport.subcategory&.humanize&.titleize %></td>
              <td class="d-none d-lg-table-cell"><%= transport.establishment.city&.name || "—" %></td>
              <td>
                <% if transport.establishment.active? %>
                  <span class="badge bg-success">Activo</span>
                <% else %>
                  <span class="badge bg-secondary">Inactivo</span>
                <% end %>
              </td>
              <td class="text-end">
                <div class="btn-group btn-group-sm">
                  <%= link_to transport_path(transport), class: "btn btn-outline-primary", title: "Ver" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  <%= link_to edit_transport_path(transport), class: "btn btn-outline-warning", title: "Editar" do %>
                    <i class="fas fa-pen"></i>
                  <% end %>
                  <%= link_to transport_path(transport), method: :delete,
                      data: { confirm: "¿Estás seguro de eliminar este transporte?" },
                      class: "btn btn-outline-danger", title: "Eliminar" do %>
                    <i class="fas fa-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="d-flex justify-content-center mt-3">
      <%== pagy_nav(@pagy) %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <i class="fas fa-bus fs-1 text-muted mb-3 d-block"></i>
      <h5 class="text-muted">No hay transportes registrados</h5>
      <p class="text-muted">Comienza registrando un nuevo servicio de transporte</p>
      <%= link_to new_transport_path, class: "gradient-btn text-decoration-none" do %>
        <i class="fas fa-plus me-1"></i> Crear primer transporte
      <% end %>
    </div>
  <% end %>

</div>
