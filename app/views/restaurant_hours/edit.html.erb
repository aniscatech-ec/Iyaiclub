<h3>Editar horario</h3>

<%= form_with model: [@restaurant, @restaurant_hour], local: true do |f| %>

  <div class="mb-3">
    <%= f.label :day_of_week, 'Día' %>
    <%= f.select :day_of_week,
                 I18n.t('date.day_names').each_with_index.map { |d, i| [d.capitalize, i] },
                 {}, class: 'form-select' %>
  </div>

  <div class="mb-3">
    <%= f.label :open_time, 'Hora de apertura' %>
    <%= f.time_field :open_time, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :close_time, 'Hora de cierre' %>
    <%= f.time_field :close_time, class: 'form-control' %>
  </div>

  <div class="form-check mb-3">
    <%= f.check_box :closed, class: 'form-check-input' %>
    <%= f.label :closed, 'Cerrado este día', class: 'form-check-label' %>
  </div>

  <%= f.submit 'Actualizar horario', class: 'btn btn-primary' %>

  <%= link_to 'Cancelar',
              restaurant_restaurant_hours_path(@restaurant),
              class: 'btn btn-secondary ms-2' %>

<% end %>
