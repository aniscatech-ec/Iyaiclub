<h3>Horarios de <%= @restaurant.establishment.name %></h3>

<table class="table table-striped">
  <thead>
  <tr>
    <th>Día</th>
    <th>Horario</th>
    <th class="text-end">Acciones</th>
  </tr>
  </thead>

  <tbody>
  <% @restaurant_hours.each do |hour| %>
    <tr>
      <td>
        <%= I18n.t('date.day_names')[hour.day_of_week].capitalize %>
      </td>

      <td>
        <% if hour.closed? %>
          <span class="text-danger">Cerrado</span>
        <% else %>
          <%= hour.open_time.strftime('%H:%M') %> –
          <%= hour.close_time.strftime('%H:%M') %>
        <% end %>
      </td>

      <td class="text-end">
        <%= link_to 'Editar',
                    edit_restaurant_restaurant_hour_path(@restaurant, hour),
                    class: 'btn btn-sm btn-outline-primary' %>

        <%= link_to 'Eliminar',
                    restaurant_restaurant_hour_path(@restaurant, hour),
                    method: :delete,
                    data: { confirm: '¿Seguro?' },
                    class: 'btn btn-sm btn-outline-danger' %>
      </td>
    </tr>
  <% end %>
  </tbody>
</table>

<%= link_to 'Agregar horario',
            new_restaurant_restaurant_hour_path(@restaurant),
            class: 'btn btn-primary' %>
