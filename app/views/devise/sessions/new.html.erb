<div class="container mt-5 mb-5">
  <div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
      <div class="card shadow-sm rounded-4 border-0">
        <div class="card-body p-4 p-md-5">

          <div class="text-center mb-4">
            <h3 class="fw-bold mb-1">Iniciar sesión</h3>
            <p class="text-muted small mb-0">Bienvenido de vuelta a IyaiClub</p>
          </div>

          <%# Alerta de error específica %>
          <% if flash[:alert].present? %>
            <div class="alert alert-danger rounded-3 d-flex align-items-start gap-2 mb-4" role="alert">
              <i class="fas fa-exclamation-circle mt-1 flex-shrink-0"></i>
              <div><%= flash[:alert] %></div>
            </div>
          <% end %>

          <%# Alerta de notice (ej: "Cerraste sesión") %>
          <% if flash[:notice].present? %>
            <div class="alert alert-success rounded-3 d-flex align-items-start gap-2 mb-4" role="alert">
              <i class="fas fa-check-circle mt-1 flex-shrink-0"></i>
              <div><%= flash[:notice] %></div>
            </div>
          <% end %>

          <%= form_for(resource, as: resource_name, url: session_path(resource_name),
                html: { class: "needs-validation", novalidate: true, data: { turbo: false } }) do |f| %>

            <div class="mb-3">
              <%= f.label :email, "Correo electrónico", class: "form-label fw-semibold" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                <%= f.email_field :email, autofocus: true, autocomplete: "email",
                      placeholder: "nombre@ejemplo.com", class: "form-control rounded-end-3", required: true %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :password, "Contraseña", class: "form-label fw-semibold" %>
              <div class="input-group" data-controller="password-toggle">
                <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                <%= f.password_field :password, autocomplete: "current-password",
                      placeholder: "••••••••", class: "form-control", required: true,
                      data: { "password-toggle-target": "field" } %>
                <button type="button" class="btn btn-outline-secondary"
                        data-action="click->password-toggle#toggle">
                  <i class="fas fa-eye" data-password-toggle-target="icon"></i>
                </button>
              </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
              <% if devise_mapping.rememberable? %>
                <div class="form-check mb-0">
                  <%= f.check_box :remember_me, class: "form-check-input" %>
                  <%= f.label :remember_me, "Recordarme", class: "form-check-label text-muted small" %>
                </div>
              <% end %>
              <%= link_to new_user_password_path, class: "small text-decoration-none" do %>
                ¿Olvidaste tu contraseña?
              <% end %>
            </div>

            <div class="d-grid mb-3">
              <%= f.submit "Iniciar sesión", class: "btn btn-primary btn-lg rounded-pill fw-bold" %>
            </div>

          <% end %>

          <hr class="my-4">

          <div class="text-center">
            <p class="text-muted small mb-2">¿No tienes cuenta?</p>
            <%= link_to new_user_registration_path, class: "btn btn-outline-success rounded-pill fw-semibold w-100" do %>
              <i class="fas fa-user-plus me-2"></i> Regístrate Gratis
            <% end %>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    'use strict'
    const forms = document.querySelectorAll('.needs-validation')
    Array.from(forms).forEach(form => {
      form.addEventListener('submit', event => {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>
