<div class="container mt-5 mb-5">
  <div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
      <div class="card shadow-sm rounded-4 border-0">
        <div class="card-body p-4 p-md-5">

          <%# Ícono y título %>
          <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                 style="width:60px;height:60px;background:linear-gradient(135deg,#e8f5e9,#c8e6c9);">
              <i class="fas fa-lock-open" style="font-size:1.5rem;color:#2e7d32;"></i>
            </div>
            <h4 class="fw-bold mb-1">Crea tu nueva contraseña</h4>
            <p class="text-muted small mb-0">
              Elige una contraseña segura de al menos <%= @minimum_password_length %> caracteres.
            </p>
          </div>

          <%# Errores %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <%= form_for(resource, as: resource_name,
                url: password_path(resource_name),
                html: { method: :put, class: "needs-validation", novalidate: true,
                        data: { turbo: false } }) do |f| %>

            <%= f.hidden_field :reset_password_token %>

            <div class="mb-3">
              <%= f.label :password, "Nueva contraseña", class: "form-label fw-semibold" %>
              <div class="input-group" data-controller="password-toggle">
                <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
                      placeholder: "••••••••", class: "form-control", required: true,
                      minlength: @minimum_password_length,
                      data: { "password-toggle-target": "field" } %>
                <button type="button" class="btn btn-outline-secondary"
                        data-action="click->password-toggle#toggle">
                  <i class="fas fa-eye" data-password-toggle-target="icon"></i>
                </button>
                <div class="invalid-feedback">Mínimo <%= @minimum_password_length %> caracteres.</div>
              </div>
            </div>

            <div class="mb-4">
              <%= f.label :password_confirmation, "Confirmar contraseña", class: "form-label fw-semibold" %>
              <div class="input-group" data-controller="password-toggle">
                <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                <%= f.password_field :password_confirmation, autocomplete: "new-password",
                      placeholder: "••••••••", class: "form-control", required: true,
                      data: { "password-toggle-target": "field" } %>
                <button type="button" class="btn btn-outline-secondary"
                        data-action="click->password-toggle#toggle">
                  <i class="fas fa-eye" data-password-toggle-target="icon"></i>
                </button>
                <div class="invalid-feedback">Las contraseñas deben coincidir.</div>
              </div>
            </div>

            <div class="d-grid">
              <%= f.submit "Guardar nueva contraseña",
                    class: "btn btn-lg rounded-pill fw-bold",
                    style: "background:#2e7d32;color:white;border:none;" %>
            </div>

          <% end %>

          <hr class="my-3">

          <div class="text-center">
            <%= link_to new_user_session_path,
                  class: "btn btn-outline-secondary rounded-pill btn-sm w-100 fw-semibold" do %>
              <i class="fas fa-arrow-left me-1"></i> Volver a iniciar sesión
            <% end %>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    'use strict'
    document.querySelectorAll('.needs-validation').forEach(form => {
      form.addEventListener('submit', event => {
        if (!form.checkValidity()) { event.preventDefault(); event.stopPropagation() }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>
