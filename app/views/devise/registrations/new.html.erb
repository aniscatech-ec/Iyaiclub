<div class="container mt-5 mb-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow rounded-4">
        <div class="card-body p-4">
          <h3 class="text-center mb-4">Crear cuenta</h3>

          <%= form_for(resource, as: resource_name,
                       url: registration_path(resource_name),
                       html: { class: "needs-validation", novalidate: true,
                               data: { turbo: false, controller: "registration-role" },
                               multipart: true }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <!-- Nombre -->
            <div class="mb-3">
              <%= f.label :name, "Nombre", class: "form-label" %>
              <%= f.text_field :name, autofocus: true, autocomplete: "name",
                    placeholder: "Nombre completo", class: "form-control", required: true %>
              <div class="invalid-feedback">Por favor ingresa tu nombre.</div>
            </div>

            <!-- Teléfono -->
            <div class="mb-3">
              <%= f.label :phone, "Teléfono", class: "form-label" %>
              <%= f.telephone_field :phone, placeholder: "0983799999", class: "form-control" %>
            </div>

            <!-- Rol -->
            <div class="mb-3">
              <%= f.label :role, "Rol", class: "form-label" %>
              <%= f.select :role,
                           User.roles.except(:administrador, :vendedor).keys.map { |r|
                             [r == "afiliado" ? "Afiliado (Socio)" : r.titleize, r]
                           },
                           { prompt: "Seleccionar rol", required: true },
                           class: "form-select",
                           data: { action: "change->registration-role#toggleDocs",
                                   registration_role_target: "roleSelect" } %>
              <div class="invalid-feedback">Por favor selecciona un rol.</div>
            </div>

            <!-- Correo -->
            <div class="mb-3">
              <%= f.label :email, "Correo electrónico", class: "form-label" %>
              <%= f.email_field :email, autocomplete: "email",
                    placeholder: "nombre@ejemplo.com", class: "form-control", required: true %>
              <div class="invalid-feedback">Por favor ingresa un correo válido.</div>
            </div>

            <div data-controller="location-user">
              <div class="mb-3">
                <%= f.label :country_id, "País" %>
                <%= f.collection_select :country_id, Country.all, :id, :name,
                      { prompt: "Seleccionar país" },
                      { class: "form-select",
                        data: { action: "change->location-user#updateCities",
                                location_user_target: "country" } } %>
              </div>
              <div class="mb-3">
                <%= f.label :city_id, "Ciudad" %>
                <%= f.collection_select :city_id, [], :id, :name,
                      { prompt: "Seleccionar ciudad" },
                      class: "form-select",
                      data: { location_user_target: "city" } %>
              </div>
            </div>

            <!-- Fecha de nacimiento -->
            <div class="mb-3">
              <%= f.label :birth_date, "Fecha de nacimiento", class: "form-label" %>
              <%= f.date_field :birth_date, class: "form-control", required: true %>
            </div>

            <!-- ── Documentos de identidad (solo afiliados) ── -->
            <div id="afiliado-docs" data-registration-role-target="docsSection" style="display:none;">
              <div class="alert alert-info rounded-3 py-2 small mb-3">
                <i class="fas fa-info-circle me-1"></i>
                Como socio afiliado, debes subir los siguientes documentos para poder ser aprobado por un administrador.
              </div>

              <div class="mb-3">
                <%= f.label :cedula_front, class: "form-label fw-semibold" do %>
                  <i class="fas fa-id-card me-1 text-primary"></i> Cédula — Anverso (frente)
                  <span class="text-danger">*</span>
                <% end %>
                <%= f.file_field :cedula_front, class: "form-control",
                      accept: "image/jpeg,image/png,image/webp,application/pdf",
                      data: { registration_role_target: "docInput" } %>
                <small class="text-muted">JPG, PNG, WEBP o PDF</small>
              </div>

              <div class="mb-3">
                <%= f.label :cedula_back, class: "form-label fw-semibold" do %>
                  <i class="fas fa-id-card me-1 text-primary"></i> Cédula — Reverso
                  <span class="text-danger">*</span>
                <% end %>
                <%= f.file_field :cedula_back, class: "form-control",
                      accept: "image/jpeg,image/png,image/webp,application/pdf",
                      data: { registration_role_target: "docInput" } %>
                <small class="text-muted">JPG, PNG, WEBP o PDF</small>
              </div>

              <div class="mb-3">
                <%= f.label :ruc_document, class: "form-label fw-semibold" do %>
                  <i class="fas fa-file-invoice me-1 text-warning"></i> Documento RUC
                  <span class="text-danger">*</span>
                <% end %>
                <%= f.file_field :ruc_document, class: "form-control",
                      accept: "image/jpeg,image/png,image/webp,application/pdf",
                      data: { registration_role_target: "docInput" } %>
                <small class="text-muted">JPG, PNG, WEBP o PDF</small>
              </div>
            </div>

            <!-- Contraseña -->
            <div class="mb-3">
              <%= f.label :password, "Contraseña", class: "form-label" %>
              <% if @minimum_password_length %>
                <small class="text-muted">(<%= @minimum_password_length %> caracteres mínimo)</small>
              <% end %>
              <%= f.password_field :password, autocomplete: "new-password",
                    class: "form-control", required: true,
                    minlength: @minimum_password_length %>
              <div class="invalid-feedback">
                La contraseña es obligatoria y debe tener al menos <%= @minimum_password_length %> caracteres.
              </div>
            </div>

            <!-- Confirmar contraseña -->
            <div class="mb-3">
              <%= f.label :password_confirmation, "Confirmar contraseña", class: "form-label" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password",
                    class: "form-control", required: true %>
              <div class="invalid-feedback">Por favor confirma tu contraseña.</div>
            </div>

            <!-- Aceptar Términos -->
            <div class="form-check mb-3">
              <%= f.check_box :terms_accepted, class: "form-check-input", required: true %>
              <%= f.label :terms_accepted,
                    "Acepto los Términos y Condiciones y la Política de Privacidad",
                    class: "form-check-label" %>
            </div>

            <!-- Consentimiento Marketing -->
            <div class="form-check mb-3">
              <%= f.check_box :marketing_consent, class: "form-check-input" %>
              <%= f.label :marketing_consent,
                    "Deseo recibir novedades y promociones", class: "form-check-label" %>
            </div>

            <!-- Botón -->
            <div class="d-grid">
              <%= f.submit "Registrarme", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    'use strict'
    const forms = document.querySelectorAll('.needs-validation')
    Array.from(forms).forEach(form => {
      form.addEventListener('submit', event => {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>
