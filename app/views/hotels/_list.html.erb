<% if hotels.any? %>
  <% hotels.each do |hotel| %>
    <div class="col-12 col-md-6 col-lg-4 mb-4">
      <%= render "hotels/show/hotel_card", hotel: hotel %>

    </div>
  <% end %>

  <!-- Paginación -->
  <div class="col-12 mt-4">
    <%= paginate hotels %>
  </div>
<% else %>
  <div class="col-12 text-center my-5 py-5">
    <div class="text-muted">
      <i class="bi bi-building display-4 opacity-50"></i>
      <h5 class="mt-3 fw-semibold">No se encontraron hoteles</h5>
      <p class="mb-0 text-muted">Intenta ajustar los filtros de búsqueda</p>
    </div>
  </div>
<% end %>

<style>
    .hotel-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .hotel-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15) !important;
    }

    .hotel-image {
        /*object-fit: cover;*/
        transition: transform 0.3s ease;
    }

    .hotel-card:hover .hotel-image {
        transform: scale(1.03);
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .fs-7 {
        font-size: 0.8rem;
    }

    /* Efecto sutil al hover para hoteles */
    .hotel-card:hover {
        border-color: var(--bs-primary);
    }

    /* Estrellas de rating */
    .bi-star-fill.text-warning {
        color: #ffc107 !important;
    }

    .bi-star-fill.text-light {
        color: #e4e5e9 !important;
    }
</style>