<% if hotels.any? %>
  <% hotels.each do |hotel| %>
    <div class="col-12 col-md-6 col-lg-4">
      <%= link_to hotel, class: "text-decoration-none text-dark" do %>
        <div class="card establishment-card shadow-sm h-100">
          <% est = hotel.establishment %>
          <% if est.galleries.any? && est.galleries.first.gallery_images.any? %>
            <% first_image = est.galleries.first.gallery_images.first.file %>
            <%= image_tag first_image, class: "card-img-top", height: 250 if first_image.attached? %>
          <% else %>
            <%= image_tag "logo-ant.jpg", class: "card-img-top", height: 250 %>
          <% end %>
          <div class="card-body">
            <h6 class="fw-semibold mb-1"><%= est.name %></h6>
            <p class="small text-muted mb-1">
              <i class="bi bi-geo-alt"></i> <%= est.city&.name %>, <i><%= est.city.province&.name %></i>
            </p>
            <div class="text-warning fs-4">
              <%= "⭐" * (hotel.stars || 0) %>
            </div>
            <p class="text-muted mb-2">
              <%= hotel.hotel_type.present? ? hotel.hotel_type.humanize : "Tipo no especificado" %>
            </p>
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="fw-bold text-primary">$<%= est.price_per_night %>/noche</span>
              <span class="badge bg-success-subtle">Hotel</span>
            </div>
            <p class="mb-0">
              <% est.amenities.limit(3).each do |amenity| %>
                <span class="badge bg-secondary"><%= amenity.name %></span>
              <% end %>
              <% if est.amenities.size > 3 %>
                <span class="badge bg-secondary">+<%= est.amenities.size - 3 %> más</span>
              <% end %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="col-12 mt-3">
    <%= paginate hotels %>
  </div>
<% else %>
  <div class="col-12 text-center my-5">
    <h6 class="text-muted">
      <i class="bi bi-info-circle me-2"></i>No se encontraron hoteles que coincidan con los filtros.
    </h6>
  </div>
<% end %>
