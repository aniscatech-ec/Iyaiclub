            </div>
            <div class="hotel-card-body">
              <h3 class="hotel-card-title"><%= hotel.establishment.name %></h3>
              <div class="hotel-card-type"><%= hotel.establishment.category&.humanize || "Hotel" %></div>
              <div class="hotel-card-location">
                <i class="bi bi-geo-alt"></i>
                <%= hotel.establishment.city&.name || "Ubicación no especificada" %>
              </div>
              <div class="hotel-rating">
                <div class="text-warning mb-1">
                  <% stars = hotel.stars || 0 %>
                  <% 5.times do |i| %>
                    <i class="bi bi-star-fill <%= i < stars ? 'text-warning' : 'text-light' %>"></i>
                  <% end %>
                  <small class="text-muted ms-1">(<%= stars %> estrellas)</small>
                </div>
              </div>
              <div class="hotel-price">$<%= hotel.establishment.price_per_night %></div>
              <div class="hotel-price-note">por noche • impuestos incluidos</div>
              <div class="hotel-features">
                <% hotel.establishment.amenities.limit(3).each do |amenity| %>
                  <span class="badge bg-light text-dark border small">
                    <i class="bi bi-check-circle text-success me-1"></i><%= amenity.name %>
                  </span>
                <% end %>
              </div>
              <%= link_to "Ver Detalles", hotel_path(hotel), class: "hotel-btn" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

