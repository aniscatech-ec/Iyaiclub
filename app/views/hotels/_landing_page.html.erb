                <%= image_tag first_image, class: "card-img-top hotel-image", alt: hotel.establishment.name, loading: "lazy", height: 200 if first_image.attached? %>
              <% else %>
                <%= image_tag "hotel-placeholder.jpg", class: "card-img-top hotel-image", height: 200 %>

              <% end %>

              <%# if hotel.images.attached? %>
              <%#= image_tag hotel.images.first, class: "hotel-card-img", alt: hotel.establishment.name, loading: "lazy" %>
              <%# else %>
              <!--                <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=600&q=80" class="hotel-card-img" alt="<%#= hotel.establishment.name %>" loading="lazy">-->
              <%# end %>
