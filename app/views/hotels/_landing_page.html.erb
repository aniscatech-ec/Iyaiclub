<style>
    /* Variables CSS para hoteles */
    :root {
        --primary-color: #2d5016;
        --secondary-color: #4a7c3a;
        --accent-color: #8db596;
        --light-bg: #f8f9fa;
        --dark-text: #2c3e50;
        --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
        --shadow-hover: 0 8px 25px rgba(0, 0, 0, 0.15);
        --gradient-primary: linear-gradient(135deg, #2d5016 0%, #4a7c3a 100%);
        --gradient-hero: linear-gradient(135deg, rgba(45, 80, 22, 0.85) 0%, rgba(0, 0, 0, 0.7) 100%);
        --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --font-heading: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    /* Estilos base */
    * {
        transition: all 0.3s ease;
    }

    body {
        font-family: var(--font-primary);
        line-height: 1.6;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
    }

    /* ==================== Hero Section Hoteles ==================== */
    .hero-section {
        position: relative;
        overflow: hidden;
        background: var(--gradient-hero), url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1800&q=80') center/cover no-repeat;
        min-height: 500px;
        display: flex;
        align-items: center;
        color: #fff;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        text-shadow: 0 4px 12px rgba(0, 0, 0, 0.6);
        line-height: 1.1;
    }

    .hero-subtitle {
        font-size: 1.3rem;
        margin-bottom: 2.5rem;
        opacity: 0.95;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
        font-weight: 400;
    }

    /* ==================== Search Card Hoteles ==================== */
    .search-section {
        margin-top: -80px;
        position: relative;
        z-index: 10;
    }

    .search-card {
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(20px);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .search-form .form-label {
        font-weight: 600;
        color: var(--dark-text);
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .search-form .form-control {
        border-radius: 12px;
        border: 2px solid #e9ecef;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }

    .search-form .form-control:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 0.2rem rgba(45, 80, 22, 0.15);
    }

    /* Input con ícono */
    .input-icon {
        position: relative;
    }

    .input-icon i {
        position: absolute;
        top: 50%;
        left: 15px;
        transform: translateY(-50%);
        color: var(--primary-color);
        font-size: 1.1rem;
        z-index: 2;
    }

    .input-icon .form-control {
        padding-left: 45px;
    }

    /* Selectores de filtro */
    .filter-select {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        background: white;
        transition: all 0.3s ease;
        width: 100%;
        cursor: pointer;
    }

    .filter-select:focus {
        border-color: var(--primary-color);
        outline: none;
    }

    /* Botón de huéspedes */
    .guests-btn {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        background: white;
        transition: all 0.3s ease;
        text-align: left;
        width: 100%;
    }

    .guests-btn:hover {
        border-color: var(--primary-color);
        background: #f8f9fa;
    }

    /* Botón buscar */
    .search-btn {
        background: var(--gradient-primary);
        border: none;
        border-radius: 12px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        height: 100%;
        color: white;
    }

    .search-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(45, 80, 22, 0.3);
    }

    /* ==================== Sección Hoteles Destacados ==================== */
    .featured-section {
        padding: 4rem 0;
        background: var(--light-bg);
    }

    .section-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .section-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .section-subtitle {
        color: #6c757d;
        font-size: 1.1rem;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Tarjetas de hoteles */
    .hotel-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: all 0.4s ease;
        height: 100%;
        border: none;
        position: relative;
        transform: translateZ(0);
        backface-visibility: hidden;
        perspective: 1000px;
    }

    .hotel-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-hover);
    }

    .hotel-card-img {
        height: 200px;
        object-fit: cover;
        width: 100%;
        transition: transform 0.4s ease;
    }

    .hotel-card:hover .hotel-card-img {
        transform: scale(1.05);
    }

    .hotel-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: var(--primary-color);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .hotel-card-body {
        padding: 1.5rem;
    }

    .hotel-card-title {
        font-weight: 700;
        margin-bottom: 0.5rem;
        font-size: 1.1rem;
        color: var(--dark-text);
    }

    .hotel-card-type {
        color: var(--primary-color);
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .hotel-card-location {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .hotel-rating {
        color: #ffc107;
        font-size: 0.9rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .hotel-price {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary-color);
        margin-bottom: 0.25rem;
    }

    .hotel-price-note {
        font-size: 0.8rem;
        color: #6c757d;
        margin-bottom: 1rem;
    }

    .hotel-features {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .feature-tag {
        background: #f8f9fa;
        color: #6c757d;
        padding: 0.25rem 0.75rem;
        border-radius: 15px;
        font-size: 0.8rem;
        border: 1px solid #e9ecef;
    }

    .hotel-btn {
        background: var(--gradient-primary);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
        width: 100%;
    }

    .hotel-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(45, 80, 22, 0.3);
    }

    /* ==================== Categorías de Hoteles ==================== */
    .categories-section {
        padding: 4rem 0;
        background: white;
    }

    .category-card {
        background: white;
        border-radius: 16px;
        padding: 2rem 1rem;
        text-align: center;
        transition: all 0.4s ease;
        border: 2px solid transparent;
        box-shadow: var(--shadow);
        height: 100%;
        position: relative;
        overflow: hidden;
        transform: translateZ(0);
        backface-visibility: hidden;
        perspective: 1000px;
    }

    .category-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-hover);
        border-color: var(--accent-color);
    }

    .category-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1rem;
        background: var(--gradient-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2rem;
        transition: all 0.3s ease;
    }

    .category-card:hover .category-icon {
        transform: scale(1.1) rotate(5deg);
    }

    .category-title {
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--dark-text);
    }

    .category-count {
        color: #6c757d;
        font-size: 0.9rem;
    }

    /* ==================== Beneficios ==================== */
    .benefits-section {
        padding: 4rem 0;
        background: var(--gradient-primary);
        color: white;
        position: relative;
        overflow: hidden;
    }

    .benefits-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: url('https://images.unsplash.com/photo-1557804506-669a67965ba0?auto=format&fit=crop&w=2000&q=80') center/cover;
        opacity: 0.1;
    }

    .benefit-item {
        text-align: center;
        padding: 2rem;
        transition: all 0.3s ease;
        border-radius: 15px;
        position: relative;
        z-index: 1;
        transform: translateZ(0);
        backface-visibility: hidden;
        perspective: 1000px;
    }

    .benefit-item:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-5px);
    }

    .benefit-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: var(--accent-color);
        transition: all 0.3s ease;
    }

    .benefit-item:hover .benefit-icon {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.1);
    }

    .benefit-title {
        font-weight: 600;
        margin-bottom: 1rem;
        font-size: 1.1rem;
    }

    .benefit-text {
        opacity: 0.9;
        font-size: 0.9rem;
        line-height: 1.5;
    }

    /* ==================== Destinos Populares ==================== */
    .destinations-section {
        padding: 4rem 0;
        background: var(--light-bg);
    }

    .destination-card {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: all 0.4s ease;
        position: relative;
        height: 200px;
        transform: translateZ(0);
        backface-visibility: hidden;
        perspective: 1000px;
    }

    .destination-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-hover);
    }

    .destination-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .destination-card:hover .destination-img {
        transform: scale(1.1);
    }

    .destination-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 1.5rem;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
        color: white;
    }

    .destination-name {
        font-weight: 600;
        margin-bottom: 0.25rem;
        font-size: 1.1rem;
    }

    .destination-count {
        font-size: 0.9rem;
        opacity: 0.9;
    }

    /* ==================== Testimonios ==================== */
    .testimonials-section {
        padding: 4rem 0;
        background: white;
    }

    .testimonial-card {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        box-shadow: var(--shadow);
        transition: all 0.3s ease;
        position: relative;
        border: 1px solid #f1f3f4;
        transform: translateZ(0);
        backface-visibility: hidden;
        perspective: 1000px;
    }

    .testimonial-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-hover);
    }

    .testimonial-card::before {
        content: '"';
        font-size: 4rem;
        color: var(--accent-color);
        position: absolute;
        top: -0.5rem;
        left: 1rem;
        opacity: 0.3;
        font-family: Georgia, serif;
        line-height: 1;
    }

    .testimonial-text {
        font-style: italic;
        margin-bottom: 1.5rem;
        position: relative;
        z-index: 1;
        line-height: 1.6;
    }

    .testimonial-author {
        font-weight: 600;
        color: var(--primary-color);
        margin-bottom: 0.25rem;
    }

    .testimonial-hotel {
        font-size: 0.85rem;
        color: #6c757d;
    }

    /* ==================== CTA Final ==================== */
    .cta-section {
        padding: 4rem 0;
        background: var(--gradient-primary);
        color: white;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .cta-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: url('https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?auto=format&fit=crop&w=2000&q=80') center/cover;
        opacity: 0.1;
    }

    .cta-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .cta-subtitle {
        font-size: 1.2rem;
        margin-bottom: 2rem;
        opacity: 0.9;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .cta-btn {
        background: white;
        color: var(--primary-color);
        border: none;
        border-radius: 12px;
        padding: 1rem 2.5rem;
        font-weight: 600;
        font-size: 1.1rem;
        transition: all 0.3s ease;
    }

    .cta-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    }

    /* ==================== Modal Huéspedes ==================== */
    .modal-content {
        border-radius: 20px;
        border: none;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
    }

    .modal-header {
        border-bottom: 1px solid #e9ecef;
        padding: 1.5rem;
    }

    .modal-title {
        font-weight: 700;
        color: var(--dark-text);
    }

    .modal-body {
        padding: 1.5rem;
    }

    .guest-control {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .guest-label {
        font-weight: 600;
        color: var(--dark-text);
    }

    .guest-counter {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .counter-btn {
        width: 40px;
        height: 40px;
        border: 2px solid var(--primary-color);
        background: white;
        color: var(--primary-color);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    .counter-btn:hover {
        background: var(--primary-color);
        color: white;
    }

    .counter-value {
        font-size: 1.2rem;
        font-weight: 600;
        min-width: 30px;
        text-align: center;
    }

    .modal-footer {
        border-top: 1px solid #e9ecef;
        padding: 1.5rem;
    }

    /* ==================== Modal Comodidades ==================== */
    .amenity-checkbox {
        display: flex;
        align-items: center;
        padding: 0.75rem;
        border: 2px solid #e9ecef;
        border-radius: 10px;
        margin-bottom: 0.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .amenity-checkbox:hover {
        border-color: var(--primary-color);
        background: #f8f9fa;
    }

    .amenity-checkbox input[type="checkbox"] {
        margin-right: 0.75rem;
    }

    /* ==================== Responsive ==================== */
    @media (max-width: 992px) {
        .search-form .col-md-2,
        .search-form .col-md-3,
        .search-form .col-md-6 {
            margin-bottom: 1rem;
        }

        .search-btn {
            height: auto;
            margin-top: 0.5rem;
        }
    }

    @media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem;
        }

        .hero-subtitle {
            font-size: 1.1rem;
        }

        .search-card {
            margin: 0 15px;
            padding: 1.5rem;
        }

        .section-title {
            font-size: 2rem;
        }

        .cta-title {
            font-size: 2rem;
        }

        .cta-subtitle {
            font-size: 1rem;
        }
    }

    @media (max-width: 576px) {
        .hero-section {
            min-height: 400px;
        }

        .hero-title {
            font-size: 2rem;
        }

        .search-section {
            margin-top: -60px;
        }
    }

    /* Estilos adicionales para la barra de búsqueda mejorada */
    .amenities-btn {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        background: white;
        transition: all 0.3s ease;
        text-align: left;
        width: 100%;
        color: #495057;
        font-size: 0.95rem;
    }

    .amenities-btn:hover {
        border-color: var(--primary-color);
        background: #f8f9fa;
    }

    /* Mejoras de accesibilidad */
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .focus-visible:focus {
        outline: 2px solid var(--primary-color);
        outline-offset: 2px;
    }
</style>

<!-- ==================== Hero Section ==================== -->
<section class="hero-section">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">Encuentra tu hospedaje ideal</h1>
      <p class="hero-subtitle">Descubre hoteles, resorts y alojamientos únicos — compara precios y encuentra las mejores
        ofertas</p>
    </div>
  </div>
</section>

<!-- ==================== Search Section ==================== -->
<section class="search-section">
  <div class="container-fluid px-4">
    <div class="search-card">
      <form action="/hotels/search_results" method="get" class="search-form row g-4 align-items-end">
        <!-- Destino -->
        <div class="col-xl-2 col-lg-3 col-md-4">
          <label for="destination" class="form-label">Destino</label>
          <div class="input-icon">
            <i class="bi bi-geo-alt"></i>
            <input type="text" id="destination" name="city" class="form-control" placeholder="Ej: Quito, Cuenca..." aria-label="Ingresa el destino">
          </div>
        </div>

        <!-- Fechas -->
        <div class="col-xl-2 col-lg-3 col-md-4">
          <label for="dateRange" class="form-label">Fechas de estadía</label>
          <div class="input-icon">
            <i class="bi bi-calendar-range"></i>
            <input type="text" id="dateRange" name="date_range" class="form-control" placeholder="Seleccionar fechas" aria-label="Seleccionar fechas de estadía">
          </div>
        </div>

        <!-- Huéspedes -->
        <div class="col-xl-3 col-lg-3 col-md-4">
          <label for="guestsSummaryBtn" class="form-label">Huéspedes y habitaciones</label>
          <button id="guestsSummaryBtn" type="button" class="guests-btn focus-visible" data-bs-toggle="modal" data-bs-target="#guestsModal" aria-haspopup="dialog" aria-expanded="false">
            <i class="bi bi-people me-2"></i> <span id="guestsText">2 adultos · 0 niños · 1 habitación</span>
          </button>
        </div>

        <!-- Comodidades -->
        <div class="col-xl-3 col-lg-3 col-md-6">
          <label for="amenitiesSummaryBtn" class="form-label">Comodidades</label>
          <button id="amenitiesSummaryBtn" type="button" class="amenities-btn focus-visible" data-bs-toggle="modal" data-bs-target="#amenitiesModal" aria-haspopup="dialog" aria-expanded="false">
            <i class="bi bi-star me-2"></i> <span id="amenitiesText">Seleccionar comodidades</span>
          </button>
        </div>
        <div id="selectedAmenities" hidden></div>

        <!-- Botón Buscar -->
        <div class="col-xl-2 col-lg-3 col-md-6">
          <button type="submit" class="search-btn w-100 focus-visible">
            <i class="bi bi-search me-2"></i> Buscar Hoteles
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- Modal Comodidades -->
<%= render "shared/amenities_modal" %>

<!-- ==================== Modal Huéspedes ==================== -->
<div class="modal fade" id="guestsModal" tabindex="-1" aria-labelledby="guestsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="guestsModalLabel" class="modal-title">Selecciona los huéspedes</h3>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <div class="guest-control">
          <div class="guest-label">Adultos</div>
          <div class="guest-counter">
            <button type="button" class="counter-btn focus-visible" onclick="updateGuests('adults', -1)" aria-label="Reducir número de adultos">-</button>
            <span id="adults" class="counter-value" aria-live="polite">2</span>
            <button type="button" class="counter-btn focus-visible" onclick="updateGuests('adults', 1)" aria-label="Aumentar número de adultos">+</button>
          </div>
        </div>

        <div class="guest-control">
          <div class="guest-label">Niños</div>
          <div class="guest-counter">
            <button type="button" class="counter-btn focus-visible" onclick="updateGuests('children', -1)" aria-label="Reducir número de niños">-</button>
            <span id="children" class="counter-value" aria-live="polite">0</span>
            <button type="button" class="counter-btn focus-visible" onclick="updateGuests('children', 1)" aria-label="Aumentar número de niños">+</button>
          </div>
        </div>

        <div class="guest-control">
          <div class="guest-label">Habitaciones</div>
          <div class="guest-counter">
            <button type="button" class="counter-btn focus-visible" onclick="updateGuests('rooms', -1)" aria-label="Reducir número de habitaciones">-</button>
            <span id="rooms" class="counter-value" aria-live="polite">1</span>
            <button type="button" class="counter-btn focus-visible" onclick="updateGuests('rooms', 1)" aria-label="Aumentar número de habitaciones">+</button>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal" onclick="applyGuests()">Aplicar</button>
      </div>
    </div>
  </div>
</div>

