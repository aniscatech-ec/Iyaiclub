<!-- ==================== Hero Section ==================== -->
<section class="hero-section">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">Encuentra tu hospedaje ideal</h1>
      <p class="hero-subtitle">Descubre hoteles, resorts y alojamientos únicos — compara precios y encuentra las mejores ofertas</p>
    </div>
  </div>
</section>

<!-- ==================== Search Section ==================== -->
<section class="search-section">
  <div class="container">
    <div class="search-card">
      <form action="/hotels/search_results" method="get" class="search-form row g-3 align-items-end">
        <!-- Destino -->
        <div class="col-md-3">
          <label class="form-label">Destino</label>
          <div class="input-icon">
            <i class="bi bi-geo-alt"></i>
            <input type="text" name="city" class="form-control" placeholder="Ej: Quito, Cuenca...">
          </div>
        </div>

        <!-- Fechas -->
        <div class="col-md-3">
          <label class="form-label">Fechas de estadía</label>
          <div class="input-icon">
            <i class="bi bi-calendar-range"></i>
            <input type="text" id="dateRange" name="date_range" class="form-control" placeholder="Seleccionar fechas">
          </div>
        </div>

        <!-- Huéspedes -->
        <div class="col-md-3">
          <label class="form-label">Huéspedes y habitaciones</label>
          <button id="guestsSummaryBtn" type="button" class="guests-btn" data-bs-toggle="modal" data-bs-target="#guestsModal">
            <i class="bi bi-people me-2"></i> <span id="guestsText">2 adultos · 0 niños · 1 habitación</span>
          </button>
        </div>

        <!-- Botón Buscar -->
        <div class="col-md-3 d-grid">
          <button type="submit" class="search-btn">
            <i class="bi bi-search me-2"></i> Buscar
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- ==================== Modal Huéspedes ==================== -->
<div class="modal fade" id="guestsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Selecciona los huéspedes</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="guest-control">
          <div class="guest-label">Adultos</div>
          <div class="guest-counter">
            <button type="button" class="counter-btn" onclick="updateGuests('adults', -1)">-</button>
            <span id="adults" class="counter-value">2</span>
            <button type="button" class="counter-btn" onclick="updateGuests('adults', 1)">+</button>
          </div>
        </div>

        <div class="guest-control">
          <div class="guest-label">Niños</div>
          <div class="guest-counter">
            <button type="button" class="counter-btn" onclick="updateGuests('children', -1)">-</button>
            <span id="children" class="counter-value">0</span>
            <button type="button" class="counter-btn" onclick="updateGuests('children', 1)">+</button>
          </div>
        </div>

        <div class="guest-control">
          <div class="guest-label">Habitaciones</div>
          <div class="guest-counter">
            <button type="button" class="counter-btn" onclick="updateGuests('rooms', -1)">-</button>
            <span id="rooms" class="counter-value">1</span>
            <button type="button" class="counter-btn" onclick="updateGuests('rooms', 1)">+</button>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal" onclick="applyGuests()">Aplicar</button>
      </div>
    </div>
  </div>
</div>

