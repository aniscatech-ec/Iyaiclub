<!-- ==================== Scripts ==================== -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Flatpickr para selección de fechas
        try {
            flatpickr("#dateRange", {
                mode: "range",
                dateFormat: "d-m-Y",
                minDate: "today",
                locale: "es",
                rangeSeparator: " a ",
                onClose: function (selectedDates) {
                    if (selectedDates.length === 2 && selectedDates[1] < selectedDates[0]) {
                        alert("La fecha de salida no puede ser menor que la de entrada.");
                        this.clear();
                    }
                }
            });
        } catch (error) {
            console.error('Error inicializando datepicker:', error);
        }

        // Inicializar texto de huéspedes
        updateGuestsText();
    });

    // Funciones para manejo de huéspedes
    window.updateGuests = function (type, change) {
        const element = document.getElementById(type);
        let value = parseInt(element.textContent) + change;

        // Validar límites
        const maxValues = {
            'adults': 10,
            'children': 6,
            'rooms': 5
        };

        if (value < 0) value = 0;
        if (value > maxValues[type]) value = maxValues[type];

        // Validar que habitaciones no sean menos que adultos/4
        if (type === 'rooms') {
            const adults = parseInt(document.getElementById('adults').textContent);
            const minRooms = Math.ceil(adults / 4);
            if (value < minRooms) value = minRooms;
        }

        element.textContent = value;
    }

    window.applyGuests = function () {
        updateGuestsText();
    }

    function updateGuestsText() {
        const adults = document.getElementById("adults").textContent;
        const children = document.getElementById("children").textContent;
        const rooms = document.getElementById("rooms").textContent;

        let text = `${adults} adulto${adults != 1 ? "s" : ""}`;
        if (children > 0) text += ` · ${children} niño${children != 1 ? "s" : ""}`;
        text += ` · ${rooms} habitación${rooms != 1 ? "es" : ""}`;

        document.getElementById("guestsText").textContent = text;
    }

    function applyAmenities() {
        const checkboxes = document.querySelectorAll('.amenity:checked');
        const selected = Array.from(checkboxes).map(cb => ({
            id: cb.value,
            name: cb.nextElementSibling.textContent.trim()
        }));

        // Limpiar los hidden inputs anteriores
        const container = document.getElementById("selectedAmenities");
        container.innerHTML = "";

        // Crear un hidden input por cada amenity seleccionado
        selected.forEach(item => {
            const hidden = document.createElement("input");
            hidden.type = "hidden";
            hidden.name = "amenities[]";
            hidden.value = item.id;
            container.appendChild(hidden);
        });

        // Actualizar el botón resumen
        let summary = `<i class="bi bi-star me-2"></i> Seleccionar`;
        if (selected.length > 0) {
            if (selected.length <= 3) {
                summary = `<i class="bi bi-star me-2"></i> ${selected.map(i => i.name).join(" · ")}`;
            } else {
                summary = `<i class="bi bi-star me-2"></i> ${selected.length} comodidades seleccionadas`;
            }
        }

        document.getElementById("amenitiesSummaryBtn").innerHTML = summary;
    }

    // Manejar estados ARIA para modales
    document.addEventListener('show.bs.modal', function (event) {
        const modal = event.target;
        const trigger = document.querySelector('[data-bs-target="#' + modal.id + '"]');
        if (trigger) {
            trigger.setAttribute('aria-expanded', 'true');
        }
    });

    document.addEventListener('hide.bs.modal', function (event) {
        const modal = event.target;
        const trigger = document.querySelector('[data-bs-target="#' + modal.id + '"]');
        if (trigger) {
            trigger.setAttribute('aria-expanded', 'false');
        }
    });
</script>