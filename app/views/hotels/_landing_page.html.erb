<!-- ==================== Estilos locales ==================== -->
<style> /* Hero section */
.hero {
    background: linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)), url(<%= asset_path 'portada.jpg' %>) center/cover no-repeat;
    min-height: 420px;
    color: #fff;
    display: flex;
    align-items: center;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
}

.search-card {
    margin-top: -60px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, .15);
    border-radius: 1rem;
}

.offer-card {
    transition: transform 0.2s ease, box-shadow 0.3s ease;
    border: none;
    border-radius: 1rem;
    overflow: hidden;
}

.offer-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
}

.offer-card img {
    height: 180px;
    object-fit: cover;
}

.feature-grid .card {
    border: 0;
    border-radius: 1rem;
    transition: background 0.2s ease, transform 0.2s ease;
    text-align: center;
}

.feature-grid .card:hover {
    background-color: #f8f9fa;
    transform: translateY(-4px);
}

/* Why choose us */
.why-us {
    background: #f7f8fa;
    padding: 60px 0;
}

.why-us .icon-circle {
    width: 70px;
    height: 70px;
    background: #007bff1a;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    margin: 0 auto 15px;
}

/* Destinations */
.destination-card img {
    height: 160px;
    object-fit: cover;
    border-radius: 1rem;
    transition: transform 0.3s ease;
}

.destination-card:hover img {
    transform: scale(1.05);
}

/* Testimonials */
.testimonial-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    padding: 1.5rem;
}

/* CTA */
.cta {
    background: linear-gradient(135deg, #007bff, #0069d9);
    color: #fff;
    padding: 70px 0;
    text-align: center;
    border-radius: 1rem;
}

@media (max-width: 575px) {
    .hero {
        min-height: 320px;
    }

    .search-card {
        margin: 0 12px;
    }
} </style> <!-- ==================== Contenido principal ==================== -->
<style>
    /* ==================== Hero Section ==================== */
    .hero {
        background: linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)),
        url('https://images.unsplash.com/photo-1501117716987-c8e86f0f7b1b?auto=format&fit=crop&w=1800&q=60') center/cover no-repeat;
        min-height: 420px;
        color: #fff;
        display: flex;
        align-items: center;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
    }

    /* ==================== Search Card ==================== */
    .search-card {
        margin-top: -60px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, .15);
        border-radius: 1rem;
    }

    /* ==================== Campos generales ==================== */
    .form-label {
        font-weight: 600;
        color: #333;
        font-size: 0.9rem;
    }

    .form-control, .btn {
        border-radius: 0.7rem;
        transition: all 0.2s ease;
        font-size: 0.95rem;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.15rem rgba(13, 110, 253, 0.2);
    }

    /* ==================== Input con ícono ==================== */
    .input-icon {
        position: relative;
    }

    .input-icon i {
        position: absolute;
        top: 50%;
        left: 12px;
        transform: translateY(-50%);
        color: #0d6efd;
        font-size: 1.1rem;
    }

    .date-input {
        padding-left: 38px;
        cursor: pointer;
        background-color: #fff;
    }

    .date-input:hover {
        background-color: #f8f9fa;
    }

    /* ==================== Flatpickr personalizado ==================== */
    .flatpickr-calendar {
        border-radius: 0.75rem !important;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15) !important;
        font-family: inherit !important;
    }

    .flatpickr-day.selected {
        background-color: #0d6efd !important;
        border-color: #0d6efd !important;
    }

    .flatpickr-day.startRange, .flatpickr-day.endRange {
        background: #0d6efd !important;
        color: #fff !important;
    }

    /* ==================== Responsive ==================== */
    @media (max-width: 575px) {
        .hero {
            min-height: 320px;
        }

        .search-card {
            margin: 0 12px;
        }
    }
</style>

<!-- ==================== Contenido principal ==================== -->
<header class="hero text-center" style="background: url('<%= asset_path('portada.jpg') %>') center/cover no-repeat">
  <div class="container">
    <h1 class="display-5 fw-bold">Encuentra tu hospedaje ideal</h1>
    <p class="lead mb-4">Busca hoteles, hostales, departamentos y más — compara precios y ofertas.</p>
  </div>
</header>

<!-- Floating search card -->
<section class="container">
  <div class="card search-card mx-auto p-3 position-relative">
    <section class="search-hotels bg-white p-3">
      <form action="/hotels/search_results" method="get" class="row g-3 align-items-end justify-content-center">

        <!-- Ciudad -->
        <div class="col-md-3">
          <label class="form-label fw-semibold">Ciudad</label>
          <input type="text" name="city" class="form-control" placeholder="Ej: Quito, Cuenca...">
        </div>

        <!-- Fechas -->
        <div class="col-md-4">
          <label class="form-label fw-semibold">Fechas</label>
          <div class="input-icon">
            <i class="bi bi-calendar-range"></i>
            <input type="text" id="dateRange" name="date_range" class="form-control date-input" placeholder="Seleccionar fechas">
          </div>
        </div>

        <!-- Huéspedes -->
        <div class="col-md-3">
          <label class="form-label fw-semibold d-block">Huéspedes</label>
          <button id="guestsSummaryBtn" type="button" class="btn btn-outline-primary w-100 text-start" data-bs-toggle="modal" data-bs-target="#guestsModal">
            <i class="bi bi-people me-2"></i> Seleccionar
          </button>
        </div>

        <!-- Botón Buscar -->
        <div class="col-md-2 d-grid">
          <button type="submit" class="btn btn-primary btn-lg">Buscar</button>
        </div>

      </form>
    </section>
  </div>
</section>

<!-- ==================== Modal Huéspedes ==================== -->
<div class="modal fade" id="guestsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 shadow">
      <div class="modal-header">
        <h5 class="modal-title fw-bold">Selecciona los huéspedes</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
          <span>Adultos</span>
          <div class="input-group" style="width: 140px;">
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('adults', -1)">-</button>
            <input type="text" id="adults" name="adults" class="form-control text-center" value="2" readonly>
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('adults', 1)">+</button>
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <span>Niños</span>
          <div class="input-group" style="width: 140px;">
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('children', -1)">-</button>
            <input type="text" id="children" name="children" class="form-control text-center" value="0" readonly>
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('children', 1)">+</button>
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center">
          <span>Habitaciones</span>
          <div class="input-group" style="width: 140px;">
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('rooms', -1)">-</button>
            <input type="text" id="rooms" name="rooms" class="form-control text-center" value="1" readonly>
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('rooms', 1)">+</button>
          </div>
        </div>

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cerrar</button>
        <button type="button" class="btn btn-primary rounded-pill" data-bs-dismiss="modal" onclick="applyGuests()">Aplicar</button>
      </div>
    </div>
  </div>
</div>

<!-- ==================== Scripts ==================== -->
<!-- Librerías necesarias -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // ==================== Flatpickr modo rango en español ====================
        flatpickr("#dateRange", {
            mode: "range",
            dateFormat: "d-m-Y", // formato más común en español
            minDate: "today",
            locale: "es", // activa idioma español
            rangeSeparator: " a ", // reemplaza 'to' por 'a'
            onClose: function (selectedDates) {
                if (selectedDates.length === 2 && selectedDates[1] < selectedDates[0]) {
                    alert("La fecha de salida no puede ser menor que la de entrada.");
                    this.clear();
                }
            }
        });

        // ==================== Huéspedes ====================
        window.updateGuests = function (type, change) {
            const input = document.getElementById(type);
            let value = parseInt(input.value) + change;
            if (type === 'adults' || type === 'rooms') {
                if (value < 1) value = 1;
            } else if (value < 0) value = 0;
            input.value = value;
        }

        window.applyGuests = function () {
            const adults = document.getElementById("adults").value;
            const children = document.getElementById("children").value;
            const rooms = document.getElementById("rooms").value;

            let summary = `${adults} adulto${adults != 1 ? "s" : ""}`;
            if (children > 0) summary += ` · ${children} niño${children != 1 ? "s" : ""}`;
            summary += ` · ${rooms} habitación${rooms != 1 ? "es" : ""}`;

            document.getElementById("guestsSummaryBtn").innerHTML = `<i class="bi bi-people me-2"></i> ${summary}`;
        }
    });
</script>


