        height: 40px;
        border: 2px solid var(--primary-color);
        background: white;
        color: var(--primary-color);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    .counter-btn:hover {
        background: var(--primary-color);
        color: white;
    }

    .counter-value {
        font-size: 1.2rem;
        font-weight: 600;
        min-width: 30px;
        text-align: center;
    }

    .modal-footer {
        border-top: 1px solid #e9ecef;
        padding: 1.5rem;
    }

