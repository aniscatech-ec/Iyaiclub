<style>
    .range-wrapper {
        position: relative;
        height: 4px;
        background: #ddd;
        margin: 20px 0;
    }

    .range-wrapper input[type=range] {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        pointer-events: none;
        -webkit-appearance: none;
        background: transparent;
    }

    .range-wrapper input[type=range]::-webkit-slider-thumb {
        pointer-events: auto;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #007bff;
        cursor: pointer;
        -webkit-appearance: none;
    }

    .slider-range {
        position: absolute;
        height: 100%;
        background: #007bff;
        top: 0;
        left: 0;
        right: 0;
    }

</style>
<div class="row mb-4" data-controller="filter-hotel">
  <!-- Filtros laterales -->
  <div class="col-md-3">
    <div class="card p-3 shadow-sm mb-4">
      <h5 class="mb-3">Filtrar por comodidades</h5>
      <% selected_amenity_ids = Amenity.where(name: params[:amenities]).pluck(:id) if params[:amenities].present? %>
      <% Amenity.all.each do |amenity| %>
        <div class="form-check">
          <%= check_box_tag "amenities[]", amenity.id,
                            selected_amenity_ids&.include?(amenity.id),
                            class: "form-check-input",
                            id: "amenity_#{amenity.id}",
                            data: { filter_hotel_target: "checkbox" } %>
          <%= label_tag "amenity_#{amenity.id}", amenity.name, class: "form-check-label" %>
        </div>
      <% end %>
    </div>

    <div class="price-filter">
      <div class="range-wrapper">
        <input type="range" class="range-min" min="0" max="1000" step="10" value="0" data-filter-hotel-target="minPrice">
        <input type="range" class="range-max" min="0" max="1000" step="10" value="1000" data-filter-hotel-target="maxPrice">
        <div class="slider-track"></div>
        <div class="slider-range"></div>
      </div>
      <div class="labels">
        <span id="labelMin" data-filter-hotel-target="minPriceValue">0</span>
        —
        <span id="labelMax" data-filter-hotel-target="maxPriceValue">1000</span>
      </div>
      <button type="button" data-action="filter-hotel#filterByPrice">Filtrar precio</button>
    </div>

  </div>



  <!-- Contenedor de hoteles -->
  <div class="col-md-9">
    <div id="resultsCount" data-filter-hotel-target="resultsCount" class="mb-3 fw-bold text-success">
      <%= @hotels.count %> hoteles encontrados
    </div>

    <div id="hotelsContainer" data-filter-hotel-target="hotelsContainer">
      <%= render partial: "hotels/hotels_list", locals: { hotels: @hotels } %>
    </div>
  </div>
</div>

