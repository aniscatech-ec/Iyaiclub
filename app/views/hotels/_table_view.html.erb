<table class="table table-hover align-middle shadow-sm">

  <thead class="table-light">
  <tr>
    <th class="text-center">ID-establishment</th>
    <th class="text-center">ID-hotel</th>
    <th class="text-center">Nombre</th>
    <th class="text-center">Razón social</th>
    <th class="text-center">Representante</th>
    <th class="text-center">Afiliado</th>
    <th class="text-center">Categoría</th>
    <th class="text-center">Acciones</th>
  </tr>
  </thead>
  <tbody>
  <% hotels.each do |hotel| %>
    <% cache [hotel, "table_row"] do %>
      <tr>
        <td class="text-center"><%= hotel.establishment.id %></td>
        <td class="text-center"><%= hotel.id %></td>
        <td class="text-center"><%= hotel.establishment.name %></td>
        <td class="text-center"><%= hotel.establishment.legal_info&.business_name || "-" %></td>
        <td class="text-center"><%= hotel.establishment.legal_info&.legal_representative || "-" %></td>
        <td class="text-center"><%= hotel.establishment.user.name %></td>
        <td class="text-center"><%= hotel_type_label(hotel.hotel_type.presence) || "-" %></td>
        <td>
          <div class="d-flex justify-content-center gap-2">
            <%= link_to hotel, class: "btn btn-info btn-sm" do %>
              <i class="fa-solid fa-eye"></i>
            <% end %>
            <%= link_to edit_hotel_path(hotel), class: "btn btn-warning btn-sm" do %>
              <i class="fa-solid fa-pen-to-square"></i>
            <% end %>
            <%= link_to hotel_path(hotel), data: { turbo_method: :delete, turbo_confirm: "¿Está seguro de eliminar este hotel?" }, class: "btn btn-danger btn-sm" do %>
              <i class="fa-solid fa-trash-can"></i>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  <% end %>
  </tbody>
</table>
