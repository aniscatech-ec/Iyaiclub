<% if user_signed_in? %>
  <% if current_user.administrador? %>
    <%= render "table_view", hotels: @hotels%>
  <% elsif current_user.afiliado? %>
    <%= render "card_view", hotels: @hotels %>
  <% elsif current_user.turista? %>
    <%#= render "catalog_view", hotels: @hotels %>
    <%= render "landing_page", hotels: @hotels %>

  <% end %>
<% else %>
  <%= render "landing_page", hotels: @hotels %>
<% end %>