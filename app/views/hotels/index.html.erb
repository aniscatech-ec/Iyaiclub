<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Hospedaje</h1>
    <% if @current_type.present? %>
      <div class="mt-2">
        <span class="badge rounded-pill bg-success fs-6 filter-badge">
          <i class="fas fa-filter me-1"></i>
          <%= hotel_type_label(@current_type) %>
          <%= link_to hotels_path, class: "remove-filter text-white ms-2", title: "Quitar filtro" do %>
            <i class="fas fa-times"></i>
          <% end %>
        </span>
      </div>
    <% end %>
  </div>
  <% if current_user&.administrador? %>
    <%= link_to select_affiliate_establishments_path, class: "btn btn-primary btn-lg" do %>
      <%#= link_to new_establishment_path, class: "btn btn-success" do %>
      <i class="fa-solid fa-plus"></i> Nuevo
    <% end %>

  <% end %>

  <% if current_user&.afiliado? %>
    <%= link_to new_hotel_path, class: "btn btn-primary btn-lg" do %>
      <%#= link_to new_establishment_path, class: "btn btn-success" do %>
      <i class="fa-solid fa-plus"></i> Nuevo
    <% end %>

  <% end %>



</div>

<% if current_user&.administrador? %>
  <%= render "table_view", hotels: @hotels %>
<% elsif current_user&.afiliado? %>
  <%= render "card_view", hotels: @hotels %>
<% elsif current_user&.turista? %>
  <%= render "catalog_view", hotels: @hotels %>
<% else %>
  <%= render "catalog_view", hotels: @hotels %>
<% end %>

<nav class="d-flex justify-content-center mt-4">
  <%== pagy_nav(@pagy) %>
</nav>

