<style>
    [data-user-search-target="results"]:empty {
        display: none;
    }

</style>
<h1>Editar hotel</h1>

<%= form_with(model: @hotel,
              local: true,
              html: { multipart: true }, # <-- necesario para subir archivos
              data: { controller: "gallery", action: "submit->gallery#submitForm", model: "hotel" }) do |f| %>

  <%= f.fields_for :establishment do |e| %>
    <!-- Datos legales -->
    <div class="card mb-4">
      <div class="card-header fw-bold">1. Datos legales y contacto</div>
      <div class="card-body">
        <%= e.fields_for :legal_info do |l| %>
          <div class="mb-3">
            <%= l.label :business_name, "Razón social / nombre comercial" %>
            <%= l.text_field :business_name, class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= l.label :document_number, "RUC / identificación fiscal" %>
            <%= l.text_field :document_number, class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= l.label :legal_representative, "Nombre del responsable / administrador" %>
            <%= l.text_field :legal_representative, class: "form-control" %>
          </div>
          <div class="mb-3">

            <%= f.fields_for :establishment do |e| %>
              <% if current_user.administrador? %>

                <div data-controller="user-search" class="position-relative"
                     data-user-search-default-name="<%= @hotel.establishment.user&.name %>"
                     data-user-search-default-id="<%= @hotel.establishment.user_id %>">
                  <label for="user_search_input">Seleccionar usuario (administrador)</label>
                  <input type="text" id="user_search_input"
                         data-user-search-target="input"
                         data-action="input->user-search#search"
                         class="form-control"
                         placeholder="Escribe nombre o email...">

                  <!-- Hidden field para enviar el user_id al guardar -->
                  <%= f.fields_for :establishment do |e| %>
                    <%= e.hidden_field :user_id, data: { user_search_target: "hidden" } %>
                  <% end %>

                  <!-- Dropdown de resultados -->
                  <div data-user-search-target="results"
                       class="border position-absolute bg-white w-100"
                       style="z-index: 1000; max-height: 200px; overflow-y: auto;"></div>
                </div>


              <% else %>
                <%= e.hidden_field :user_id, value: current_user.id %>
              <% end %>
            <% end %>
          </div>


          <div class="mb-3">
            <%= l.label :contact_email, "Email de contacto" %>
            <%= l.email_field :contact_email, class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= l.label :contact_phone, "Teléfono de contacto" %>
            <%= l.telephone_field :contact_phone, class: "form-control" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Perfil -->
  <div class="card mb-4">
    <div class="card-header fw-bold">2. Perfil del hotel</div>
    <div class="card-body">
      <%= f.fields_for :establishment do |e| %>

        <div class="mb-3">
          <%= e.label :name, "Nombre público del hotel" %>
          <%= e.text_field :name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= e.label :price_per_night, "Precio por noche" %>
          <%= e.number_field :price_per_night, step: 0.01, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= e.label :address, "Dirección completa" %>
          <%= e.text_field :address, class: "form-control" %>
        </div>

        <div data-controller="map-edit"
             data-map-edit-lat-value="<%= @hotel.establishment.latitude %>"
             data-map-edit-lng-value="<%= @hotel.establishment.longitude %>">

          <div id="map" style="height: 400px; width: 100%; border-radius: 8px;"></div>

          <div class="row mt-3">
            <div class="col-md-6">
              <%= e.label :latitude, "Latitud" %>
              <%= e.text_field :latitude, class: "form-control", data: { map_edit_target: "latitude" }, readonly: true %>
            </div>
            <div class="col-md-6">
              <%= e.label :longitude, "Longitud" %>
              <%= e.text_field :longitude, class: "form-control", data: { map_edit_target: "longitude" }, readonly: true %>
            </div>
          </div>
        </div>



    <% end %>

      <div class="mb-3">
        <%= f.label :hotel_type, "Tipo de hotel", class: "form-label" %>
        <%= f.select :hotel_type, options_for_select([
                                                       ['Hotel convencional', 'conventional'],
                                                       ['Hotel boutique', 'boutique'],
                                                       ['Hotel de cadena', 'chain'],
                                                       ['Resort', 'resort'],
                                                       ['Ecohotel / Ecolodge', 'ecohotel']
                                                     ], @hotel.hotel_type), { include_blank: 'Selecciona un tipo' }, class: "form-select" %>
      </div>

      <div class="mb-3">
        <%= f.label :stars, "Categoría" %>
        <%= f.select :stars,
                     options_for_select((1..5).map { |i| ["#{"⭐" * i}", i] }, @hotel.stars),
                     {}, class: "form-select" %>
      </div>

    </div>
  </div>


  <div class="card mb-4">
    <div class="card-header fw-bold">3. Ubicación general</div>
    <div class="card-body">
      <%= f.fields_for :establishment do |e| %>


        <div data-controller="location">

          <div class="mb-3">
            <%= e.label :country_id, "País" %>
            <%= e.collection_select :country_id, Country.all, :id, :name, { prompt: "Seleccionar país" },
                                    { class: "form-select",
                                      data: { action: "change->location#updateProvinces", location_target: "country" } } %>
          </div>

          <div class="mb-3">
            <%= e.label :province_id, "Provincia" %>
            <%= e.collection_select :province_id,
                                    e.object.country.present? ? e.object.country.provinces : [],
                                    :id, :name, { prompt: "Seleccionar provincia" },
                                    { class: "form-select", data: { action: "change->location#updateCities", location_target: "province" } } %>
          </div>


          <div class="mb-3">
            <%= e.label :city_id, "Ciudad" %>
            <%= e.collection_select :city_id,
                                    e.object.province.present? ? e.object.province.cities : [],
                                    :id, :name,
                                    { prompt: "Seleccionar ciudad" },
                                    class: "form-select",
                                    data: { location_target: "city" } %>
          </div>
        </div>

      <% end %>

    </div>
  </div>


  <div class="card mb-4">
    <div class="card-header fw-bold">4. Comodidades</div>
    <div class="card-body">

      <%= f.fields_for :establishment do |e| %>
        <div class="mb-3" data-controller="amenity-selector">

          <div class="row row-cols-2 row-cols-md-5 g-3 mt-2">
            <% Amenity.all.each do |amenity| %>
              <div class="col">
                <div class="form-check d-flex flex-column align-items-center border rounded p-2 h-100
              <%= "selected" if @hotel.establishment&.amenity_ids&.include?(amenity.id) %>"
                     data-action="click->amenity-selector#toggle">

                  <%= e.check_box :amenity_ids,
                                  { multiple: true,
                                    checked: @hotel.establishment&.amenity_ids&.include?(amenity.id),
                                    id: "amenity_#{amenity.id}",
                                    class: "d-none",
                                    data: { amenity_selector_target: "checkbox" } },
                                  amenity.id, nil %>

                  <%# if amenity.custom_icon.attached? %>
                  <%# if amenity.custom_icon.blob.content_type == "image/svg+xml" %>
                  <%#= image_tag url_for(amenity.custom_icon), alt: amenity.name, style: "width:32px; height:32px; object-fit:contain;" %>
                  <%# else %>
                  <%#= image_tag amenity.custom_icon.variant(resize_to_limit: [32,32]), alt: amenity.name %>
                  <%# end %>
                  <%# end %>

                  <% if amenity.custom_icon.attached? && amenity.custom_icon.content_type == 'image/svg+xml' %>
                    <% svg_content = amenity.custom_icon.download %>
                    <%= raw svg_content.gsub('<svg', '<svg width="32" height="32"') %>
                  <% else %>
                    <i class="fa fa-circle-question fa-2x text-muted"></i>
                  <% end %>


                  <span class="mt-1 text-center"><%= amenity.name %></span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      <style>
          /* Estilo de tarjeta seleccionada */
          .form-check.selected {
              background-color: rgba(13, 110, 253, 0.15);
              border-color: #0d6efd;
          }

          /* Ícono de la tarjeta seleccionada */
          .form-check.selected img {
              transform: scale(1.1);
              filter: brightness(1.2);
              transition: transform 0.2s, filter 0.2s;
          }

          /* Hover sobre la tarjeta */
          .form-check:hover {
              border-color: #0d6efd;
              background-color: rgba(13, 110, 253, 0.05);
              cursor: pointer;
          }
      </style>

    </div>
  </div>


  <%= f.fields_for :units do |e| %>
    <div class="card p-3 mb-4 shadow-sm">
      <h4 class="mb-3">Información general</h4>

      <div class="mb-3">
        <%= e.label :unit_type, "Tipo de unidad" %>
        <%= e.text_field :unit_type, class: "form-control" %>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <%= e.label :capacity, "Capacidad de personas" %>
          <%= e.number_field :capacity, class: "form-control" %>
        </div>

        <div class="col-md-4 mb-3">
          <%= e.label :base_price, "Precio base por noche (USD)" %>
          <%= e.number_field :base_price, step: 0.01, class: "form-control" %>
        </div>
      </div>

      <!-- Distribución de camas -->
<!--      <div data-controller="bed">-->
<!--        <label class="form-label">Distribución de camas</label>-->

<!--        <div data-bed-target="container">-->
          <%# if e.object.bed_configuration.present? %>
            <%# e.object.bed_configuration.each do |key, value| %>
<!--              <div class="row mb-2 bed-row">-->
<!--                <div class="col-md-6">-->
                  <%#= text_field_tag "unit[bed_configuration_keys][]", key, class: "form-control" %>
<!--                </div>-->
<!--                <div class="col-md-4">-->
                  <%#= number_field_tag "unit[bed_configuration_values][]", value, min: 0, class: "form-control" %>
<!--                </div>-->
<!--                <div class="col-md-2 d-flex align-items-center">-->
<!--                  <button class="btn btn-sm btn-danger" data-action="bed#removeField">✖</button>-->
<!--                </div>-->
<!--              </div>-->
            <%# end %>
          <%# end %>
<!--        </div>-->

<!--        <template data-bed-target="template">-->
<!--          <div class="row mb-2 bed-row">-->
<!--            <div class="col-md-6">-->
<!--              <input type="text" name="unit[bed_configuration_keys][]" class="form-control" placeholder="Tipo de cama">-->
<!--            </div>-->
<!--            <div class="col-md-4">-->
<!--              <input type="number" name="unit[bed_configuration_values][]" class="form-control" min="0" placeholder="Cantidad">-->
<!--            </div>-->
<!--            <div class="col-md-2 d-flex align-items-center">-->
<!--              <button class="btn btn-sm btn-danger" data-action="bed#removeField">✖</button>-->
<!--            </div>-->
<!--          </div>-->
<!--        </template>-->

<!--        <button type="button" class="btn btn-sm btn-outline-primary mt-2" data-action="bed#addField">-->
<!--          + Agregar cama-->
<!--        </button>-->
<!--      </div>-->
    </div>

    <!-- Tarifas -->
    <div class="card p-3 mb-4 shadow-sm">
      <h4 class="mb-3">Tarifas por temporada</h4>
      <table class="table table-bordered">
        <thead class="table-light">
        <tr>
          <th>Temporada</th>
          <th>Precio (USD)</th>
        </tr>
        </thead>
        <tbody>
        <%= e.fields_for :unit_prices do |price_form| %>
          <tr>
            <td><%= price_form.select :season, [["Alta", "high"], ["Baja", "low"], ["Especial", "special"]], {}, class: "form-control" %></td>
            <td><%= price_form.number_field :price, step: 0.01, class: "form-control" %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

    <!-- Disponibilidad -->
    <div class="card p-3 mb-4 shadow-sm"
         data-controller="fullcalendar-edit"
         data-fullcalendar-edit-events-value="<%= e.object.unit_availabilities.select(:date, :available).map { |u|
           {
             id: u.date.to_s,
             title: u.available ? 'Disponible' : 'No disponible',
             start: u.date.to_s,
             color: u.available ? 'green' : 'red'
           }
         }.to_json %>">
      <div data-fullcalendar-edit-target="calendar"></div>
      <%= hidden_field_tag 'unit[availabilities_json]', '', id: 'unit_availabilities_json' %>
    </div>

  <% end %>



  <!-- Galerías existentes -->
  <%= f.fields_for :establishment do |e| %>
    <% if e.object.galleries.any? %>
      <h2>Galerías existentes</h2>

      <%= e.fields_for :galleries do |g| %>
        <div class="card mb-4 p-3">
          <p class="fw-bold">Galería: <%= g.object.name %> (ID: <%= g.object.id %>)</p>
          <div class="mb-2">
            <%= g.label :name, "Nombre de la galería", class: "form-label fw-bold" %>
            <%= g.text_field :name, class: "form-control", value: g.object.name %>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <% g.object.gallery_images.each do |img| %>
              <div class="position-relative me-2 mb-2">
                <% if img.file.attached? %>
                  <%= image_tag img.file.variant(resize_to_limit: [200, 120]) %>
                <% end %>

                <%# Campos correctly-nested para cada imagen %>
                <%= g.fields_for :gallery_images, img do |gi| %>
                  <%= gi.hidden_field :id %>              <!-- imprescindible -->
                  <div class="form-check">
                    <%= gi.check_box :_destroy, class: "form-check-input" %>
                    <%= gi.label :_destroy, "Eliminar imagen", class: "form-check-label" %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>

          <!-- NUEVO: input para agregar más imágenes a esta galería -->
          <div class="mt-3">
            <label class="form-label">Agregar imágenes a esta galería</label>
            <!-- name es gallery_uploads[<gallery_id>][] para procesarlo fácilmente en el controlador -->
            <%= file_field_tag "gallery_uploads[#{g.object.id}][]",
                               multiple: true,
                               accept: "image/*",
                               class: "form-control" %>
            <small class="text-muted">Selecciona varias imágenes (no reemplazan las existentes).</small>
          </div>

          <div class="form-check mt-2">
            <%= g.hidden_field :id %>                  <!-- imprescindible -->
            <%= g.check_box :_destroy, class: "form-check-input" %>
            <%= g.label :_destroy, "Eliminar galería", class: "form-check-label" %>
          </div>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <!-- Aquí Stimulus inyectará las nuevas galerías -->
  <div id="galleries-container" data-gallery-target="container"></div>

  <!-- Formulario para agregar nuevas galerías -->
  <div class="card mb-4">
    <div class="card-header fw-bold">Agregar nueva galería</div>
    <div class="card-body">
      <input type="text" data-gallery-target="name" class="form-control mb-2" placeholder="Nombre de la galería">
      <input type="file" data-gallery-target="files" multiple class="form-control mb-2">
      <button type="button" class="btn btn-secondary" data-action="gallery#addGallery">Agregar galería</button>
    </div>
  </div>

  <%= f.submit "Actualizar hotel", class: "btn btn-primary" %>
<% end %>
