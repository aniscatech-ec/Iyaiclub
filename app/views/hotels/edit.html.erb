<style>
    [data-user-search-target="results"]:empty { display: none; }
    .amenity-card.selected { background-color: rgba(63,189,2,0.12) !important; border-color: var(--brand-green) !important; }
    .amenity-card:hover { border-color: var(--brand-green); background-color: rgba(63,189,2,0.05); cursor: pointer; }
    .amenity-card.selected img { transform: scale(1.1); filter: brightness(1.2); transition: transform 0.2s, filter 0.2s; }
</style>

<!-- ═══════════════ ENCABEZADO ═══════════════ -->
<div class="text-center mb-4">
  <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-2"
       style="width: 60px; height: 60px; background: var(--brand-green); opacity: 0.9;">
    <i class="fas fa-hotel text-white fs-4"></i>
  </div>
  <h2 class="fw-bold mb-1">Editar hotel</h2>
  <% if @hotel.establishment&.name.present? %>
    <p class="text-muted"><%= @hotel.establishment.name %></p>
  <% end %>
</div>

<%= render_validation_errors(@hotel) %>

<%= form_with(model: @hotel,
              local: true,
              html: { multipart: true },
              data: { controller: "form-validation gallery", model: "hotel" }) do |f| %>

  <%= f.fields_for :establishment do |e| %>

    <!-- ═══════════════ 1. DATOS LEGALES ═══════════════ -->
    <div class="card border-0 shadow-sm rounded-3 mb-4">
      <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-green), #2a8c00); color: white; border-radius: 0.5rem 0.5rem 0 0;">
        <h5 class="mb-0 fw-bold"><i class="fas fa-file-contract me-2"></i> 1. Datos legales y contacto</h5>
      </div>
      <div class="card-body p-4">
        <%= e.fields_for :legal_info do |l| %>
          <div class="row g-3">
            <div class="col-md-6">
              <%= l.label :business_name, "Razón social / nombre comercial", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-building"></i></span>
                <%= l.text_field :business_name, class: "form-control", required: true, minlength: 3, maxlength: 150, placeholder: "Nombre legal" %>
              </div>
            </div>
            <div class="col-md-3">
              <%= l.label :document_type, "Tipo de documento", class: "form-label fw-semibold required-field" %>
              <%= l.select :document_type, ["RUC", "DNI", "Pasaporte", "Cédula"], {}, class: "form-select", required: true %>
            </div>
            <div class="col-md-3">
              <%= l.label :document_number, "Número de documento", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                <%= l.text_field :document_number, class: "form-control", required: true, placeholder: "Ej: 0901234567001" %>
              </div>
            </div>
            <div class="col-md-6">
              <%= l.label :legal_representative, "Representante legal", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-user-tie"></i></span>
                <%= l.text_field :legal_representative, class: "form-control", required: true, minlength: 3, maxlength: 100, placeholder: "Nombre completo" %>
              </div>
            </div>
            <div class="col-md-6">
              <%= f.fields_for :establishment do |e2| %>
                <% if current_user.administrador? %>
                  <div data-controller="user-search" class="position-relative"
                       data-user-search-default-name="<%= @hotel.establishment.user&.name %>"
                       data-user-search-default-id="<%= @hotel.establishment.user_id %>">
                    <label class="form-label fw-semibold">Afiliado asignado</label>
                    <div class="input-group">
                      <span class="input-group-text"><i class="fas fa-user-shield"></i></span>
                      <input type="text" id="user_search_input"
                             data-user-search-target="input"
                             data-action="input->user-search#search"
                             class="form-control"
                             placeholder="Escribe nombre o email...">
                    </div>
                    <%= f.fields_for :establishment do |e3| %>
                      <%= e3.hidden_field :user_id, data: { user_search_target: "hidden" } %>
                    <% end %>
                    <div data-user-search-target="results"
                         class="border position-absolute bg-white w-100 rounded shadow-sm"
                         style="z-index: 1000; max-height: 200px; overflow-y: auto;"></div>
                  </div>
                <% else %>
                  <%= e2.hidden_field :user_id, value: current_user.id %>
                <% end %>
              <% end %>
            </div>
            <div class="col-md-6">
              <%= l.label :contact_email, "Email de contacto", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                <%= l.email_field :contact_email, class: "form-control", required: true, placeholder: "correo@ejemplo.com" %>
              </div>
            </div>
            <div class="col-md-6">
              <%= l.label :contact_phone, "Teléfono de contacto", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                <%= l.telephone_field :contact_phone, class: "form-control", required: true, pattern: "[0-9]{10}", maxlength: 10, placeholder: "Ej: 0991234567" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- ═══════════════ 2. PERFIL DEL HOTEL ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-orange), #c94a28); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-hotel me-2"></i> 2. Perfil del hotel</h5>
    </div>
    <div class="card-body p-4">
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.fields_for :establishment do |e| %>
            <%= e.label :name, "Nombre público del hotel", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-tag"></i></span>
              <%= e.text_field :name, class: "form-control", placeholder: "Nombre visible para los clientes", required: true %>
            </div>
          <% end %>
        </div>
        <div class="col-md-3">
          <%= f.label :hotel_type, "Tipo de hotel", class: "form-label fw-semibold required-field" %>
          <%= f.select :hotel_type, options_for_select([
                                                         ['Hotel convencional', 'conventional'],
                                                         ['Hotel boutique', 'boutique'],
                                                         ['Hotel de cadena', 'chain'],
                                                         ['Resort', 'resort'],
                                                         ['Ecohotel / Ecolodge', 'ecohotel']
                                                       ], @hotel.hotel_type), { include_blank: 'Selecciona un tipo' }, class: "form-select", required: true %>
        </div>
        <div class="col-md-3">
          <%= f.label :stars, "Categoría (estrellas)", class: "form-label fw-semibold" %>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-star" style="color: #f1c40f;"></i></span>
            <%= f.select :stars,
                         options_for_select((1..5).map { |i| ["#{"⭐" * i}", i] }, @hotel.stars),
                         {}, class: "form-select" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════ 3. UBICACIÓN ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, #3498db, #2475a8); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-map-marked-alt me-2"></i> 3. Ubicación general</h5>
    </div>
    <div class="card-body p-4">
      <%= f.fields_for :establishment do |e| %>
        <div data-controller="location">
          <div class="row g-3">
            <div class="col-md-4">
              <%= e.label :country_id, "País", class: "form-label fw-semibold" %>
              <%= e.collection_select :country_id, Country.all, :id, :name, { prompt: "Seleccionar país" },
                                      { class: "form-select",
                                        data: { action: "change->location#updateProvinces", location_target: "country" } } %>
            </div>
            <div class="col-md-4">
              <%= e.label :province_id, "Provincia", class: "form-label fw-semibold" %>
              <%= e.collection_select :province_id,
                                      e.object.country.present? ? e.object.country.provinces : [],
                                      :id, :name, { prompt: "Seleccionar provincia" },
                                      { class: "form-select", data: { action: "change->location#updateCities", location_target: "province" } } %>
            </div>
            <div class="col-md-4">
              <%= e.label :city_id, "Ciudad", class: "form-label fw-semibold" %>
              <%= e.collection_select :city_id,
                                      e.object.province.present? ? e.object.province.cities : [],
                                      :id, :name,
                                      { prompt: "Seleccionar ciudad" },
                                      class: "form-select",
                                      data: { location_target: "city" } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- ═══════════════ 4. COMODIDADES ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, #27ae60, #1e8449); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-concierge-bell me-2"></i> 4. Comodidades y servicios</h5>
    </div>
    <div class="card-body p-4">
      <%= f.fields_for :establishment do |e| %>
        <div class="mb-3" data-controller="amenity-selector">
          <div class="row row-cols-2 row-cols-md-5 g-3">
            <% Amenity.with_attached_custom_icon.each do |amenity| %>
              <div class="col">
                <div class="amenity-card form-check d-flex flex-column align-items-center border rounded-3 p-2 h-100
              <%= "selected" if @hotel.establishment&.amenity_ids&.include?(amenity.id) %>"
                     data-action="click->amenity-selector#toggle">

                  <%= e.check_box :amenity_ids,
                                  { multiple: true,
                                    checked: @hotel.establishment&.amenity_ids&.include?(amenity.id),
                                    id: "amenity_#{amenity.id}",
                                    class: "d-none",
                                    data: { amenity_selector_target: "checkbox" } },
                                  amenity.id, nil %>

                  <% if amenity.custom_icon.attached? && amenity.custom_icon.content_type == 'image/svg+xml' %>
                    <% svg_content = amenity.custom_icon.download %>
                    <%= raw svg_content.gsub('<svg', '<svg width="32" height="32"') %>
                  <% else %>
                    <i class="fa fa-circle-question fa-2x text-muted"></i>
                  <% end %>

                  <span class="mt-1 text-center small"><%= amenity.name %></span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- ═══════════════ 5. HABITACIONES ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4" data-controller="nested-form">
    <div class="card-header border-0 py-3 d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #8e44ad, #6c3483); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-bed me-2"></i> 5. Tipos de habitaciones <small class="opacity-75">(max. 10)</small></h5>
      <button type="button" class="btn btn-sm btn-light fw-semibold rounded-pill px-3" data-action="click->nested-form#add">
        <i class="fas fa-plus me-1"></i> Añadir habitación
      </button>
    </div>
    <div class="card-body p-4">

      <%# ── Template para nueva habitación ── %>
      <template data-nested-form-target="template">
        <div class="nested-fields border rounded-3 p-3 mb-3" style="background: #f5f0ff;" data-new-record="true">
          <%= f.fields_for :rooms, Room.new, child_index: 'NEW_RECORD' do |r| %>
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="mb-0 fw-bold"><i class="fas fa-door-open me-2" style="color: #8e44ad;"></i> Nueva habitación</h6>
              <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" data-action="click->nested-form#remove">
                <i class="fas fa-trash me-1"></i> Eliminar
              </button>
            </div>
            <%= r.hidden_field :_destroy %>

            <div class="row g-3">
              <div class="col-md-6">
                <%= r.label :name, "Nombre de la habitación", class: "form-label fw-semibold required-field" %>
                <div class="input-group">
                  <span class="input-group-text"><i class="fas fa-tag"></i></span>
                  <%= r.text_field :name, class: "form-control", required: true, placeholder: "Ej: Suite Presidencial, Habitación Doble" %>
                </div>
              </div>

              <div class="col-md-3">
                <%= r.label :room_type, "Tipo", class: "form-label fw-semibold" %>
                <%= r.select :room_type,
                    options_for_select([["Individual", "individual"], ["Doble", "doble"], ["Triple", "triple"], ["Cuádruple", "cuadruple"], ["Suite", "suite"], ["Familiar", "familiar"]]),
                    { include_blank: "Seleccione" },
                    class: "form-select" %>
              </div>

              <div class="col-md-3">
                <%= r.label :quantity, "Cantidad disponible", class: "form-label fw-semibold" %>
                <div class="input-group">
                  <span class="input-group-text"><i class="fas fa-hashtag"></i></span>
                  <%= r.number_field :quantity, class: "form-control", min: 1, value: 1, placeholder: "Ej: 5" %>
                </div>
                <small class="text-muted">¿Cuántas de este tipo?</small>
              </div>

              <div class="col-md-3">
                <%= r.label :guest_capacity, "Capacidad", class: "form-label fw-semibold" %>
                <div class="input-group">
                  <span class="input-group-text"><i class="fas fa-users"></i></span>
                  <%= r.number_field :guest_capacity, class: "form-control", min: 1, placeholder: "Ej: 2" %>
                </div>
                <small class="text-muted">Huéspedes</small>
              </div>

              <div class="col-md-3">
                <%= r.label :price_per_night, "Precio/noche ($)", class: "form-label fw-semibold" %>
                <div class="input-group">
                  <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                  <%= r.number_field :price_per_night, step: 0.01, class: "form-control", placeholder: "0.00" %>
                </div>
              </div>

              <%# ── Camas de esta habitación (sub-nested) ── %>
              <div class="col-12">
                <label class="form-label fw-semibold"><i class="fas fa-bed me-1"></i> Camas en esta habitación</label>
                <div class="room-beds-container border rounded p-2" style="background: #ece6f5;" data-controller="nested-form">
                  <template data-nested-form-target="template">
                    <div class="nested-fields d-flex align-items-center gap-2 mb-2">
                      <%= r.fields_for :room_beds, RoomBed.new, child_index: 'NEW_BED' do |rb| %>
                        <%= rb.hidden_field :_destroy %>
                        <%= rb.select :bed_type,
                            options_for_select([["1 Plaza", "1_plaza"], ["Plaza y media", "plaza_y_media"], ["Doble", "doble"], ["Queen", "queen"], ["King", "king"]]),
                            { include_blank: "Tipo de cama" },
                            class: "form-select form-select-sm", style: "max-width: 200px;" %>
                        <span class="text-muted">x</span>
                        <%= rb.number_field :quantity, class: "form-control form-control-sm", min: 1, value: 1, style: "max-width: 80px;" %>
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" data-action="click->nested-form#remove">
                          <i class="fas fa-times"></i>
                        </button>
                      <% end %>
                    </div>
                  </template>
                  <div data-nested-form-target="target"></div>
                  <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill mt-1" data-action="click->nested-form#add">
                    <i class="fas fa-plus me-1"></i> Agregar cama
                  </button>
                </div>
              </div>

              <div class="col-12">
                <%= r.label :description, "Descripción", class: "form-label fw-semibold" %>
                <%= r.text_area :description, rows: 2, class: "form-control", placeholder: "Descripción de la habitación, características especiales..." %>
              </div>

              <div class="col-md-6">
                <%= r.label :photo, "Foto de la habitación", class: "form-label fw-semibold" %>
                <%= r.file_field :photo, class: "form-control", accept: "image/jpeg,image/png,image/webp" %>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold">Comodidades de esta habitación</label>
                <div class="row g-2">
                  <% Amenity.order(:name).each do |amenity| %>
                    <div class="col-6 col-md-4 col-lg-3">
                      <div class="form-check">
                        <%= check_box_tag "hotel[rooms_attributes][NEW_RECORD][amenity_ids][]", amenity.id, false, class: "form-check-input", id: "room_NEW_RECORD_amenity_#{amenity.id}" %>
                        <label class="form-check-label" for="room_NEW_RECORD_amenity_<%= amenity.id %>"><%= amenity.name %></label>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </template>

      <%# ── Habitaciones existentes ── %>
      <div data-nested-form-target="target">
        <%= f.fields_for :rooms do |r| %>
          <div class="nested-fields border rounded-3 p-3 mb-3" style="background: #f5f0ff;" data-new-record="<%= r.object.new_record? %>">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="mb-0 fw-bold"><i class="fas fa-door-open me-2" style="color: #8e44ad;"></i> <%= r.object.name || "Habitación" %></h6>
              <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" data-action="click->nested-form#remove">
                <i class="fas fa-trash me-1"></i> Eliminar
              </button>
            </div>
            <%= r.hidden_field :_destroy %>

            <div class="row g-3">
              <div class="col-md-6">
                <%= r.label :name, "Nombre de la habitación", class: "form-label fw-semibold required-field" %>
                <div class="input-group">
                  <span class="input-group-text"><i class="fas fa-tag"></i></span>
                  <%= r.text_field :name, class: "form-control", required: true, placeholder: "Ej: Suite Presidencial, Habitación Doble" %>
                </div>
              </div>

              <div class="col-md-3">
                <%= r.label :room_type, "Tipo", class: "form-label fw-semibold" %>
                <%= r.select :room_type,
                    options_for_select([["Individual", "individual"], ["Doble", "doble"], ["Triple", "triple"], ["Cuádruple", "cuadruple"], ["Suite", "suite"], ["Familiar", "familiar"]], r.object.room_type),
                    { include_blank: "Seleccione" },
                    class: "form-select" %>
              </div>

              <div class="col-md-3">
                <%= r.label :quantity, "Cantidad disponible", class: "form-label fw-semibold" %>
                <div class="input-group">
                  <span class="input-group-text"><i class="fas fa-hashtag"></i></span>
                  <%= r.number_field :quantity, class: "form-control", min: 1, placeholder: "Ej: 5" %>
                </div>
                <small class="text-muted">¿Cuántas de este tipo?</small>
              </div>

              <div class="col-md-3">
                <%= r.label :guest_capacity, "Capacidad", class: "form-label fw-semibold" %>
                <div class="input-group">
                  <span class="input-group-text"><i class="fas fa-users"></i></span>
                  <%= r.number_field :guest_capacity, class: "form-control", min: 1, placeholder: "Ej: 2" %>
                </div>
                <small class="text-muted">Huéspedes</small>
              </div>

              <div class="col-md-3">
                <%= r.label :price_per_night, "Precio/noche ($)", class: "form-label fw-semibold" %>
                <div class="input-group">
                  <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                  <%= r.number_field :price_per_night, step: 0.01, class: "form-control", placeholder: "0.00" %>
                </div>
              </div>

              <%# ── Camas de esta habitación (sub-nested) ── %>
              <div class="col-12">
                <label class="form-label fw-semibold"><i class="fas fa-bed me-1"></i> Camas en esta habitación</label>
                <div class="room-beds-container border rounded p-2" style="background: #ece6f5;" data-controller="nested-form">
                  <template data-nested-form-target="template">
                    <div class="nested-fields d-flex align-items-center gap-2 mb-2">
                      <%= r.fields_for :room_beds, RoomBed.new, child_index: 'NEW_BED' do |rb| %>
                        <%= rb.hidden_field :_destroy %>
                        <%= rb.select :bed_type,
                            options_for_select([["1 Plaza", "1_plaza"], ["Plaza y media", "plaza_y_media"], ["Doble", "doble"], ["Queen", "queen"], ["King", "king"]]),
                            { include_blank: "Tipo de cama" },
                            class: "form-select form-select-sm", style: "max-width: 200px;" %>
                        <span class="text-muted">x</span>
                        <%= rb.number_field :quantity, class: "form-control form-control-sm", min: 1, value: 1, style: "max-width: 80px;" %>
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" data-action="click->nested-form#remove">
                          <i class="fas fa-times"></i>
                        </button>
                      <% end %>
                    </div>
                  </template>
                  <div data-nested-form-target="target">
                    <%= r.fields_for :room_beds do |rb| %>
                      <div class="nested-fields d-flex align-items-center gap-2 mb-2">
                        <%= rb.hidden_field :_destroy %>
                        <%= rb.select :bed_type,
                            options_for_select([["1 Plaza", "1_plaza"], ["Plaza y media", "plaza_y_media"], ["Doble", "doble"], ["Queen", "queen"], ["King", "king"]], rb.object.bed_type),
                            { include_blank: "Tipo de cama" },
                            class: "form-select form-select-sm", style: "max-width: 200px;" %>
                        <span class="text-muted">x</span>
                        <%= rb.number_field :quantity, class: "form-control form-control-sm", min: 1, style: "max-width: 80px;" %>
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" data-action="click->nested-form#remove">
                          <i class="fas fa-times"></i>
                        </button>
                      </div>
                    <% end %>
                  </div>
                  <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill mt-1" data-action="click->nested-form#add">
                    <i class="fas fa-plus me-1"></i> Agregar cama
                  </button>
                </div>
              </div>

              <div class="col-12">
                <%= r.label :description, "Descripción", class: "form-label fw-semibold" %>
                <%= r.text_area :description, rows: 2, class: "form-control", placeholder: "Descripción de la habitación, características especiales..." %>
              </div>

              <div class="col-md-6">
                <%= r.label :photo, "Foto de la habitación", class: "form-label fw-semibold" %>
                <% if r.object.persisted? && r.object.photo.attached? %>
                  <div class="mb-2">
                    <%= image_tag r.object.photo.variant(resize_to_limit: [200, 120]), class: "img-thumbnail rounded shadow-sm", loading: "lazy" %>
                  </div>
                <% end %>
                <%= r.file_field :photo, class: "form-control", accept: "image/jpeg,image/png,image/webp" %>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold">Comodidades de esta habitación</label>
                <div class="row g-2">
                  <% Amenity.order(:name).each do |amenity| %>
                    <div class="col-6 col-md-4 col-lg-3">
                      <div class="form-check">
                        <%= r.check_box :amenity_ids, { multiple: true, checked: r.object.amenity_ids.include?(amenity.id), class: "form-check-input", id: "room_#{r.object.id || r.index}_amenity_#{amenity.id}" }, amenity.id, nil %>
                        <label class="form-check-label" for="room_<%= r.object.id || r.index %>_amenity_<%= amenity.id %>"><%= amenity.name %></label>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <p class="text-muted text-center py-3 mb-0 empty-rooms-message" <%= 'style="display: none;"' unless @hotel.rooms.empty? %>>
        <i class="fas fa-info-circle me-1"></i> Aún no has agregado tipos de habitaciones. Haz click en "Añadir habitación" para comenzar.
      </p>
    </div>
  </div>

  <!-- ═══════════════ 6. GALERÍAS EXISTENTES ═══════════════ -->
  <%= f.fields_for :establishment do |e| %>
    <% if e.object.galleries.any? %>
      <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-cofee-black), #5a3d1f); color: white; border-radius: 0.5rem 0.5rem 0 0;">
          <h5 class="mb-0 fw-bold"><i class="fas fa-images me-2"></i> 6. Galerías de imágenes</h5>
        </div>
        <div class="card-body p-4">
          <%= e.fields_for :galleries do |g| %>
            <div class="border rounded-3 p-3 mb-3" style="background: #fafafa;">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0"><i class="fas fa-folder-open me-2" style="color: var(--brand-cofee);"></i> <%= g.object.name %></h6>
                <div class="form-check">
                  <%= g.hidden_field :id %>
                  <%= g.check_box :_destroy, class: "form-check-input" %>
                  <%= g.label :_destroy, "Eliminar galería", class: "form-check-label text-danger small" %>
                </div>
              </div>

              <div class="mb-2">
                <%= g.label :name, "Nombre de la galería", class: "form-label fw-semibold" %>
                <div class="input-group">
                  <span class="input-group-text"><i class="fas fa-pencil-alt"></i></span>
                  <%= g.text_field :name, class: "form-control", value: g.object.name %>
                </div>
              </div>

              <div class="d-flex flex-wrap gap-3 mb-3">
                <% g.object.gallery_images.each do |img| %>
                  <div class="text-center" style="max-width: 150px;">
                    <% if img.persisted? && img.file.attached? %>
                      <%= image_tag img.file.variant(resize_to_limit: [200, 120]), class: "img-thumbnail rounded shadow-sm mb-1", loading: "lazy" %>
                    <% end %>
                    <%= g.fields_for :gallery_images, img do |gi| %>
                      <%= gi.hidden_field :id %>
                      <div class="form-check">
                        <%= gi.check_box :_destroy, class: "form-check-input" %>
                        <%= gi.label :_destroy, "Eliminar", class: "form-check-label text-danger small" %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>

              <div class="mt-2">
                <label class="form-label fw-semibold"><i class="fas fa-plus-circle me-1" style="color: var(--brand-green);"></i> Agregar más imágenes</label>
                <%= file_field_tag "gallery_uploads[#{g.object.id}][]",
                                   multiple: true,
                                   accept: "image/*",
                                   class: "form-control form-control-sm" %>
                <small class="text-muted">No reemplazan las existentes.</small>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- ═══════════════ 7. NUEVA GALERÍA ═══════════════ -->
  <div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-cofee), #6b5320); color: white; border-radius: 0.5rem 0.5rem 0 0;">
      <h5 class="mb-0 fw-bold"><i class="fas fa-folder-plus me-2"></i> 7. Agregar nueva galería</h5>
    </div>
    <div class="card-body p-4">
      <div id="galleries-container" data-gallery-target="container"></div>
      <div class="border rounded-3 p-3" style="background: #fafafa;">
        <div class="row g-2 align-items-end">
          <div class="col-md-5">
            <label class="form-label fw-semibold">Nombre de la galería</label>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-folder-open"></i></span>
              <input type="text" data-gallery-target="name" class="form-control" placeholder="Ej: Habitaciones, Exteriores...">
            </div>
          </div>
          <div class="col-md-5">
            <label class="form-label fw-semibold">Imágenes</label>
            <input type="file" data-gallery-target="files" multiple class="form-control" accept="image/jpeg,image/png,image/webp">
          </div>
          <div class="col-md-2 d-grid">
            <button type="button" class="btn btn-primary rounded-pill" data-action="gallery#addGallery">
              <i class="fas fa-plus me-1"></i> Agregar
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════ BOTONES ═══════════════ -->
  <div class="d-flex gap-2 mb-4">
    <%= f.submit "Actualizar hotel", class: "btn btn-primary btn-lg rounded-pill px-4 fw-bold", data: { disable_with: "Guardando..." } %>
    <%= link_to hotels_path, class: "btn btn-outline-secondary btn-lg rounded-pill px-4" do %>
      <i class="fas fa-times me-1"></i> Cancelar
    <% end %>
  </div>
<% end %>
