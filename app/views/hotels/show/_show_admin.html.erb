<div class="container my-5">
  <!-- Encabezado principal -->
  <div class="text-center mb-5">
    <h1 class="fw-bold text-primary">
      <i class="fas fa-hotel me-2"></i><%= hotel.establishment.name %>
    </h1>
    <p class="text-muted">Detalles completos del hotel</p>
  </div>

  <!-- Datos legales -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-primary text-white fw-bold">
      <i class="fas fa-file-contract me-2"></i> Datos legales y contacto
    </div>
    <div class="card-body">
      <p><strong>Razón social:</strong> <%= hotel.establishment.legal_info.business_name %></p>
      <p><strong>RUC / identificación fiscal:</strong> <%= hotel.establishment.legal_info.document_number %></p>
      <p><strong>Responsable:</strong> <%= hotel.establishment.legal_info.legal_representative %></p>
      <p><strong>Email:</strong> <%= hotel.establishment.legal_info.contact_email %></p>
      <p><strong>Teléfono:</strong> <%= hotel.establishment.legal_info.contact_phone %></p>
    </div>
  </div>

  <!-- Perfil -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-success text-white fw-bold">
      <i class="fas fa-info-circle me-2"></i> Perfil del hotel
    </div>
    <div class="card-body">
      <p><strong>Nombre público:</strong> <%= hotel.establishment.name %></p>
      <p><strong>Tipo de hotel:</strong>
        <span class="badge bg-info text-dark"><%= hotel_type_label(hotel.hotel_type) %></span>
      </p>
      <p><strong>Categoría:</strong>
        <span class="fs-5 text-warning"><%= "⭐" * hotel.stars.to_i %></span>
      </p>
    </div>
  </div>

  <!-- Ubicación -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-warning text-white fw-bold">
      <i class="fas fa-map-marker-alt me-2"></i> Ubicación
    </div>
    <div class="card-body">
      <p><strong>País:</strong> <%= hotel.establishment.country&.name %></p>
      <p><strong>Provincia:</strong> <%= hotel.establishment.province&.name %></p>
      <p><strong>Ciudad:</strong> <%= hotel.establishment.city&.name %></p>
      <p><strong>Dirección:</strong> <%= hotel.establishment.address %></p>
      <p><strong>Latitud:</strong> <%= hotel.establishment.latitude %></p>
      <p><strong>Longitud:</strong> <%= hotel.establishment.longitude %></p>

      <% if hotel.establishment.latitude.present? && hotel.establishment.longitude.present? %>
        <div id="map"
             data-controller="map-show"
             data-map-show-lat-value="<%= hotel.establishment.latitude %>"
             data-map-show-lng-value="<%= hotel.establishment.longitude %>"
             style="height: 400px; border-radius: 10px; box-shadow: 0 0 8px rgba(0,0,0,0.1);">
        </div>
      <% else %>
        <p class="text-muted fst-italic">Coordenadas del hotel no registradas.</p>
      <% end %>
    </div>
  </div>

  <!-- Galería -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-dark text-white fw-bold">
      <i class="fas fa-images me-2"></i> Galería
    </div>
    <div class="card-body">
      <% if hotel.establishment.galleries.any? %>
        <% hotel.establishment.galleries.each do |gallery| %>
          <h5 class="fw-bold mt-3"><i class="fas fa-folder-open me-2 text-primary"></i><%= gallery.name %></h5>
          <div class="d-flex flex-wrap">
            <% gallery.gallery_images.each do |gi| %>
              <% if gi.file.attached? %>
                <div class="m-2">
                  <%= image_tag gi.file.variant(resize_to_limit: [200, 200]),
                                class: "img-thumbnail shadow-sm rounded" %>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-muted fst-italic">No hay imágenes registradas.</p>
      <% end %>
    </div>
  </div>

  <!-- Unidades -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-info text-white fw-bold">
      <i class="fas fa-bed me-2"></i> Unidades del hotel
    </div>
    <div class="card-body">
      <% if hotel.units.any? %>
        <% hotel.units.each do |unit| %>
          <div class="border rounded p-3 mb-5 shadow-sm">
            <h5 class="fw-bold"><i class="fas fa-door-open me-2 text-primary"></i><%= unit.unit_type %></h5>
            <p><strong>Capacidad:</strong> <%= unit.capacity %> personas</p>

            <p><strong>Distribución de camas:</strong></p>
            <% if unit.bed_configuration.present? %>
              <ul>
                <% unit.bed_configuration.each do |tipo, cantidad| %>
                  <li><%= cantidad %> × <%= tipo %></li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-muted fst-italic">No especificada</p>
            <% end %>

            <p><strong>Precio base:</strong> $<%= number_with_precision(unit.base_price, precision: 2) %> / noche</p>

            <% if unit.unit_prices.any? %>
              <h6 class="mt-3 text-secondary"><i class="fas fa-calendar me-2"></i>Tarifas por temporada</h6>
              <ul>
                <% unit.unit_prices.each do |p| %>
                  <li><%= p.season.capitalize %>: $<%= number_with_precision(p.price, precision: 2) %></li>
                <% end %>
              </ul>
            <% end %>

            <!-- Disponibilidad (calendario) -->
            <!-- Disponibilidad (calendario) -->
            <div class="mt-4">
              <h6 class="text-secondary mb-2">
                <i class="fas fa-calendar-check me-2"></i>Disponibilidad
              </h6>

              <div class="card p-3 shadow-sm"
                   data-controller="fullcalendar-show"
                   data-fullcalendar-show-events-value="<%= unit.unit_availabilities
                                                                .select(:date, :available)
                                                                .map { |u| { title: u.available ? 'Disponible' : 'Ocupado',
                                                                             start: u.date.to_s,
                                                                             color: u.available ? 'green' : 'red' } }
                                                                .to_json %>">
                <div class="calendar-container" style="height: 400px;"></div>
              </div>

            </div>
            <% availabilities = unit.unit_availabilities.order(:date) %>
            <% if availabilities.any? %>
              <div class="mt-3">
                <h6 class="fw-bold text-secondary">
                  <i class="fas fa-list me-2"></i> Lista de disponibilidad
                </h6>
                <ul class="list-group small">
                  <% availabilities.each do |a| %>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                      <span><%= a.date.strftime("%A, %d de %B de %Y") %></span>
                      <span class="<%= a.available ? 'text-success' : 'text-danger' %> fw-bold">
                        <%= a.available ? "Disponible" : "Ocupado" %>
                      </span>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% else %>
              <p class="text-muted fst-italic mt-2">No hay fechas de disponibilidad registradas.</p>
            <% end %>

          </div>
        <% end %>
      <% else %>
        <p class="text-muted fst-italic">No hay unidades registradas para este hotel.</p>
      <% end %>
    </div>
  </div>

  <!-- Botones -->
  <div class="text-center mt-4">
    <%= link_to "Editar", edit_hotel_path(hotel), class: "btn btn-primary me-2 px-4" %>
    <%= link_to "Volver", hotels_path, class: "btn btn-outline-secondary px-4" %>
  </div>
</div>
<style>
    .calendar-container {
        min-height: 400px;
        border-radius: 10px;
        overflow: hidden;
    }

</style>