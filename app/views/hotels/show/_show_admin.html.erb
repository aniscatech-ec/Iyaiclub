<div class="container my-5">
  <!-- Encabezado principal -->
  <div class="text-center mb-5">
    <h1 class="fw-bold text-primary">
      <i class="fas fa-hotel me-2"></i><%= hotel.establishment.name %>
    </h1>
    <p class="text-muted">Detalles completos del hotel</p>
  </div>

  <!-- Datos legales -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-primary text-white fw-bold">
      <i class="fas fa-file-contract me-2"></i> Datos legales y contacto
    </div>
    <div class="card-body">
      <p><strong>Razón social:</strong> <%= hotel.establishment.legal_info.business_name %></p>
      <p><strong>RUC / identificación fiscal:</strong> <%= hotel.establishment.legal_info.document_number %></p>
      <p><strong>Responsable:</strong> <%= hotel.establishment.legal_info.legal_representative %></p>
      <p><strong>Email:</strong> <%= hotel.establishment.legal_info.contact_email %></p>
      <p><strong>Teléfono:</strong> <%= hotel.establishment.legal_info.contact_phone %></p>
    </div>
  </div>

  <!-- Perfil -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-success text-white fw-bold">
      <i class="fas fa-info-circle me-2"></i> Perfil del hotel
    </div>
    <div class="card-body">
      <p><strong>Nombre público:</strong> <%= hotel.establishment.name %></p>
      <p><strong>Tipo de hotel:</strong>
        <span class="badge bg-info text-dark"><%= hotel_type_label(hotel.hotel_type) %></span>
      </p>
      <p><strong>Categoría:</strong>
        <span class="fs-5 text-warning"><%= "⭐" * hotel.stars.to_i %></span>
      </p>
    </div>
  </div>

  <!-- Ubicación -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-warning text-white fw-bold">
      <i class="fas fa-map-marker-alt me-2"></i> Ubicación
    </div>
    <div class="card-body">
      <p><strong>País:</strong> <%= hotel.establishment.country&.name %></p>
      <p><strong>Provincia:</strong> <%= hotel.establishment.province&.name %></p>
      <p><strong>Ciudad:</strong> <%= hotel.establishment.city&.name %></p>
      <p><strong>Dirección:</strong> <%= hotel.establishment.address %></p>
      <p><strong>Latitud:</strong> <%= hotel.establishment.latitude %></p>
      <p><strong>Longitud:</strong> <%= hotel.establishment.longitude %></p>

      <% if hotel.establishment.latitude.present? && hotel.establishment.longitude.present? %>
        <div id="map"
             data-controller="map-show"
             data-map-show-lat-value="<%= hotel.establishment.latitude %>"
             data-map-show-lng-value="<%= hotel.establishment.longitude %>"
             style="height: 400px; border-radius: 10px; box-shadow: 0 0 8px rgba(0,0,0,0.1);">
        </div>
      <% else %>
        <p class="text-muted fst-italic">Coordenadas del hotel no registradas.</p>
      <% end %>
    </div>
  </div>


  <h2 class="my-4 text-primary fw-bold">Habitaciones</h2>

  <% if hotel.units.any? %>
    <div class="table-responsive">
      <table class="table table-striped table-hover align-middle shadow-sm">
        <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>Tipo de habitación</th>
          <th>Capacidad</th>
          <th>Precio base (USD)</th>
          <th>Distribución de camas</th>
          <th>Acciones</th>
        </tr>
        </thead>
        <tbody>
        <% hotel.units.each do |unit| %>
          <tr>
            <td><%= unit.id %></td>
            <td><%= unit.unit_type %></td>
            <td>
              <% if unit.capacity == 1 %>
                <%= unit.capacity %> (persona)
              <% elsif unit.capacity > 1 %>
                <%= unit.capacity %> (personas)
              <% else %>
                -
              <% end %>
            </td>
            <td><%= number_to_currency(unit.base_price, unit: "$", precision: 2) %></td>
            <td>
              <% if unit.bed_configuration.present? %>
                <% bed_config = JSON.parse(unit.bed_configuration) rescue unit.bed_configuration %>
                <ul class="mb-0">
                  <% bed_config.each do |tipo, cantidad| %>
                    <li><strong><%= tipo.capitalize %>:</strong> <%= cantidad %></li>
                  <% end if bed_config.is_a?(Hash) %>
                </ul>
              <% else %>
                <em>Sin datos</em>
              <% end %>
            </td>
            <td>
              <%= link_to 'Editar', edit_hotel_unit_path(hotel, unit), class: "btn btn-sm btn-outline-primary" %>
              <%= link_to 'Ver', hotel_unit_path(hotel, unit), class: "btn btn-sm btn-outline-primary" %>
              <%#= link_to 'Eliminar', unit, method: :delete, data: { confirm: '¿Estás seguro?' }, class: "btn btn-sm btn-outline-danger ms-1" %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info mt-3">
      No hay unidades registradas para este hotel todavía.
    </div>
  <% end %>

  <div class="mt-4">
    <%= link_to 'Agregar nueva habitación', new_hotel_unit_path(hotel), class: "btn btn-success" %>
  </div>


  <%= link_to "Galerías",establishment_galleries_path(hotel.establishment), class: "btn btn-secondary mt-3"%>


  <div class="gallery-list mt-3">
    <% if hotel.establishment.galleries.any? %>
      <% hotel.establishment.galleries.each do |gallery| %>
        <div class="card mb-3">
          <div class="card-header d-flex justify-content-between">
            <!--            <strong><%#= gallery.name %></strong>-->
            <%= link_to gallery.name, establishment_gallery_path(hotel.establishment, gallery), class: "btn btn-sm btn-info" %>
            <%#= link_to "Eliminar", establishment_gallery_path(hotel.establishment, gallery), data: { turbo_method: :delete, turbo_confirm: "¿Eliminar esta galería?" }, class: "btn btn-sm btn-danger" %>
          </div>
<!--          <div class="card-body d-flex flex-wrap gap-3">-->
            <%# gallery.gallery_images.each do |image| %>
<!--              <div class="position-relative">-->
                <%#= image_tag image.display_image, class: "rounded shadow" %>
                <%#= link_to "×", establishment_gallery_gallery_image_path(hotel.establishment, gallery, image), data: { turbo_method: :delete }, class: "btn btn-sm btn-danger position-absolute top-0 end-0" %>
<!--              </div>-->
            <%# end %>
<!--          </div>-->
        </div>
      <% end %>
    <% else %>
      <div class="alert alert-info mt-3">
        No hay galerías registradas para este hotel todavía.
      </div>
    <% end %>

  </div>

  <div class="mt-4">
    <%= link_to "Agregar galería", new_establishment_gallery_path(hotel.establishment), class: "btn btn-primary" %>
  </div>


  <!-- Botones -->
  <div class="text-center mt-4">
    <%= link_to "Editar", edit_hotel_path(hotel), class: "btn btn-primary me-2 px-4" %>
    <%= link_to "Volver", hotels_path, class: "btn btn-outline-secondary me-2 px-4" %>
    <%= link_to "Eliminar", hotels_path, class: "btn btn-danger px-4" %>
  </div>
</div>
<style>
    .calendar-container {
        min-height: 400px;
        border-radius: 10px;
        overflow: hidden;
    }

</style>