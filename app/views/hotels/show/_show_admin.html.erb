<div class="container my-5">

  <!-- Encabezado principal -->
  <div class="text-center mb-5">
    <h1 class="fw-bold text-primary"><i class="fas fa-hotel me-2"></i><%= hotel.establishment.name %></h1>
    <p class="text-muted">Detalles completos del hotel</p>
  </div>

  <!-- Datos legales -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-primary text-white fw-bold">
      <i class="fas fa-file-contract me-2"></i> Datos legales y contacto
    </div>
    <div class="card-body">
      <p><i class="fas fa-building me-2 text-secondary"></i><strong>Razón social:</strong> <%= hotel.establishment.legal_info.business_name %></p>
      <p><i class="fas fa-id-card me-2 text-secondary"></i><strong>RUC / identificación fiscal:</strong> <%= hotel.establishment.legal_info.document_number %></p>
      <p><i class="fas fa-user-tie me-2 text-secondary"></i><strong>Responsable:</strong> <%= hotel.establishment.legal_info.legal_representative %></p>
      <p><i class="fas fa-envelope me-2 text-secondary"></i><strong>Email:</strong> <%= hotel.establishment.legal_info.contact_email %></p>
      <p><i class="fas fa-phone me-2 text-secondary"></i><strong>Teléfono:</strong> <%= hotel.establishment.legal_info.contact_phone %></p>
    </div>
  </div>

  <!-- Perfil del hotel -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-success text-white fw-bold">
      <i class="fas fa-info-circle me-2"></i> Perfil del hotel
    </div>
    <div class="card-body">
      <p><i class="fas fa-signature me-2 text-secondary"></i><strong>Nombre público:</strong> <%= hotel.establishment.name %></p>
      <p><i class="fas fa-tag me-2 text-secondary"></i><strong>Tipo de hotel:</strong>
        <span class="badge bg-info text-dark"><%= hotel_type_label(hotel.hotel_type) %></span>
      </p>
      <p><i class="fas fa-star text-warning me-2"></i><strong>Categoría:</strong>
        <span class="fs-5 text-warning"><%= "⭐" * hotel.stars.to_i %></span>
      </p>
    </div>
  </div>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-warning text-white fw-bold">
      <i class="fas fa-info-circle me-2"></i> Ubicación
    </div>
    <div class="card-body">
      <p><i class="fas fa-signature me-2 text-secondary"></i><strong>País:</strong> <%= hotel.establishment.country.name if hotel.establishment.country %></p>
      <p><i class="fas fa-signature me-2 text-secondary"></i><strong>Provincia:</strong> <%= hotel.establishment.province.name if hotel.establishment.province %></p>
      <p><i class="fas fa-signature me-2 text-secondary"></i><strong>Ciudad:</strong> <%= hotel.establishment.city.name if hotel.establishment.city %></p>
      <p><i class="fas fa-signature me-2 text-secondary"></i><strong>Ubicación:</strong> <%= hotel.establishment.address if hotel.establishment.address %></p>

    </div>
  </div>

  <!-- Galería -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-dark text-white fw-bold">
      <i class="fas fa-images me-2"></i> Galería
    </div>
    <div class="card-body">
      <% if hotel.establishment.galleries.any? %>
        <% hotel.establishment.galleries.each do |gallery| %>
          <h5 class="fw-bold mt-3"><i class="fas fa-folder-open me-2 text-primary"></i><%= gallery.name %></h5>
          <div class="d-flex flex-wrap">
            <% gallery.gallery_images.each do |gi| %>
              <% if gi.file.attached? %>
                <div class="m-2">
                  <%= image_tag gi.file.variant(resize_to_limit: [200, 200]),
                                class: "img-thumbnail shadow-sm rounded" %>
                </div>
              <% else %>
                <p class="text-muted fst-italic">Sin imágenes</p>
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-muted fst-italic">No hay imágenes registradas en la galería.</p>
      <% end %>
    </div>
  </div>



  <!-- Botones -->
  <div class="text-center mt-4">
    <%= link_to "Editar", edit_hotel_path(hotel), class: "btn btn-primary me-2 px-4" %>
    <%= link_to "Volver", hotels_path, class: "btn btn-outline-secondary px-4" %>
  </div>

</div>
