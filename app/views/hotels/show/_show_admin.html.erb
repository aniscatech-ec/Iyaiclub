<div class="container my-5">

  <!-- HEADER ADMIN -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold text-primary mb-1">
        <i class="fas fa-hotel me-2"></i><%= hotel.establishment.name %>
      </h1>
      <small class="text-muted">
        Hotel ID: <%= hotel.id %> · Establecimiento ID: <%= hotel.establishment.id %>
      </small>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "Editar hotel", edit_hotel_path(hotel), class: "btn btn-outline-primary" %>
      <%= link_to "Galerías", establishment_galleries_path(hotel.establishment), class: "btn btn-outline-secondary" %>
      <%= link_to "Nueva habitación", new_hotel_unit_path(hotel), class: "btn btn-success" %>
    </div>
  </div>

  <!-- DATOS LEGALES -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-dark text-white fw-bold">
      <i class="fas fa-file-contract me-2"></i> Datos legales y contacto
    </div>
    <div class="card-body row">
      <div class="col-md-6">
        <p><strong>Razón social:</strong> <%= hotel.establishment.legal_info.business_name %></p>
        <p><strong>RUC / Identificación:</strong> <%= hotel.establishment.legal_info.document_number %></p>
        <p><strong>Representante legal:</strong> <%= hotel.establishment.legal_info.legal_representative %></p>
      </div>
      <div class="col-md-6">
        <p><strong>Email:</strong> <%= hotel.establishment.legal_info.contact_email %></p>
        <p><strong>Teléfono:</strong> <%= hotel.establishment.legal_info.contact_phone %></p>
      </div>
    </div>
  </div>

  <!-- PERFIL DEL HOTEL -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-success text-white fw-bold">
      <i class="fas fa-info-circle me-2"></i> Perfil del hotel
    </div>
    <div class="card-body">
      <p>
        <strong>Tipo:</strong>
        <span class="badge bg-info text-dark">
          <%= hotel_type_label(hotel.hotel_type) %>
        </span>
      </p>
      <p>
        <strong>Categoría:</strong>
        <span class="fs-5 text-warning"><%= "⭐" * hotel.stars.to_i %></span>
      </p>
    </div>
  </div>

  <!-- UBICACIÓN -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-warning text-dark fw-bold">
      <i class="fas fa-map-marker-alt me-2"></i> Ubicación
    </div>
    <div class="card-body">
      <p><strong>País:</strong> <%= hotel.establishment.country&.name %></p>
      <p><strong>Provincia:</strong> <%= hotel.establishment.province&.name %></p>
      <p><strong>Ciudad:</strong> <%= hotel.establishment.city&.name %></p>
      <p><strong>Dirección:</strong> <%= hotel.establishment.address %></p>

      <% if hotel.establishment.latitude.present? && hotel.establishment.longitude.present? %>
        <div
          id="map"
          data-controller="map-show"
          data-map-show-lat-value="<%= hotel.establishment.latitude %>"
          data-map-show-lng-value="<%= hotel.establishment.longitude %>"
          style="height: 300px; border-radius: 10px;">
        </div>
      <% else %>
        <p class="text-muted fst-italic">Coordenadas no registradas.</p>
      <% end %>
    </div>
  </div>

  <!-- HABITACIONES -->
  <h3 class="fw-bold text-primary mb-3">Habitaciones</h3>

  <% if hotel.units.any? %>
    <div class="table-responsive mb-4">
      <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>Tipo</th>
          <th>Capacidad</th>
          <th>Precio base</th>
          <th>Camas</th>
          <th>Acciones</th>
        </tr>
        </thead>
        <tbody>
        <% hotel.units.each do |unit| %>
          <tr>
            <td><%= unit.id %></td>
            <td><%= unit.unit_type %></td>
            <td><%= unit.capacity %></td>
            <td><%= number_to_currency(unit.base_price, unit: "$") %></td>
            <td>
              <% if unit.bed_configuration.present? %>
                <% bed_config = JSON.parse(unit.bed_configuration) rescue unit.bed_configuration %>
                <% if bed_config.is_a?(Hash) %>
                  <ul class="mb-0">
                    <% bed_config.each do |tipo, cantidad| %>
                      <li><%= tipo.capitalize %>: <%= cantidad %></li>
                    <% end %>
                  </ul>
                <% else %>
                  <%= bed_config %>
                <% end %>
              <% else %>
                <em>Sin datos</em>
              <% end %>
            </td>
            <td>
              <%= link_to "Editar", edit_hotel_unit_path(hotel, unit), class: "btn btn-sm btn-outline-primary" %>
              <%= link_to "Ver", hotel_unit_path(hotel, unit), class: "btn btn-sm btn-outline-secondary" %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info">No hay habitaciones registradas.</div>
  <% end %>

  <!-- GALERÍAS -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-secondary text-white fw-bold">
      <i class="fas fa-images me-2"></i> Galerías
    </div>
    <div class="card-body">
      <% if hotel.establishment.galleries.any? %>
        <% hotel.establishment.galleries.each do |gallery| %>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <strong><%= gallery.name %></strong>
            <%= link_to "Administrar",
                        establishment_gallery_path(hotel.establishment, gallery),
                        class: "btn btn-sm btn-outline-info" %>
          </div>
        <% end %>
      <% else %>
        <div class="alert alert-info">No hay galerías registradas.</div>
      <% end %>

      <%= link_to "Agregar galería",
                  new_establishment_gallery_path(hotel.establishment),
                  class: "btn btn-primary mt-3" %>
    </div>
  </div>

  <!-- ACCIONES FINALES -->
  <div class="text-center mt-5">
    <%= link_to "Volver", hotels_path, class: "btn btn-outline-secondary me-2 px-4" %>
    <%= link_to "Eliminar hotel",
                hotel_path(hotel),
                method: :delete,
                data: { confirm: "⚠️ Esta acción es irreversible. ¿Eliminar hotel?" },
                class: "btn btn-danger px-4" %>
  </div>

</div>
