<% @hotel = hotel %>

<div class="hybrid-hotel-show">

  <!-- Hero -->
  <section class="hotel-hero mb-5">
    <div class="hero-container position-relative">
      <% est = hotel.establishment %>

      <% cover_image = est.galleries.joins(:gallery_images)
                          .find_by(gallery_images: { is_cover: true })&.gallery_images
        &.find_by(is_cover: true)&.file %>

      <% if cover_image&.attached? %>
        <%= image_tag cover_image, class: "w-100 hero-image", height: 300 %>
      <% elsif est.galleries.any? && est.galleries.first.gallery_images.any? %>
        <% first_image = est.galleries.first.gallery_images.first.file %>
        <%= image_tag first_image, class: "w-100 hero-image", height: 300 if first_image.attached? %>
      <% else %>
        <%= image_tag "hotel-placeholder.jpg", class: "w-100 hero-image", height: 300 %>
      <% end %>

      <div class="hero-content position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end">
        <div class="container">
          <h1 class="text-white display-5 fw-light mb-2">
            <%= @hotel.establishment.name %>
          </h1>
          <div class="text-white-80 mb-3">
            <i class="bi bi-geo-alt me-1"></i>
            <%= @hotel.establishment.city&.name || "No especificado" %>,
            <%= @hotel.establishment.country&.name || "No especificado" %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">

    <!-- INFORMACIÓN RÁPIDA -->
    <section class="quick-info-cards mb-5">
      <div class="row g-3">

        <div class="col-12 col-sm-6 col-md-3">
          <div class="info-card text-center p-3 border rounded">
            <i class="bi bi-geo-alt text-primary fs-4 mb-2"></i>
            <div class="fw-medium">Ubicación</div>
            <div class="text-muted small">
              <%= @hotel.establishment.address.presence || "No especificada" %>
            </div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
          <div class="info-card text-center p-3 border rounded">
            <i class="bi bi-clock text-primary fs-4 mb-2"></i>
            <div class="fw-medium">Check-in / Check-out</div>
            <div class="text-muted small">
              <%= @hotel.check_in_time&.strftime("%H:%M") || "No definido" %> /
              <%= @hotel.check_out_time&.strftime("%H:%M") || "No definido" %>
            </div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
          <div class="info-card text-center p-3 border rounded">
            <i class="bi bi-telephone text-primary fs-4 mb-2"></i>
            <div class="fw-medium">Teléfono</div>
            <div class="text-muted small">No disponible</div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
          <div class="info-card text-center p-3 border rounded">
            <i class="bi bi-star text-primary fs-4 mb-2"></i>
            <div class="fw-medium">Categoría</div>
            <div class="text-muted small">
              <%= @hotel.stars || 0 %> Estrellas
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- DESCRIPCIÓN -->
    <section class="description-section mb-5">
      <h3 class="h5 fw-normal text-dark mb-3">Descripción</h3>
      <p class="text-muted lh-lg">
        <%= @hotel.establishment.long_description.presence || "No existe descripción para este hotel." %>
      </p>
    </section>

    <!-- COMODIDADES -->
    <section class="amenities-section mb-5">
      <h3 class="h5 fw-normal text-dark mb-4">Comodidades</h3>
      <div class="row g-3">
        <% hotel.establishment.amenities.limit(3).each do |amenity| %>
          <div class="col-6 col-sm-4 col-md-3">
            <div class="amenity-item text-center p-3 border rounded">
              <% if amenity.custom_icon.attached? &&
                    amenity.custom_icon.content_type == 'image/svg+xml' %>
                <% svg = amenity.custom_icon.download.gsub(/fill="[^"]*"/, '') %>
                <%= raw svg.gsub('<svg', '<svg width="32" height="32" fill="#28a745"') %>
              <% else %>
                <i class="bi bi-check-circle text-success me-1"></i>
              <% end %>
              <div class="small"><%= amenity.name %></div>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- GALERÍA -->
    <section class="gallery-section mt-5 pt-5 border-top">
      <h3 class="h5 fw-normal text-dark mb-4">Galería</h3>
      <div class="row g-3">
        <% images = hotel.establishment.galleries.flat_map(&:gallery_images) %>

        <% images.first(4).each do |img| %>
          <% if img.file.attached? %>
            <div class="col-6 col-md-3">
              <%= image_tag img.file.variant(resize_to_limit: [600, 600]),
                            class: "w-100 gallery-image rounded" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>

    <!-- UBICACIÓN -->
    <section class="location-section mt-5 pt-5 border-top">
      <h3 class="h5 fw-normal text-dark mb-4">Ubicación</h3>
      <div class="card border-light shadow-sm">
        <div class="card-body text-center py-5">
          <i class="bi bi-geo-alt fs-1 text-primary mb-3"></i>
          <p class="text-muted">
            <%= @hotel.establishment.address.presence || "Ubicación no disponible" %>
          </p>
        </div>
      </div>
    </section>

  </div>
</div>
