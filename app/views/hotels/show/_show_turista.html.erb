<%# end %>



<% if phone.present? %>
  <div class="whatsapp-circle-wrapper">
    <svg viewBox="0 0 100 100" class="whatsapp-circle-text">
      <defs>
        <path
          id="circlePath"
          d="M50,50 m-38,0 a38,38 0 1,1 76,0 a38,38 0 1,1 -76,0"
          />
      </defs>

      <text>
        <textPath href="#circlePath">
          Reservar ahora · Reservar ahora ·
        </textPath>
      </text>
    </svg>

    <a
      href="https://wa.me/<%= phone %>?text=<%= CGI.escape(message) %>"
      target="_blank"
      rel="noopener"
      class="floating-whatsapp-btn"
      aria-label="Reservar por WhatsApp"
      data-controller="booking-request"
      data-booking-request-establishment-id-value="<%= hotel.establishment.id %>"
      data-booking-request-source-value="whatsapp"
    >
      <i class="bi bi-whatsapp"></i>
    </a>
  </div>
<% end %>



<div class="hybrid-hotel-show">

  <!-- HERO -->
  <section class="hotel-hero mb-5">
    <div class="container">

      <% cover_image = est.galleries.joins(:gallery_images)
                          .find_by(gallery_images: { is_cover: true })&.gallery_images
        &.find_by(is_cover: true)&.file %>

      <% if cover_image&.attached? %>
        <%= image_tag cover_image, class: "w-100 hero-image rounded-4" %>
      <% else %>
        <%= image_tag "hotel-placeholder.jpg", class: "w-100 hero-image rounded-4" %>
      <% end %>

      <div class="mt-3">
        <h1 class="fw-light"><%= est.name %></h1>
        <div class="text-muted">
          <i class="bi bi-geo-alt"></i>
          <%= est.city&.name %>, <%= est.country&.name %>
        </div>
      </div>

    </div>
  </section>

  <div class="container">

    <!-- INFO RÁPIDA -->
    <section class="quick-info-cards mb-5">
      <div class="row g-3">

        <div class="col-6 col-md-3">
          <div class="info-card">
            <i class="bi bi-clock"></i>
            <div>
              <strong>Check-in / out</strong>
              <div>
                <%= hotel.check_in_time&.strftime("%H:%M") || "-" %> /
                <%= hotel.check_out_time&.strftime("%H:%M") || "-" %>
              </div>
            </div>
          </div>
        </div>

        <div class="col-6 col-md-3">
          <div class="info-card">
            <i class="bi bi-telephone"></i>
            <div>
              <strong>Contacto</strong>
              <div><%= phone || "No disponible" %></div>
            </div>
          </div>
        </div>

        <div class="col-6 col-md-3">
          <div class="info-card">
            <i class="bi bi-star"></i>
            <div>
              <strong>Categoría</strong>
              <div><%= hotel.stars || 0 %> estrellas</div>
            </div>
          </div>
        </div>

        <div class="col-6 col-md-3">
          <div class="info-card">
            <i class="bi bi-geo-alt"></i>
            <div>
              <strong>Dirección</strong>
              <div><%= est.address.presence || "No definida" %></div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- DESCRIPCIÓN -->
    <section class="mb-5">
      <h3 class="h5 mb-3">Descripción</h3>
      <p class="text-muted lh-lg">
        <%= est.long_description.presence || "No existe descripción disponible." %>
      </p>
    </section>

    <!-- GALERÍA -->
    <section class="gallery-section mt-5 pt-5 border-top">
      <h3 class="h5 mb-4">Galería</h3>

      <% images = est.galleries.flat_map(&:gallery_images)
                     .select { |img| img.file.attached? } %>

      <div class="row g-3">

        <% images.first(3).each do |img| %>
          <div class="col-6 col-md-3">
            <%= image_tag img.file.variant(resize_to_limit: [600,600]),
                          class: "w-100 gallery-image" %>
          </div>
        <% end %>

        <% if images.size > 3 %>
          <div class="col-6 col-md-3">
            <div
              class="gallery-more-card"
              data-bs-toggle="modal"
              data-bs-target="#galleryModal">
              <i class="bi bi-images"></i>
              <div>Ver todas</div>
              <small><%= images.size %> fotos</small>
            </div>
          </div>
        <% end %>

      </div>
    </section>

  </div>
</div>

<!-- MODAL GALERÍA -->
<div class="modal fade" id="galleryModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content rounded-4">
      <div class="modal-header border-0">
        <h5 class="modal-title">Galería completa</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <div class="row g-3">
          <% images.each do |img| %>
            <div class="col-6 col-md-3">
              <%= image_tag img.file.variant(resize_to_limit: [900,900]),
                            class: "w-100 modal-gallery-image" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
    .hero-image {
        max-height: 420px;
        width: 100%;
        height: auto;
    }

    .info-card {
        display: flex;
        gap: 12px;
        padding: 14px;
        border-radius: 16px;
        background: #f8f9fb;
    }

    .info-card i {
        font-size: 1.4rem;
        color: #0d6efd;
    }

    .gallery-image,
    .modal-gallery-image {
        border-radius: 18px;
        transition: transform .3s ease;
    }

    .gallery-image:hover {
        transform: scale(1.04);
    }

    .gallery-more-card {
        height: 100%;
        border-radius: 18px;
        background: linear-gradient(135deg, #f1f3f5, #e9ecef);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        text-align: center;
        font-weight: 500;
    }

    .gallery-more-card i {
        font-size: 2rem;
        margin-bottom: 8px;
    }


    .whatsapp-circle-wrapper {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 110px;
        height: 110px;
        z-index: 9999;
    }

    /* TEXTO CIRCULAR */
    .whatsapp-circle-text {
        position: absolute;
        inset: 0;
        fill: #00ff00;
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        pointer-events: none; /* no molesta el click */
    }

    /* BOTÓN CENTRAL */
    .floating-whatsapp-btn {
        position: absolute;
        inset: 22px;
        background-color: #25D366;
        color: #fff;
        border-radius: 50%;

        display: flex;
        align-items: center;
        justify-content: center;

        font-size: 2rem;
        text-decoration: none;

        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
        z-index: 2;
    }

    /* MOBILE: ocultamos el texto circular */
    @media (max-width: 576px) {
        /*.whatsapp-circle-text {*/
        /*    display: none;*/
        /*}*/
    }
</style>
