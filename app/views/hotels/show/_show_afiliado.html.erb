<div class="container my-5">

  <!-- ================= HEADER ================= -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-1">
        <i class="fas fa-hotel text-primary me-2"></i>
        <%= hotel.establishment.name %>
      </h1>

    </div>

    <div>
      <%= link_to edit_hotel_path(hotel), class: "btn btn-outline-primary me-2" do %>
        <i class="fas fa-edit me-1"></i> Editar
      <% end %>

      <%= link_to hotels_path, class: "btn btn-outline-secondary" do %>
        <i class="fas fa-arrow-left me-1"></i> Volver
      <% end %>
    </div>
  </div>

  <!-- ================= DATOS LEGALES ================= -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-primary text-white fw-bold">
      <i class="fas fa-file-contract me-2"></i> Datos legales y contacto
    </div>

    <div class="card-body row g-3">
      <div class="col-md-6">
        <strong>Razón social</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.legal_info.business_name %>
        </p>
      </div>

      <div class="col-md-6">
        <strong>RUC / Identificación fiscal</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.legal_info.document_number %>
        </p>
      </div>

      <div class="col-md-6">
        <strong>Representante legal</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.legal_info.legal_representative %>
        </p>
      </div>

      <div class="col-md-6">
        <strong>Email de contacto</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.legal_info.contact_email %>
        </p>
      </div>

      <div class="col-md-6">
        <strong>Teléfono</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.legal_info.contact_phone %>
        </p>
      </div>
    </div>
  </div>

  <!-- ================= PERFIL DEL HOTEL ================= -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-success text-white fw-bold">
      <i class="fas fa-info-circle me-2"></i> Perfil del hotel
    </div>

    <div class="card-body row g-3">
      <div class="col-md-4">
        <strong>Nombre público</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.name %>
        </p>
      </div>

      <div class="col-md-4">
        <strong>Tipo de hotel</strong>
        <p class="text-muted mb-0">
          <%= hotel_type_label(hotel.hotel_type) %>
        </p>
      </div>
      <div class="col-md-4">
        <strong>Categoría</strong>
        <p class="text-muted mb-0">
          <%= "⭐" * hotel.stars.presence.to_i || "No definido" %>
        </p>
      </div>
    </div>
  </div>

  <!-- ================= UBICACIÓN ================= -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-warning text-white fw-bold">
      <i class="fas fa-map-marker-alt me-2"></i> Ubicación
    </div>

    <div class="card-body row g-3">
      <div class="col-md-3">
        <strong>País</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.country&.name || "No definido" %>
        </p>
      </div>

      <div class="col-md-3">
        <strong>Provincia</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.province&.name || "No definido" %>
        </p>
      </div>

      <div class="col-md-3">
        <strong>Ciudad</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.city&.name || "No definido" %>
        </p>
      </div>
      <div class="col-md-3">
        <strong>Dirección</strong>
        <p class="text-muted mb-0">
          <%= hotel.establishment.address.presence || "No definido" %>
        </p>
      </div>

      <% if hotel.establishment.latitude.present? && hotel.establishment.longitude.present? %>
        <div
          id="map"
          data-controller="map-show"
          data-map-show-lat-value="<%= hotel.establishment.latitude %>"
          data-map-show-lng-value="<%= hotel.establishment.longitude %>"
          style="height: 300px; border-radius: 10px;">
        </div>
      <% else %>
        <p class="text-muted fst-italic">Coordenadas no registradas.</p>
      <% end %>

    </div>

  </div>

  <!-- HABITACIONES -->

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-secondary text-white fw-bold d-flex justify-content-between align-items-center">
    <span>
      <i class="fa-solid fa-bed me-2"></i> Habitaciones
    </span>
      <%= link_to new_hotel_unit_path(hotel),
                  class: "btn btn-sm btn-light" do %>
        <i class="fas fa-plus me-1"></i> Nueva habitación
      <% end %>
    </div>
    <div class="card-body">

      <% if hotel.units.any? %>
        <div class="table-responsive mb-4">
          <table class="table table-hover align-middle">
            <thead>
            <tr>
<!--              <th>ID</th>-->
              <th>Tipo</th>
              <th>Capacidad</th>
              <th>Precio base</th>
              <th>Camas</th>
              <th>Acciones</th>
            </tr>
            </thead>
            <tbody>
            <% hotel.units.each do |unit| %>
              <tr>
<!--                <td><%#= unit.id %></td>-->
                <td><%= unit.unit_type %></td>
                <td><%= unit.capacity %></td>
                <td><%= number_to_currency(unit.base_price, unit: "$") %></td>
                <td>
                  <% if unit.bed_configuration.present? %>
                    <% bed_config = JSON.parse(unit.bed_configuration) rescue unit.bed_configuration %>
                    <% if bed_config.is_a?(Hash) %>
                      <ul class="mb-0">
                        <% bed_config.each do |tipo, cantidad| %>
                          <li><%= tipo.capitalize %>: <%= cantidad %></li>
                        <% end %>
                      </ul>
                    <% else %>
                      <%= bed_config %>
                    <% end %>
                  <% else %>
                    <em>Sin datos</em>
                  <% end %>
                </td>
                <td>
                  <%#= link_to "Editar", edit_hotel_unit_path(hotel, unit), class: "btn btn-sm btn-outline-primary" %>
                  <%= link_to edit_hotel_unit_path(hotel, unit), class: "btn btn-outline-warning me-2" do %>
                    <i class="fas fa-edit me-1"></i>
                  <% end %>
                  <%#= link_to "Ver", hotel_unit_path(hotel, unit), class: "btn btn-sm btn-outline-secondary" %>
                  <%= link_to hotel_unit_path(hotel, unit), class: "btn btn-outline-info me-2" do %>
                    <i class="fas fa-eye me-1"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="alert alert-info">No hay habitaciones registradas.</div>
      <% end %>
    </div>
  </div>
  <!-- ================= GALERÍAS ================= -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
    <span>
      <i class="fas fa-images me-2"></i> Galerías
    </span>

      <%= link_to new_establishment_gallery_path(hotel.establishment),
                  class: "btn btn-sm btn-light" do %>
        <i class="fas fa-plus me-1"></i> Nueva galería
      <% end %>
    </div>

    <div class="card-body">
      <% if hotel.establishment.galleries.any? %>

        <% hotel.establishment.galleries.each do |gallery| %>
          <% images = gallery.gallery_images.select { |i| i.file.attached? } %>

          <div class="mb-4">
            <h6 class="fw-bold mb-2">
              <i class="fas fa-folder-open text-primary me-1"></i>
              <%= link_to gallery.name,
                          establishment_gallery_path(hotel.establishment, gallery),
                          class: "text-decoration-none" %>
            </h6>

            <div class="gallery-grid d-flex flex-wrap gap-2">
              <% images.each_with_index do |image, index| %>
                <div class="gallery-image-wrapper"
                     <% if index == 1 && images.count > 2 %>
                     data-more="+<%= images.count - 2 %> fotos"
                     <% end %>>

                  <%= image_tag image.file.variant(resize_to_limit: [180, 180]),
                                class: "gallery-image rounded shadow-sm border" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

      <% else %>
        <div class="alert alert-info mb-0">
          No hay galerías registradas para este hotel.
        </div>
      <% end %>
    </div>
  </div>


</div>
