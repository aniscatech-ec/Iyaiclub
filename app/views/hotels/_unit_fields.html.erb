<div class="card p-3 mb-4 shadow-sm unit-instance">
  <h4 class="mb-3">Información general</h4>

  <div class="mb-3">
    <%= f.label :unit_type, "Tipo de unidad" %>
    <%= f.text_field :unit_type, class: "form-control", placeholder: "Ej: Simple, Doble, Suite, Casa entera" %>
  </div>

  <div class="row">
    <div class="col-md-4 mb-3">
      <%= f.label :capacity, "Capacidad de personas" %>
      <%= f.number_field :capacity, class: "form-control" %>
    </div>

    <div class="col-md-4" data-controller="bed">
      <label class="form-label">Distribución de camas</label>
      <div data-bed-target="container"></div>

      <template data-bed-target="template">
        <div class="row mb-2 bed-row">
          <input type="text"
                 name="<%= f.object_name %>[bed_configuration_keys][]"
                 class="form-control"
                 placeholder="Tipo de cama">

          <input type="number"
                 name="<%= f.object_name %>[bed_configuration_values][]"
                 class="form-control"
                 min="0"
                 placeholder="Cantidad">

          <div class="col-md-2 d-flex align-items-center">
            <button class="btn btn-sm btn-danger" data-action="bed#removeField">✖</button>
          </div>
        </div>
      </template>

      <button type="button" class="btn btn-sm btn-outline-primary mt-2" data-action="bed#addField">
        + Agregar cama
      </button>
    </div>

    <div class="col-md-4 mb-3">
      <%= f.label :base_price, "Precio base por noche (USD)" %>
      <%= f.number_field :base_price, step: 0.01, class: "form-control" %>
    </div>
  </div>

  <div class="card p-3 mb-4 shadow-sm">
    <h4 class="mb-3">Tarifas por temporada</h4>
    <%= f.fields_for :unit_prices do |price_form| %>
      <div class="row mb-2">
        <div class="col-md-6">
          <%= price_form.select :season,
                                [["Alta", "high"], ["Baja", "low"], ["Especial", "special"]],
                                {}, class: "form-select" %>
        </div>
        <div class="col-md-6">
          <%= price_form.number_field :price, step: 0.01, class: "form-control" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- === Calendario de disponibilidad === -->
  <div class="card p-3 mb-4 shadow-sm"
       data-controller="fullcalendarreg"
       data-fullcalendarreg-events-value="<%= f.object.unit_availabilities&.map { |u| { id: u.date.to_s, title: u.available ? 'Disponible' : 'No disponible', start: u.date.to_s, color: u.available ? 'green' : 'red' } }.to_json || '[]' %>">

    <div data-fullcalendarreg-target="calendar"></div>
    <div data-fullcalendarreg-target="availabilitiesContainer"></div>
  </div>

  <button type="button" class="btn btn-danger mt-2" data-action="units#removeUnit">Eliminar unidad</button>
</div>
