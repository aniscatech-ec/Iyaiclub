<div class="row">
  <% if hotels.any? %>
    <% hotels.each do |hotel| %>
      <% est = hotel.establishment %>
      <div class="col-12 col-md-6 col-lg-4 mb-4">
        <div class="card hotel-card shadow-sm border-0 h-100 rounded-4 overflow-hidden transition-all">

          <!-- Imagen principal con badges superpuestos -->
          <div class="position-relative">
            <% cover_image = est.galleries.joins(:gallery_images).find_by(gallery_images: { is_cover: true })&.gallery_images&.find_by(is_cover: true)&.file %>

            <% if cover_image&.attached? %>
              <%= image_tag cover_image, class: "card-img-top hotel-image", height: 300 %>
            <% elsif est.galleries.any? && est.galleries.first.gallery_images.any? %>
              <% first_image = est.galleries.first.gallery_images.first.file %>
              <%= image_tag first_image, class: "card-img-top hotel-image", height: 300 if first_image.attached? %>
            <% else %>
              <%= image_tag "hotel-placeholder.jpg", class: "card-img-top hotel-image", height: 300 %>
            <% end %>

            <!-- Badges superpuestos -->
            <div class="position-absolute top-0 start-0 p-2">
              <span class="badge bg-success bg-opacity-90 text-white fs-7">
                <i class="bi bi-check-circle-fill me-1"></i>
                Activo
              </span>
            </div>
            <div class="position-absolute top-0 end-0 p-2">
              <span class="badge bg-primary bg-opacity-90 text-white fs-7">
                <i class="bi bi-building me-1"></i>
                <%= hotel.hotel_type.present? ? hotel.hotel_type.humanize : "Hotel" %>
              </span>
            </div>

            <!-- Precio por noche -->
            <div class="position-absolute bottom-0 end-0 m-2">
              <span class="badge bg-dark bg-opacity-75 text-white fs-6">
                $<%= est.price_per_night || "150" %>
              </span>
            </div>
          </div>

          <div class="card-body p-3 d-flex flex-column">
            <!-- Información principal -->
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h6 class="fw-bold text-dark mb-0 flex-grow-1 me-2"><%= est.name %></h6>
              <div class="text-success">
                <i class="bi bi-star-fill"></i>
                <span class="fw-bold">4.5/5</span>
              </div>
            </div>

            <!-- Ubicación -->
            <div class="d-flex align-items-center mb-2">
              <i class="bi bi-geo-alt text-muted me-2"></i>
              <small class="text-muted">
                <%= est.city&.name || "Ciudad no definida" %>,
                <%= est.city&.province&.name || "Provincia no definida" %>
              </small>
            </div>

            <!-- Rating con estrellas -->
            <div class="mb-2">
              <div class="text-warning mb-1">
                <% stars = hotel.stars || 3 %>
                <% 5.times do |i| %>
                  <i class="bi bi-star-fill <%= i < stars ? 'text-warning' : 'text-light' %>"></i>
                <% end %>
                <small class="text-muted ms-1">(<%= stars %> estrellas)</small>
              </div>
            </div>

            <!-- Tipo de hotel y estado -->
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="badge bg-light text-dark border small">
                <i class="bi bi-door-closed me-1"></i><%= hotel.hotel_type.present? ? hotel.hotel_type.humanize : "Hotel" %>
              </span>
              <span class="badge bg-success bg-opacity-10 text-success border-0 small">
                <i class="bi bi-check-circle me-1"></i>Disponible
              </span>
            </div>

            <!-- Estadísticas del afiliado -->
            <div class="affiliate-stats border-top pt-2 mb-3">
              <div class="row small text-muted">
                <div class="col-6">
                  <i class="bi bi-calendar-check me-1"></i>
                  8 reservas hoy
                </div>
                <div class="col-6 text-end">
                  <i class="bi bi-cash-coin me-1"></i>
                  32 esta semana
                </div>
              </div>
            </div>

            <!-- Comodidades destacadas -->
            <div class="amenities-preview mb-3">
              <div class="d-flex flex-wrap gap-1">
                <% est.amenities.limit(3).each do |amenity| %>
                  <span class="badge bg-light text-dark border small">
                    <i class="bi bi-check-circle text-success me-1"></i><%= amenity.name %>
                  </span>
                <% end %>
                <% if est.amenities.empty? %>
                  <span class="badge bg-light text-dark border small">
                    <i class="bi bi-ban text-primary me-1"></i>No se han registrado comodidades
                  </span>
                <% end %>
                <% if est.amenities.size > 3 %>
                  <span class="badge bg-secondary bg-opacity-10 text-secondary border-0 small">
                    +<%= est.amenities.size - 3 %> más
                  </span>
                <% end %>
              </div>
            </div>

            <!-- Información adicional -->
            <div class="additional-info border-top pt-2 mb-3">
              <div class="row small text-muted">
                <div class="col-6">
                  <i class="bi bi-clock me-1"></i>
                  Check-in: 15:00
                </div>
                <div class="col-6 text-end">
                  <% if hotel.units.any? %>
                    <i class="bi bi-door-open me-1"></i>
                    <%= hotel.units.count %> habitaciones
                  <% else %>
                    <span class="text-danger">
                      <i class="bi bi-exclamation-triangle me-1"></i>Sin habitaciones
                    </span>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Acciones del afiliado -->
            <div class="mt-auto">
              <div class="d-grid gap-2">

                <div class="btn-group w-100" role="group">
                  <%= link_to hotel, class: "btn btn-info btn-sm" do %>
                    <i class="fa-solid fa-eye"></i>
                  <% end %>
                  <%= link_to edit_hotel_path(hotel), class: "btn btn-warning btn-sm" do %>
                    <i class="fa-solid fa-pen-to-square"></i>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="col-12 text-center my-5 py-5">
      <div class="text-muted">
        <i class="bi bi-building display-4 opacity-50"></i>
        <h5 class="mt-3 fw-semibold">No tienes hoteles registrados</h5>
        <p class="mb-3 text-muted">Comienza agregando tu primer hotel para gestionar reservas</p>
        <button class="btn btn-primary rounded-pill">
          <i class="bi bi-plus-circle me-2"></i>Registrar Primer Hotel
        </button>
      </div>
    </div>
  <% end %>
</div>



<style>
    .hotel-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .hotel-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15) !important;
    }

    .hotel-image {
        transition: transform 0.3s ease;
        /*height: 200px;*/
        /*object-fit: cover;*/
        width: 100%;
    }

    .hotel-card:hover .hotel-image {
        transform: scale(1.03);
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .fs-7 {
        font-size: 0.8rem;
    }

    /* Efecto sutil al hover para hoteles */
    .hotel-card:hover {
        border-color: var(--bs-primary);
    }

    /* Estrellas de rating */
    .bi-star-fill.text-warning {
        color: #ffc107 !important;
    }

    .bi-star-fill.text-light {
        color: #e4e5e9 !important;
    }

    /* Botones de acción */
    .btn-group .btn {
        flex: 1;
    }

    /* Estadísticas del afiliado */
    .affiliate-stats {
        font-size: 0.8rem;
    }

    /* Asegurar que las tarjetas tengan la misma altura */
    .card-body.d-flex {
        min-height: 320px;
    }
</style>