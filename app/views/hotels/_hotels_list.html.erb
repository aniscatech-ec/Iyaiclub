<!-- _hotels_list.html.erb -->
<!-- Meta (usado por Stimulus para obtener total y rango) -->
<div id="hotels-meta"
     data-total="<%= hotels.total_count %>"
     data-offset="<%= hotels.offset_value %>"
     data-length="<%= hotels.length %>"></div>

<div class="row g-4">
  <% hotels.each do |hotel| %>
    <div class="col-lg-4 col-md-6 hotel-card">
      <%= link_to hotel_path(hotel), class: "card h-100 shadow-sm border-0 text-decoration-none text-dark d-block" do %>
        <% if hotel.establishment.galleries.any? && hotel.establishment.galleries.first.gallery_images.any? %>
          <% first_image = hotel.establishment.galleries.first.gallery_images.first.file %>
          <%= image_tag first_image, height: 300, class: "card-img-top" if first_image.attached? %>
        <% else %>
          <%= image_tag "logo-ant.jpg", height: 300, class: "card-img-top" %>
        <% end %>
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= hotel.establishment.name %></h5>
          <p class="text-muted mb-2"><i class="bi bi-geo-alt"></i>
            <%= hotel.establishment&.city&.name.presence || "-" %>, <%= hotel.establishment&.country&.name.presence || "-" %>
          </p>

          <p><span><%= "⭐" * hotel.stars.to_i %></span><br>
            <small class="text-muted"><%= hotel.hotel_type.present? ? hotel.hotel_type.humanize : "Sin categoría" %></small>
          </p>

          <p class="mb-2">
            <% hotel.establishment.amenities.limit(3).each do |amenity| %>
              <span class="badge bg-secondary"><%= amenity.name %></span>
            <% end %>
          </p>

          <p class="fw-bold text-success">$<%= hotel.establishment.price_per_night %> / noche</p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<div class="d-flex justify-content-center mt-4">
  <!-- IMPORTANTE: pasar params actuales para mantener filtros entre páginas -->
  <%= paginate hotels%>
</div>
