<p>Hola <strong><%= @name %></strong>,</p>
<p>Tu ticket para <strong><%= @event_name %></strong> ha sido acreditado. El pago por transferencia fue confirmado por el vendedor.</p>

<!-- Ticket card -->
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin: 24px 0;">
  <tr>
    <td align="center" style="border: 2px solid #34c759; border-radius: 10px; padding: 20px; text-align: center;">
      <p style="margin: 0 0 4px 0; font-size: 13px; color: #666;">Código de Ticket</p>
      <p style="margin: 0 0 16px 0; font-size: 24px; font-weight: bold; color: #2E7D32;"><%= @ticket.ticket_code %></p>

      <p style="margin: 0 0 4px 0; font-size: 13px; color: #666;">Tu número de rifa</p>
      <p style="display: inline-block; background: linear-gradient(135deg, #FFD700, #FFA500); color: #333; font-size: 32px; font-weight: bold; padding: 12px 24px; border-radius: 10px; margin: 0 0 6px 0;"><%= @ticket.raffle_number %></p>
      <p style="margin: 4px 0 0 0; font-size: 12px; color: #888;">Con este número participas en el sorteo</p>
    </td>
  </tr>
</table>

<!-- Detalles -->
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin: 20px 0; font-size: 15px;">
  <tr>
    <td style="padding: 8px 0; border-bottom: 1px solid #eee; color: #555;">Evento</td>
    <td style="padding: 8px 0; border-bottom: 1px solid #eee; text-align: right; font-weight: bold;"><%= @ticket.event_name %></td>
  </tr>
  <tr>
    <td style="padding: 8px 0; border-bottom: 1px solid #eee; color: #555;">Fecha</td>
    <td style="padding: 8px 0; border-bottom: 1px solid #eee; text-align: right; font-weight: bold;"><%= @ticket.event_date&.strftime('%d/%m/%Y') %></td>
  </tr>
  <tr>
    <td style="padding: 8px 0; border-bottom: 1px solid #eee; color: #555;">Lugar</td>
    <td style="padding: 8px 0; border-bottom: 1px solid #eee; text-align: right; font-weight: bold;"><%= @ticket.event_location %></td>
  </tr>
  <tr>
    <td style="padding: 8px 0; border-bottom: 1px solid #eee; color: #555;">Asistente</td>
    <td style="padding: 8px 0; border-bottom: 1px solid #eee; text-align: right; font-weight: bold;"><%= @ticket.guest_name %></td>
  </tr>
  <tr>
    <td style="padding: 8px 0; color: #555;">Monto</td>
    <td style="padding: 8px 0; text-align: right; font-weight: bold;">$<%= '%.2f' % @ticket.total_price %> USD</td>
  </tr>
</table>

<p style="text-align: center; margin: 28px 0 0 0;">
  <a href="<%= @ticket_url %>" style="display: inline-block; background: #34c759; color: #ffffff; padding: 12px 30px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 15px;">
    Ver mi ticket
  </a>
</p>

<p style="font-size: 13px; color: #888; text-align: center; margin-top: 20px;">
  Presenta tu ticket (código QR) en la entrada del evento.
</p>
