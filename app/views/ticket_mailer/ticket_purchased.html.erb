<p>Hola <strong><%= @user.name %></strong>,</p>
<p>¡Gracias por tu compra! Has adquirido <strong><%= @tickets.count %> ticket(s)</strong> para el evento:</p>

<p style="font-size: 18px; font-weight: bold; color: #2E7D32; margin: 4px 0 8px 0;"><%= @event_name %></p>

<p style="font-size: 13px; color: #555; margin-bottom: 20px;">
  Tus tickets están adjuntos a este correo en formato PDF. También puedes verlos desde tu cuenta.
</p>

<% @tickets.each do |ticket| %>
  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin: 12px 0; border: 1px solid #e0e0e0; border-radius: 8px; background-color: #fafafa;">
    <tr>
      <td style="padding: 14px 16px; text-align: center;">
        <p style="margin: 0 0 4px 0; font-size: 12px; color: #666;">Código de Ticket</p>
        <p style="margin: 0 0 10px 0; font-size: 18px; font-weight: bold; color: #2E7D32;"><%= ticket.ticket_code %></p>
        <p style="margin: 0 0 4px 0; font-size: 12px; color: #666;">Asistente</p>
        <p style="margin: 0 0 10px 0; font-weight: bold;"><%= ticket.guest_name %></p>
        <p style="margin: 0; font-size: 22px; font-weight: bold; color: #F57F17;">
          &#127921; <%= ticket.raffle_number %>
        </p>
        <p style="margin: 4px 0 0 0; font-size: 11px; color: #666;">
          Con este número participas en el sorteo oficial del evento
        </p>
      </td>
    </tr>
  </table>
<% end %>

<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin: 20px 0; background-color: #FFF8E1; border-radius: 8px;">
  <tr>
    <td style="padding: 14px; text-align: center; font-size: 18px; font-weight: bold; color: #E65100;">
      Total pagado: $<%= number_with_precision(@total_amount, precision: 2) %> USD
    </td>
  </tr>
</table>

<p style="font-size: 13px; color: #888; margin-top: 20px;">
  Presenta tus tickets (adjuntos en PDF) en la entrada del evento.<br><br>
  ¡Buena suerte en el sorteo! &#127808;
</p>
