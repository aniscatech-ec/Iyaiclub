<div class="container py-4">
  <h2 class="mb-4">Subir comprobante de pago</h2>

  <div class="card">
    <div class="card-body">

      <%= form_with model: [@subscription, @payment_receipt], local: true, html: { multipart: true } do |f| %>

        <div class="mb-3">
          <%= f.label :file, "Comprobante de pago (imagen o PDF)", class: "form-label" %>
          <%= f.file_field :file, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :notes, "Notas (opcional)", class: "form-label" %>
          <%= f.text_area :notes, class: "form-control", rows: 3 %>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit "Enviar comprobante", class: "btn btn-success" %>
          <%= link_to "Cancelar", @subscription, class: "btn btn-secondary" %>
        </div>

      <% end %>

    </div>
  </div>
</div>
