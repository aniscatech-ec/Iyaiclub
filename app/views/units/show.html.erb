<div class="container my-5">
  <h2 class="mb-4 text-primary fw-bold">Detalles de la unidad</h2>

  <div class="card shadow-sm">
    <div class="card-body">
      <h4 class="card-title mb-3"><%= @unit.unit_type %></h4>

      <table class="table table-borderless">
        <tbody>
        <tr>
          <th scope="row" style="width: 200px;">Capacidad</th>
          <td><%= @unit.capacity %> personas</td>
        </tr>
        <tr>
          <th scope="row">Precio base</th>
          <td><%= number_to_currency(@unit.base_price, unit: "$", precision: 2) %></td>
        </tr>
        <tr>
          <th scope="row">Hotel asociado</th>
          <td><%= @unit.hotel.establishment.name if @unit.hotel %></td>
        </tr>
        <tr>
          <th scope="row">Configuración de camas</th>
          <td>
            <% if @unit.bed_configuration.present? %>
              <% bed_config = JSON.parse(@unit.bed_configuration) rescue @unit.bed_configuration %>
              <ul class="mb-0">
                <% bed_config.each do |tipo, cantidad| %>
                  <li><strong><%= tipo.capitalize %>:</strong> <%= cantidad %></li>
                <% end if bed_config.is_a?(Hash) %>
              </ul>
            <% else %>
              <em>Sin datos</em>
            <% end %>
          </td>
        </tr>
        </tbody>
      </table>

      <div class="mt-4 d-flex gap-2">
        <%= link_to "Editar", edit_hotel_unit_path(@unit.hotel, @unit), class: "btn btn-primary" %>
        <%= link_to "Volver", hotel_path(@unit.hotel), class: "btn btn-secondary" %>
        <%#= link_to "Eliminar", @unit, method: :delete, data: { confirm: "¿Seguro que deseas eliminar esta unidad?" }, class: "btn btn-danger" %>
      </div>


    </div>
  </div>

  <div class="mt-4">
    <%= link_to 'Ver disponibilidad', hotel_unit_unit_availabilities_path(@unit.hotel, @unit), class: "btn btn-success" %>
  </div>

  <%= link_to "Crear reserva", new_hotel_unit_reservation_path(@unit.hotel, @unit), class: "btn btn-primary" %>
  <%= link_to "Ver reservas", hotel_unit_reservations_path(@unit.hotel, @unit), class: "btn btn-primary" %>


  <h2 class="my-4 text-primary fw-bold">Disponibilidad</h2>

  <% if @unit.unit_availabilities.any? %>
    <div class="table-responsive">
      <table class="table table-striped table-hover align-middle shadow-sm">
        <thead class="table-light">
        <tr>
          <th>Fecha</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
        </thead>
        <tbody>
        <% @unit.unit_availabilities.order(date: :asc).each do |availability| %>
          <tr>
            <td><%= availability.date.strftime("%d de %B de %Y") %></td>
              <td>
              <% if availability.available %>
                <span class="badge bg-success">Disponible</span>
              <% else %>
                <span class="badge bg-danger">No disponible</span>
              <% end %>
            </td>
            <td>
              <%#= link_to 'Ver', unit_unit_availability_path(@unit, availability), class: "btn btn-sm btn-outline-info" %>
              <%#= link_to 'Editar', edit_unit_unit_availability_path(@unit, availability), class: "btn btn-sm btn-outline-primary ms-1" %>
              <%#= link_to 'Eliminar', unit_unit_availability_path(@unit, availability), method: :delete, data: { confirm: '¿Seguro que deseas eliminar este registro?' }, class: "btn btn-sm btn-outline-danger ms-1" %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info mt-3">
      No hay registros de disponibilidad para esta unidad.
    </div>
  <% end %>





  <div class="mt-4">
    <%= link_to 'Agregar disponibilidad', new_hotel_unit_unit_availability_path(@unit.hotel, @unit), class: "btn btn-success" %>
  </div>



</div>
