<div class="container-fluid px-3 px-md-4 py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <!-- Header -->
      <div class="text-center mb-4">
        <div class="display-1 text-warning mb-3">
          <i class="fas fa-hourglass-half"></i>
        </div>
        <h3 class="fw-bold">Ticket Reservado</h3>
        <p class="text-muted">
          Tu ticket se acreditará una vez que el vendedor confirme tu pago.
          Recibirás un email con tu(s) ticket(s) en PDF cuando sea confirmado.
        </p>
      </div>

      <!-- Ticket info -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
          <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Código de Ticket</span>
              <strong style="color: #2E7D32;"><%= @ticket.ticket_code %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Evento</span>
              <strong><%= @event.name %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Asistente</span>
              <strong><%= @ticket.guest_name.to_s.split("·").first.strip %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Monto a transferir</span>
              <strong class="text-success">$<%= number_with_precision(@ticket.total_price, precision: 2) %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Vendedor</span>
              <strong><%= @vendedor.name %></strong>
            </li>
          </ul>
        </div>
      </div>

      <!-- WhatsApp button -->
      <div class="d-grid mb-3">
        <a href="<%= @whatsapp_url %>" target="_blank" class="btn btn-success btn-lg">
          <i class="fab fa-whatsapp me-2"></i> Contactar Vendedor por WhatsApp
        </a>
      </div>

      <div class="alert alert-info">
        <i class="fas fa-envelope me-2"></i>
        <small>
          Una vez confirmado, recibirás tu ticket en PDF a
          <strong><%= @ticket.guest_email %></strong>.
          Guarda este código: <strong><%= @ticket.ticket_code %></strong>
        </small>
      </div>

      <div class="text-center mt-3">
        <%= link_to events_path, class: "text-muted" do %>
          <i class="fas fa-arrow-left me-1"></i> Volver a eventos
        <% end %>
      </div>

    </div>
  </div>
</div>
