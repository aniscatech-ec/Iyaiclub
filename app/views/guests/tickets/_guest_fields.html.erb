<div class="card border-0 shadow-sm rounded-4 mb-4">
  <div class="card-header bg-transparent border-0 pt-4 px-4">
    <h6 class="fw-bold mb-0">
      <i class="fas fa-user me-2 text-primary"></i>
      Datos del comprador
    </h6>
  </div>
  <div class="card-body px-4 pb-4">
    <div class="mb-3">
      <label class="form-label">Nombre completo <span class="text-danger">*</span></label>
      <input type="text" name="guest_name" class="form-control"
             placeholder="Tu nombre completo" value="<%= params[:guest_name] %>" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Cédula / Pasaporte <span class="text-danger">*</span></label>
      <input type="text" name="cedula" class="form-control"
             placeholder="Número de cédula o pasaporte" value="<%= params[:cedula] %>" required>
      <div class="form-text">Necesario para identificar tu ticket en caso de inconvenientes.</div>
    </div>
    <div class="mb-3">
      <label class="form-label">Correo electrónico <span class="text-danger">*</span></label>
      <input type="email" name="guest_email" class="form-control"
             placeholder="tu@email.com" value="<%= params[:guest_email] %>" required>
      <div class="form-text">Te enviaremos tu ticket a este correo.</div>
    </div>
    <div class="mb-0">
      <label class="form-label">Teléfono móvil <span class="text-danger">*</span></label>
      <div class="input-group">
        <span class="input-group-text">
          <i class="fas fa-mobile-alt text-muted"></i>
        </span>
        <input type="tel" name="guest_phone" class="form-control"
               placeholder="09XXXXXXXX" value="<%= params[:guest_phone] %>" required>
      </div>
      <div class="form-text">Número de Ecuador (ej: 0987654321).</div>
    </div>
  </div>
</div>
