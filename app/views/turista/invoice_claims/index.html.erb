<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h3 class="fw-bold mb-1">
        <i class="fas fa-file-invoice-dollar me-2" style="color: var(--brand-orange);"></i>
        Mis Facturas
      </h3>
      <p class="text-muted mb-0 small">Sube facturas de gastos en establecimientos para acreditar puntos</p>
    </div>
    <%= link_to new_turista_invoice_claim_path, class: "btn btn-primary rounded-pill fw-semibold" do %>
      <i class="fas fa-plus me-1"></i> Subir Factura
    <% end %>
  </div>

  <% if @claims.any? %>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Fecha</th>
                <th>N° Factura</th>
                <th>Descripción</th>
                <th>Monto</th>
                <th>Estado</th>
                <th class="text-end pe-4">Puntos</th>
              </tr>
            </thead>
            <tbody>
              <% @claims.each do |claim| %>
                <tr>
                  <td class="ps-4">
                    <small class="text-muted"><%= claim.created_at.strftime("%d/%m/%Y") %></small>
                  </td>
                  <td>
                    <span class="fw-semibold"><%= claim.invoice_number.presence || "—" %></span>
                  </td>
                  <td><%= truncate(claim.description, length: 50) %></td>
                  <td class="fw-semibold">$<%= number_with_precision(claim.amount, precision: 2) %></td>
                  <td>
                    <span class="badge bg-<%= claim.status_badge %> rounded-pill">
                      <%= claim.status_label %>
                    </span>
                  </td>
                  <td class="text-end pe-4">
                    <% if claim.aprobada? && claim.points_granted %>
                      <span class="badge bg-success rounded-pill fw-bold">
                        +<%= claim.points_granted %> pts
                      </span>
                    <% elsif claim.pendiente? %>
                      <span class="text-muted small">En revisión</span>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body text-center py-5">
        <i class="fas fa-file-invoice fa-3x text-muted mb-3"></i>
        <h5 class="fw-bold text-muted">Aún no has subido facturas</h5>
        <p class="text-muted mb-4">Sube tus facturas de gastos en establecimientos IyaiClub para acumular puntos</p>
        <%= link_to new_turista_invoice_claim_path, class: "btn btn-primary rounded-pill" do %>
          <i class="fas fa-plus me-1"></i> Subir mi primera factura
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm rounded-4 mt-4" style="background: #fff9e6; border: 1px solid #ffd966 !important;">
    <div class="card-body p-4">
      <h6 class="fw-bold mb-2" style="color: #7a5d00;">
        <i class="fas fa-info-circle me-2"></i> ¿Cómo funciona?
      </h6>
      <ol class="mb-0 small" style="color: #7a5d00;">
        <li class="mb-1">Sube la foto o PDF de tu factura de consumo en un establecimiento IyaiClub</li>
        <li class="mb-1">Un administrador revisará tu solicitud</li>
        <li>Si es aprobada, recibirás los puntos correspondientes según tu plan de membresía</li>
      </ol>
    </div>
  </div>
</div>
