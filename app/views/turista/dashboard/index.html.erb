<div class="container-fluid px-3 px-md-4 py-4">

  <!-- ═══════════════ HERO / BIENVENIDA ═══════════════ -->
  <div class="rounded-4 shadow overflow-hidden mb-4"
       style="background: linear-gradient(135deg, var(--brand-green), #2a8c00); color: white;">
    <div class="row align-items-center g-0">
      <div class="col-lg-8 p-4 p-md-5">
        <h2 class="fw-bold mb-1">
          ¡Hola, <%= current_user.name %>!
        </h2>
        <p class="mb-3 opacity-75 fs-5">Descubre los mejores destinos y experiencias cerca de ti</p>
        <form action="<%= establishments_path %>" method="get" class="d-flex gap-2" style="max-width: 500px;">
          <div class="input-group input-group-lg">
            <span class="input-group-text bg-white border-0"><i class="fas fa-search text-muted"></i></span>
            <input type="search" name="search" class="form-control border-0 shadow-none"
                   placeholder="Buscar destinos, hoteles, restaurantes..." style="font-size: 0.95rem;">
          </div>
          <button class="btn btn-warning fw-bold px-4 rounded-3" type="submit">
            <i class="fas fa-search d-md-none"></i>
            <span class="d-none d-md-inline">Buscar</span>
          </button>
        </form>
      </div>
      <div class="col-lg-4 d-none d-lg-block text-center p-4">
        <i class="fas fa-compass" style="font-size: 6rem; opacity: 0.2;"></i>
      </div>
    </div>
  </div>

  
  <!-- ═══════════════ CATEGORÍAS RÁPIDAS ═══════════════ -->
  <div class="mb-5">
    <h4 class="fw-bold mb-3"><i class="fas fa-th-large me-2" style="color: var(--brand-orange);"></i> Explorar por categoría</h4>
    <div class="row g-3">
      <% category_catalog.each do |cat| %>
        <div class="col-4 col-md-2">
          <%= render "shared/category_card_with_dropdown", category: cat %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- ═══════════════ RESUMEN RÁPIDO ═══════════════ -->
  <div class="row g-3 mb-5">
    <div class="col-6 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, var(--brand-orange), #ff6b00);">
        <div class="card-body p-3 text-white">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <p class="mb-0 small opacity-75">Mis puntos</p>
              <h3 class="fw-bold mb-0"><%= number_with_delimiter(@total_points) %></h3>
            </div>
            <i class="fas fa-star fa-2x opacity-50"></i>
          </div>
          <%= link_to turista_points_path, class: "btn btn-sm btn-light mt-2 w-100" do %>
            Ver detalle
          <% end %>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, var(--brand-green), #2a8c00);">
        <div class="card-body p-3 text-white">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <p class="mb-0 small opacity-75">Reservas</p>
              <h3 class="fw-bold mb-0"><%= @bookings_count %></h3>
            </div>
            <i class="fas fa-calendar-check fa-2x opacity-50"></i>
          </div>
          <%= link_to turista_bookings_path, class: "btn btn-sm btn-light mt-2 w-100" do %>
            Ver todas
          <% end %>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, var(--brand-cofee), #8B4513);">
        <div class="card-body p-3 text-white">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <p class="mb-0 small opacity-75">Visitados</p>
              <h3 class="fw-bold mb-0"><%= @visits_count %></h3>
            </div>
            <i class="fas fa-map-marker-alt fa-2x opacity-50"></i>
          </div>
          <%= link_to turista_visits_path, class: "btn btn-sm btn-light mt-2 w-100" do %>
            Ver historial
          <% end %>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, <%= @active_membership ? '#FFD700' : '#6c757d' %>, <%= @active_membership ? '#FFA500' : '#495057' %>);">
        <div class="card-body p-3 text-white">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <p class="mb-0 small opacity-75">Membresía</p>
              <h5 class="fw-bold mb-0"><%= @active_membership&.plan_type&.capitalize || 'Sin plan' %></h5>
            </div>
            <i class="fas fa-crown fa-2x opacity-50"></i>
          </div>
          <%= link_to turista_memberships_path, class: "btn btn-sm btn-light mt-2 w-100" do %>
            Ver planes
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════ MIS PRÓXIMAS RESERVAS ═══════════════ -->
  <div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="fw-bold mb-0"><i class="fas fa-calendar-check me-2" style="color: var(--brand-green);"></i> Mis próximas reservas</h4>
      <%= link_to turista_bookings_path, class: "text-decoration-none fw-semibold", style: "color: var(--brand-green);" do %>
        Ver todas <i class="fas fa-arrow-right ms-1"></i>
      <% end %>
    </div>
    <div class="row g-3">
      <% if @recent_bookings.any? %>
        <% @recent_bookings.each do |booking| %>
          <div class="col-12 col-md-6">
            <%= render "turista/shared/booking_card", booking: booking %>
          </div>
        <% end %>
      <% else %>
        <div class="col-12">
          <div class="card border-0 shadow-sm rounded-3 p-4 text-center">
            <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
            <p class="text-muted mb-2">No tienes reservas aún</p>
            <%= link_to establishments_path, class: "btn btn-outline-primary btn-sm" do %>
              <i class="fas fa-search me-1"></i> Explorar establecimientos
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- ═══════════════ RECOMENDACIONES ═══════════════ -->
  <div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="fw-bold mb-0"><i class="fas fa-star me-2" style="color: var(--brand-orange);"></i> Recomendaciones para ti</h4>
      <%= link_to establishments_path, class: "text-decoration-none fw-semibold", style: "color: var(--brand-green);" do %>
        Ver todos <i class="fas fa-arrow-right ms-1"></i>
      <% end %>
    </div>
    <div class="row g-3">
      <% recomendaciones = [
        { nombre: "Playa Dorada", desc: "Arena blanca y aguas cristalinas", icon: "fa-umbrella-beach", color: "#3498db", badge: "Escapada" },
        { nombre: "Montaña Verde", desc: "Senderismo y naturaleza pura", icon: "fa-mountain", color: "var(--brand-green)", badge: "Aventura" },
        { nombre: "Tour Gastronómico", desc: "Sabores auténticos de la región", icon: "fa-utensils", color: "var(--brand-orange)", badge: "Gastronomía" },
        { nombre: "Ruta del Cacao", desc: "Descubre el origen del chocolate", icon: "fa-seedling", color: "var(--brand-cofee)", badge: "Cultural" },
        { nombre: "Cajas National Park", desc: "Lagunas y páramos andinos", icon: "fa-water", color: "#2ecc71", badge: "Naturaleza" },
        { nombre: "City Tour Cuenca", desc: "Patrimonio cultural de la humanidad", icon: "fa-city", color: "var(--brand-cofee-black)", badge: "Turismo" }
      ] %>
      <% recomendaciones.each do |r| %>
        <div class="col-6 col-md-4 col-lg-2">
          <a href="#" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 rounded-3 overflow-hidden text-center"
                 style="transition: all 0.3s ease;"
                 onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 24px rgba(0,0,0,0.15)';"
                 onmouseout="this.style.transform=''; this.style.boxShadow='';">
              <div class="d-flex align-items-center justify-content-center"
                   style="height: 110px; background: linear-gradient(135deg, <%= r[:color] %>22, <%= r[:color] %>44);">
                <i class="fas <%= r[:icon] %>" style="font-size: 2.5rem; color: <%= r[:color] %>; opacity: 0.8;"></i>
              </div>
              <div class="card-body p-2">
                <span class="badge rounded-pill mb-1" style="background: <%= r[:color] %>; font-size: 0.6rem;"><%= r[:badge] %></span>
                <h6 class="fw-bold text-dark mb-1" style="font-size: 0.8rem;"><%= r[:nombre] %></h6>
                <small class="text-muted" style="font-size: 0.7rem;"><%= r[:desc] %></small>
              </div>
            </div>
          </a>
        </div>
      <% end %>
    </div>
  </div>

  <!-- ═══════════════ ACCESOS RÁPIDOS ═══════════════ -->
  <div class="mb-5">
    <h4 class="fw-bold mb-3"><i class="fas fa-bolt me-2" style="color: var(--brand-cofee);"></i> Accesos rápidos</h4>
    <div class="row g-3">
      <div class="col-6 col-md-3">
        <%= link_to turista_bookings_path, class: "text-decoration-none" do %>
          <div class="card border-0 shadow-sm rounded-3 p-3 text-center h-100"
               style="transition: all 0.3s ease;"
               onmouseover="this.style.transform='translateY(-3px)';"
               onmouseout="this.style.transform='';">
            <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle mb-2"
                 style="width: 50px; height: 50px; background: var(--brand-green); opacity: 0.9;">
              <i class="fas fa-calendar-alt text-white fs-5"></i>
            </div>
            <h6 class="fw-bold text-dark mb-0" style="font-size: 0.85rem;">Mis reservas</h6>
            <small class="text-muted"><%= @bookings_count %> registradas</small>
          </div>
        <% end %>
      </div>
      <div class="col-6 col-md-3">
        <%= link_to turista_rewards_path, class: "text-decoration-none" do %>
          <div class="card border-0 shadow-sm rounded-3 p-3 text-center h-100"
               style="transition: all 0.3s ease;"
               onmouseover="this.style.transform='translateY(-3px)';"
               onmouseout="this.style.transform='';">
            <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle mb-2"
                 style="width: 50px; height: 50px; background: var(--brand-orange); opacity: 0.9;">
              <i class="fas fa-gift text-white fs-5"></i>
            </div>
            <h6 class="fw-bold text-dark mb-0" style="font-size: 0.85rem;">Recompensas</h6>
            <small class="text-muted">Canjear puntos</small>
          </div>
        <% end %>
      </div>
      <div class="col-6 col-md-3">
        <%= link_to turista_memberships_path, class: "text-decoration-none" do %>
          <div class="card border-0 shadow-sm rounded-3 p-3 text-center h-100"
               style="transition: all 0.3s ease;"
               onmouseover="this.style.transform='translateY(-3px)';"
               onmouseout="this.style.transform='';">
            <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle mb-2"
                 style="width: 50px; height: 50px; background: var(--brand-cofee); opacity: 0.9;">
              <i class="fas fa-crown text-white fs-5"></i>
            </div>
            <h6 class="fw-bold text-dark mb-0" style="font-size: 0.85rem;">Mi membresía</h6>
            <small class="text-muted">Ver planes</small>
          </div>
        <% end %>
      </div>
      <div class="col-6 col-md-3">
        <%= link_to turista_visits_path, class: "text-decoration-none" do %>
          <div class="card border-0 shadow-sm rounded-3 p-3 text-center h-100"
               style="transition: all 0.3s ease;"
               onmouseover="this.style.transform='translateY(-3px)';"
               onmouseout="this.style.transform='';">
            <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle mb-2"
                 style="width: 50px; height: 50px; background: #3498db; opacity: 0.9;">
              <i class="fas fa-map-marked-alt text-white fs-5"></i>
            </div>
            <h6 class="fw-bold text-dark mb-0" style="font-size: 0.85rem;">Visitados</h6>
            <small class="text-muted"><%= @visits_count %> lugares</small>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- ═══════════════ CTA / EXPLORAR MÁS ═══════════════ -->
  <div class="rounded-4 shadow p-4 p-md-5 text-center mb-4"
       style="background: linear-gradient(135deg, var(--brand-orange), #c94a28); color: white;">
    <i class="fas fa-binoculars fs-1 mb-3 d-block" style="opacity: 0.7;"></i>
    <h3 class="fw-bold mb-2">Explora todo lo que tenemos para ti</h3>
    <p class="mb-3 opacity-75">Hoteles, restaurantes, transporte, actividades y mucho más</p>
    <%= link_to establishments_path, class: "btn btn-light btn-lg fw-bold rounded-pill px-4" do %>
      <i class="fas fa-compass me-2" style="color: var(--brand-orange);"></i> Explorar catálogo
    <% end %>
  </div>

</div>
