<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-crown me-2" style="color: var(--brand-orange);"></i>
      Membresías
    </h3>
    <%= link_to turista_dashboard_index_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fas fa-arrow-left me-1"></i> Volver
    <% end %>
  </div>

  <div class="row g-4">
    <div class="col-12 col-lg-4">
      <%= render "turista/shared/membership_badge", membership: @active_membership %>
    </div>

    <div class="col-12 col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 p-4 pb-0">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-list me-2" style="color: var(--brand-green);"></i>
            Planes disponibles
          </h5>
        </div>
        <div class="card-body p-4">
          <% if @available_plans.any? %>
            <div class="row g-3">
              <% @available_plans.each do |plan_price| %>
                <div class="col-12 col-md-6">
                  <div class="card border rounded-3 h-100 <%= @active_membership&.plan_type == plan_price.plan_type ? 'border-success border-2' : '' %>">
                    <div class="card-body p-3">
                      <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="fw-bold mb-0"><%= plan_price.plan&.name || plan_price.plan_type&.capitalize %></h5>
                        <% if @active_membership&.plan_type == plan_price.plan_type %>
                          <span class="badge bg-success">Activo</span>
                        <% end %>
                      </div>
                      <p class="text-muted small mb-3"><%= plan_price.plan&.description %></p>
                      <div class="mb-3">
                        <span class="fs-4 fw-bold" style="color: var(--brand-green);">
                          $<%= number_with_precision(plan_price.price, precision: 2) %>
                        </span>
                        <span class="text-muted">/ <%= plan_price.duration %> días</span>
                      </div>
                      <% if plan_price.features.present? %>
                        <ul class="list-unstyled small mb-3">
                          <% plan_price.features.each do |feature| %>
                            <li class="mb-1">
                              <i class="fas fa-check text-success me-2"></i><%= feature %>
                            </li>
                          <% end %>
                        </ul>
                      <% end %>
                      <% unless @active_membership&.plan_type == plan_price.plan_type %>
                        <%= link_to subscriptions_path, class: "btn btn-outline-primary btn-sm w-100" do %>
                          Suscribirse
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4">
              <i class="fas fa-crown fa-3x text-muted mb-3"></i>
              <p class="text-muted mb-0">No hay planes disponibles actualmente</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
