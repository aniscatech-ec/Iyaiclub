<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-exchange-alt me-2" style="color: var(--brand-cofee);"></i>
      Historial de Canjes
    </h3>
    <%= link_to turista_dashboard_index_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fas fa-arrow-left me-1"></i> Volver
    <% end %>
  </div>

  <% if @redemptions.any? %>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Fecha</th>
                <th>Recompensa</th>
                <th>Puntos usados</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody>
              <% @redemptions.each do |redemption| %>
                <tr>
                  <td class="ps-4"><%= redemption.created_at.strftime("%d/%m/%Y") %></td>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <div class="rounded-circle d-flex align-items-center justify-content-center"
                           style="width: 35px; height: 35px; background: var(--brand-cofee)15;">
                        <i class="fas <%= reward_icon(redemption.reward.category) %>" 
                           style="color: var(--brand-cofee); font-size: 0.8rem;"></i>
                      </div>
                      <span><%= redemption.reward.name %></span>
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-secondary">-<%= number_with_delimiter(redemption.points_used) %></span>
                  </td>
                  <td>
                    <span class="badge bg-<%= redemption_status_class(redemption.status) %>">
                      <%= redemption.status.capitalize %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-5">
      <i class="fas fa-exchange-alt fa-4x text-muted mb-3"></i>
      <h5 class="text-muted">No has realizado canjes aún</h5>
      <p class="text-muted">Acumula puntos y canjéalos por increíbles recompensas</p>
      <%= link_to turista_rewards_path, class: "btn btn-warning" do %>
        <i class="fas fa-gift me-1"></i> Ver recompensas
      <% end %>
    </div>
  <% end %>
</div>
