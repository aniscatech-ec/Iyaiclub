<div class="card border-0 shadow-sm rounded-3 h-100">
  <div class="card-body p-3">
    <div class="d-flex align-items-center gap-3">
      <div class="rounded-circle d-flex align-items-center justify-content-center"
           style="width: 45px; height: 45px; background: var(--brand-green)15;">
        <i class="fas fa-map-marker-alt" style="color: var(--brand-green);"></i>
      </div>
      <div class="flex-grow-1">
        <h6 class="fw-bold mb-1"><%= visit.establishment.name %></h6>
        <p class="text-muted small mb-0">
          <i class="fas fa-calendar me-1"></i>
          <%= visit.visited_at.strftime("%d/%m/%Y") %>
        </p>
      </div>
      <span class="badge bg-<%= visit.booking? ? 'success' : 'info' %>">
        <%= visit.booking? ? 'Reserva' : 'Manual' %>
      </span>
    </div>
  </div>
</div>
