<div class="card border-0 shadow-sm rounded-3 overflow-hidden h-100"
     style="transition: all 0.3s ease;"
     onmouseover="this.style.transform='translateY(-3px)';"
     onmouseout="this.style.transform='translateY(0)';">
  <div class="card-body p-3">
    <div class="d-flex align-items-start gap-3">
      <div class="rounded-circle d-flex align-items-center justify-content-center"
           style="width: 50px; height: 50px; background: <%= status_color(booking.status) %>15;">
        <i class="fas fa-hotel" style="color: <%= status_color(booking.status) %>;"></i>
      </div>
      <div class="flex-grow-1">
        <h6 class="fw-bold mb-1"><%= booking.establishment&.name || "Establecimiento" %></h6>
        <p class="text-muted small mb-2">
          <i class="fas fa-map-marker-alt me-1"></i>
          <%= booking.establishment&.city&.name %>
        </p>
        <div class="d-flex flex-wrap gap-2 small">
          <span class="badge bg-light text-dark">
            <i class="fas fa-calendar-alt me-1"></i>
            <%= booking.start_date&.strftime("%d/%m/%Y") %>
          </span>
          <span class="badge bg-light text-dark">
            <i class="fas fa-calendar-check me-1"></i>
            <%= booking.end_date&.strftime("%d/%m/%Y") %>
          </span>
          <span class="badge bg-<%= status_badge_class(booking.status) %>">
            <%= booking.status&.capitalize %>
          </span>
        </div>
      </div>
    </div>
  </div>
  <div class="card-footer bg-transparent border-top-0 p-3 pt-0">
    <div class="d-flex gap-2">
      <%= link_to turista_booking_path(booking), class: "btn btn-sm btn-outline-secondary flex-grow-1" do %>
        <i class="fas fa-eye me-1"></i> Ver detalle
      <% end %>
      <% if booking.establishment&.whatsapp.present? %>
        <%= render "shared/whatsapp_button", whatsapp: booking.establishment.whatsapp, size: "sm" %>
      <% end %>
    </div>
  </div>
</div>
