<div class="card border-0 shadow-sm rounded-3 h-100">
  <div class="card-body p-3">
    <div class="d-flex align-items-start gap-3">
      <div class="rounded-circle d-flex align-items-center justify-content-center"
           style="width: 50px; height: 50px; background: var(--brand-cofee)15;">
        <i class="fas <%= reward_icon(reward.category) %>" style="color: var(--brand-cofee);"></i>
      </div>
      <div class="flex-grow-1">
        <h6 class="fw-bold mb-1"><%= reward.name %></h6>
        <p class="text-muted small mb-2"><%= truncate(reward.description, length: 60) %></p>
        <div class="d-flex align-items-center justify-content-between">
          <span class="badge bg-warning text-dark">
            <i class="fas fa-star me-1"></i><%= number_with_delimiter(reward.points_required) %> pts
          </span>
          <% if reward.establishment.present? %>
            <span class="text-muted small"><%= reward.establishment.name %></span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <div class="card-footer bg-transparent border-top-0 p-3 pt-0">
    <% if total_points >= reward.points_required %>
      <%= button_to "Canjear", redeem_turista_reward_path(reward), 
          method: :post, 
          class: "btn btn-sm btn-success w-100",
          data: { confirm: "¿Estás seguro de canjear #{reward.points_required} puntos por #{reward.name}?" } %>
    <% else %>
      <button class="btn btn-sm btn-outline-secondary w-100" disabled>
        Faltan <%= number_with_delimiter(reward.points_required - total_points) %> pts
      </button>
    <% end %>
  </div>
</div>
