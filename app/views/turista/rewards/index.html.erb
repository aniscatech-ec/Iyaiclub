<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-gift me-2" style="color: var(--brand-orange);"></i>
      Catálogo de Recompensas
    </h3>
    <div class="d-flex align-items-center gap-3">
      <%= membership_badge(current_user) %>
      <span class="badge bg-warning text-dark fs-6 px-3 py-2">
        <i class="fas fa-star me-1"></i> <%= number_with_delimiter(@total_points) %> pts disponibles
      </span>
      <%= link_to turista_dashboard_index_path, class: "btn btn-outline-secondary btn-sm" do %>
        <i class="fas fa-arrow-left me-1"></i> Volver
      <% end %>
    </div>
  </div>

  <% unless current_user.can_redeem_points_fully? %>
    <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
      <i class="fas fa-info-circle fa-lg me-3"></i>
      <div>
        <strong>Canje limitado</strong> - Con tu membresía Free puedes acumular puntos pero el canje completo requiere una membresía activa.
        <%= link_to "Ver planes", turista_memberships_path, class: "alert-link" %>
      </div>
    </div>
  <% end %>

  <%# Banner para subir facturas y acumular puntos %>
  <div class="card border-0 rounded-4 mb-4 overflow-hidden shadow-sm"
       style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
    <div class="card-body p-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
      <div class="d-flex align-items-center gap-3">
        <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
             style="width: 52px; height: 52px; background: rgba(235,99,59,0.2);">
          <i class="fas fa-file-invoice-dollar fa-lg" style="color: var(--brand-orange, #EB633B);"></i>
        </div>
        <div class="text-white">
          <div class="fw-bold mb-1">¿Tuviste gastos en un establecimiento IyaiClub?</div>
          <small style="color: rgba(255,255,255,0.65);">
            Sube tu factura y un administrador te acreditará los puntos correspondientes según tu plan.
          </small>
        </div>
      </div>
      <%= link_to new_turista_invoice_claim_path, class: "btn rounded-pill fw-semibold flex-shrink-0",
            style: "background: var(--brand-orange, #EB633B); color: white;" do %>
        <i class="fas fa-upload me-2"></i> Subir Factura
      <% end %>
    </div>
  </div>

  <div class="mb-4">
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "Todos", turista_rewards_path, 
          class: "btn btn-sm #{params[:category].blank? ? 'btn-primary' : 'btn-outline-primary'}" %>
      <% Reward.categories.keys.each do |cat| %>
        <%= link_to cat.capitalize, turista_rewards_path(category: cat), 
            class: "btn btn-sm #{params[:category] == cat ? 'btn-primary' : 'btn-outline-primary'}" %>
      <% end %>
    </div>
  </div>

  <% if @rewards.any? %>
    <div class="row g-3">
      <% @rewards.each do |reward| %>
        <div class="col-12 col-md-6 col-lg-4">
          <%= render "turista/shared/reward_card", reward: reward, total_points: @total_points %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <i class="fas fa-gift fa-4x text-muted mb-3"></i>
      <h5 class="text-muted">No hay recompensas disponibles</h5>
      <p class="text-muted">Pronto tendremos nuevas recompensas para ti</p>
    </div>
  <% end %>
</div>
