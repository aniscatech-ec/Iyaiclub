<div class="container-fluid px-3 px-md-4 py-4">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-chart-line me-2" style="color: var(--brand-orange);"></i>
      Historial de Ventas
    </h3>
    <%= link_to vendedor_dashboard_index_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fas fa-arrow-left me-1"></i> Dashboard
    <% end %>
  </div>

  <!-- Totales generales -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="display-5 fw-bold text-success"><%= @total_tickets %></div>
        <small class="text-muted">Tickets Vendidos</small>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="display-5 fw-bold text-info"><%= @total_memberships %></div>
        <small class="text-muted">Membresías Vendidas</small>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="display-5 fw-bold text-primary"><%= @total_tickets + @total_memberships %></div>
        <small class="text-muted">Total Ventas</small>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="fs-4 fw-bold text-warning">$<%= number_with_precision(@total_revenue, precision: 2) %></div>
        <small class="text-muted">Ingresos Gestionados</small>
      </div>
    </div>
  </div>

  <!-- Contador de ventas por mes -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-transparent border-0 pt-4 px-4">
      <h5 class="fw-bold mb-0">
        <i class="fas fa-calendar-alt me-2 text-primary"></i>
        Ventas por Mes
      </h5>
    </div>
    <div class="card-body px-4 pb-4">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Mes</th>
              <th class="text-center">
                <i class="fas fa-ticket-alt text-warning me-1"></i> Tickets
              </th>
              <th class="text-center">
                <i class="fas fa-id-card text-info me-1"></i> Membresías
              </th>
              <th class="text-center fw-bold">Total</th>
            </tr>
          </thead>
          <tbody>
            <% @monthly_counts.each do |_key, data| %>
              <tr>
                <td><%= data[:label] %></td>
                <td class="text-center">
                  <% if data[:tickets] > 0 %>
                    <span class="badge bg-warning text-dark"><%= data[:tickets] %></span>
                  <% else %>
                    <span class="text-muted small">—</span>
                  <% end %>
                </td>
                <td class="text-center">
                  <% if data[:memberships] > 0 %>
                    <span class="badge bg-info"><%= data[:memberships] %></span>
                  <% else %>
                    <span class="text-muted small">—</span>
                  <% end %>
                </td>
                <td class="text-center fw-bold">
                  <% if data[:total] > 0 %>
                    <span class="badge bg-success"><%= data[:total] %></span>
                  <% else %>
                    <span class="text-muted small">0</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Filtros del historial detallado -->
  <div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-body p-3">
      <%= form_with url: vendedor_sales_path, method: :get, local: true do |f| %>
        <div class="row g-2 align-items-end">
          <div class="col-6 col-md-3">
            <label class="form-label small fw-bold mb-1">Mes</label>
            <%= f.select :month,
                options_for_select(
                  (1..12).map { |m| [I18n.t("date.month_names")[m]&.capitalize, m] },
                  params[:month]
                ),
                { include_blank: "Todos" },
                class: "form-select form-select-sm" %>
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label small fw-bold mb-1">Año</label>
            <%= f.select :year,
                options_for_select(
                  (Date.current.year - 2..Date.current.year).to_a.reverse.map { |y| [y, y] },
                  params[:year] || Date.current.year
                ),
                {},
                class: "form-select form-select-sm" %>
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label small fw-bold mb-1">Tipo</label>
            <%= f.select :type,
                options_for_select(
                  [["Todos", ""], ["Tickets", "ticket"], ["Membresías", "membresia"]],
                  params[:type]
                ),
                {},
                class: "form-select form-select-sm" %>
          </div>
          <div class="col-6 col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm w-100">
              <i class="fas fa-filter me-1"></i> Filtrar
            </button>
            <%= link_to vendedor_sales_path, class: "btn btn-outline-secondary btn-sm" do %>
              <i class="fas fa-times"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Historial detallado de ventas -->
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
      <h5 class="fw-bold mb-0">
        <i class="fas fa-list me-2 text-secondary"></i>
        Detalle de Ventas
        <% if @sales.any? %>
          <span class="badge bg-secondary ms-2"><%= @sales.size %></span>
        <% end %>
      </h5>
    </div>
    <div class="card-body px-4 pb-4">
      <% if @sales.any? %>
        <!-- Vista móvil: cards -->
        <div class="d-md-none">
          <% @sales.each do |sale| %>
            <div class="card border rounded-3 mb-3">
              <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <% if sale[:type] == "ticket" %>
                    <span class="badge bg-warning text-dark">
                      <i class="fas fa-ticket-alt me-1"></i> Ticket
                    </span>
                  <% else %>
                    <span class="badge bg-info">
                      <i class="fas fa-id-card me-1"></i> Membresía
                    </span>
                  <% end %>
                  <small class="text-muted"><%= sale[:date].strftime('%d/%m/%Y') %></small>
                </div>
                <p class="fw-bold mb-1"><%= sale[:client_name] %></p>
                <% if sale[:client_email].present? %>
                  <p class="text-muted small mb-1">
                    <i class="fas fa-envelope me-1"></i><%= sale[:client_email] %>
                  </p>
                <% end %>
                <p class="text-muted small mb-1">
                  <i class="fas fa-box me-1"></i><%= sale[:product] %>
                </p>
                <p class="text-muted small mb-0">
                  <i class="fas fa-tag me-1"></i><%= sale[:detail] %>
                </p>
                <div class="mt-2 d-flex justify-content-between align-items-center">
                  <strong class="text-success">$<%= number_with_precision(sale[:amount], precision: 2) %></strong>
                  <span class="badge <%= sale[:status] == "activo" || sale[:status] == "activada" ? "bg-success" : "bg-secondary" %>">
                    <%= sale[:status].to_s.humanize %>
                  </span>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Vista desktop: tabla -->
        <div class="d-none d-md-block">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Tipo</th>
                  <th>Fecha</th>
                  <th>Cliente</th>
                  <th>Producto</th>
                  <th>Referencia</th>
                  <th class="text-end">Monto</th>
                  <th class="text-center">Estado</th>
                </tr>
              </thead>
              <tbody>
                <% @sales.each do |sale| %>
                  <tr>
                    <td>
                      <% if sale[:type] == "ticket" %>
                        <span class="badge bg-warning text-dark">
                          <i class="fas fa-ticket-alt me-1"></i> Ticket
                        </span>
                      <% else %>
                        <span class="badge bg-info">
                          <i class="fas fa-id-card me-1"></i> Membresía
                        </span>
                      <% end %>
                    </td>
                    <td>
                      <small><%= sale[:date].strftime('%d/%m/%Y %H:%M') %></small>
                    </td>
                    <td>
                      <div class="fw-semibold"><%= sale[:client_name] %></div>
                      <% if sale[:client_email].present? %>
                        <small class="text-muted"><%= sale[:client_email] %></small>
                      <% end %>
                    </td>
                    <td><%= sale[:product] %></td>
                    <td>
                      <small class="text-muted font-monospace"><%= sale[:detail] %></small>
                    </td>
                    <td class="text-end fw-bold text-success">
                      $<%= number_with_precision(sale[:amount], precision: 2) %>
                    </td>
                    <td class="text-center">
                      <span class="badge <%= sale[:status].to_s.in?(%w[activo activada usado]) ? "bg-success" : "bg-secondary" %>">
                        <%= sale[:status].to_s.humanize %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% else %>
        <div class="text-center text-muted py-5">
          <i class="fas fa-chart-bar fa-3x mb-3 opacity-25"></i>
          <p class="mb-0">No hay ventas para el período seleccionado.</p>
        </div>
      <% end %>
    </div>
  </div>

</div>
