<div class="container-fluid px-3 px-md-4 py-4">
  <div class="mb-4">
    <h3 class="fw-bold mb-1">
      <i class="fas fa-store me-2" style="color: var(--brand-orange);"></i>
      Portal de Vendedor
    </h3>
    <p class="text-muted mb-0">Bienvenido, <%= current_user.name %></p>
  </div>

  <!-- Resumen -->
  <div class="row mb-4">
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="display-4 fw-bold text-warning"><%= @pending_count %></div>
        <small class="text-muted">Tickets Pendientes</small>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <%= link_to vendedor_memberships_path, class: "text-decoration-none" do %>
        <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100 <%= @pending_memberships_count > 0 ? 'border-warning border' : '' %>">
          <div class="display-4 fw-bold text-info"><%= @pending_memberships_count %></div>
          <small class="text-muted">Membresías Pendientes</small>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="display-4 fw-bold text-primary"><%= @total_events_count %></div>
        <small class="text-muted">Eventos Asignados</small>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <%= link_to vendedor_sales_path, class: "text-decoration-none" do %>
        <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100">
          <div class="display-4 fw-bold" style="color: var(--brand-orange);">
            <i class="fas fa-chart-line"></i>
          </div>
          <small class="text-muted">Mis Ventas</small>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Stands asignados (con sus eventos) -->
  <% if @stands.any? %>
    <div class="mb-2">
      <h5 class="fw-bold mb-3">
        <i class="fas fa-store me-2 text-warning"></i>Mis Stands
      </h5>
    </div>
    <% @stands.each do |stand| %>
      <% stand_slots = @stand_slots.select { |s| s.stand_id == stand.id } %>
      <div class="card border-0 shadow-sm rounded-4 mb-3" style="border-left: 4px solid #ffc107 !important;">
        <div class="card-header bg-transparent border-0 pt-3 px-4 pb-2 d-flex align-items-center justify-content-between">
          <div class="d-flex align-items-center gap-3">
            <div>
              <span class="fw-bold fs-6">
                <i class="fas fa-store me-2 text-warning"></i><%= stand.name %>
              </span>
              <code class="ms-2 small" style="color: var(--brand-orange);"><%= stand.stand_code %></code>
              <% if stand.location.present? %>
                <small class="text-muted ms-2"><i class="fas fa-map-marker-alt me-1"></i><%= stand.location %></small>
              <% end %>
            </div>
          </div>
          <span class="badge <%= stand.activo? ? 'bg-success' : 'bg-warning text-dark' %>">
            <%= stand.activo? ? 'Activo' : 'Reservado' %>
          </span>
        </div>
        <div class="card-body px-4 pb-3 pt-0">
          <% if stand_slots.any? %>
            <div class="row g-3">
              <% stand_slots.each do |slot| %>
                <% event = slot.event %>
                <% pending  = Ticket.reservados.where(vendedor: current_user, event: event, stand: stand).count %>
                <% acreditados = Ticket.where(vendedor: current_user, event: event, stand: stand, status: :activo).count %>
                <div class="col-12 col-md-6 col-lg-4">
                  <div class="card border rounded-3 h-100">
                    <div class="card-body">
                      <h6 class="fw-bold mb-2">
                        <i class="fas fa-calendar-day me-1 text-primary"></i><%= event.name %>
                      </h6>
                      <p class="text-muted small mb-2">
                        <i class="fas fa-calendar me-1"></i> <%= event.event_date&.strftime('%d/%m/%Y %H:%M') %>
                      </p>
                      <% if event.location.present? %>
                        <p class="text-muted small mb-2">
                          <i class="fas fa-map-marker-alt me-1"></i> <%= event.location %>
                        </p>
                      <% end %>
                      <% if slot.has_quota? %>
                        <p class="text-muted small mb-2">
                          <i class="fas fa-ticket-alt me-1"></i> Cuota: <%= slot.tickets_sold %>/<%= slot.quota %>
                        </p>
                      <% end %>
                      <div class="d-flex gap-2 mb-3">
                        <span class="badge bg-warning text-dark"><%= pending %> pendientes</span>
                        <span class="badge bg-success"><%= acreditados %> acreditados</span>
                      </div>
                      <%= link_to vendedor_event_stand_tickets_path(event, stand), class: "btn btn-primary btn-sm w-100" do %>
                        <i class="fas fa-ticket-alt me-1"></i> Ver Tickets
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted small mb-0">Este stand no tiene eventos asignados actualmente.</p>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Membresías -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-transparent border-0 pt-4 px-4">
      <h5 class="fw-bold mb-0">
        <i class="fas fa-id-card me-2" style="color: var(--brand-orange);"></i>
        Mis Membresías
      </h5>
    </div>
    <div class="card-body px-4 pb-4">
      <% memberships_by_plan = @memberships.group_by(&:plan_type) %>
      <% if memberships_by_plan.any? %>
        <div class="row g-3">
          <% memberships_by_plan.each do |plan_type_id, group| %>
            <% plan_price = PlanPrice.find_by(id: plan_type_id) %>
            <% pending = group.count { |m| m.reservada? } %>
            <% acreditadas = group.count { |m| m.activada? } %>
            <div class="col-12 col-md-6 col-lg-4">
              <div class="card border rounded-3 h-100">
                <div class="card-body">
                  <h6 class="fw-bold mb-2">
                    <%= plan_price ? plan_price.plan_type&.humanize : "Plan desconocido" %>
                  </h6>
                  <% if plan_price %>
                    <p class="text-muted small mb-2">
                      <i class="fas fa-clock me-1"></i> <%= plan_price.display_duration %>
                    </p>
                    <p class="text-muted small mb-3">
                      <i class="fas fa-dollar-sign me-1"></i> $<%= number_with_precision(plan_price.price, precision: 2) %>
                    </p>
                  <% end %>
                  <div class="d-flex gap-3 mb-3">
                    <span class="badge bg-warning text-dark"><%= pending %> pendientes</span>
                    <span class="badge bg-success"><%= acreditadas %> acreditadas</span>
                  </div>
                  <%= link_to vendedor_memberships_path(plan: plan_price&.id), class: "btn btn-primary btn-sm w-100" do %>
                    <i class="fas fa-id-card me-1"></i> Ver Membresías
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center text-muted py-4">
          <i class="fas fa-id-card fa-3x mb-3"></i>
          <p>No tienes membresías asignadas actualmente</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Eventos directos (sin stand) -->
  <% if @events_direct.any? %>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-header bg-transparent border-0 pt-4 px-4">
        <h5 class="fw-bold mb-0">
          <i class="fas fa-calendar-alt me-2 text-primary"></i>
          Mis Eventos
        </h5>
      </div>
      <div class="card-body px-4 pb-4">
        <div class="row g-3">
          <% @events_direct.each do |event| %>
            <% pending = event.tickets.reservados.where(vendedor: current_user).count %>
            <% acreditados = event.tickets.where(vendedor: current_user, status: :activo).count %>
            <div class="col-12 col-md-6 col-lg-4">
              <div class="card border rounded-3 h-100">
                <div class="card-body">
                  <h6 class="fw-bold mb-2"><%= event.name %></h6>
                  <p class="text-muted small mb-2">
                    <i class="fas fa-calendar me-1"></i> <%= event.event_date&.strftime('%d/%m/%Y %H:%M') %>
                  </p>
                  <p class="text-muted small mb-3">
                    <i class="fas fa-map-marker-alt me-1"></i> <%= event.location %>
                  </p>
                  <div class="d-flex gap-3 mb-3">
                    <span class="badge bg-warning text-dark"><%= pending %> pendientes</span>
                    <span class="badge bg-success"><%= acreditados %> acreditados</span>
                  </div>
                  <%= link_to vendedor_event_tickets_path(event), class: "btn btn-primary btn-sm w-100" do %>
                    <i class="fas fa-ticket-alt me-1"></i> Ver Tickets
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @events_direct.empty? && @stands.empty? %>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body text-center text-muted py-5">
        <i class="fas fa-calendar-times fa-3x mb-3"></i>
        <p>No tienes eventos ni stands asignados actualmente</p>
      </div>
    </div>
  <% end %>
</div>
