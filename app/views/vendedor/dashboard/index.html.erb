<div class="container-fluid px-3 px-md-4 py-4">
  <div class="mb-4">
    <h3 class="fw-bold">
      <i class="fas fa-store me-2" style="color: var(--brand-orange);"></i>
      Portal de Vendedor
    </h3>
    <p class="text-muted">Bienvenido, <%= current_user.name %></p>
  </div>

  <!-- Resumen -->
  <div class="row mb-4">
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="display-4 fw-bold text-warning"><%= @pending_count %></div>
        <small class="text-muted">Tickets Pendientes</small>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="display-4 fw-bold text-primary"><%= @events.count %></div>
        <small class="text-muted">Eventos Asignados</small>
      </div>
    </div>
  </div>

  <!-- Eventos asignados -->
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-transparent border-0 pt-4 px-4">
      <h5 class="fw-bold mb-0">
        <i class="fas fa-calendar-alt me-2 text-primary"></i>
        Mis Eventos
      </h5>
    </div>
    <div class="card-body px-4 pb-4">
      <% if @events.any? %>
        <div class="row g-3">
          <% @events.each do |event| %>
            <% pending = event.tickets.reservados.where(vendedor: current_user).count %>
            <% acreditados = event.tickets.where(vendedor: current_user, status: :activo).count %>
            <div class="col-12 col-md-6 col-lg-4">
              <div class="card border rounded-3 h-100">
                <div class="card-body">
                  <h6 class="fw-bold mb-2"><%= event.name %></h6>
                  <p class="text-muted small mb-2">
                    <i class="fas fa-calendar me-1"></i> <%= event.event_date&.strftime('%d/%m/%Y %H:%M') %>
                  </p>
                  <p class="text-muted small mb-3">
                    <i class="fas fa-map-marker-alt me-1"></i> <%= event.location %>
                  </p>
                  <div class="d-flex gap-3 mb-3">
                    <span class="badge bg-warning text-dark"><%= pending %> pendientes</span>
                    <span class="badge bg-success"><%= acreditados %> acreditados</span>
                  </div>
                  <%= link_to vendedor_event_tickets_path(event), class: "btn btn-primary btn-sm w-100" do %>
                    <i class="fas fa-ticket-alt me-1"></i> Ver Tickets
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center text-muted py-4">
          <i class="fas fa-calendar-times fa-3x mb-3"></i>
          <p>No tienes eventos asignados actualmente</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
