<!DOCTYPE html>
<html>
<head>
  <title><%= content_for(:title) || "Iyaib Club App" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1,interactive-widget=resizes-content">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
  <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.1/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" data-turbo-track="reload">
  <noscript><link href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.1/css/all.min.css" rel="stylesheet"></noscript>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" data-turbo-track="reload">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css" rel="stylesheet" data-turbo-track="reload">


  <%# Includes all stylesheet files in app/assets/stylesheets %>
  <%= stylesheet_link_tag :"application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin="" data-turbo-track="reload"/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
          crossorigin="" defer></script>
  <style>
      .gradient-text {
          font-size: 1.5rem;
          font-weight: bold;
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          -webkit-background-clip: text;
          background-clip: text;
          color: transparent;
      }

      .icon-bg {
          width: 40px;
          height: 40px;
          border-radius: 50%;
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          display: flex;
          align-items: center;
          justify-content: center;
      }

      .gradient-btn {
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          border: none;
          color: white;
          font-weight: bold;
          padding: 0.5rem 1rem;
          border-radius: 8px;
          transition: 0.3s ease;
      }

      .gradient-btn:hover {
          filter: brightness(1.1);
          transform: scale(1.05);
      }

      .gradient-outline-btn {
          background: transparent;
          color: #34c759; /* Color inicial del texto */
          font-weight: bold;
          padding: 0.5rem 1rem;
          border: 2px solid transparent;
          border-image: linear-gradient(to right, #34c759, #c0aa40, #ff9500) 1;
          border-radius: 8px;
          transition: 0.3s ease;
      }

      .gradient-outline-btn:hover {
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          color: white;
      }

  </style>
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg iyai-navbar">
  <div class="container-fluid px-3">

    <%# ── Logo ── %>
    <a class="navbar-brand py-0 me-3" href="/">
      <%= image_tag("logo.jpeg", height: 52, alt: "IyaiClub") %>
    </a>

    <%# ── Zona derecha en móvil: emergencia + panel + toggler ── %>
    <div class="d-flex d-lg-none align-items-center gap-2 ms-auto">

      <%# Asistencia de emergencia %>
      <%= link_to root_path,
            class: "iyai-icon-btn iyai-icon-btn--danger",
            title: "Asistencia de Emergencia" do %>
        <i class="fas fa-kit-medical"></i>
      <% end %>

      <%# Avatar dropdown (móvil) %>
      <% if user_signed_in? %>
        <%
          panel_path = current_user.administrador? ? admin_dashboard_index_path :
                       current_user.afiliado?      ? afiliado_dashboard_index_path :
                                                     turista_dashboard_index_path
          panel_label = current_user.administrador? ? "Panel Admin" : "Mi Panel"
          panel_icon  = current_user.administrador? ? "fa-shield-alt" :
                        current_user.afiliado?      ? "fa-store" : "fa-compass"
        %>
        <div class="dropdown">
          <button class="iyai-avatar iyai-avatar--dropdown border-0"
                  type="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false">
            <%= current_user.name.first.upcase %>
          </button>
          <ul class="dropdown-menu dropdown-menu-end iyai-user-dropdown shadow-sm">
            <li class="iyai-user-dropdown__header">
              <p class="fw-bold mb-0 lh-sm"><%= current_user.name.split.first(2).join(" ") %></p>
              <small class="text-muted"><%= current_user.email %></small>
            </li>
            <li><hr class="dropdown-divider my-1"></li>
            <li>
              <%= link_to panel_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
                <i class="fas <%= panel_icon %> fa-fw" style="color:var(--brand-green);"></i>
                <%= panel_label %>
              <% end %>
            </li>
            <li><hr class="dropdown-divider my-1"></li>
            <li>
              <%= link_to destroy_user_session_path,
                    data: { turbo_method: :delete },
                    class: "dropdown-item d-flex align-items-center gap-2 text-danger" do %>
                <i class="fas fa-sign-out-alt fa-fw"></i> Cerrar sesión
              <% end %>
            </li>
          </ul>
        </div>
      <% else %>
        <%= link_to new_user_session_path, class: "iyai-icon-btn iyai-icon-btn--primary", title: "Iniciar sesión" do %>
          <i class="fas fa-user"></i>
        <% end %>
      <% end %>

      <%# Toggler personalizado %>
      <button class="iyai-toggler" type="button"
              data-bs-toggle="collapse"
              data-bs-target="#navbarSupportedContent"
              aria-controls="navbarSupportedContent"
              aria-expanded="false"
              aria-label="Menú">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <%# ── Menú colapsable ── %>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav align-items-lg-center ms-auto gap-lg-1">

        <li class="nav-item">
          <%= link_to root_path, class: "nav-link iyai-nav-link", "aria-current": "page" do %>
            <i class="fas fa-home d-lg-none me-2"></i>Inicio
          <% end %>
        </li>

        <li class="nav-item">
          <%= link_to "#", class: "nav-link iyai-nav-link" do %>
            <i class="fas fa-star d-lg-none me-2"></i>Club Iyai
          <% end %>
        </li>

        <%# ── Asistencia: solo en desktop (en móvil ya aparece como ícono) ── %>
        <li class="nav-item d-none d-lg-block">
          <%= link_to root_path,
                class: "btn iyai-btn-emergency btn-sm d-flex align-items-center gap-2",
                title: "Asistencia de Emergencia" do %>
            <i class="fas fa-kit-medical"></i>
            <span>Asistencia</span>
          <% end %>
        </li>

        <% if user_signed_in? %>

          <%# ── Separador visual desktop ── %>
          <li class="nav-item d-none d-lg-block"><span class="iyai-nav-divider"></span></li>

          <%# ── Avatar dropdown (desktop) ── %>
          <%
            panel_path  = current_user.administrador? ? admin_dashboard_index_path :
                          current_user.afiliado?      ? afiliado_dashboard_index_path :
                                                        turista_dashboard_index_path
            panel_label = current_user.administrador? ? "Panel Admin" : "Mi Panel"
            panel_icon  = current_user.administrador? ? "fa-shield-alt" :
                          current_user.afiliado?      ? "fa-store" : "fa-compass"
          %>
          <li class="nav-item dropdown">
            <button class="iyai-avatar iyai-avatar--dropdown border-0"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    title="<%= current_user.name %>">
              <%= current_user.name.first.upcase %>
            </button>
            <ul class="dropdown-menu dropdown-menu-end iyai-user-dropdown shadow-sm">
              <li class="iyai-user-dropdown__header">
                <p class="fw-bold mb-0 lh-sm"><%= current_user.name.split.first(2).join(" ") %></p>
                <small class="text-muted"><%= current_user.email %></small>
              </li>
              <li><hr class="dropdown-divider my-1"></li>
              <li>
                <%= link_to panel_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
                  <i class="fas <%= panel_icon %> fa-fw" style="color:var(--brand-green);"></i>
                  <%= panel_label %>
                <% end %>
              </li>
              <li><hr class="dropdown-divider my-1"></li>
              <li>
                <%= link_to destroy_user_session_path,
                      data: { turbo_method: :delete },
                      class: "dropdown-item d-flex align-items-center gap-2 text-danger" do %>
                  <i class="fas fa-sign-out-alt fa-fw"></i> Cerrar sesión
                <% end %>
              </li>
            </ul>
          </li>

        <% else %>
          <%# ── No autenticado ── %>
          <li class="nav-item d-lg-none">
            <%= link_to new_user_registration_path, class: "nav-link iyai-nav-link" do %>
              <i class="fas fa-user-plus me-2"></i>Suscribirse
            <% end %>
          </li>
          <li class="nav-item d-none d-lg-flex align-items-center gap-2">
            <%= link_to "Suscribirse", new_user_registration_path,
                  class: "btn iyai-btn-outline btn-sm" %>
            <%= link_to "Iniciar sesión", new_user_session_path,
                  class: "btn iyai-btn-primary btn-sm" %>
          </li>
        <% end %>

      </ul>
    </div><%# /collapse %>

  </div>
</nav>
<%#= render "shared/search_hotels" %>

<div class="d-none d-md-block"><%= yield :search_bar %></div>

<div class="container-fluid">
