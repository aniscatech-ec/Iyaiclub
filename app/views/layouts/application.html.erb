<!DOCTYPE html>
<html>
<head>
  <title><%= content_for(:title) || "Iyaib Club App" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <%= yield :head %>

  <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
  <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.19/index.global.min.js" defer></script>




  <%# Includes all stylesheet files in app/assets/stylesheets %>
  <%= stylesheet_link_tag :"application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <style>
      .gradient-text {
          font-size: 1.5rem;
          font-weight: bold;
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          -webkit-background-clip: text;
          background-clip: text;
          color: transparent;
      }

      .icon-bg {
          width: 40px;
          height: 40px;
          border-radius: 50%;
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          display: flex;
          align-items: center;
          justify-content: center;
      }

      .gradient-btn {
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          border: none;
          color: white;
          font-weight: bold;
          padding: 0.5rem 1rem;
          border-radius: 8px;
          transition: 0.3s ease;
      }

      .gradient-btn:hover {
          filter: brightness(1.1);
          transform: scale(1.05);
      }

      .gradient-outline-btn {
          background: transparent;
          color: #34c759; /* Color inicial del texto */
          font-weight: bold;
          padding: 0.5rem 1rem;
          border: 2px solid transparent;
          border-image: linear-gradient(to right, #34c759, #c0aa40, #ff9500) 1;
          border-radius: 8px;
          transition: 0.3s ease;
      }

      .gradient-outline-btn:hover {
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          color: white;
      }

  </style>
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">
      <%= image_tag("logo.jpg", size: "72x72") %>Iyaiclub.com</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse justify-content-end" id="navbarSupportedContent">
      <ul class="navbar-nav mb-2 mb-lg-0">
        <li class="nav-item mx-2">
          <%= link_to "Inicio", root_path, class: "nav-link fw-bold", "aria-current": "page" %>
          <%#= link_to "Inicio", root_path, class: "nav-link"%>

        </li>
        <li class="nav-item mx-2">
          <%= link_to "Club Iyai", "#", class: "nav-link fw-bold" %>

        </li>

        <% if user_signed_in? %>
        <%else %>
          <li class="nav-item mx-2">
            <%= link_to "Suscribirse", new_user_registration_path, class: "nav-link fw-bold" %>
          </li>
        <% end %>

        <% if user_signed_in? %>
          <% if current_user.administrador? %>
            <li class="nav-item mx-2">
              <%= link_to current_user.name, admin_dashboard_index_path, class: "nav-link fw-bold"  %>

            </li>
          <% elsif current_user.afiliado?%>
            <li class="nav-item mx-2">
              <%= link_to current_user.name, afiliado_dashboard_index_path, class: "nav-link fw-bold"  %>

            </li>
          <% elsif current_user.turista?%>
            <li class="nav-item mx-2">
              <%= link_to current_user.name, turista_dashboard_index_path, class: "nav-link fw-bold"  %>

            </li>
          <% end %>

          <li class="nav-item mx-2">
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-danger" do %>
              <i class="bi bi-box-arrow-right"></i>
            <% end %>
          </li>
        <% else %>
          <li class="nav-item mx-2">
            <%= link_to "Iniciar sesion", new_user_session_path, class: "btn btn-primary" %>
          </li>
        <% end %>


      </ul>
    </div>
  </div>
</nav>


<%= yield %>
</body>


<footer class="pt-5 pb-4 mt-5 border-top">
  <div class="container text-md-left">
    <div class="row text-md-left">

      <!-- Logo y descripción -->
      <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
        <h5 class="mb-4 fw-bold text-primary">IyaiClub</h5>
        <p>
          Plataforma de reservas para hoteles, restaurantes y alquiler de vehículos.
          Encuentra la mejor opción en un solo lugar.
        </p>
      </div>

      <!-- Enlaces rápidos -->
      <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mt-3">
        <h5 class="text-uppercase mb-4 fw-bold text-primary">Servicios</h5>
        <p><a href="#" class="text-dark text-decoration-none">Hoteles</a></p>
        <p><a href="#" class="text-dark text-decoration-none">Restaurantes</a></p>
        <p><a href="#" class="text-dark text-decoration-none">Vehículos</a></p>
        <p><a href="#" class="text-dark text-decoration-none">Promociones</a></p>
      </div>

      <!-- Recursos -->
      <div class="col-md-3 col-lg-2 col-xl-2 mx-auto mt-3">
        <h5 class="text-uppercase mb-4 fw-bold text-primary">Enlaces útiles</h5>
        <p><a href="#" class="text-dark text-decoration-none">Tu cuenta</a></p>
        <p><a href="#" class="text-dark text-decoration-none">Preguntas frecuentes</a></p>
        <p><a href="#" class="text-dark text-decoration-none">Términos y condiciones</a></p>
        <p><a href="#" class="text-dark text-decoration-none">Política de privacidad</a></p>
      </div>

      <!-- Contacto -->
      <div class="col-md-4 col-lg-3 col-xl-3 mx-auto mt-3">
        <h5 class="text-uppercase mb-4 fw-bold text-primary">Contacto</h5>
        <p><i class="bi bi-geo-alt-fill me-2 text-primary"></i> Quito, Ecuador</p>
        <p><i class="bi bi-envelope-fill me-2 text-primary"></i> info@iyaiclub.com</p>
        <p><i class="bi bi-telephone-fill me-2 text-primary"></i> +593 99 123 4567</p>
      </div>
    </div>

    <hr class="mb-4">

    <!-- Redes sociales -->
    <div class="row align-items-center">
      <div class="col-md-7 col-lg-8">
        <p class="mb-0">
          © 2025 Derechos reservados:
          <a href="#" class="text-primary fw-bold text-decoration-none">IyaiClub.com</a>
        </p>
      </div>

      <div class="col-md-5 col-lg-4">
        <div class="text-center text-md-end">
          <ul class="list-unstyled list-inline mb-0">
            <li class="list-inline-item">
              <a href="#"><i class="bi bi-facebook fs-5 text-primary"></i></a>
            </li>
            <li class="list-inline-item">
              <a href="#"><i class="bi bi-twitter-x fs-5 text-primary"></i></a>
            </li>
            <li class="list-inline-item">
              <a href="#"><i class="bi bi-instagram fs-5 text-primary"></i></a>
            </li>
            <li class="list-inline-item">
              <a href="#"><i class="bi bi-linkedin fs-5 text-primary"></i></a>
            </li>
          </ul>
        </div>
      </div>
    </div>

  </div>
</footer>

<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</html>
