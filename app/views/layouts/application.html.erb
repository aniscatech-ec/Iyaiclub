<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer data-turbo-track="reload"></script>

<%# ── Bottom sheets (fuera del nav, position:fixed funciona sin clip) ── %>
<% category_catalog.each do |cat| %>
  <% next unless cat[:subtypes].present? %>
  <%
    cat_color  = cat[:color]
    cat_icon   = cat[:icon]
    cat_name   = cat[:name]
    cat_path   = cat[:path]
    is_grouped = cat[:grouped]
    sheet_id   = "bnav-sheet-#{cat_name.parameterize}"
  %>
  <div id="<%= sheet_id %>" class="bnav-sheet d-lg-none">
    <%# Overlay %>
    <div class="bnav-sheet__overlay" data-sheet-id="<%= sheet_id %>"></div>
    <%# Panel deslizante %>
    <div class="bnav-sheet__panel">
      <div class="bnav-sheet__handle"></div>
      <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom flex-shrink-0">
        <span class="fw-bold" style="color:<%= cat_color %>;">
          <i class="fas <%= cat_icon %> me-2"></i><%= cat_name %>
        </span>
        <button type="button" class="btn-close btn-sm" data-sheet-id="<%= sheet_id %>" aria-label="Cerrar"></button>
      </div>
      <div class="list-group list-group-flush bnav-sheet__list">
        <%= link_to cat_path,
              class: "list-group-item list-group-item-action px-3 py-2 fw-semibold",
              style: "font-size:0.9rem; color:#{cat_color};" do %>
          <i class="fas fa-th-list me-2"></i> Ver todos
        <% end %>
        <% if is_grouped %>
          <% cat[:subtypes].each do |group| %>
            <div class="dropdown-section-header px-3 py-1" style="background:<%= cat_color %>15;">
              <small class="fw-bold text-uppercase" style="font-size:0.7rem; color:<%= cat_color %>; letter-spacing:0.5px;">
                <%= group[:group] %>
              </small>
            </div>
            <% group[:items].each do |sub| %>
              <%= link_to sub[:path], class: "list-group-item list-group-item-action px-4 py-2", style: "font-size:0.9rem;" do %>
                <i class="fas fa-angle-right me-2" style="color:<%= cat_color %>;"></i><%= sub[:label] %>
              <% end %>
            <% end %>
          <% end %>
        <% else %>
          <% cat[:subtypes].each do |sub| %>
            <%= link_to sub[:path], class: "list-group-item list-group-item-action px-3 py-2", style: "font-size:0.9rem;" do %>
              <i class="fas fa-angle-right me-2" style="color:<%= cat_color %>;"></i><%= sub[:label] %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# ── Bottom Nav Bar (solo móvil) ── %>
<nav class="iyai-bottom-nav d-lg-none" aria-label="Navegación principal">

  <%# Tab fijo: Inicio %>
  <div class="iyai-bottom-nav__fixed">
    <%= link_to root_path, class: "iyai-bottom-nav__item #{current_page?(root_path) ? 'is-active' : ''}" do %>
      <i class="fas fa-home"></i>
      <span>Inicio</span>
    <% end %>
  </div>

  <%# Zona scrollable: categorías %>
  <div class="iyai-bottom-nav__scroll">
    <% category_catalog.each do |cat| %>
      <%
        has_sub   = cat[:subtypes].present?
        cat_color = cat[:color]
        cat_icon  = cat[:icon]
        cat_name  = cat[:name]
        cat_path  = cat[:path]
        sheet_id  = "bnav-sheet-#{cat_name.parameterize}"
      %>
      <% if has_sub %>
        <button type="button"
                class="iyai-bottom-nav__item iyai-bottom-nav__tab-btn"
                style="--tab-color: <%= cat_color %>;"
                data-open-sheet="<%= sheet_id %>">
          <i class="fas <%= cat_icon %>"></i>
          <span><%= cat_name.split.first %></span>
        </button>
      <% else %>
        <%= link_to cat_path,
              class: "iyai-bottom-nav__item",
              style: "--tab-color: #{cat_color};" do %>
          <i class="fas <%= cat_icon %>"></i>
          <span><%= cat_name.split.first %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>

</nav>

<script>
(function() {
  function openSheet(id) {
    var el = document.getElementById(id);
    if (el) el.classList.add('is-open');
  }
  function closeSheet(id) {
    var el = document.getElementById(id);
    if (el) el.classList.remove('is-open');
  }
  document.addEventListener('click', function(e) {
    // Abrir
    var btn = e.target.closest('[data-open-sheet]');
    if (btn) {
      // Cerrar cualquier otro abierto
      document.querySelectorAll('.bnav-sheet.is-open').forEach(function(s) {
        s.classList.remove('is-open');
      });
      openSheet(btn.dataset.openSheet);
      return;
    }
    // Cerrar por overlay o btn-close
    var closer = e.target.closest('[data-sheet-id]');
    if (closer) {
      closeSheet(closer.dataset.sheetId);
      return;
    }
  });

  // Ocultar bottom nav cuando el teclado virtual aparece en móvil
  // (evita pantallazzo blanco / contenido tapado en Android/iOS)
  var bottomNav = document.querySelector('.iyai-bottom-nav');
  if (bottomNav) {
    document.addEventListener('focusin', function(e) {
      var tag = e.target.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') {
        bottomNav.style.display = 'none';
      }
    });
    document.addEventListener('focusout', function() {
      // Pequeño delay para que el teclado cierre antes de mostrar el nav
      setTimeout(function() {
        bottomNav.style.display = '';
      }, 150);
    });
  }
})();
</script>

</body>
</html>
