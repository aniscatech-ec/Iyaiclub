<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="es">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="format-detection" content="telephone=no" />
  <title>IyaiClub</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f4f4f7; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #333333; line-height: 1.6;">

  <!-- Preheader oculto (preview en la bandeja) -->
  <div style="display: none; max-height: 0; overflow: hidden; font-size: 1px; line-height: 1px; color: #f4f4f7; opacity: 0;">
    Confirma tu cuenta en IyaiClub y comienza a descubrir experiencias únicas.
  </div>

  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f4f4f7;">
    <tr>
      <td align="center" style="padding: 30px 15px;">

        <!-- Contenedor principal -->
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600" style="max-width: 600px; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">

          <!-- Header -->
          <tr>
            <td align="center" style="background-color: #EB633B; padding: 32px 20px; border-bottom: 4px solid #c94a28;">
              <% if attachments["logo.jpeg"] %>
                <img src="<%= attachments["logo.jpeg"].url %>" alt="IyaiClub" width="72" height="72" style="display: block; width: 72px; height: 72px; border-radius: 50%; border: 3px solid #ffffff; background-color: #ffffff; margin-bottom: 12px;" />
              <% end %>
              <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: bold; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">IyaiClub</h1>
              <p style="margin: 6px 0 0 0; color: #ffffff; font-size: 14px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">Descubre los mejores destinos y experiencias</p>
            </td>
          </tr>

          <!-- Contenido -->
          <tr>
            <td style="padding: 40px 32px; color: #333333; font-size: 16px; line-height: 1.6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
              <%= yield %>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="background-color: #2a2a2a; padding: 28px 20px; color: #cccccc; font-size: 13px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
              <p style="margin: 0 0 8px 0; color: #ffffff; font-size: 15px; font-weight: bold;">IyaiClub</p>
              <p style="margin: 0 0 12px 0; color: #cccccc;">
                <a href="https://iyaiclub.com" style="color: #EB633B; text-decoration: none;">iyaiclub.com</a>
                &nbsp;|&nbsp;
                <a href="mailto:info@iyaiclub.com" style="color: #EB633B; text-decoration: none;">info@iyaiclub.com</a>
              </p>
              <p style="margin: 0 0 8px 0; color: #999999; font-size: 12px;">
                &copy; <%= Date.current.year %> IyaiClub. Todos los derechos reservados.
              </p>
              <p style="margin: 0; color: #999999; font-size: 11px;">
                Recibiste este correo porque te registraste en IyaiClub.<br/>
                Si no fuiste tú, puedes ignorar este mensaje de forma segura.
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
