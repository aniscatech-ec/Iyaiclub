<!DOCTYPE html>
<html>
<head>
  <title><%= content_for(:title) || "Iyaib Club App" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
  <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.1/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" data-turbo-track="reload">
  <noscript><link href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.1/css/all.min.css" rel="stylesheet"></noscript>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css" rel="stylesheet" data-turbo-track="reload">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin="" data-turbo-track="reload"/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
          crossorigin="" defer data-turbo-track="reload"></script>
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.19/index.global.min.js" defer data-turbo-track="reload"></script>
  <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.19/locales-all.global.min.js" defer data-turbo-track="reload"></script>
  <%# Includes all stylesheet files in app/assets/stylesheets %>
  <%= stylesheet_link_tag :"application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <style>
      .gradient-text {
          font-size: 1.5rem;
          font-weight: bold;
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          -webkit-background-clip: text;
          background-clip: text;
          color: transparent;
      }

      .icon-bg {
          width: 40px;
          height: 40px;
          border-radius: 50%;
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          display: flex;
          align-items: center;
          justify-content: center;
      }

      .gradient-btn {
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          border: none;
          color: white;
          font-weight: bold;
          padding: 0.5rem 1rem;
          border-radius: 8px;
          transition: 0.3s ease;
      }

      .gradient-btn:hover {
          filter: brightness(1.1);
          transform: scale(1.05);
      }

      .gradient-outline-btn {
          background: transparent;
          color: #34c759; /* Color inicial del texto */
          font-weight: bold;
          padding: 0.5rem 1rem;
          border: 2px solid transparent;
          border-image: linear-gradient(to right, #34c759, #c0aa40, #ff9500) 1;
          border-radius: 8px;
          transition: 0.3s ease;
      }

      .gradient-outline-btn:hover {
          background: linear-gradient(to right, #34c759, #c0aa40, #ff9500);
          color: white;
      }
  </style>
</head>
<body>
<!-- Navbar común -->

