<header>
  <div class="px-3 py-2 border-bottom">
    <div class="container">
      <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
        <a href="/" class="d-flex align-items-center my-2 my-lg-0 me-lg-auto text-decoration-none">
          <div class="d-flex align-items-center p-2" style="gap: 10px;">
            <!-- Icono -->
            <div class="d-flex align-items-center justify-content-center icon-bg rounded-circle" style="width: 50px; height: 50px;">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="url(#gradiente)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin h-6 w-6">
                <defs>
                  <linearGradient id="gradiente" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#000000"/>
                    <stop offset="100%" stop-color="#000000"/>
                  </linearGradient>
                </defs>
                <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>

            <!-- Texto -->
            <div class="d-flex flex-column">
              <span class="gradient-text">IyaiClub</span>
              <span class="text-muted" style="font-size: 0.85rem;">Descubre • Reserva • Disfruta</span>
            </div>
          </div>
        </a>
        <ul class="nav col-12 col-lg-auto my-2 justify-content-center my-md-0 text-small">
          <li><a href="/" class="nav-link text-secondary">
            <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
              <use xlink:href="#home"></use>
            </svg>
            Inicio
          </a></li>
          <% if user_signed_in? %>
            <% if current_user.administrador? %>
              <li>
                <%= link_to admin_dashboard_index_path, class: "nav-link" do %>
                  <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                    <use xlink:href="#speedometer2"></use>
                  </svg>
                  Dashboard
                <% end %>
              </li>


              <li>
                <%= link_to plan_prices_path, class: "nav-link" do %>
                  <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                    <use xlink:href="#diamond"></use>
                  </svg>
                  Planes de pago
                <% end %>
              </li>

            <% end %>
            <% if current_user.afiliado? %>
              <li>
                <%= link_to afiliado_dashboard_index_path, class: "nav-link" do %>
                  <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                    <use xlink:href="#speedometer2"></use>
                  </svg>
                  Dashboard
                <% end %>
              </li>

            <% end %>
            <% if current_user.turista? %>
              <li>
                <%= link_to turista_dashboard_index_path, class: "nav-link" do %>
                  <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                    <use xlink:href="#speedometer2"></use>
                  </svg>
                  Dashboard
                <% end %>
              </li>

            <% end %>

          <% end %>

          <li>
            <%= link_to subscriptions_path, class: "nav-link" do %>
              <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                <use xlink:href="#card"></use>
              </svg>
              Suscripciones
            <% end %>
          </li>

          <li>
            <%= link_to countries_path, class: "nav-link" do %>
              <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                <use xlink:href="#province"></use>
              </svg>
              Paises
            <% end %>
          </li>

          <li>
            <%= link_to provinces_path, class: "nav-link" do %>
              <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                <use xlink:href="#province"></use>
              </svg>
              Provincias
            <% end %>
          </li>
          <li>
            <%= link_to cities_path, class: "nav-link" do %>
              <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                <use xlink:href="#city"></use>
              </svg>
              Ciudades
            <% end %>
          </li>

          <li>
            <%= link_to edit_user_registration_path, class: "nav-link" do %>
              <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                <use xlink:href="#people-circle"></use>
              </svg>
              Perfil
            <% end %>
          </li>
          <li>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" do %>
              <svg class="bi d-block mx-auto mb-1" width="24" height="24" aria-hidden="true">
                <use xlink:href="#exit"></use>
              </svg>
              Cerrar sesión
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  </div>

</header>


<main class="container-fluid my-4">
  <% if flash[:notice] %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="fas fa-check-circle me-2"></i><%= flash[:notice] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
  <% end %>
  <% if flash[:alert] %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i><%= flash[:alert] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
  <% end %>
  <%= yield %>
</main>
</body>
</html>
