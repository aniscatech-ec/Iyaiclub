<!DOCTYPE html>
<html>
<head>
  <title><%= content_for(:title) || "Iyaib Club App" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
  <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.19/index.global.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.19/locales-all.global.min.js" defer></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

  <%#= stylesheet_link_tag "leaflet", "data-turbo-track": "reload" %>
  <%#= javascript_include_tag "leaflet", "data-turbo-track": "reload" %>

  <!-- Scripts Swiper -->
  <%# Includes all stylesheet files in app/assets/stylesheets %>
  <%= stylesheet_link_tag :"application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <style>

  </style>
</head>
<body>
<!-- Navbar común -->


<nav class="navbar navbar-expand-lg border-bottom">
  <div class="container-fluid">
    <a class="navbar-brand d-flex flex-column" href="/">
      <%= image_tag("logo.jpeg", size: "187x77") %>
      <span class="text-muted" style="font-size: 0.85rem;">Descubre • Reserva • Disfruta</span>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarContent">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
        <li class="nav-item"><%= link_to "Inicio", root_path, class: "nav-link" %></li>

        <% if user_signed_in? %>
          <% if current_user.administrador? %>
            <li class="nav-item"><%= link_to "Dashboard", admin_dashboard_index_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Menús", menu_categories_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Planes", plans_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Planes de pago", plan_prices_path, class: "nav-link" %></li>

          <% end %>

          <% if current_user.afiliado? %>
            <li class="nav-item"><%= link_to "Dashboard", afiliado_dashboard_index_path, class: "nav-link" %></li>
          <% end %>

          <% if current_user.turista? %>
            <li class="nav-item"><%= link_to "Dashboard", turista_dashboard_index_path, class: "nav-link" %></li>
          <% end %>
        <% end %>

        <li class="nav-item"><%= link_to "Suscripciones", subscriptions_path, class: "nav-link" %></li>
        <% if user_signed_in? && current_user.administrador? %>


          <li class="nav-item"><%= link_to "Países", countries_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Provincias", provinces_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Ciudades", cities_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Logs", booking_requests_path, class: "nav-link" %></li>
        <% end %>

        <li class="nav-item"><%= link_to "Perfil", edit_user_registration_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "Cerrar sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %></li>
      </ul>
    </div>
  </div>
</nav>
<!-- Barra tipo Booking -->
<%= render "shared/navigation_bar" %>

<main class="container-fluid">
  <%= yield %>
</main>
</body>
<!-- Bootstrap Icons -->
<!--<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css" rel="stylesheet">-->
</html>
