<div class="container-fluid px-3 px-md-4 py-4">

  <%# ── Acciones rápidas ── %>
  <div class="d-flex flex-wrap gap-2 mb-4">
    <%= link_to owner_memberships_path, class: "btn btn-outline-primary" do %>
      <i class="fas fa-id-card me-1"></i> Gestionar Membresías
    <% end %>
    <% if @events.any? %>
      <div class="dropdown">
        <button class="btn btn-outline-warning dropdown-toggle" type="button" data-bs-toggle="dropdown">
          <i class="fas fa-ticket-alt me-1"></i> Gestionar Tickets
        </button>
        <ul class="dropdown-menu">
          <% @events.each do |event| %>
            <li>
              <%= link_to owner_stand_event_tickets_path(event), class: "dropdown-item" do %>
                <i class="fas fa-calendar-alt me-1 text-muted"></i> <%= event.name %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <%# ── Header ── %>
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
      <h3 class="fw-bold mb-1">
        <i class="fas fa-store me-2" style="color: var(--brand-orange);"></i>
        Mi Stand
      </h3>
      <p class="text-muted mb-0 small">
        <code style="color: var(--brand-orange);"><%= @stand.stand_code %></code>
        <% if @stand.location.present? %>
          &bull; <i class="fas fa-map-marker-alt ms-1 me-1"></i><%= @stand.location %>
        <% end %>
      </p>
    </div>
    <span class="badge <%= @stand.activo? ? 'bg-success' : 'bg-warning text-dark' %> fs-6 px-3 py-2">
      <%= @stand.activo? ? "Activo" : "Reservado" %>
    </span>
  </div>

  <%# ── Tarjetas resumen ── %>
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="fs-2 fw-bold text-success"><%= @total_tickets_sold %></div>
        <div class="small text-muted"><i class="fas fa-ticket-alt me-1"></i>Tickets vendidos</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="fs-2 fw-bold text-warning"><%= @total_tickets_pending %></div>
        <div class="small text-muted"><i class="fas fa-clock me-1"></i>Pendientes</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="fs-2 fw-bold text-primary"><%= @events.count %></div>
        <div class="small text-muted"><i class="fas fa-calendar-alt me-1"></i>Eventos</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-4 text-center p-3">
        <div class="fs-2 fw-bold" style="color: var(--brand-orange);">
          <i class="fas fa-store" style="font-size: 1.5rem;"></i>
        </div>
        <div class="small text-muted">Venta directa</div>
        <div class="badge bg-warning text-dark mt-1" style="font-size: .65rem;">Stand autónomo</div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <%# ── Columna izquierda: datos + eventos ── %>
    <div class="col-12 col-lg-4">

      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2">
          <h6 class="fw-bold mb-0"><i class="fas fa-store me-2 text-warning"></i>Datos del Stand</h6>
        </div>
        <div class="card-body p-4 pt-2">
          <ul class="list-unstyled mb-0">
            <li class="d-flex align-items-center py-2 border-bottom">
              <i class="fas fa-barcode text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Código</small>
                <code class="fw-semibold" style="color: var(--brand-orange);"><%= @stand.stand_code %></code>
              </div>
            </li>
            <li class="d-flex align-items-center py-2 border-bottom">
              <i class="fas fa-tag text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Nombre</small>
                <span class="fw-semibold small"><%= @stand.name %></span>
              </div>
            </li>
            <li class="d-flex align-items-center py-2 border-bottom">
              <i class="fas fa-map-marker-alt text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Ubicación</small>
                <span class="fw-semibold small"><%= @stand.location.presence || "—" %></span>
              </div>
            </li>
            <li class="d-flex align-items-center py-2">
              <i class="fas fa-user-tie text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Propietario</small>
                <span class="fw-semibold small"><%= current_user.name %></span>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <%# Eventos asignados %>
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2 d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0"><i class="fas fa-calendar-alt me-2 text-primary"></i>Eventos</h6>
          <span class="badge bg-secondary rounded-pill"><%= @events.count %></span>
        </div>
        <div class="card-body p-4 pt-2">
          <% if @events.any? %>
            <ul class="list-unstyled mb-0">
              <% @events.each do |event| %>
                <% ev_slot = @stand_event_vendedores.find { |ev| ev.event_id == event.id } %>
                <li class="py-2 border-bottom">
                  <span class="fw-semibold small d-block"><%= event.name %></span>
                  <div class="d-flex align-items-center justify-content-between mt-1">
                    <small class="text-muted">
                      <i class="fas fa-calendar-day me-1"></i>
                      <%= event.event_date&.strftime("%d/%m/%Y") || "—" %>
                    </small>
                    <% if ev_slot %>
                      <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2" style="font-size:.7rem;">
                        <i class="fas fa-ticket-alt me-1"></i><%= ev_slot.tickets_sold %> vendidos
                      </span>
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-muted small mb-0">No hay eventos asignados aún.</p>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Columna derecha: ventas por evento ── %>
    <div class="col-12 col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2 d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0">
            <i class="fas fa-chart-bar me-2 text-success"></i>Ventas del Stand por Evento
          </h6>
          <span class="badge bg-warning text-dark rounded-pill">
            <i class="fas fa-store me-1"></i>Venta directa
          </span>
        </div>
        <div class="card-body p-4 pt-2">
          <% if @stand_event_vendedores.any? %>
            <% @stand_event_vendedores.each_with_index do |ev_slot, idx| %>
              <% sold    = ev_slot.tickets_sold %>
              <% pending = ev_slot.tickets_pending %>
              <% has_q   = ev_slot.quota.present? %>
              <% pct     = has_q ? ev_slot.quota_progress_percent : nil %>
              <% bar_cls = if !has_q        then "bg-info"
                           elsif pct >= 100 then "bg-success"
                           elsif pct >= 60  then "bg-warning"
                           else                  "bg-danger"
                           end %>

              <% unless idx == 0 %><hr class="my-3"><% end %>

              <%# Cabecera del evento %>
              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <div>
                  <span class="fw-semibold"><%= ev_slot.event.name %></span>
                  <small class="text-muted ms-2">
                    <i class="fas fa-calendar-day me-1"></i><%= ev_slot.event.event_date&.strftime("%d/%m/%Y") || "—" %>
                  </small>
                </div>
                <div class="d-flex gap-2">
                  <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2">
                    <i class="fas fa-ticket-alt me-1"></i><%= sold %> vendidos
                  </span>
                  <% if pending > 0 %>
                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill px-2">
                      <i class="fas fa-clock me-1"></i><%= pending %> pendientes
                    </span>
                  <% end %>
                </div>
              </div>

              <%# Cuota + progreso %>
              <div class="row g-3 align-items-center">
                <div class="col-12 col-md-4">
                  <div class="border rounded-3 p-3 text-center">
                    <div class="small text-muted mb-1">Cuota asignada</div>
                    <% if has_q %>
                      <div class="fw-bold fs-5"><%= ev_slot.quota %></div>
                      <div class="small text-muted">tickets</div>
                    <% else %>
                      <div class="fw-bold fs-5 text-info">∞</div>
                      <div class="small text-muted">Sin límite</div>
                    <% end %>
                  </div>
                </div>
                <div class="col-12 col-md-4">
                  <div class="border rounded-3 p-3 text-center">
                    <div class="small text-muted mb-1">Tickets vendidos</div>
                    <div class="fw-bold fs-5 text-success"><%= sold %></div>
                    <% if has_q %>
                      <div class="small text-muted">de <%= ev_slot.quota %></div>
                    <% end %>
                  </div>
                </div>
                <div class="col-12 col-md-4">
                  <div class="border rounded-3 p-3 text-center">
                    <div class="small text-muted mb-1">Pendientes</div>
                    <div class="fw-bold fs-5 <%= pending > 0 ? 'text-warning' : 'text-muted' %>"><%= pending %></div>
                    <div class="small text-muted">transferencias</div>
                  </div>
                </div>
              </div>

              <% if has_q %>
                <div class="mt-3">
                  <div class="d-flex justify-content-between small text-muted mb-1">
                    <span>Progreso de cuota</span>
                    <span><%= pct %>%</span>
                  </div>
                  <div class="progress" style="height: 10px;">
                    <div class="progress-bar <%= bar_cls %>" role="progressbar" style="width:<%= pct %>%"></div>
                  </div>
                  <% if ev_slot.quota_met? %>
                    <div class="mt-2">
                      <span class="badge bg-primary"><i class="fas fa-check-circle me-1"></i>Cuota completada</span>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <div class="mt-2">
                <span class="badge <%= ev_slot.active? ? 'bg-success' : 'bg-secondary' %>">
                  <%= ev_slot.active? ? "Activo en evento" : "Inactivo" %>
                </span>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="fas fa-calendar-times fa-3x mb-3 opacity-25"></i>
              <p class="mb-1 fw-semibold">Sin ventas registradas</p>
              <p class="small">El stand aún no está asignado a ningún evento.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

</div>
