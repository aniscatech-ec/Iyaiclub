<div class="container-fluid px-3 px-md-4 py-4">

  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><%= link_to "Mi Stand", owner_stand_path %></li>
      <li class="breadcrumb-item active">Vendedores</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="fas fa-users me-2 text-success"></i>Vendedores del Stand</h4>
    <%= link_to new_owner_stand_vendedor_path, class: "btn btn-success" do %>
      <i class="fas fa-user-plus me-1"></i> Asignar Vendedor
    <% end %>
  </div>

  <% if @vendors_by_event.any? %>
    <% @vendors_by_event.each do |event, vendors| %>
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2 d-flex justify-content-between align-items-center">
          <div>
            <h6 class="fw-bold mb-0">
              <i class="fas fa-calendar-alt me-2 text-primary"></i><%= event.name %>
            </h6>
            <small class="text-muted">
              <i class="fas fa-calendar-day me-1"></i>
              <%= event.event_date&.strftime("%d de %B de %Y") || "Sin fecha" %>
            </small>
          </div>
          <span class="badge bg-secondary rounded-pill"><%= vendors.count %> vendedor<%= vendors.count == 1 ? "" : "es" %></span>
        </div>
        <div class="card-body p-4 pt-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Vendedor</th>
                  <th>Estado</th>
                  <th>Cuota</th>
                  <th>Vendidos</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% vendors.each do |ev| %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center gap-2">
                        <div class="avatar-circle bg-success-subtle text-success rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;flex-shrink:0;">
                          <i class="fas fa-user small"></i>
                        </div>
                        <div>
                          <div class="fw-semibold small"><%= ev.user.name %></div>
                          <small class="text-muted"><%= ev.user.email %></small>
                        </div>
                      </div>
                    </td>
                    <td>
                      <span class="badge <%= ev.active? ? 'bg-success' : 'bg-secondary' %>">
                        <%= ev.active? ? "Activo" : "Inactivo" %>
                      </span>
                    </td>
                    <td>
                      <% if ev.quota.present? %>
                        <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill px-2">
                          <%= ev.quota %> tickets
                        </span>
                      <% else %>
                        <span class="text-muted small">Sin límite</span>
                      <% end %>
                    </td>
                    <td>
                      <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2">
                        <i class="fas fa-ticket-alt me-1"></i><%= ev.tickets_sold %>
                      </span>
                      <% if ev.tickets_pending > 0 %>
                        <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill px-2 ms-1">
                          <i class="fas fa-clock me-1"></i><%= ev.tickets_pending %>
                        </span>
                      <% end %>
                    </td>
                    <td>
                      <%= link_to owner_stand_vendedor_path(ev),
                          data: { turbo_method: :delete,
                                  turbo_confirm: "¿Quitar a #{ev.user.name} del stand en este evento?" },
                          class: "btn btn-sm btn-outline-danger" do %>
                        <i class="fas fa-user-minus me-1"></i>Quitar
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-5 text-center text-muted">
        <i class="fas fa-users fa-3x mb-3 opacity-50"></i>
        <p class="fw-semibold mb-1">No hay vendedores asignados aún.</p>
        <p class="small mb-3">Asigna vendedores para que puedan vender tickets en nombre de tu stand.</p>
        <%= link_to new_owner_stand_vendedor_path, class: "btn btn-success" do %>
          <i class="fas fa-user-plus me-1"></i> Asignar primer vendedor
        <% end %>
      </div>
    </div>
  <% end %>

</div>
