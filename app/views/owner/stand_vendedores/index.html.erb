<div class="container-fluid px-3 px-md-4 py-4">

  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><%= link_to "Mi Stand", owner_stand_path %></li>
      <li class="breadcrumb-item active">Vendedores</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="fas fa-users me-2 text-success"></i>Vendedores del Stand</h4>
  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
      <% if @vendors.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Vendedor</th>
                <th>Evento</th>
                <th>Estado</th>
                <th>Cuota</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @vendors.each do |ev| %>
                <tr>
                  <td>
                    <div class="fw-semibold small"><%= ev.user.name %></div>
                    <small class="text-muted"><%= ev.user.email %></small>
                  </td>
                  <td><small><%= ev.event.name %></small></td>
                  <td>
                    <span class="badge <%= ev.active? ? 'bg-success' : 'bg-secondary' %>">
                      <%= ev.active? ? "Activo" : "Inactivo" %>
                    </span>
                  </td>
                  <td>
                    <% if ev.quota.present? %>
                      <small><%= ev.tickets_sold %> / <%= ev.quota %></small>
                    <% else %>
                      <small class="text-muted">Sin límite</small>
                    <% end %>
                  </td>
                  <td>
                    <%= link_to owner_stand_vendedor_path(ev),
                        data: { turbo_method: :delete, turbo_confirm: "¿Quitar a #{ev.user.name} del stand?" },
                        class: "btn btn-sm btn-outline-danger" do %>
                      <i class="fas fa-user-minus"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-5 text-muted">
          <i class="fas fa-users fa-3x mb-3 opacity-50"></i>
          <p class="mb-0">No hay vendedores asignados a tu stand aún.</p>
        </div>
      <% end %>
    </div>
  </div>

</div>
