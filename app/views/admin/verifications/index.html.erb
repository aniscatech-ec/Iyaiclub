<div class="container-fluid px-3 px-md-4 py-4">

  <%# ── Header ── %>
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
      <h3 class="fw-bold mb-1">Establecimientos pendientes de aprobación</h3>
      <p class="text-muted mb-0 small">Revisa los establecimientos registrados por afiliados y aprueba o rechaza su publicación.</p>
    </div>
  </div>

  <%# ── Filtros + búsqueda ── %>
  <%= form_with url: admin_verifications_path, method: :get, local: true, data: { turbo: false } do |f| %>
    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-body p-3">
        <div class="row g-2 align-items-end">

          <%# Búsqueda libre %>
          <div class="col-12 col-md-4">
            <label class="form-label small fw-semibold mb-1">Buscar</label>
            <div class="input-group input-group-sm">
              <span class="input-group-text"><i class="fas fa-search"></i></span>
              <%= f.text_field :q, value: params[:q], class: "form-control",
                    placeholder: "Nombre, socio, email..." %>
            </div>
          </div>

          <%# Estado %>
          <div class="col-6 col-md-2">
            <label class="form-label small fw-semibold mb-1">Estado</label>
            <%= f.select :status,
                  [["Pendientes", "pending"], ["Aprobados", "approved"],
                   ["Rechazados", "rejected"], ["Todos", "all"]],
                  { selected: @status_filter },
                  class: "form-select form-select-sm" %>
          </div>

          <%# Tipo de establecimiento %>
          <div class="col-6 col-md-2">
            <label class="form-label small fw-semibold mb-1">Tipo</label>
            <%= f.select :category,
                  [["Todos los tipos", ""]] +
                  Establishment.categories.keys.map { |k| [k.humanize.titleize, k] },
                  { selected: params[:category] },
                  class: "form-select form-select-sm" %>
          </div>

          <%# Afiliado %>
          <div class="col-8 col-md-3">
            <label class="form-label small fw-semibold mb-1">Socio afiliado</label>
            <%= f.select :user_id,
                  [["Todos los socios", ""]] +
                  @afiliados.map { |u| ["#{u.name} (#{u.email})", u.id] },
                  { selected: params[:user_id] },
                  class: "form-select form-select-sm" %>
          </div>

          <div class="col-4 col-md-1">
            <%= f.submit "Filtrar", class: "btn btn-primary btn-sm w-100" %>
          </div>

        </div>
      </div>
    </div>
  <% end %>

  <%# ── Tabla ── %>
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
      <% if @establishments.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Establecimiento</th>
                <th>Socio</th>
                <th class="d-none d-md-table-cell">Tipo</th>
                <th class="d-none d-lg-table-cell">Registrado</th>
                <th>Estado</th>
                <th class="text-end pe-4">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @establishments.each do |est| %>
                <% v = est.verification %>
                <tr>
                  <td class="ps-4">
                    <div class="fw-semibold"><%= est.name %></div>
                    <small class="text-muted"><%= est.city&.name %>, <%= est.country&.name %></small>
                  </td>
                  <td>
                    <div class="fw-semibold small"><%= est.user.name %></div>
                    <small class="text-muted"><%= est.user.email %></small>
                  </td>
                  <td class="d-none d-md-table-cell">
                    <span class="badge bg-secondary rounded-pill"><%= est.category&.humanize %></span>
                  </td>
                  <td class="d-none d-lg-table-cell">
                    <small class="text-muted"><%= est.created_at.strftime("%d/%m/%Y") %></small>
                  </td>
                  <td>
                    <% badge = case est.approval_status
                       when "pending"  then ["bg-warning text-dark", "Pendiente"]
                       when "approved" then ["bg-success", "Aprobado"]
                       when "rejected" then ["bg-danger",  "Rechazado"]
                       else ["bg-secondary", est.approval_status]
                       end %>
                    <span class="badge <%= badge[0] %> rounded-pill"><%= badge[1] %></span>
                  </td>
                  <td class="text-end pe-4">
                    <% if v %>
                      <%= link_to admin_verification_path(v), class: "btn btn-sm btn-outline-primary rounded-pill" do %>
                        <i class="fas fa-eye me-1"></i> Gestionar
                      <% end %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-5 text-muted">
          <i class="fas fa-check-circle fa-3x mb-3 text-success opacity-50"></i>
          <p class="fw-semibold mb-1">No hay establecimientos con ese filtro</p>
          <small>Prueba cambiando los criterios de búsqueda</small>
        </div>
      <% end %>
    </div>
  </div>

</div>
