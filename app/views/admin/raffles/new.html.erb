<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-plus-circle me-2" style="color: var(--brand-orange);"></i>
      Nuevo Sorteo - <%= @event.name %>
    </h3>
    <%= link_to admin_event_raffles_path(@event), class: "btn btn-outline-secondary" do %>
      <i class="fas fa-arrow-left me-1"></i> Volver
    <% end %>
  </div>

  <div class="row">
    <div class="col-12 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-trophy me-2 text-warning"></i>
            Datos del Sorteo
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <%= form_with(model: [:admin, @event, @raffle], local: true) do |form| %>
            <% if @raffle.errors.any? %>
              <div class="alert alert-danger">
                <ul class="mb-0">
                  <% @raffle.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :prize, "Premio", class: "form-label fw-bold" %>
              <%= form.text_field :prize, class: "form-control", placeholder: "Ej: Auto 0 KM, Moto eléctrica, Viaje todo incluido" %>
            </div>

            <div class="mb-3">
              <%= form.label :draw_date, "Fecha programada del sorteo", class: "form-label fw-bold" %>
              <%= form.datetime_field :draw_date, class: "form-control" %>
              <small class="text-muted">Opcional. Puedes realizar el sorteo en cualquier momento.</small>
            </div>

            <div class="alert alert-info">
              <i class="fas fa-info-circle me-1"></i>
              Este sorteo se realizará entre los <strong><%= @event.tickets.participantes.count %> tickets activos</strong> del evento "<%= @event.name %>".
            </div>

            <div class="d-flex gap-2">
              <%= form.submit "Crear Sorteo", class: "btn btn-primary" %>
              <%= link_to "Cancelar", admin_event_raffles_path(@event), class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
