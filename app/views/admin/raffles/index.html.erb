<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-trophy me-2" style="color: var(--brand-orange);"></i>
      Sorteos - <%= @event.name %>
    </h3>
    <div class="d-flex gap-2">
      <%= link_to new_admin_event_raffle_path(@event), class: "btn btn-success" do %>
        <i class="fas fa-plus me-1"></i> Nuevo Sorteo
      <% end %>
      <%= link_to admin_event_path(@event), class: "btn btn-outline-secondary" do %>
        <i class="fas fa-arrow-left me-1"></i> Volver al evento
      <% end %>
    </div>
  </div>

  <% if @raffles.any? %>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Premio</th>
                <th>Estado</th>
                <th>N° Ganador</th>
                <th>Ganador</th>
                <th>Fecha Sorteo</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @raffles.each do |raffle| %>
                <tr>
                  <td><strong><%= raffle.prize %></strong></td>
                  <td><span class="badge <%= raffle.status == 'realizado' ? 'bg-success' : 'bg-secondary' %>"><%= raffle.status.humanize %></span></td>
                  <td>
                    <% if raffle.winning_number.present? %>
                      <span class="badge bg-warning text-dark fs-6"><%= raffle.winning_number %></span>
                    <% else %>
                      <span class="text-muted">-</span>
                    <% end %>
                  </td>
                  <td>
                    <% if raffle.winner.present? %>
                      <strong><%= raffle.winner.guest_name %></strong>
                    <% else %>
                      <span class="text-muted">Pendiente</span>
                    <% end %>
                  </td>
                  <td>
                    <small><%= raffle.draw_date&.strftime('%d/%m/%Y %H:%M') || '-' %></small>
                  </td>
                  <td>
                    <div class="btn-group btn-group-sm">
                      <%= link_to admin_event_raffle_path(@event, raffle), class: "btn btn-outline-info" do %>
                        <i class="fas fa-eye"></i>
                      <% end %>
                      <% if raffle.pendiente? %>
                        <%= link_to draw_winner_admin_event_raffle_path(@event, raffle),
                            data: { turbo_method: :patch, turbo_confirm: "¿Realizar sorteo ahora? Se seleccionará un ganador aleatorio." },
                            class: "btn btn-outline-warning" do %>
                          <i class="fas fa-random"></i>
                        <% end %>
                      <% end %>
                      <%= link_to admin_event_raffle_path(@event, raffle), method: :delete,
                          data: { turbo_method: :delete, turbo_confirm: "¿Eliminar este sorteo?" },
                          class: "btn btn-outline-danger" do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body text-center py-5">
        <i class="fas fa-trophy fa-3x text-muted mb-3"></i>
        <h5 class="fw-bold">No hay sorteos</h5>
        <p class="text-muted">Crea un sorteo para este evento.</p>
        <%= link_to new_admin_event_raffle_path(@event), class: "btn btn-success" do %>
          <i class="fas fa-plus me-1"></i> Crear sorteo
        <% end %>
      </div>
    </div>
  <% end %>
</div>
