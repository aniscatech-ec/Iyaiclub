<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-trophy me-2" style="color: var(--brand-orange);"></i>
      Sorteo: <%= @raffle.prize %>
    </h3>
    <div class="d-flex gap-2">
      <% if @raffle.pendiente? %>
        <button class="btn btn-warning fw-semibold" data-bs-toggle="modal" data-bs-target="#drawModal">
          <i class="fas fa-random me-1"></i> Realizar Sorteo
        </button>
      <% end %>
      <%= link_to admin_event_raffles_path(@event), class: "btn btn-outline-secondary" do %>
        <i class="fas fa-arrow-left me-1"></i> Volver
      <% end %>
    </div>
  </div>

  <div class="row">
    <div class="col-12 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-info-circle me-2 text-primary"></i>
            Información del Sorteo
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Evento</span>
              <strong><%= @event.name %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Premio</span>
              <strong><%= @raffle.prize %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Estado</span>
              <span class="badge <%= @raffle.realizado? ? 'bg-success' : 'bg-secondary' %>"><%= @raffle.status.humanize %></span>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Fecha realizado</span>
              <strong><%= @raffle.draw_date&.strftime('%d/%m/%Y %H:%M') || 'Pendiente' %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Tickets participantes</span>
              <strong><%= @event.tickets.participantes.count %></strong>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-6">
      <% if @raffle.realizado? && @winner.present? %>
        <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: linear-gradient(135deg, #FFF8E1, #FFE082); border-left: 5px solid #F57F17 !important;">
          <div class="card-body py-4 px-4">
            <div class="text-center mb-3">
              <i class="fas fa-trophy fa-3x mb-2" style="color: #F57F17;"></i>
              <h4 class="fw-bold mb-0" style="color: #E65100;">¡Ganador del Sorteo!</h4>
            </div>
            <div class="text-center mb-4">
              <small class="text-muted d-block">Número ganador</small>
              <div class="fw-bold" style="font-size: 56px; color: #E65100; line-height:1;">#<%= @raffle.winning_number %></div>
            </div>
            <div class="card border-0 shadow-sm rounded-3 p-4">
              <div class="d-flex align-items-center gap-3 mb-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                     style="width:48px;height:48px;background:var(--brand-orange);font-size:1.2rem;flex-shrink:0;">
                  <%= @winner.guest_name.first.upcase %>
                </div>
                <div>
                  <div class="fw-bold fs-5"><%= @winner.guest_name %></div>
                  <div class="text-muted small"><%= @winner.guest_email %></div>
                </div>
              </div>
              <hr class="my-2">
              <div class="row g-2 small">
                <div class="col-6">
                  <span class="text-muted">Código ticket</span>
                  <div class="fw-semibold" style="color:#2E7D32;"><%= @winner.ticket_code %></div>
                </div>
                <div class="col-6">
                  <span class="text-muted">Evento</span>
                  <div class="fw-semibold"><%= @winner.event_name %></div>
                </div>
                <% if @winner.user.present? %>
                  <div class="col-6">
                    <span class="text-muted">Usuario registrado</span>
                    <div class="fw-semibold"><%= @winner.user.email %></div>
                  </div>
                  <% if @winner.user.phone.present? %>
                    <div class="col-6">
                      <span class="text-muted">Teléfono</span>
                      <div class="fw-semibold"><%= @winner.user.phone %></div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% elsif @raffle.realizado? && @winner.nil? %>
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-body text-center py-4">
            <i class="fas fa-trophy fa-3x mb-2" style="color: #F57F17;"></i>
            <h5 class="fw-bold">Número ganador: #<%= @raffle.winning_number %></h5>
            <p class="text-muted">El ticket ganador no fue encontrado (posiblemente cancelado).</p>
          </div>
        </div>
      <% elsif @raffle.pendiente? %>
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-body text-center py-5">
            <i class="fas fa-hourglass-half fa-3x text-muted mb-3"></i>
            <h5 class="fw-bold">Sorteo Pendiente</h5>
            <p class="text-muted">Este sorteo aún no ha sido realizado.</p>
            <button class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#drawModal">
              <i class="fas fa-random me-1"></i> Realizar Sorteo
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Modal de sorteo con animación -->
<% if @raffle.pendiente? %>
  <div class="modal fade" id="drawModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 rounded-4 overflow-hidden">

        <%# Estado: confirmación inicial %>
        <div id="drawStep1">
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-bold">
              <i class="fas fa-random me-2" style="color:var(--brand-orange);"></i>
              Realizar Sorteo
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body text-center py-4">
            <i class="fas fa-ticket-alt fa-3x mb-3 text-muted"></i>
            <p class="mb-1">Se sortearán <strong><%= @event.tickets.participantes.count %> tickets</strong> participantes.</p>
            <p class="text-muted small mb-0">Premio: <strong><%= @raffle.prize %></strong></p>
          </div>
          <div class="modal-footer border-0 pt-0">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="button" class="btn btn-warning fw-semibold" onclick="startDraw()">
              <i class="fas fa-play me-1"></i> ¡Iniciar Sorteo!
            </button>
          </div>
        </div>

        <%# Estado: animación ruleta %>
        <div id="drawStep2" style="display:none;">
          <div class="modal-body text-center py-5" style="background: linear-gradient(135deg, #1a1a2e, #16213e);">
            <p class="text-white mb-2 fw-semibold">Sorteando entre <%= @event.tickets.participantes.count %> tickets...</p>
            <div id="rouletteDisplay"
                 style="font-size:72px; font-weight:900; font-family:monospace; color:#F57F17;
                        text-shadow: 0 0 20px #F57F17; letter-spacing:4px; min-height:100px;
                        display:flex; align-items:center; justify-content:center;">
              ?????
            </div>
            <p class="text-muted small mt-2">🎰 Eligiendo el número ganador...</p>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script>
    function startDraw() {
      document.getElementById('drawStep1').style.display = 'none';
      document.getElementById('drawStep2').style.display = 'block';

      const display = document.getElementById('rouletteDisplay');
      let speed = 50;
      let elapsed = 0;
      const total = 3500; // ms de animación

      function tick() {
        display.textContent = String(Math.floor(Math.random() * 90000) + 10000);
        elapsed += speed;
        // desacelera progresivamente en el último tercio
        if (elapsed > total * 0.65) speed = Math.min(speed + 18, 500);
        if (elapsed < total) {
          setTimeout(tick, speed);
        } else {
          // una vez termina la animación, envía el request al servidor
          submitDraw();
        }
      }
      tick();
    }

    function submitDraw() {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '<%= draw_winner_admin_event_raffle_path(@event, @raffle) %>';
      const method = document.createElement('input');
      method.type  = 'hidden';
      method.name  = '_method';
      method.value = 'PATCH';
      const token  = document.createElement('input');
      token.type   = 'hidden';
      token.name   = '<%= request_forgery_protection_token %>';
      token.value  = '<%= form_authenticity_token %>';
      form.appendChild(method);
      form.appendChild(token);
      document.body.appendChild(form);
      form.submit();
    }
  </script>
<% end %>
