<%= form_with model: [:admin, shared_raffle], local: true do |f| %>
  <% if shared_raffle.errors.any? %>
    <div class="alert alert-danger mb-4">
      <ul class="mb-0">
        <% shared_raffle.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-transparent border-0 pt-4 px-4">
      <h6 class="fw-bold mb-0"><i class="fas fa-info-circle me-2 text-primary"></i>Información del Sorteo</h6>
    </div>
    <div class="card-body px-4 pb-4">
      <div class="mb-3">
        <%= f.label :name, "Nombre del sorteo", class: "form-label fw-semibold" %>
        <%= f.text_field :name, class: "form-control", placeholder: "Ej: Gran Rifa Anual 2026", required: true %>
      </div>
      <div class="mb-3">
        <%= f.label :prize, "Premio", class: "form-label fw-semibold" %>
        <%= f.text_field :prize, class: "form-control", placeholder: "Ej: iPhone 15 Pro + $500 en efectivo", required: true %>
      </div>
      <div class="mb-3">
        <%= f.label :draw_date, "Fecha del sorteo", class: "form-label fw-semibold" %>
        <%= f.datetime_local_field :draw_date, class: "form-control" %>
        <div class="form-text">Opcional — solo referencial, no ejecuta el sorteo automáticamente.</div>
      </div>
      <div class="mb-3">
        <%= f.label :description, "Descripción", class: "form-label fw-semibold" %>
        <%= f.text_area :description, class: "form-control", rows: 3,
            placeholder: "Información adicional sobre el sorteo, bases, condiciones..." %>
      </div>
    </div>
  </div>

  <% if shared_raffle.new_record? && defined?(@available_events) && @available_events.any? %>
    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-header bg-transparent border-0 pt-4 px-4">
        <h6 class="fw-bold mb-0"><i class="fas fa-calendar-alt me-2 text-info"></i>Eventos participantes</h6>
      </div>
      <div class="card-body px-4 pb-4">
        <div class="form-text mb-3">
          <i class="fas fa-info-circle me-1 text-info"></i>
          Selecciona los eventos cuyos tickets participarán en este sorteo.
          Los tickets existentes se incluyen automáticamente.
        </div>
        <div class="row g-2">
          <% @available_events.each do |event| %>
            <div class="col-12 col-md-6">
              <div class="form-check border rounded-3 p-3">
                <input type="checkbox" name="event_ids[]" value="<%= event.id %>"
                       id="event_<%= event.id %>" class="form-check-input">
                <label class="form-check-label w-100" for="event_<%= event.id %>">
                  <strong><%= event.name %></strong>
                  <br>
                  <small class="text-muted">
                    <%= event.event_date&.strftime('%d/%m/%Y') %>
                    · <%= event.tickets.participantes.count %> tickets activos
                  </small>
                </label>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="d-flex gap-2">
    <%= f.submit shared_raffle.new_record? ? "Crear Sorteo" : "Guardar Cambios",
        class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancelar", admin_shared_raffles_path, class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
