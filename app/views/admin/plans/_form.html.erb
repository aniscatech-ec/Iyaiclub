<%= form_with(model: [:admin, @plan], local: true, class: "needs-validation") do |form| %>
  <% if @plan.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @plan.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-12 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-info-circle me-2 text-primary"></i>
            Información Básica
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="mb-3">
            <%= form.label :name, "Nombre del Plan", class: "form-label fw-bold" %>
            <%= form.text_field :name, class: "form-control", placeholder: "Ej: Gold, Platinum, Básico" %>
          </div>

          <div class="mb-3">
            <%= form.label :plan_key, "Clave del Plan", class: "form-label fw-bold" %>
            <%= form.select :plan_key, [
              ["Free", "free"],
              ["Básico", "basico"],
              ["Bronce", "bronce"],
              ["Gold", "gold"],
              ["Platinum", "platinum"],
              ["Gold Estudiantil", "gold_estudiantil"]
            ], { prompt: "Seleccione..." }, class: "form-select" %>
            <small class="text-muted">Identifica el nivel del plan para el sistema de permisos</small>
          </div>

          <div class="mb-3">
            <%= form.label :description, "Descripción", class: "form-label fw-bold" %>
            <%= form.text_area :description, class: "form-control", rows: 3 %>
          </div>

          <div class="row">
            <div class="col-6">
              <div class="mb-3">
                <%= form.label :sort_order, "Orden", class: "form-label fw-bold" %>
                <%= form.number_field :sort_order, class: "form-control", min: 0 %>
              </div>
            </div>
            <div class="col-6">
              <div class="mb-3 pt-4">
                <div class="form-check form-switch">
                  <%= form.check_box :is_active, class: "form-check-input", role: "switch" %>
                  <%= form.label :is_active, "Plan Activo", class: "form-check-label" %>
                </div>
                <div class="form-check form-switch">
                  <%= form.check_box :is_student_plan, class: "form-check-input", role: "switch" %>
                  <%= form.label :is_student_plan, "Plan Estudiantil", class: "form-check-label" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-percentage me-2 text-success"></i>
            Descuentos
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="row">
            <div class="col-6">
              <div class="mb-3">
                <%= form.label :discount_percentage, "Descuento Máximo (%)", class: "form-label fw-bold" %>
                <%= form.number_field :discount_percentage, class: "form-control", min: 0, max: 100 %>
              </div>
            </div>
            <div class="col-6">
              <div class="mb-3">
                <%= form.label :fixed_discount, "Descuento Fijo (%)", class: "form-label fw-bold" %>
                <%= form.number_field :fixed_discount, class: "form-control", min: 0, max: 100 %>
                <small class="text-muted">Adicional al descuento máximo</small>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-coins me-2 text-warning"></i>
            Sistema de Puntos
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="row">
            <div class="col-6">
              <div class="mb-3">
                <%= form.label :points_earned, "Puntos Ganados", class: "form-label fw-bold" %>
                <%= form.number_field :points_earned, class: "form-control", min: 1 %>
              </div>
            </div>
            <div class="col-6">
              <div class="mb-3">
                <%= form.label :dollars_per_point, "Por cada $ USD", class: "form-label fw-bold" %>
                <%= form.number_field :dollars_per_point, class: "form-control", min: 1 %>
              </div>
            </div>
          </div>
          <p class="text-muted small mb-0">
            <i class="fas fa-info-circle me-1"></i>
            Ejemplo: 2 puntos por cada $3 gastados
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-swimming-pool me-2 text-info"></i>
            Beneficio Piscinas
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="row">
            <div class="col-4">
              <div class="mb-3">
                <%= form.label :pool_visits_per_year, "Visitas/Año", class: "form-label fw-bold" %>
                <%= form.number_field :pool_visits_per_year, class: "form-control", min: 0 %>
              </div>
            </div>
            <div class="col-4">
              <div class="mb-3">
                <%= form.label :pool_level, "Nivel", class: "form-label fw-bold" %>
                <%= form.select :pool_level, [["-", 0], ["Nivel 1", 1], ["Nivel 2", 2]], {}, class: "form-select" %>
              </div>
            </div>
            <div class="col-4">
              <div class="mb-3">
                <%= form.label :max_pool_guests, "Máx. Personas", class: "form-label fw-bold" %>
                <%= form.number_field :max_pool_guests, class: "form-control", min: 0 %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-bed me-2 text-primary"></i>
            Noches Gratis
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="row">
            <div class="col-4">
              <div class="mb-3">
                <%= form.label :free_nights, "Noches", class: "form-label fw-bold" %>
                <%= form.number_field :free_nights, class: "form-control", min: 0 %>
              </div>
            </div>
            <div class="col-4">
              <div class="mb-3">
                <%= form.label :free_days, "Días", class: "form-label fw-bold" %>
                <%= form.number_field :free_days, class: "form-control", min: 0 %>
              </div>
            </div>
            <div class="col-4">
              <div class="mb-3">
                <%= form.label :max_lodging_guests, "Máx. Huéspedes", class: "form-label fw-bold" %>
                <%= form.number_field :max_lodging_guests, class: "form-control", min: 0 %>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-6">
              <div class="form-check">
                <%= form.check_box :includes_breakfast, class: "form-check-input" %>
                <%= form.label :includes_breakfast, "Incluye Desayuno", class: "form-check-label" %>
              </div>
            </div>
            <div class="col-6">
              <div class="form-check">
                <%= form.check_box :includes_dinner, class: "form-check-input" %>
                <%= form.label :includes_dinner, "Incluye Cena", class: "form-check-label" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-calendar-check me-2 text-success"></i>
            Otros Beneficios
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="form-check form-switch">
            <%= form.check_box :events_access, class: "form-check-input", role: "switch" %>
            <%= form.label :events_access, "Acceso gratuito a eventos Iyai Club", class: "form-check-label" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mb-4">
    <%= form.submit "Guardar Plan", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_plans_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<% if @plan.persisted? %>
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
      <h5 class="fw-bold mb-0">
        <i class="fas fa-user-tie me-2 text-info"></i>
        Vendedores asignados a este plan
      </h5>
      <span class="badge bg-info"><%= @plan.plan_vendedores.count %> asignados</span>
    </div>
    <div class="card-body px-4 pb-4">

      <%# Lista de vendedores actuales %>
      <% if @plan.plan_vendedores.any? %>
        <div class="table-responsive mb-4">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Vendedor</th>
                <th>Email</th>
                <th class="text-center">Estado</th>
                <th class="text-end">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @plan.plan_vendedores.includes(:vendedor).each do |pv| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center"
                           style="width:36px;height:36px;font-size:1rem;color:#0dcaf0;">
                        <i class="fas fa-user-tie"></i>
                      </div>
                      <strong><%= pv.vendedor.name %></strong>
                    </div>
                  </td>
                  <td><small class="text-muted"><%= pv.vendedor.email %></small></td>
                  <td class="text-center">
                    <% if pv.active? %>
                      <span class="badge bg-success">Activo</span>
                    <% else %>
                      <span class="badge bg-secondary">Inactivo</span>
                    <% end %>
                  </td>
                  <td class="text-end">
                    <div class="d-flex gap-1 justify-content-end">
                      <%= button_to toggle_active_admin_plan_vendedor_path(@plan, pv),
                          method: :patch,
                          class: "btn btn-sm #{pv.active? ? 'btn-outline-warning' : 'btn-outline-success'}",
                          title: pv.active? ? "Desactivar" : "Activar" do %>
                        <i class="fas fa-<%= pv.active? ? 'pause' : 'play' %>"></i>
                      <% end %>
                      <%= button_to admin_plan_vendedor_path(@plan, pv),
                          method: :delete,
                          form: { data: { turbo_confirm: "¿Quitar a #{pv.vendedor.name} de este plan?" } },
                          class: "btn btn-sm btn-outline-danger",
                          title: "Quitar" do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted small mb-4">
          <i class="fas fa-info-circle me-1"></i>
          No hay vendedores asignados aún. Agrega uno abajo.
        </p>
      <% end %>

      <%# Formulario para añadir vendedor %>
      <% available_vendedores = User.where(role: :vendedor)
                                    .where.not(id: @plan.vendedores.pluck(:id))
                                    .order(:name) %>
      <% if available_vendedores.any? %>
        <%= form_with url: admin_plan_plan_vendedores_path(@plan), method: :post, class: "d-flex gap-2 align-items-end flex-wrap" do |f| %>
          <div class="flex-grow-1" style="min-width: 200px;">
            <label class="form-label fw-bold small mb-1">
              <i class="fas fa-plus me-1 text-success"></i>
              Agregar vendedor
            </label>
            <%= select_tag :vendedor_id,
                  options_for_select(available_vendedores.map { |v| [v.name, v.id] }),
                  prompt: "Selecciona un vendedor...",
                  class: "form-select form-select-sm" %>
          </div>
          <%= f.submit "Agregar", class: "btn btn-success btn-sm" %>
        <% end %>
      <% else %>
        <p class="text-muted small mb-0">
          <i class="fas fa-check-circle text-success me-1"></i>
          Todos los vendedores disponibles ya están asignados a este plan.
        </p>
      <% end %>

    </div>
  </div>
<% end %>
