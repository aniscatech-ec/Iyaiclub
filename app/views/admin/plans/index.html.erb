<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-crown me-2" style="color: var(--brand-orange);"></i>
      Planes de Membresía
    </h3>
    <%= link_to new_admin_plan_path, class: "btn btn-success" do %>
      <i class="fas fa-plus me-1"></i> Nuevo Plan
    <% end %>
  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Orden</th>
              <th>Nombre</th>
              <th>Descuento</th>
              <th>Puntos</th>
              <th>Piscinas</th>
              <th>Noches Gratis</th>
              <th>Estado</th>
              <th>Precios</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% @plans.each do |plan| %>
              <tr>
                <td><%= plan.sort_order %></td>
                <td>
                  <strong><%= plan.name %></strong>
                  <% if plan.is_student_plan %>
                    <span class="badge bg-info ms-1">Estudiantil</span>
                  <% end %>
                </td>
                <td>
                  <span class="badge bg-success">
                    <%= plan.discount_percentage || 0 %>%
                    <% if plan.fixed_discount.to_i > 0 %>
                      + <%= plan.fixed_discount %>% fijo
                    <% end %>
                  </span>
                </td>
                <td>
                  <small>
                    <%= plan.points_earned || 1 %> pts / $<%= plan.dollars_per_point || 5 %>
                  </small>
                </td>
                <td>
                  <% if plan.pool_visits_per_year.to_i > 0 %>
                    <%= plan.pool_visits_per_year %>/año (N<%= plan.pool_level %>)
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td>
                  <% if plan.free_nights.to_i > 0 %>
                    <%= plan.free_nights %> noches
                    <% if plan.includes_breakfast %><i class="fas fa-coffee text-warning" title="Desayuno"></i><% end %>
                    <% if plan.includes_dinner %><i class="fas fa-utensils text-warning" title="Cena"></i><% end %>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td>
                  <% if plan.is_active %>
                    <span class="badge bg-success">Activo</span>
                  <% else %>
                    <span class="badge bg-secondary">Inactivo</span>
                  <% end %>
                </td>
                <td>
                  <span class="badge bg-secondary"><%= plan.plan_prices.count %> precios</span>
                </td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <%= link_to admin_plan_path(plan), class: "btn btn-outline-info" do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                    <%= link_to edit_admin_plan_path(plan), class: "btn btn-outline-warning" do %>
                      <i class="fas fa-edit"></i>
                    <% end %>
                    <%= link_to admin_plan_path(plan), method: :delete, 
                        data: { turbo_method: :delete, turbo_confirm: "¿Eliminar este plan?" },
                        class: "btn btn-outline-danger" do %>
                      <i class="fas fa-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
