<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-user-plus me-2" style="color: var(--brand-orange);"></i>
      Asignar Vendedor - <%= @event.name %>
    </h3>
    <%= link_to admin_event_vendedores_path(@event), class: "btn btn-outline-secondary" do %>
      <i class="fas fa-arrow-left me-1"></i> Volver
    <% end %>
  </div>

  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
          <% if @event_vendedor.errors.any? %>
            <div class="alert alert-danger">
              <ul class="mb-0">
                <% @event_vendedor.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <% if @vendedores.any? %>
            <%= form_with model: @event_vendedor, url: admin_event_vendedores_path(@event), class: "needs-validation" do |f| %>
              <div class="mb-4">
                <label class="form-label fw-bold">Seleccionar Vendedor</label>
                <%= f.select :user_id,
                    @vendedores.map { |v| ["#{v.name} - #{v.phone || 'Sin teléfono'}", v.id] },
                    { prompt: "Seleccione un vendedor..." },
                    class: "form-select" %>
              </div>

              <div class="d-grid">
                <%= f.submit "Asignar al Evento", class: "btn btn-primary btn-lg" %>
              </div>
            <% end %>
          <% else %>
            <div class="text-center text-muted py-3">
              <i class="fas fa-exclamation-triangle fa-2x mb-2 text-warning"></i>
              <p>No hay vendedores disponibles para asignar.</p>
              <p class="small">Todos los vendedores existentes ya están asignados a este evento, o no se han creado vendedores aún.</p>
              <%= link_to new_vendedor_admin_event_vendedores_path(@event), class: "btn btn-success" do %>
                <i class="fas fa-plus me-1"></i> Crear Nuevo Vendedor
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
