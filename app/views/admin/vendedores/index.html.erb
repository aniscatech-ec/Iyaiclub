<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-users me-2" style="color: var(--brand-orange);"></i>
      Vendedores - <%= @event.name %>
    </h3>
    <div class="d-flex gap-2">
      <%= link_to new_admin_event_vendedor_path(@event), class: "btn btn-primary" do %>
        <i class="fas fa-user-plus me-1"></i> Asignar Vendedor
      <% end %>
      <%= link_to new_vendedor_admin_event_vendedores_path(@event), class: "btn btn-success" do %>
        <i class="fas fa-plus me-1"></i> Crear Vendedor
      <% end %>
      <%= link_to admin_event_path(@event), class: "btn btn-outline-secondary" do %>
        <i class="fas fa-arrow-left me-1"></i> Volver al Evento
      <% end %>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body px-4 pb-4">
      <% if @event_vendedores.any? %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead class="table-light">
              <tr>
                <th>Nombre</th>
                <th>WhatsApp</th>
                <th>Email</th>
                <th>Estado</th>
                <th>Tickets Pendientes</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @event_vendedores.each do |ev| %>
                <tr>
                  <td><strong><%= ev.user.name %></strong></td>
                  <td>
                    <% if ev.user.phone.present? %>
                      <%= link_to ev.user.phone, whatsapp_link(ev.user.phone), target: "_blank", class: "text-success" %>
                    <% else %>
                      <span class="text-muted">-</span>
                    <% end %>
                  </td>
                  <td><%= ev.user.email %></td>
                  <td>
                    <% if ev.active? %>
                      <span class="badge bg-success">Activo</span>
                    <% else %>
                      <span class="badge bg-secondary">Inactivo</span>
                    <% end %>
                  </td>
                  <td>
                    <% pending_count = Ticket.where(vendedor: ev.user, event: @event, status: :reservado).count %>
                    <% if pending_count > 0 %>
                      <span class="badge bg-warning text-dark"><%= pending_count %></span>
                    <% else %>
                      <span class="text-muted">0</span>
                    <% end %>
                  </td>
                  <td>
                    <div class="btn-group btn-group-sm">
                      <%= link_to toggle_active_admin_event_vendedor_path(@event, ev),
                          data: { turbo_method: :patch },
                          class: "btn btn-outline-#{ev.active? ? 'secondary' : 'success'}" do %>
                        <i class="fas fa-<%= ev.active? ? 'pause' : 'play' %>"></i>
                        <%= ev.active? ? 'Desactivar' : 'Activar' %>
                      <% end %>
                      <%= link_to admin_event_vendedor_path(@event, ev),
                          data: { turbo_method: :delete, turbo_confirm: "¿Remover a #{ev.user.name} de este evento?" },
                          class: "btn btn-outline-danger" do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center text-muted py-4">
          <i class="fas fa-users fa-3x mb-3"></i>
          <p class="mb-3">No hay vendedores asignados a este evento</p>
          <div class="d-flex gap-2 justify-content-center">
            <%= link_to new_admin_event_vendedor_path(@event), class: "btn btn-primary" do %>
              <i class="fas fa-user-plus me-1"></i> Asignar Vendedor Existente
            <% end %>
            <%= link_to new_vendedor_admin_event_vendedores_path(@event), class: "btn btn-success" do %>
              <i class="fas fa-plus me-1"></i> Crear Nuevo Vendedor
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
