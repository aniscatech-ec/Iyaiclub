<div class="container-fluid px-3 px-md-4 py-4"
     data-controller="qr-scanner"
     data-qr-scanner-verify-url-value="<%= verify_ticket_admin_event_path(@event) %>"
     data-qr-scanner-mark-used-url-value="<%= admin_event_tickets_path(@event) %>">

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-qrcode me-2" style="color: var(--brand-orange);"></i>
      Verificar Tickets - <%= @event.name %>
    </h3>
    <div class="d-flex gap-2">
      <%= link_to admin_event_path(@event), class: "btn btn-outline-secondary" do %>
        <i class="fas fa-arrow-left me-1"></i> Volver al evento
      <% end %>
    </div>
  </div>

  <div class="row">
    <!-- Escáner QR -->
    <div class="col-12 col-lg-6 mb-4">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-camera me-2 text-primary"></i>
            Escáner QR
          </h5>
          <button class="btn btn-primary btn-sm" data-action="qr-scanner#startScanner">
            <i class="fas fa-play me-1"></i> Iniciar cámara
          </button>
        </div>
        <div class="card-body px-4 pb-4">
          <div id="qr-reader" class="mb-3 rounded-3 overflow-hidden" style="width: 100%;"></div>

          <!-- Entrada manual -->
          <div class="mt-3">
            <label class="form-label fw-bold">
              <i class="fas fa-keyboard me-1"></i> Ingreso manual del código
            </label>
            <div class="input-group">
              <input type="text"
                     class="form-control"
                     placeholder="Ej: EXP-000001"
                     data-qr-scanner-target="manualInput"
                     data-action="keydown->qr-scanner#verifyManualKey">
              <button type="button" class="btn btn-primary" data-action="qr-scanner#verifyManual">
                <i class="fas fa-search"></i>
              </button>
            </div>
            <small class="text-muted">Ingresa el código del ticket si no tienes cámara disponible</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Resultado de la verificación -->
    <div class="col-12 col-lg-6 mb-4">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-check-circle me-2 text-success"></i>
            Resultado
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div data-qr-scanner-target="status" class="mb-3"></div>
          <div data-qr-scanner-target="ticketInfo"></div>

          <!-- Estado inicial -->
          <div class="text-center text-muted py-4 qr-placeholder">
            <i class="fas fa-qrcode fa-3x mb-3"></i>
            <h6 class="fw-bold">Escanea o ingresa un código de ticket</h6>
            <p class="small">El resultado aparecerá aquí</p>
          </div>
        </div>
      </div>

      <!-- Resumen del evento -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-chart-bar me-2 text-info"></i>
            Resumen del Evento
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="row g-3 text-center">
            <div class="col-4">
              <div class="border rounded p-2">
                <div class="fs-4 fw-bold text-success"><%= @event.tickets.where(status: :activo).count %></div>
                <small class="text-muted">Activos</small>
              </div>
            </div>
            <div class="col-4">
              <div class="border rounded p-2">
                <div class="fs-4 fw-bold text-secondary"><%= @event.tickets.where(status: :usado).count %></div>
                <small class="text-muted">Usados</small>
              </div>
            </div>
            <div class="col-4">
              <div class="border rounded p-2">
                <div class="fs-4 fw-bold text-primary"><%= @event.tickets.count %></div>
                <small class="text-muted">Total</small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
