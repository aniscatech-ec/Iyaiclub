<%= form_with(model: [:admin, @event], local: true, class: "needs-validation") do |form| %>
  <% if @event.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-12 col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-info-circle me-2 text-primary"></i>
            Información del Evento
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="mb-3">
            <%= form.label :name, "Nombre del Evento", class: "form-label fw-bold" %>
            <%= form.text_field :name, class: "form-control", placeholder: "Ej: Expo Quito 2026" %>
          </div>

          <div class="mb-3">
            <%= form.label :description, "Descripción", class: "form-label fw-bold" %>
            <%= form.text_area :description, class: "form-control", rows: 4, placeholder: "Describe el evento..." %>
          </div>

          <div class="row g-3">
            <div class="col-12 col-md-6">
              <div class="mb-3">
                <%= form.label :event_date, "Fecha del Evento", class: "form-label fw-bold" %>
                <%= form.datetime_field :event_date, class: "form-control" %>
              </div>
            </div>
            <div class="col-12 col-md-6">
              <div class="mb-3">
                <%= form.label :status, "Estado", class: "form-label fw-bold" %>
                <%= form.select :status, Event.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "form-select" %>
              </div>
            </div>
          </div>

          <div class="row g-3">
            <div class="col-12 col-md-6">
              <div class="mb-3">
                <%= form.label :location, "Lugar", class: "form-label fw-bold" %>
                <%= form.text_field :location, class: "form-control", placeholder: "Ej: Centro de Convenciones" %>
              </div>
            </div>
            <div class="col-12 col-md-6">
              <div class="mb-3">
                <%= form.label :maps_url, "URL Google Maps", class: "form-label fw-bold" %>
                <%= form.url_field :maps_url, class: "form-control", placeholder: "https://maps.google.com/..." %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-ticket-alt me-2 text-success"></i>
            Tickets y Precios
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="row g-3 mb-3">
            <div class="col-12 col-sm-4">
              <%= form.label :member_price, "Precio Afiliado (USD)", class: "form-label fw-bold" %>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <%= form.number_field :member_price, class: "form-control", step: 0.01, min: 0, placeholder: "0.00" %>
              </div>
              <div class="form-text">Usuarios con cuenta registrada.</div>
            </div>
            <div class="col-12 col-sm-4">
              <%= form.label :non_member_price, "Precio No Afiliado (USD)", class: "form-label fw-bold" %>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <%= form.number_field :non_member_price, class: "form-control", step: 0.01, min: 0, placeholder: "0.00" %>
              </div>
              <div class="form-text">Visitantes sin cuenta.</div>
            </div>
            <div class="col-12 col-sm-4">
              <%= form.label :stand_price, "Precio Stand (USD)", class: "form-label fw-bold" %>
              <div class="input-group">
                <span class="input-group-text" style="background:#fff3e0;">
                  <i class="fas fa-store text-warning"></i>
                </span>
                <%= form.number_field :stand_price, class: "form-control", step: 0.01, min: 0, placeholder: "0.00" %>
              </div>
              <div class="form-text">Vendedores de stand (independiente del rol).</div>
            </div>
          </div>

          <!-- Precio Combo -->
          <div class="border rounded-3 p-3 mb-3" style="background: #fffbf0;">
            <div class="d-flex align-items-center gap-2 mb-2">
              <i class="fas fa-tags text-warning"></i>
              <strong>Precio Combo <span class="text-muted fw-normal">(opcional)</span></strong>
            </div>
            <p class="small text-muted mb-3">
              Descuento automático por ticket cuando el comprador adquiere <em>N</em> o más tickets a la vez.
              Aplica sobre el precio afiliado o no afiliado según el tipo de usuario.
            </p>
            <div class="row g-2">
              <div class="col-6">
                <%= form.label :combo_quantity, "Mínimo de tickets", class: "form-label small fw-bold" %>
                <%= form.number_field :combo_quantity, class: "form-control form-control-sm",
                      min: 2, placeholder: "Ej: 3",
                      data: { combo_field: "quantity" } %>
                <div class="form-text">Cantidad mínima para activar el descuento</div>
              </div>
              <div class="col-6">
                <%= form.label :combo_discount, "Descuento sobre el total (USD)", class: "form-label small fw-bold" %>
                <div class="input-group input-group-sm">
                  <span class="input-group-text">-$</span>
                  <%= form.number_field :combo_discount, class: "form-control",
                        step: 0.01, min: 0.01, placeholder: "Ej: 2.00",
                        data: { combo_field: "discount" } %>
                </div>
                <div class="form-text">Descuento fijo aplicado al precio final del lote</div>
              </div>
            </div>
            <% if @event.combo_active? %>
              <div class="mt-2 alert alert-warning alert-sm py-1 px-2 mb-0 small">
                <i class="fas fa-tag me-1"></i>
                Activo: comprando <%= @event.combo_quantity %>+ tickets se descuentan
                $<%= '%.2f' % @event.combo_discount %> del precio total.
              </div>
            <% end %>
            <div class="mt-2">
              <%= link_to "#", class: "small text-danger", data: { action: "click->combo-clear#clear" } do %>
                <i class="fas fa-times me-1"></i>Quitar precio combo
              <% end %>
            </div>
          </div>

          <div class="mb-3">
            <%= form.label :total_tickets, "Total de Tickets Disponibles", class: "form-label fw-bold" %>
            <%= form.number_field :total_tickets, class: "form-control", min: 1 %>
          </div>

          <div class="mb-3">
            <%= form.label :available_tickets, "Tickets Disponibles", class: "form-label fw-bold" %>
            <%= form.number_field :available_tickets, class: "form-control", min: 0 %>
            <small class="text-muted">Se actualiza automáticamente al vender tickets</small>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-image me-2 text-info"></i>
            Imagen del Evento
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <%= form.file_field :image, class: "form-control", accept: "image/*" %>
          <small class="text-muted">Imagen de portada del evento</small>
          <% if @event.image.attached? %>
            <div class="mt-2">
              <%= image_tag @event.image, class: "img-fluid rounded", style: "max-height: 150px;" %>
            </div>
          <% end %>
        </div>
      </div>

      <%# Stands del evento %>
      <% all_stands = Stand.activo.order(:name) %>
      <% if all_stands.any? %>
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h5 class="fw-bold mb-0">
              <i class="fas fa-store me-2 text-warning"></i>
              Stands del Evento
            </h5>
          </div>
          <div class="card-body px-4 pb-4">
            <p class="text-muted small mb-3">
              Selecciona los stands disponibles para este evento. Los vendedores de tipo stand podrán asignarse a uno de estos.
            </p>
            <div class="row g-2">
              <% assigned_stand_ids = @event.persisted? ? @event.stand_ids : [] %>
              <% all_stands.each do |stand| %>
                <div class="col-12 col-md-6">
                  <div class="form-check border rounded-3 p-3">
                    <input type="checkbox"
                           name="stand_ids[]"
                           value="<%= stand.id %>"
                           id="stand_<%= stand.id %>"
                           class="form-check-input"
                           <%= "checked" if assigned_stand_ids.include?(stand.id) %>>
                    <label class="form-check-label w-100" for="stand_<%= stand.id %>">
                      <strong><%= stand.name %></strong>
                      <span class="ms-2">
                        <code class="small" style="color:var(--brand-orange);"><%= stand.stand_code %></code>
                      </span>
                      <% if stand.location.present? %>
                        <br><small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i><%= stand.location %></small>
                      <% end %>
                    </label>
                  </div>
                </div>
              <% end %>
            </div>
            <input type="hidden" name="stand_ids_submitted" value="1">
          </div>
        </div>
      <% end %>

      <%# Notificación masiva — solo visible al crear %>
      <% if @event.new_record? %>
        <div class="card border-0 shadow-sm rounded-4 mb-4"
             style="border-left: 4px solid #EB633B !important;">
          <div class="card-body px-4 py-3">
            <div class="form-check form-switch d-flex align-items-start gap-3">
              <%= check_box_tag :notify_users, "1", false,
                    id:    "notify_users_switch",
                    class: "form-check-input mt-1 flex-shrink-0",
                    role:  "switch",
                    style: "width:2.5em; height:1.4em; cursor:pointer;" %>
              <label for="notify_users_switch" class="form-check-label" style="cursor:pointer;">
                <span class="fw-bold d-block" style="font-size:0.9rem;">
                  <i class="fas fa-bell me-1" style="color:#EB633B;"></i>
                  Avisar a usuarios por correo
                </span>
                <span class="text-muted d-block" style="font-size:0.78rem; line-height:1.4; margin-top:2px;">
                  Se enviará un email de anuncio a todos los usuarios registrados en lotes. No afecta la velocidad de guardado.
                </span>
              </label>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <% if @event.persisted? %>
    <!-- Vendedores -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0">
          <i class="fas fa-users me-2 text-info"></i>
          Vendedores (<%= @event.event_vendedores.count %>)
        </h5>
        <div class="d-flex gap-2">
          <% unassigned_vendedores = User.where(role: :vendedor).where.not(id: @event.vendedores.select(:id)) %>
          <% if unassigned_vendedores.any? %>
            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#assignVendedorModal">
              <i class="fas fa-user-plus me-1"></i> Asignar Existente
            </button>
          <% end %>
          <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#createVendedorModal" data-turbo="false">
            <i class="fas fa-plus me-1"></i> Crear Vendedor
          </button>
        </div>
      </div>
      <div class="card-body px-4 pb-4">
        <% event_vendedores = @event.event_vendedores.includes(:user).order(created_at: :desc) %>
        <% if event_vendedores.any? %>
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Nombre</th>
                  <th>WhatsApp</th>
                  <th>Email</th>
                  <th>Estado</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% event_vendedores.each do |ev| %>
                  <% contact = ev.seller %>
                  <tr>
                    <td>
                      <strong><%= ev.display_name %></strong>
                      <% if ev.vendor_type_stand_autonomo? %>
                        <span class="badge bg-warning text-dark ms-1" style="font-size:.65rem;">
                          <i class="fas fa-store me-1"></i>Stand
                        </span>
                      <% end %>
                    </td>
                    <td>
                      <% if contact&.phone.present? %>
                        <%= link_to contact.phone, whatsapp_link(contact.phone), target: "_blank", class: "text-success text-decoration-none" %>
                      <% else %>
                        <span class="text-muted">-</span>
                      <% end %>
                    </td>
                    <td><small><%= contact&.email %></small></td>
                    <td>
                      <span class="badge <%= ev.active? ? 'bg-success' : 'bg-secondary' %>">
                        <%= ev.active? ? 'Activo' : 'Inactivo' %>
                      </span>
                    </td>
                    <td>
                      <div class="btn-group btn-group-sm">
                        <%= link_to toggle_active_admin_event_vendedor_path(@event, ev),
                            data: { turbo_method: :patch },
                            class: "btn btn-outline-#{ev.active? ? 'secondary' : 'success'}" do %>
                          <i class="fas fa-<%= ev.active? ? 'pause' : 'play' %>"></i>
                        <% end %>
                        <%= link_to admin_event_vendedor_path(@event, ev),
                            data: { turbo_method: :delete, turbo_confirm: "¿Remover a #{ev.display_name} de este evento?" },
                            class: "btn btn-outline-danger" do %>
                          <i class="fas fa-trash"></i>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center text-muted py-3">
            <i class="fas fa-users fa-2x mb-2"></i>
            <p class="mb-0">No hay vendedores asignados a este evento</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="d-flex flex-column flex-md-row gap-2 mb-4">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_events_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<% if @event.persisted? %>
  <!-- Modal: Asignar vendedor existente -->
  <% unassigned_vendedores = User.where(role: :vendedor).where.not(id: @event.vendedores.select(:id)) %>
  <% if unassigned_vendedores.any? %>
    <div class="modal fade" id="assignVendedorModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content rounded-4">
          <div class="modal-header border-0">
            <h5 class="modal-title fw-bold"><i class="fas fa-user-plus me-2 text-primary"></i>Asignar Vendedor</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <%= form_with url: admin_event_vendedores_path(@event), method: :post, local: true do %>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label fw-bold">Seleccionar Vendedor</label>
                <select name="event_vendedor[user_id]" class="form-select" required>
                  <option value="">Seleccione...</option>
                  <% unassigned_vendedores.each do |v| %>
                    <option value="<%= v.id %>"><%= v.name %> - <%= v.phone || 'Sin teléfono' %></option>
                  <% end %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label fw-bold">Tipo de vendedor</label>
                <div class="row g-2">
                  <div class="col-6">
                    <input type="radio" class="btn-check" name="event_vendedor[vendor_type]"
                           id="form_av_vtype_normal" value="normal" checked autocomplete="off">
                    <label class="btn btn-outline-primary w-100 d-flex flex-column align-items-center py-3"
                           for="form_av_vtype_normal">
                      <i class="fas fa-user mb-1"></i>
                      <span class="fw-semibold">Normal</span>
                      <small class="text-muted fw-normal" style="font-size:.72rem;">Precio afiliado / no afiliado</small>
                    </label>
                  </div>
                  <div class="col-6">
                    <input type="radio" class="btn-check" name="event_vendedor[vendor_type]"
                           id="form_av_vtype_stand" value="stand" autocomplete="off">
                    <label class="btn btn-outline-warning w-100 d-flex flex-column align-items-center py-3"
                           for="form_av_vtype_stand">
                      <i class="fas fa-store mb-1"></i>
                      <span class="fw-semibold">Stand</span>
                      <small class="text-muted fw-normal" style="font-size:.72rem;">
                        Precio stand
                        <% if @event.stand_price? %>
                          ($<%= '%.2f' % @event.stand_price %>)
                        <% else %>
                          <span class="text-danger">(no configurado)</span>
                        <% end %>
                      </small>
                    </label>
                  </div>
                </div>
                <% unless @event.stand_price? %>
                  <div class="mt-2 alert alert-warning py-2 px-3 small mb-0">
                    <i class="fas fa-exclamation-triangle me-1"></i>
                    El evento no tiene precio de stand.
                    <%= link_to "Configurar", edit_admin_event_path(@event), class: "fw-semibold" %>.
                  </div>
                <% end %>
              </div>
              <div class="mb-3">
                <label class="form-label fw-bold">Cupo de tickets <small class="text-muted fw-normal">(opcional)</small></label>
                <input type="number" name="event_vendedor[quota]" class="form-control" min="1" placeholder="Ej: 50 — dejar vacío para sin límite">
                <small class="text-muted">Al alcanzar el cupo se marcará como "cupo cumplido", pero podrá seguir vendiendo.</small>
              </div>
            </div>
            <div class="modal-footer border-0">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
              <button type="submit" class="btn btn-primary">Asignar al Evento</button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Modal: Crear nuevo vendedor -->
  <div class="modal fade" id="createVendedorModal" tabindex="-1" aria-labelledby="createVendedorModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content rounded-4">
        <div class="modal-header border-0">
          <h5 class="modal-title fw-bold" id="createVendedorModalLabel"><i class="fas fa-plus me-2 text-success"></i>Crear Vendedor</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <%= form_with url: create_vendedor_admin_event_vendedores_path(@event), method: :post, local: true do %>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label fw-bold">Nombre completo</label>
              <input type="text" name="user[name]" class="form-control" required placeholder="Nombre del vendedor">
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">WhatsApp / Teléfono</label>
              <input type="text" name="user[phone]" class="form-control" required placeholder="0999999999">
              <small class="text-muted">Los compradores contactarán a este número</small>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Email</label>
              <input type="email" name="user[email]" class="form-control" required placeholder="vendedor@email.com">
              <small class="text-muted">Se usará para iniciar sesión</small>
            </div>
            <div class="row mb-3">
              <div class="col-6">
                <label class="form-label fw-bold">Contraseña</label>
                <input type="password" name="user[password]" class="form-control" required minlength="6">
              </div>
              <div class="col-6">
                <label class="form-label fw-bold">Confirmar</label>
                <input type="password" name="user[password_confirmation]" class="form-control" required>
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-6">
                <label class="form-label fw-bold">País</label>
                <%= collection_select(:user, :country_id, Country.all, :id, :name, { prompt: "Seleccione..." }, class: "form-select", required: true) %>
              </div>
              <div class="col-6">
                <label class="form-label fw-bold">Ciudad</label>
                <%= collection_select(:user, :city_id, City.all.limit(50), :id, :name, { prompt: "Seleccione..." }, class: "form-select", required: true) %>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Tipo de vendedor</label>
              <div class="row g-2">
                <div class="col-6">
                  <input type="radio" class="btn-check" name="vendor_type"
                         id="form_cv_vtype_normal" value="normal" checked autocomplete="off">
                  <label class="btn btn-outline-primary w-100 d-flex flex-column align-items-center py-3"
                         for="form_cv_vtype_normal">
                    <i class="fas fa-user mb-1"></i>
                    <span class="fw-semibold">Normal</span>
                    <small class="text-muted fw-normal" style="font-size:.72rem;">Precio afiliado / no afiliado</small>
                  </label>
                </div>
                <div class="col-6">
                  <input type="radio" class="btn-check" name="vendor_type"
                         id="form_cv_vtype_stand" value="stand" autocomplete="off">
                  <label class="btn btn-outline-warning w-100 d-flex flex-column align-items-center py-3"
                         for="form_cv_vtype_stand">
                    <i class="fas fa-store mb-1"></i>
                    <span class="fw-semibold">Stand</span>
                    <small class="text-muted fw-normal" style="font-size:.72rem;">
                      Precio stand
                      <% if @event.stand_price? %>
                        ($<%= '%.2f' % @event.stand_price %>)
                      <% else %>
                        <span class="text-danger">(no configurado)</span>
                      <% end %>
                    </small>
                  </label>
                </div>
              </div>
              <% unless @event.stand_price? %>
                <div class="mt-2 alert alert-warning py-2 px-3 small mb-0">
                  <i class="fas fa-exclamation-triangle me-1"></i>
                  El evento no tiene precio de stand.
                  <%= link_to "Configurar", edit_admin_event_path(@event), class: "fw-semibold" %>.
                </div>
              <% end %>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Cupo de tickets <small class="text-muted fw-normal">(opcional)</small></label>
              <input type="number" name="quota" class="form-control" min="1" placeholder="Ej: 50 — dejar vacío para sin límite">
              <small class="text-muted">Al alcanzar el cupo se marcará como "cupo cumplido".</small>
            </div>
            <div class="form-check">
              <input type="checkbox" name="auto_assign" value="1" class="form-check-input" id="form_autoAssignCheck" checked>
              <label class="form-check-label" for="form_autoAssignCheck">Asignar automáticamente a este evento</label>
            </div>
          </div>
          <div class="modal-footer border-0">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-success">Crear Vendedor</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
