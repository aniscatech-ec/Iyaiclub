<div class="container-fluid px-3 px-md-4 py-4">

  <div class="d-flex align-items-center justify-content-between mb-4 gap-3 flex-wrap">
    <div>
      <h3 class="fw-bold mb-0">Cuentas Bancarias</h3>
      <p class="text-muted small mb-0">Cuentas que verán los usuarios al reservar por transferencia</p>
    </div>
    <%= link_to new_admin_bank_account_path, class: "btn btn-primary rounded-pill fw-bold" do %>
      <i class="fas fa-plus me-2"></i> Nueva cuenta
    <% end %>
  </div>

  <% if @bank_accounts.empty? %>
    <div class="card border-0 shadow-sm rounded-4 text-center py-5">
      <i class="fas fa-university fa-3x text-muted mb-3"></i>
      <p class="text-muted mb-3">No hay cuentas bancarias registradas.</p>
      <%= link_to new_admin_bank_account_path, class: "btn btn-primary rounded-pill" do %>
        <i class="fas fa-plus me-1"></i> Agregar primera cuenta
      <% end %>
    </div>
  <% else %>
    <div class="row g-3">
      <% @bank_accounts.each do |account| %>
        <div class="col-12 col-md-6 col-xl-4">
          <div class="card border-0 shadow-sm rounded-4 h-100 <%= account.active? ? '' : 'opacity-60' %>">
            <div class="card-body p-4">

              <%# Header: institución + badge %>
              <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="d-flex align-items-center gap-2">
                  <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                       style="width:40px;height:40px;background:rgba(63,189,2,0.1);">
                    <i class="fas fa-university" style="color:var(--brand-green);"></i>
                  </div>
                  <div>
                    <p class="fw-bold mb-0 lh-sm"><%= account.institution %></p>
                    <span class="badge bg-light text-dark border" style="font-size:0.65rem;">
                      Cta. <%= account.account_type_label %>
                    </span>
                  </div>
                </div>
                <span class="badge rounded-pill <%= account.active? ? 'bg-success' : 'bg-secondary' %>">
                  <%= account.active? ? 'Activa' : 'Inactiva' %>
                </span>
              </div>

              <%# Datos %>
              <ul class="list-unstyled mb-3 small">
                <li class="d-flex justify-content-between py-1 border-bottom">
                  <span class="text-muted">N° de cuenta</span>
                  <strong class="font-monospace"><%= account.account_number %></strong>
                </li>
                <li class="d-flex justify-content-between py-1 border-bottom">
                  <span class="text-muted">Propietario</span>
                  <strong><%= account.owner_name %></strong>
                </li>
                <li class="d-flex justify-content-between py-1">
                  <span class="text-muted"><%= account.identifier_type_label %></span>
                  <strong class="font-monospace"><%= account.identifier %></strong>
                </li>
              </ul>

              <% if account.notes.present? %>
                <p class="text-muted small mb-3 fst-italic"><%= account.notes %></p>
              <% end %>

              <%# Acciones %>
              <div class="d-flex gap-2">
                <%= link_to edit_admin_bank_account_path(account),
                      class: "btn btn-sm btn-outline-secondary rounded-pill flex-grow-1" do %>
                  <i class="fas fa-edit me-1"></i> Editar
                <% end %>
                <%= button_to toggle_active_admin_bank_account_path(account),
                      method: :patch,
                      class: "btn btn-sm #{account.active? ? 'btn-outline-warning' : 'btn-outline-success'} rounded-pill flex-grow-1" do %>
                  <i class="fas fa-<%= account.active? ? 'eye-slash' : 'eye' %> me-1"></i>
                  <%= account.active? ? 'Desactivar' : 'Activar' %>
                <% end %>
                <%= button_to admin_bank_account_path(account),
                      method: :delete,
                      class: "btn btn-sm btn-outline-danger rounded-pill",
                      data: { turbo_confirm: "¿Eliminar la cuenta de #{account.institution}?" } do %>
                  <i class="fas fa-trash"></i>
                <% end %>
              </div>

            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
