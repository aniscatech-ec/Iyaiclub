<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-id-card me-2" style="color: var(--brand-orange);"></i>
      Membresía #<%= @membership.id %>
    </h3>
    <%= link_to admin_memberships_path, class: "btn btn-outline-secondary" do %>
      <i class="fas fa-arrow-left me-1"></i> Volver
    <% end %>
  </div>

  <div class="row">
    <div class="col-12 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-user me-2 text-primary"></i>
            Información del Turista
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <% if @user %>
            <div class="d-flex align-items-center mb-3">
              <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width: 60px; height: 60px;">
                <i class="fas fa-user fa-2x text-muted"></i>
              </div>
              <div>
                <h5 class="mb-0"><%= @user.name %></h5>
                <small class="text-muted"><%= @user.email %></small>
              </div>
            </div>
            <ul class="list-group list-group-flush">
              <li class="list-group-item d-flex justify-content-between px-0">
                <span>Teléfono</span>
                <strong><%= @user.phone || "-" %></strong>
              </li>
              <li class="list-group-item d-flex justify-content-between px-0">
                <span>País</span>
                <strong><%= @user.country&.name || "-" %></strong>
              </li>
              <li class="list-group-item d-flex justify-content-between px-0">
                <span>Ciudad</span>
                <strong><%= @user.city&.name || "-" %></strong>
              </li>
              <li class="list-group-item d-flex justify-content-between px-0">
                <span>Puntos Acumulados</span>
                <strong class="text-warning"><%= @user.total_points %> pts</strong>
              </li>
            </ul>
          <% else %>
            <div class="alert alert-warning mb-0">
              <i class="fas fa-exclamation-triangle me-2"></i>
              Usuario no encontrado
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-crown me-2 text-warning"></i>
            Detalles de la Membresía
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="text-center mb-4">
            <% case @membership.status %>
            <% when "pendiente" %>
              <span class="badge bg-warning text-dark fs-5 px-4 py-2">
                <i class="fas fa-clock me-1"></i> Pendiente de Aprobación
              </span>
            <% when "activada" %>
              <span class="badge bg-success fs-5 px-4 py-2">
                <i class="fas fa-check-circle me-1"></i> Activa
              </span>
            <% when "vencida" %>
              <span class="badge bg-secondary fs-5 px-4 py-2">
                <i class="fas fa-calendar-times me-1"></i> Vencida
              </span>
            <% when "cancelada" %>
              <span class="badge bg-danger fs-5 px-4 py-2">
                <i class="fas fa-ban me-1"></i> Cancelada
              </span>
            <% end %>
          </div>

          <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Plan</span>
              <strong><%= @plan_price&.plan_type&.humanize || "ID: #{@membership.plan_type}" %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
              <span>Precio</span>
              <div class="d-flex align-items-center gap-2">
                <strong>$<%= @plan_price ? number_with_precision(@plan_price.price, precision: 2) : "-" %></strong>
                <% if @plan_price.present? %>
                  <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editPriceModal">
                    <i class="fas fa-edit"></i>
                  </button>
                <% else %>
                  <small class="text-muted">No hay plan asociado</small>
                <% end %>
              </div>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Duración</span>
              <strong><%= @plan_price&.display_duration || "-" %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Fecha de Inicio</span>
              <strong><%= @membership.start_date&.strftime("%d/%m/%Y") || "Pendiente" %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Fecha de Fin</span>
              <strong><%= @membership.end_date&.strftime("%d/%m/%Y") || "Pendiente" %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span>Método de Pago</span>
              <strong><%= @membership.payment_method&.humanize || "-" %></strong>
            </li>
          </ul>

          <% if @membership.payment_instructions.present? %>
            <div class="mt-3">
              <strong>Instrucciones de Pago:</strong>
              <p class="text-muted small mb-0"><%= @membership.payment_instructions %></p>
            </div>
          <% end %>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-cogs me-2 text-secondary"></i>
            Acciones
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          <div class="d-grid gap-2">
            <% if @membership.pendiente? %>
              <%= link_to approve_admin_membership_path(@membership), method: :patch,
                  data: { turbo_method: :patch, turbo_confirm: "¿Aprobar esta membresía?" },
                  class: "btn btn-success" do %>
                <i class="fas fa-check me-1"></i> Aprobar Membresía
              <% end %>
            <% end %>

            <% if @membership.activada? %>
              <%= link_to cancel_admin_membership_path(@membership), method: :patch,
                  data: { turbo_method: :patch, turbo_confirm: "¿Cancelar esta membresía?" },
                  class: "btn btn-danger" do %>
                <i class="fas fa-ban me-1"></i> Cancelar Membresía
              <% end %>
            <% end %>

            <% if @membership.cancelada? %>
              <%= link_to approve_admin_membership_path(@membership), method: :patch,
                  data: { turbo_method: :patch, turbo_confirm: "¿Reactivar esta membresía?" },
                  class: "btn btn-success" do %>
                <i class="fas fa-redo me-1"></i> Reactivar Membresía
              <% end %>
            <% end %>

            <%= link_to admin_membership_path(@membership), method: :delete,
                data: { turbo_method: :delete, turbo_confirm: "¿Eliminar permanentemente esta membresía?" },
                class: "btn btn-outline-danger" do %>
              <i class="fas fa-trash me-1"></i> Eliminar Membresía
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal para editar precio del plan -->
<div class="modal fade" id="editPriceModal" tabindex="-1" aria-labelledby="editPriceModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editPriceModalLabel">
          <i class="fas fa-dollar-sign me-2"></i>Editar Precio del Plan
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <%= form_with(url: update_plan_price_admin_membership_path(@membership), method: :patch, local: true, class: "needs-validation") do |f| %>
        <div class="modal-body">
          <div class="mb-3">
            <%= f.fields_for :plan_price do |pf| %>
              <%= pf.label :price, "Nuevo precio", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <%= pf.number_field :price, class: "form-control", step: "0.01", min: "0", value: @plan_price&.price, required: true %>
              </div>
              <small class="form-text text-muted">Ingrese el nuevo precio para el plan <%= @plan_price&.plan_type&.humanize %></small>
            <% end %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <%= f.submit "Actualizar Precio", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
