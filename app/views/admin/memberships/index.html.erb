<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-users me-2" style="color: var(--brand-orange);"></i>
      Membresías de Turistas
    </h3>
  </div>

  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
      <div class="d-flex flex-wrap gap-2">
        <%= link_to admin_memberships_path, class: "btn btn-sm #{params[:status].blank? ? 'btn-primary' : 'btn-outline-primary'}" do %>
          Todas
        <% end %>
        <%= link_to admin_memberships_path(status: :pendiente), class: "btn btn-sm #{params[:status] == 'pendiente' ? 'btn-warning' : 'btn-outline-warning'}" do %>
          <i class="fas fa-clock me-1"></i> Pendientes
        <% end %>
        <%= link_to admin_memberships_path(status: :activada), class: "btn btn-sm #{params[:status] == 'activada' ? 'btn-success' : 'btn-outline-success'}" do %>
          <i class="fas fa-check me-1"></i> Activas
        <% end %>
        <%= link_to admin_memberships_path(status: :vencida), class: "btn btn-sm #{params[:status] == 'vencida' ? 'btn-secondary' : 'btn-outline-secondary'}" do %>
          <i class="fas fa-calendar-times me-1"></i> Vencidas
        <% end %>
        <%= link_to admin_memberships_path(status: :cancelada), class: "btn btn-sm #{params[:status] == 'cancelada' ? 'btn-danger' : 'btn-outline-danger'}" do %>
          <i class="fas fa-ban me-1"></i> Canceladas
        <% end %>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Turista</th>
              <th>Plan</th>
              <th>Estado</th>
              <th>Fecha Inicio</th>
              <th>Fecha Fin</th>
              <th>Método Pago</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% @memberships.each do |membership| %>
              <tr>
                <td><%= membership.id %></td>
                <td>
                  <% if membership.subscribable %>
                    <strong><%= membership.subscribable.name %></strong>
                    <br><small class="text-muted"><%= membership.subscribable.email %></small>
                  <% else %>
                    <span class="text-muted">Usuario eliminado</span>
                  <% end %>
                </td>
                <td>
                  <% plan_price = PlanPrice.find_by(id: membership.plan_type) %>
                  <% if plan_price %>
                    <span class="badge bg-info"><%= plan_price.plan_type&.humanize %></span>
                    <br><small>$<%= number_with_precision(plan_price.price, precision: 2) %> / <%= plan_price.display_duration %></small>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td>
                  <% case membership.status %>
                  <% when "pendiente" %>
                    <span class="badge bg-warning text-dark">Pendiente</span>
                  <% when "activada" %>
                    <span class="badge bg-success">Activa</span>
                  <% when "vencida" %>
                    <span class="badge bg-secondary">Vencida</span>
                  <% when "cancelada" %>
                    <span class="badge bg-danger">Cancelada</span>
                  <% end %>
                </td>
                <td><%= membership.start_date&.strftime("%d/%m/%Y") || "-" %></td>
                <td>
                  <%= membership.end_date&.strftime("%d/%m/%Y") || "-" %>
                  <% if membership.end_date && membership.end_date < Date.current && membership.activada? %>
                    <br><small class="text-danger">Expirada</small>
                  <% end %>
                </td>
                <td><%= membership.payment_method&.humanize || "-" %></td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <%= link_to admin_membership_path(membership), class: "btn btn-outline-info" do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                    <% if membership.pendiente? %>
                      <%= link_to approve_admin_membership_path(membership), method: :patch,
                          data: { turbo_method: :patch, turbo_confirm: "¿Aprobar esta membresía?" },
                          class: "btn btn-outline-success" do %>
                        <i class="fas fa-check"></i>
                      <% end %>
                    <% end %>
                    <% if membership.activada? %>
                      <%= link_to cancel_admin_membership_path(membership), method: :patch,
                          data: { turbo_method: :patch, turbo_confirm: "¿Cancelar esta membresía?" },
                          class: "btn btn-outline-danger" do %>
                        <i class="fas fa-ban"></i>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @memberships.empty? %>
        <div class="text-center py-5 text-muted">
          <i class="fas fa-inbox fa-3x mb-3"></i>
          <p>No hay membresías para mostrar</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
