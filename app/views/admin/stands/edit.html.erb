<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-edit me-2" style="color: var(--brand-orange);"></i>
      Editar Stand — <%= @stand.name %>
    </h3>
    <%= link_to admin_stands_path, class: "btn btn-outline-secondary" do %>
      <i class="fas fa-arrow-left me-1"></i> Volver
    <% end %>
  </div>

  <%= render "form", stand: @stand %>

  <%= render "vendedores", stand: @stand, events: @events, all_vendors: @all_vendors %>

  <% if @stand.owner_user %>
    <% user = @stand.owner_user %>
    <div id="owner-section" class="card border-0 shadow-sm rounded-4 mt-4">
      <div class="card-header bg-transparent border-0 p-4 pb-2">
        <h6 class="fw-bold mb-0">
          <i class="fas fa-user-shield me-2 text-warning"></i>Datos del propietario
        </h6>
        <p class="text-muted small mb-0 mt-1">Solo los administradores pueden editar estos datos.</p>
      </div>
      <div class="card-body p-4 pt-2">
        <%= form_with url: update_owner_admin_stand_path(@stand), method: :patch, local: true do |f| %>
          <div class="row g-3">
            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold">Nombre</label>
              <%= text_field_tag "owner_user[name]", user.name, class: "form-control form-control-sm" %>
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold">Correo electrónico</label>
              <%= email_field_tag "owner_user[email]", user.email, class: "form-control form-control-sm" %>
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold">Teléfono</label>
              <%= text_field_tag "owner_user[phone]", user.phone, class: "form-control form-control-sm" %>
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold">Rol</label>
              <select name="owner_user[role]" class="form-select form-select-sm">
                <option value="afiliado" <%= "selected" if user.role == "afiliado" %>>Afiliado</option>
                <option value="vendedor" <%= "selected" if user.role == "vendedor" %>>Vendedor</option>
                <option value="administrador" <%= "selected" if user.role == "administrador" %>>Administrador</option>
              </select>
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold">Nueva contraseña <span class="text-muted fw-normal">(dejar vacío para no cambiar)</span></label>
              <div class="input-group input-group-sm">
                <%= password_field_tag "owner_user[password]", nil, id: "owner_password", class: "form-control form-control-sm" %>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="togglePassword('owner_password', this)">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label small fw-semibold">Confirmar contraseña</label>
              <div class="input-group input-group-sm">
                <%= password_field_tag "owner_user[password_confirmation]", nil, id: "owner_password_confirmation", class: "form-control form-control-sm" %>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="togglePassword('owner_password_confirmation', this)">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>
          </div>
          <div class="mt-3">
            <button type="submit" class="btn btn-warning btn-sm rounded-pill">
              <i class="fas fa-save me-1"></i> Guardar cambios
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<script>
function togglePassword(fieldId, btn) {
  const input = document.getElementById(fieldId);
  const isHidden = input.type === 'password';
  input.type = isHidden ? 'text' : 'password';
  btn.innerHTML = isHidden ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
}
</script>
