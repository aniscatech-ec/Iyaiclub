<%= form_with model: [:admin, stand], local: true do |f| %>
  <% if stand.errors.any? %>
    <div class="alert alert-danger mb-4">
      <ul class="mb-0">
        <% stand.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-transparent border-0 pt-4 px-4">
      <h6 class="fw-bold mb-0"><i class="fas fa-info-circle me-2 text-primary"></i>Información del Stand</h6>
    </div>
    <div class="card-body px-4 pb-4">
      <div class="mb-3">
        <%= f.label :name, "Nombre del stand", class: "form-label fw-semibold" %>
        <%= f.text_field :name, class: "form-control", placeholder: "Ej: Stand Central A", required: true %>
      </div>
      <div class="mb-3">
        <%= f.label :location, "Ubicación", class: "form-label fw-semibold" %>
        <%= f.text_field :location, class: "form-control", placeholder: "Ej: Pasillo 3, Puerta Norte" %>
        <div class="form-text">Descripción del lugar físico del stand (opcional).</div>
      </div>
      <% unless stand.new_record? %>
        <div class="mb-3">
          <label class="form-label fw-semibold">Código del stand</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-barcode"></i></span>
            <input type="text" class="form-control" value="<%= stand.stand_code %>" disabled>
          </div>
          <div class="form-text">El código se genera automáticamente y no puede modificarse.</div>
        </div>
      <% end %>
      <div class="form-check form-switch mb-0">
        <%= f.check_box :active, class: "form-check-input", role: "switch", id: "stand_active" %>
        <%= f.label :active, "Stand activo", class: "form-check-label fw-semibold", for: "stand_active" %>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-transparent border-0 pt-4 px-4">
      <h6 class="fw-bold mb-0"><i class="fas fa-user-tie me-2 text-warning"></i>Datos del propietario</h6>
      <% if stand.new_record? %>
        <p class="text-muted small mb-0 mt-1">
          Se creará automáticamente una cuenta de vendedor con estos datos y se enviará un correo de bienvenida.
        </p>
      <% end %>
    </div>
    <div class="card-body px-4 pb-4">
      <div class="row g-3 mb-3">
        <div class="col-12 col-md-6">
          <%= f.label :owner_name, "Nombre", class: "form-label fw-semibold" %>
          <% if stand.new_record? %>
            <%= f.text_field :owner_name, class: "form-control", placeholder: "Nombre(s)", required: true %>
          <% else %>
            <input type="text" class="form-control" value="<%= stand.owner_name %>" disabled>
          <% end %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :owner_lastname, "Apellido", class: "form-label fw-semibold" %>
          <% if stand.new_record? %>
            <%= f.text_field :owner_lastname, class: "form-control", placeholder: "Apellido(s)", required: true %>
          <% else %>
            <input type="text" class="form-control" value="<%= stand.owner_lastname %>" disabled>
          <% end %>
        </div>
      </div>
      <% unless stand.new_record? %>
        <div class="form-text mb-3" style="margin-top:-8px;">El nombre del propietario no puede modificarse desde aquí.</div>
      <% end %>
      <div class="mb-3">
        <%= f.label :ruc, "RUC", class: "form-label fw-semibold" %>
        <% if stand.new_record? %>
          <%= f.text_field :ruc, class: "form-control", placeholder: "1234567890001",
                           maxlength: 13, pattern: "\\d{13}", required: true,
                           title: "El RUC debe tener exactamente 13 dígitos" %>
          <div class="form-text">Número de RUC del propietario o empresa (13 dígitos).</div>
        <% else %>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-id-card"></i></span>
            <input type="text" class="form-control" value="<%= stand.ruc %>" disabled>
          </div>
          <div class="form-text">El RUC no puede modificarse después de creado.</div>
        <% end %>
      </div>
      <div class="mb-3">
        <%= f.label :email, "Correo electrónico", class: "form-label fw-semibold" %>
        <% if stand.new_record? %>
          <%= f.email_field :email, class: "form-control", placeholder: "vendedor@ejemplo.com", required: true %>
          <div class="form-text">Se usará como usuario para ingresar a la plataforma.</div>
        <% else %>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-envelope"></i></span>
            <input type="text" class="form-control" value="<%= stand.email %>" disabled>
          </div>
          <div class="form-text">El correo no puede modificarse desde aquí.</div>
        <% end %>
      </div>
      <% if stand.new_record? %>
        <div class="row g-3"
             data-controller="location-select"
             data-location-select-country-id-value="stand_country_id"
             data-location-select-province-id-value="stand_province_id"
             data-location-select-city-id-value="stand_city_id">
          <div class="col-12 col-md-4">
            <%= f.label :country_id, "País", class: "form-label fw-semibold" %>
            <%= f.collection_select :country_id, Country.order(:name), :id, :name,
                { prompt: "Seleccione país..." },
                class: "form-select", required: true, id: "stand_country_id" %>
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label fw-semibold">Provincia</label>
            <select id="stand_province_id" class="form-select" required>
              <option value="">Seleccione provincia...</option>
            </select>
          </div>
          <div class="col-12 col-md-4">
            <%= f.label :city_id, "Ciudad", class: "form-label fw-semibold" %>
            <select name="stand[city_id]" id="stand_city_id" class="form-select" required>
              <option value="">Seleccione ciudad...</option>
            </select>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit stand.new_record? ? "Crear Stand" : "Guardar Cambios",
        class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancelar", admin_stands_path, class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
