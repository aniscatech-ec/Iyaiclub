<div class="container-fluid px-3 px-md-4 py-4">

  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><%= link_to "Stands", admin_stands_path %></li>
      <li class="breadcrumb-item active"><%= @stand.name %></li>
    </ol>
  </nav>

  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
      <h3 class="fw-bold mb-1"><%= @stand.name %></h3>
      <p class="text-muted mb-0 small">
        <code style="color: var(--brand-orange);"><%= @stand.stand_code %></code>
        <% if @stand.location.present? %>
          &bull; <i class="fas fa-map-marker-alt ms-1 me-1"></i><%= @stand.location %>
        <% end %>
      </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <% unless @stand.activo? %>
        <%= button_to activate_admin_stand_path(@stand), method: :post,
            form: { style: "display:inline" },
            onclick: "return confirm('¿Activar el stand \"#{@stand.name}\"? Se creará el usuario y se enviará el correo de bienvenida.')",
            class: "btn btn-sm btn-success rounded-pill" do %>
          <i class="fas fa-check me-1"></i> Activar Stand
        <% end %>
      <% end %>
      <%= link_to edit_admin_stand_path(@stand), class: "btn btn-sm btn-outline-warning rounded-pill" do %>
        <i class="fas fa-edit me-1"></i> Editar
      <% end %>
      <%= button_to admin_stand_path(@stand), method: :delete,
          form: { style: "display:inline" },
          onclick: "return confirm('¿Eliminar el stand \"#{@stand.name}\"?')",
          class: "btn btn-sm btn-outline-danger rounded-pill" do %>
        <i class="fas fa-trash me-1"></i> Eliminar
      <% end %>
      <%= link_to admin_stands_path, class: "btn btn-sm btn-outline-secondary rounded-pill" do %>
        <i class="fas fa-arrow-left me-1"></i> Volver
      <% end %>
    </div>
  </div>

  <% unless @stand.activo? %>
    <div class="alert alert-warning rounded-4 d-flex align-items-center gap-3 mb-4" role="alert">
      <i class="fas fa-clock fa-lg"></i>
      <div>
        <strong>Stand en estado reservado.</strong>
        <% if @stand.has_pending_user? %>
          Al activarlo se creará el usuario (<strong><%= @stand.pending_user_email %></strong>) y se le enviará el correo de bienvenida.
        <% else %>
          No tiene usuario asignado. Puedes activarlo directamente o asignar un usuario primero desde Editar.
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="row g-4">
    <%# Info del stand %>
    <div class="col-12 col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2">
          <h6 class="fw-bold mb-0">
            <i class="fas fa-store me-2 text-warning"></i>Info del Stand
          </h6>
        </div>
        <div class="card-body p-4 pt-2">
          <ul class="list-unstyled mb-0">
            <li class="d-flex align-items-center py-2 border-bottom">
              <i class="fas fa-barcode text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Código</small>
                <code class="fw-semibold" style="color: var(--brand-orange);"><%= @stand.stand_code %></code>
              </div>
            </li>
            <li class="d-flex align-items-center py-2 border-bottom">
              <i class="fas fa-map-marker-alt text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Ubicación</small>
                <span class="fw-semibold small"><%= @stand.location.presence || "—" %></span>
              </div>
            </li>
            <li class="d-flex align-items-center py-2 border-bottom">
              <i class="fas fa-id-card text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">RUC</small>
                <span class="fw-semibold small"><%= @stand.ruc %></span>
              </div>
            </li>
            <li class="d-flex align-items-center py-2 border-bottom">
              <i class="fas fa-user text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Propietario</small>
                <span class="fw-semibold small"><%= "#{@stand.owner_name} #{@stand.owner_lastname}".strip.presence || "—" %></span>
              </div>
            </li>
            <li class="d-flex align-items-center py-2 border-bottom">
              <i class="fas fa-envelope text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Correo</small>
                <span class="fw-semibold small"><%= @stand.email %></span>
              </div>
            </li>
            <li class="d-flex align-items-center py-2 border-bottom">
              <i class="fas fa-crown text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Propietario</small>
                <% if @stand.owner_user %>
                  <span class="fw-semibold small"><%= @stand.owner_user.name %></span>
                  <small class="text-muted d-block"><%= @stand.owner_user.email %></small>
                <% else %>
                  <span class="text-muted small">Sin propietario asignado</span>
                <% end %>
              </div>
            </li>
            <li class="d-flex align-items-center py-2">
              <i class="fas fa-toggle-on text-muted me-3" style="width:16px;"></i>
              <div>
                <small class="text-muted d-block">Estado</small>
                <% if @stand.activo? %>
                  <span class="badge bg-success">Activo</span>
                <% else %>
                  <span class="badge bg-warning text-dark">Reservado</span>
                <% end %>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <%# Usuario propietario — solo lectura %>
    <% if @stand.owner_user %>
      <% user = @stand.owner_user %>
      <div class="col-12 col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-header bg-transparent border-0 p-4 pb-2 d-flex align-items-center justify-content-between">
            <h6 class="fw-bold mb-0">
              <i class="fas fa-user-shield me-2 text-warning"></i>Usuario propietario
            </h6>
            <%= link_to edit_admin_stand_path(@stand, anchor: "owner-section"), class: "btn btn-sm btn-outline-warning rounded-pill" do %>
              <i class="fas fa-pen me-1"></i> Editar
            <% end %>
          </div>
          <div class="card-body p-4 pt-2">
            <div class="d-flex align-items-center gap-3 mb-3">
              <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                   style="width:44px;height:44px;background:linear-gradient(135deg,var(--brand-orange),#f7c59f);color:#fff;font-weight:700;font-size:.9rem;">
                <%= user.name.split.map(&:first).first(2).join.upcase %>
              </div>
              <div>
                <div class="fw-semibold"><%= user.name %></div>
                <small class="text-muted"><%= user.email %></small>
              </div>
            </div>
            <ul class="list-unstyled mb-0">
              <li class="d-flex align-items-center py-2 border-bottom">
                <i class="fas fa-phone text-muted me-3" style="width:16px;"></i>
                <div>
                  <small class="text-muted d-block">Teléfono</small>
                  <span class="fw-semibold small"><%= user.phone.presence || "—" %></span>
                </div>
              </li>
              <li class="d-flex align-items-center py-2 border-bottom">
                <i class="fas fa-tag text-muted me-3" style="width:16px;"></i>
                <div>
                  <small class="text-muted d-block">Rol</small>
                  <span class="badge bg-success rounded-pill"><%= user.role.titleize %></span>
                </div>
              </li>
              <li class="d-flex align-items-center py-2">
                <i class="fas fa-calendar text-muted me-3" style="width:16px;"></i>
                <div>
                  <small class="text-muted d-block">Creado</small>
                  <span class="fw-semibold small"><%= user.created_at.strftime("%d/%m/%Y") %></span>
                </div>
              </li>
            </ul>
          </div>
          <div class="card-footer bg-transparent border-0 px-4 pb-4 pt-0">
            <%= link_to resend_welcome_admin_stand_path(@stand),
                data: { turbo_method: :post,
                        turbo_confirm: "¿Reenviar el correo de bienvenida con el link para crear contraseña a #{user.email}?" },
                class: "btn btn-sm btn-outline-primary w-100" do %>
              <i class="fas fa-envelope me-1"></i> Reenviar correo de bienvenida
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# Eventos asignados %>
    <div class="col-12 col-lg-7">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2 d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0">
            <i class="fas fa-calendar-alt me-2 text-primary"></i>Eventos asignados
          </h6>
          <span class="badge bg-secondary rounded-pill"><%= @stand.events.count %></span>
        </div>
        <div class="card-body p-4 pt-2">
          <% if @stand.events.any? %>
            <ul class="list-unstyled mb-0">
              <% @stand.events.order(event_date: :desc).each do |event| %>
                <li class="d-flex align-items-center justify-content-between py-2 border-bottom">
                  <div>
                    <span class="fw-semibold small"><%= event.name %></span>
                    <small class="text-muted d-block">
                      <i class="fas fa-calendar-day me-1"></i>
                      <%= event.event_date&.strftime("%d/%m/%Y") || "—" %>
                    </small>
                  </div>
                  <%= link_to admin_event_path(event), class: "btn btn-outline-info btn-sm", title: "Ver evento" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <div class="text-center py-3 text-muted">
              <i class="fas fa-calendar-alt fa-2x mb-2 opacity-50"></i>
              <p class="mb-0 small">Este stand no está asignado a ningún evento.</p>
            </div>
          <% end %>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2 d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0">
            <i class="fas fa-chart-bar me-2 text-success"></i>Ventas por vendedor
          </h6>
          <span class="badge bg-secondary rounded-pill"><%= @vendors.count %> vendedor(es)</span>
        </div>
        <div class="card-body p-4 pt-2">
          <%= render "shared/vendor_stats", vendors: @vendors %>
        </div>
      </div>
    </div>
  </div>

</div>

