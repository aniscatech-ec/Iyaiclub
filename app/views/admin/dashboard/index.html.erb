<div class="container my-5">
  <h2 class="mb-5 text-center fw-bold">Panel de Administración</h2>

  <!-- Métricas principales -->
  <div class="row g-4 mb-5">
    <% metrics = [
      {title: "Usuarios", count: User.count - 1, icon: "fa-users", color: "primary"},
      {title: "Establecimientos", count: Establishment.count, icon: "fa-building", color: "success"},
      {title: "Reservas", count: 210, icon: "fa-calendar-check", color: "warning"},
      {title: "Membresías", count: 32, icon: "fa-credit-card", color: "danger"}
    ] %>

    <% metrics.each do |m| %>
      <div class="col-md-3">
        <div class="card shadow-sm h-100 text-center p-3 border-0">
          <div class="card-body">
            <i class="fa-solid <%= m[:icon] %> fa-3x text-<%= m[:color] %> mb-3"></i>
            <h6 class="card-title fw-bold"><%= m[:title] %></h6>
            <p class="display-6"><%= m[:count] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Sección Usuarios -->
  <h4 class="mb-3 fw-bold">Usuarios</h4>
  <div class="row g-4 mb-5">
    <% users_links = [
      {title: "Todos", path: admin_users_path, icon: "fa-user", color: "primary"},
      {title: "Afiliados", path: admin_users_path(role: "afiliado"), icon: "fa-user-tie", color: "info"},
      {title: "Turistas", path: admin_users_path(role: "turista"), icon: "fa-user-check", color: "secondary"}
    ] %>

    <% users_links.each do |u| %>
      <div class="col-md-4">
        <%= link_to u[:path], class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
          <div class="card-body">
            <i class="fa-solid <%= u[:icon] %> fa-3x text-<%= u[:color] %> mb-3"></i>
            <h6 class="card-title fw-bold"><%= u[:title] %></h6>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Sección Establecimientos -->
  <h4 class="mb-3 fw-bold">Establecimientos</h4>
  <div class="row g-4 mb-5">
    <div class="col-6 col-md-2">
      <%= link_to establishments_path, class: "text-decoration-none" do %>
        <div class="card border-0 shadow-sm d-flex flex-row align-items-center p-2 rounded-3" style="min-height: 45px;">
          <div class="d-flex align-items-center justify-content-center rounded-2 me-2 flex-shrink-0"
               style="width: 32px; height: 32px; background: #28a74515;">
            <i class="fa-solid fa-building" style="color: #28a745; font-size: 0.9rem;"></i>
          </div>
          <span class="fw-semibold text-dark" style="font-size: 0.75rem; line-height: 1.2;">Todos</span>
        </div>
      <% end %>
    </div>

    <% ["Hospedaje", "Gastronomia", "Transporte", "Alojamientos Temporales", "Escapadas"].each do |cat_name| %>
      <% cat = category_catalog.find { |c| c[:name] == cat_name } %>
      <% next unless cat %>
      <div class="col-6 col-md-2">
        <%= render "shared/category_card_with_dropdown", category: cat %>
      </div>
    <% end %>

    <div class="col-6 col-md-2">
      <%= link_to amenities_path, class: "text-decoration-none" do %>
        <div class="card border-0 shadow-sm d-flex flex-row align-items-center p-2 rounded-3" style="min-height: 45px;">
          <div class="d-flex align-items-center justify-content-center rounded-2 me-2 flex-shrink-0"
               style="width: 32px; height: 32px; background: #6c757d15;">
            <i class="fa-solid fa-star" style="color: #6c757d; font-size: 0.9rem;"></i>
          </div>
          <span class="fw-semibold text-dark" style="font-size: 0.75rem; line-height: 1.2;">Comodidades</span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Sección Membresías -->
  <h4 class="mb-3 fw-bold">Membresías</h4>
  <div class="row g-4 mb-5">
    <% memb_links = [
      {title: "Todas", path: admin_memberships_path, icon: "fa-list", color: "danger"},
      {title: "Activas", path: admin_memberships_path(status: :activada), icon: "fa-circle-check", color: "success"},
      {title: "Vencidas", path: admin_memberships_path(status: :vencida), icon: "fa-circle-xmark", color: "secondary"}
    ] %>

    <% memb_links.each do |m| %>
      <div class="col-md-3">
        <%= link_to m[:path], class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
          <div class="card-body">
            <i class="fa-solid <%= m[:icon] %> fa-3x text-<%= m[:color] %> mb-3"></i>
            <h6 class="card-title fw-bold"><%= m[:title] %></h6>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="col-md-3">
      <%= link_to benefit_requests_admin_memberships_path, class: "card shadow-sm h-100 text-center text-decoration-none border-0 position-relative" do %>
        <% pending_count = Booking.pending_benefits.count %>
        <% if pending_count > 0 %>
          <span class="position-absolute top-0 end-0 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
            <%= pending_count %>
          </span>
        <% end %>
        <div class="card-body">
          <i class="fa-solid fa-crown fa-3x text-warning mb-3"></i>
          <h6 class="card-title fw-bold">Beneficios Exclusivos</h6>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Sección Planes de Membresía -->
  <h4 class="mb-3 fw-bold">Planes de Membresía</h4>
  <div class="row g-4 mb-5">
    <div class="col-md-4">
      <%= link_to admin_plans_path, class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
        <div class="card-body">
          <i class="fa-solid fa-crown fa-3x text-warning mb-3"></i>
          <h6 class="card-title fw-bold">Ver Planes</h6>
        </div>
      <% end %>
    </div>
    <div class="col-md-4">
      <%= link_to new_admin_plan_path, class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
        <div class="card-body">
          <i class="fa-solid fa-plus-circle fa-3x text-success mb-3"></i>
          <h6 class="card-title fw-bold">Nuevo Plan</h6>
        </div>
      <% end %>
    </div>
    <div class="col-md-4">
      <%= link_to subscriptions_path, class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
        <div class="card-body">
          <i class="fa-solid fa-file-invoice-dollar fa-3x text-info mb-3"></i>
          <h6 class="card-title fw-bold">Suscripciones</h6>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Sección Puntos y Facturas -->
  <h4 class="mb-3 fw-bold">Puntos y Facturas</h4>
  <div class="row g-4 mb-5">
    <div class="col-md-4">
      <%= link_to admin_invoice_claims_path, class: "card shadow-sm h-100 text-center text-decoration-none border-0 position-relative" do %>
        <% pending_invoices = InvoiceClaim.where(status: :pendiente).count %>
        <% if pending_invoices > 0 %>
          <span class="position-absolute top-0 end-0 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
            <%= pending_invoices %>
          </span>
        <% end %>
        <div class="card-body">
          <i class="fa-solid fa-file-invoice-dollar fa-3x text-warning mb-3"></i>
          <h6 class="card-title fw-bold">Facturas Pendientes</h6>
        </div>
      <% end %>
    </div>
    <div class="col-md-4">
      <%= link_to admin_invoice_claims_path(status: :aprobada), class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
        <div class="card-body">
          <i class="fa-solid fa-circle-check fa-3x text-success mb-3"></i>
          <h6 class="card-title fw-bold">Facturas Aprobadas</h6>
        </div>
      <% end %>
    </div>
    <div class="col-md-4">
      <%= link_to admin_invoice_claims_path(status: :rechazada), class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
        <div class="card-body">
          <i class="fa-solid fa-circle-xmark fa-3x text-danger mb-3"></i>
          <h6 class="card-title fw-bold">Facturas Rechazadas</h6>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Sección Eventos y Tickets -->
  <h4 class="mb-3 fw-bold">Eventos y Tickets</h4>
  <div class="row g-4 mb-5">
    <div class="col-6 col-md-3">
      <%= link_to admin_events_path, class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
        <div class="card-body">
          <i class="fa-solid fa-calendar-alt fa-3x text-primary mb-3"></i>
          <h6 class="card-title fw-bold">Eventos</h6>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to new_admin_event_path, class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
        <div class="card-body">
          <i class="fa-solid fa-plus-circle fa-3x text-success mb-3"></i>
          <h6 class="card-title fw-bold">Nuevo Evento</h6>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to admin_events_path(status: "publicado"), class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
        <div class="card-body">
          <i class="fa-solid fa-ticket-alt fa-3x text-warning mb-3"></i>
          <h6 class="card-title fw-bold">Publicados</h6>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to admin_custom_requests_path, class: "card shadow-sm h-100 text-center text-decoration-none border-0" do %>
        <div class="card-body">
          <i class="fa-solid fa-headset fa-3x text-danger mb-3"></i>
          <h6 class="card-title fw-bold">Solicitudes</h6>
        </div>
      <% end %>
    </div>
  </div>
</div>
