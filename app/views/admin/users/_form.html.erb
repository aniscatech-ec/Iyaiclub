<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow rounded-4">
        <div class="card-body p-4">

          <% if @user.errors.any? %>
            <div class="alert alert-danger d-flex align-items-center" role="alert">
              <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
              <div>
                <strong>Por favor corrige los siguientes errores:</strong>
                <ul class="mb-0">
                  <% @user.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          <% end %>

          <%= form_with(model: [:admin, @user], local: true,
                       html: { class: "needs-validation", novalidate: true,
                               multipart: true,
                               data: { controller: "registration-role",
                                       registration_role_admin_mode_value: "true" } }) do |f| %>

            <div class="mb-3">
              <%= f.label :name, "Nombre", class: "form-label" %>
              <div class="input-group has-validation">
                <span class="input-group-text"><i class="fa-regular fa-circle-user"></i></span>
                <%= f.text_field :name, class: "form-control", placeholder: "Nombre completo", required: true %>
                <div class="invalid-feedback">
                  Por favor ingresa un nombre válido.
                </div>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :email, "Correo", class: "form-label" %>
              <div class="input-group has-validation">
                <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                <%= f.email_field :email, class: "form-control", placeholder: "correo@ejemplo.com", required: true %>
                <div class="invalid-feedback">
                  Por favor ingresa un correo válido.
                </div>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :phone, "Teléfono", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                <%= f.text_field :phone, class: "form-control", placeholder: "0981234567" %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :role, "Rol", class: "form-label" %>
              <div class="input-group has-validation">
                <span class="input-group-text"><i class="fa-regular fa-id-badge"></i></span>
                <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] },
                             { prompt: "Seleccionar rol" },
                             class: "form-select", required: true,
                             data: { action: "change->registration-role#toggleDocs",
                                     registration_role_target: "roleSelect" } %>
                <div class="invalid-feedback">Por favor selecciona un rol.</div>
              </div>
            </div>

            <!-- ── Documentos de identidad (solo afiliados) ── -->
            <div data-registration-role-target="docsSection" style="display:none;">
              <div class="alert alert-info rounded-3 py-2 small mb-3">
                <i class="fas fa-info-circle me-1"></i>
                El afiliado necesita estos documentos para ser verificado.
              </div>

              <div class="mb-3">
                <%= f.label :cedula_front, class: "form-label fw-semibold" do %>
                  <i class="fas fa-id-card me-1 text-primary"></i> Cédula — Anverso (frente)
                <% end %>
                <% if @user.persisted? && @user.cedula_front.attached? %>
                  <div class="mb-1 small text-success"><i class="fas fa-check-circle me-1"></i> Documento ya subido</div>
                <% end %>
                <%= f.file_field :cedula_front, class: "form-control",
                      accept: "image/jpeg,image/png,image/webp,application/pdf",
                      data: { registration_role_target: "docInput" } %>
                <small class="text-muted">JPG, PNG, WEBP o PDF</small>
              </div>

              <div class="mb-3">
                <%= f.label :cedula_back, class: "form-label fw-semibold" do %>
                  <i class="fas fa-id-card me-1 text-primary"></i> Cédula — Reverso
                <% end %>
                <% if @user.persisted? && @user.cedula_back.attached? %>
                  <div class="mb-1 small text-success"><i class="fas fa-check-circle me-1"></i> Documento ya subido</div>
                <% end %>
                <%= f.file_field :cedula_back, class: "form-control",
                      accept: "image/jpeg,image/png,image/webp,application/pdf",
                      data: { registration_role_target: "docInput" } %>
                <small class="text-muted">JPG, PNG, WEBP o PDF</small>
              </div>

              <div class="mb-3">
                <%= f.label :ruc_document, class: "form-label fw-semibold" do %>
                  <i class="fas fa-file-invoice me-1 text-warning"></i> Documento RUC
                <% end %>
                <% if @user.persisted? && @user.ruc_document.attached? %>
                  <div class="mb-1 small text-success"><i class="fas fa-check-circle me-1"></i> Documento ya subido</div>
                <% end %>
                <%= f.file_field :ruc_document, class: "form-control",
                      accept: "image/jpeg,image/png,image/webp,application/pdf",
                      data: { registration_role_target: "docInput" } %>
                <small class="text-muted">JPG, PNG, WEBP o PDF</small>
              </div>
            </div>

            <div data-controller="location-user"
                 data-location-user-saved-city-id-value="<%= @user.city_id %>">

              <div class="mb-3">
                <%= f.label :country_id, "País" %>
                <%= f.collection_select :country_id, Country.all, :id, :name, { prompt: "Seleccionar país" },
                                        { class: "form-select",
                                          data: { action: "change->location-user#updateCities", location_user_target: "country" } } %>
              </div>

              <div class="mb-3">
                <%= f.label :city_id, "Ciudad" %>
                <%= f.collection_select :city_id, [],
                                        :id, :name,
                                        { prompt: "Seleccionar ciudad" },
                                        class: "form-select",
                                        data: { location_user_target: "city" } %>
              </div>
            </div>


            <!-- Fecha de nacimiento -->
            <div class="mb-3">
              <%= f.label :birth_date, "Fecha de nacimiento", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fa-regular fa-calendar"></i></span>
                <%= f.date_field :birth_date, class: "form-control" %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :password, "Contraseña", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                <%= f.password_field :password, class: "form-control" %>
              </div>
<!--              <small class="form-text text-muted">Dejar vacío para no cambiar la contraseña.</small>-->
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, "Confirmar Contraseña", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                <%= f.password_field :password_confirmation, class: "form-control" %>
              </div>
            </div>

            <!-- Aceptar términos -->
            <div class="form-check mb-3">
              <%= f.check_box :terms_accepted, class: "form-check-input" %>
              <%= f.label :terms_accepted, "Aceptó Términos y Condiciones", class: "form-check-label" %>
            </div>

            <!-- Consentimiento marketing -->
            <div class="form-check mb-3">
              <%= f.check_box :marketing_consent, class: "form-check-input" %>
              <%= f.label :marketing_consent, "Aceptó recibir promociones", class: "form-check-label" %>
            </div>


            <div class="d-grid">
              <%= f.submit "Guardar cambios", class: "btn btn-success btn-lg" %>
            </div>

          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
    (() => {
        'use strict'
        const forms = document.querySelectorAll('.needs-validation')
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
    })()
</script>
