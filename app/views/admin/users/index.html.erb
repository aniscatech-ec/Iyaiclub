<h1>Usuarios</h1>

<%= link_to "Nuevo Usuario", new_admin_user_path, class: "btn btn-primary" %>

<table class="table">
  <thead>
  <tr>
    <th>Nombre</th>
    <th>Email</th>
    <th>Teléfono</th>
    <th>Rol</th>
    <th>Acciones</th>
  </tr>
  </thead>
  <tbody>
  <% @users.each do |user| %>
    <tr>
      <td><%= user.name %></td>
      <td><%= user.email %></td>
      <td><%= user.phone %></td>
      <td><%= user.role.titleize %></td>
      <td>
        <%= link_to "Ver", admin_user_path(user), class: "btn btn-info btn-sm" %>
        <%= link_to "Editar", edit_admin_user_path(user), class: "btn btn-warning btn-sm" %>
        <%= link_to "Eliminar", admin_user_path(user), data: { turbo_method: :delete, turbo_confirm: "¿Está seguro de eliminar este usuario?" }, class: "btn btn-danger btn-sm" %>

      </td>
    </tr>
  <% end %>
  </tbody>
</table>
