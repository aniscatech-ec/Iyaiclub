<div class="container-fluid px-3 px-md-4 py-4">

  <div class="d-flex align-items-center justify-content-between mb-4 gap-3 flex-wrap">
    <div>
      <h3 class="fw-bold mb-0">Publicidades</h3>
      <p class="text-muted small mb-0">Gestiona los banners publicitarios del inicio</p>
    </div>
    <%= link_to new_admin_advertisement_path, class: "btn btn-primary rounded-pill fw-bold" do %>
      <i class="fas fa-plus me-2"></i> Nueva publicidad
    <% end %>
  </div>

  <% if @advertisements.empty? %>
    <div class="card border-0 shadow-sm rounded-4 text-center py-5">
      <i class="fas fa-ad fa-3x text-muted mb-3"></i>
      <p class="text-muted mb-3">No hay publicidades creadas todavía.</p>
      <%= link_to new_admin_advertisement_path, class: "btn btn-primary rounded-pill" do %>
        <i class="fas fa-plus me-1"></i> Crear primera publicidad
      <% end %>
    </div>
  <% else %>
    <div class="row g-4">
      <% @advertisements.each do |ad| %>
        <div class="col-12 col-md-6 col-xl-4">
          <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">

            <%# Imagen preview %>
            <div class="position-relative" style="height: 160px; background: #1a1a2e; overflow: hidden;">
              <% if ad.image.attached? %>
                <%= image_tag ad.image.variant(resize_to_fill: [600, 320]),
                      class: "w-100 h-100",
                      style: "object-fit: cover; opacity: #{ad.active? ? '1' : '0.4'};" %>
              <% else %>
                <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                  <i class="fas fa-image fa-3x text-secondary"></i>
                </div>
              <% end %>

              <%# Overlay con título %>
              <div class="position-absolute bottom-0 start-0 w-100 px-3 py-2"
                   style="background: linear-gradient(transparent, rgba(0,0,0,0.8));">
                <p class="text-white fw-bold mb-0 small text-truncate"><%= ad.title %></p>
              </div>

              <%# Badge activo/inactivo %>
              <div class="position-absolute top-0 end-0 m-2">
                <span class="badge rounded-pill <%= ad.active? ? 'bg-success' : 'bg-secondary' %>">
                  <%= ad.active? ? 'Activo' : 'Inactivo' %>
                </span>
              </div>
            </div>

            <div class="card-body p-3">
              <% if ad.description.present? %>
                <p class="text-muted small mb-2 text-truncate"><%= ad.description %></p>
              <% end %>

              <% if ad.tags_array.any? %>
                <div class="d-flex flex-wrap gap-1 mb-2">
                  <% ad.tags_array.first(4).each do |tag| %>
                    <span class="badge rounded-pill bg-light text-dark border" style="font-size: 0.65rem;"><%= tag %></span>
                  <% end %>
                </div>
              <% end %>

              <% if ad.link_url.present? %>
                <p class="small text-muted mb-2 text-truncate">
                  <i class="fas fa-link me-1"></i> <%= ad.link_url %>
                </p>
              <% end %>

              <div class="d-flex gap-2 mt-3">
                <%= link_to edit_admin_advertisement_path(ad),
                      class: "btn btn-sm btn-outline-secondary rounded-pill flex-grow-1" do %>
                  <i class="fas fa-edit me-1"></i> Editar
                <% end %>
                <%= button_to toggle_active_admin_advertisement_path(ad),
                      method: :patch,
                      class: "btn btn-sm #{ad.active? ? 'btn-outline-warning' : 'btn-outline-success'} rounded-pill flex-grow-1" do %>
                  <i class="fas fa-<%= ad.active? ? 'eye-slash' : 'eye' %> me-1"></i>
                  <%= ad.active? ? 'Desactivar' : 'Activar' %>
                <% end %>
                <%= button_to admin_advertisement_path(ad),
                      method: :delete,
                      class: "btn btn-sm btn-outline-danger rounded-pill",
                      data: { turbo_confirm: "¿Eliminar la publicidad \"#{ad.title}\"?" } do %>
                  <i class="fas fa-trash"></i>
                <% end %>
              </div>
            </div>

          </div>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
