<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">
      <i class="fas fa-magic me-2" style="color: var(--brand-orange);"></i>
      Solicitudes personalizadas
    </h3>
  </div>

  <!-- Filtros por estado -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
      <div class="d-flex flex-wrap gap-2">
        <%= link_to admin_custom_requests_path, class: "btn btn-sm #{params[:status].blank? ? 'btn-primary' : 'btn-outline-primary'}" do %>
          Todas
        <% end %>
        <% CustomRequest.statuses.keys.each do |status_key| %>
          <% active = params[:status] == status_key %>
          <%= link_to admin_custom_requests_path(status: status_key),
                      class: "btn btn-sm #{active ? 'btn-warning' : 'btn-outline-warning'}" do %>
            <%= status_key.humanize %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Búsqueda -->
  <%= form_with url: admin_custom_requests_path, method: :get, local: true, class: "mb-4" do %>
    <div class="input-group">
      <span class="input-group-text"><i class="fas fa-search"></i></span>
      <%= text_field_tag :q, params[:q], class: "form-control",
                         placeholder: "Buscar por destino o comentarios..." %>
      <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
      <button class="btn btn-primary" type="submit">Buscar</button>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Turista</th>
              <th>Destino</th>
              <th>Fechas</th>
              <th>Personas</th>
              <th>Experiencia</th>
              <th>Estado</th>
              <th>Asignado a</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% @custom_requests.each do |req| %>
              <tr>
                <td>#<%= req.id %></td>
                <td>
                  <strong><%= req.user&.name.presence || req.user&.email %></strong>
                  <br><small class="text-muted"><%= req.user&.email %></small>
                </td>
                <td><i class="fas fa-map-marker-alt me-1"></i><%= req.destination %></td>
                <td>
                  <small>
                    <%= req.start_date&.strftime("%d/%m/%Y") %><br>
                    <%= req.end_date&.strftime("%d/%m/%Y") %>
                  </small>
                </td>
                <td><%= req.guests_count %></td>
                <td>
                  <span class="badge rounded-pill"
                        style="background: <%= experience_type_color(req.experience_type) %>;">
                    <%= experience_type_label(req.experience_type) %>
                  </span>
                </td>
                <td><%= custom_request_status_badge(req.status) %></td>
                <td>
                  <% if req.assigned_to %>
                    <small><%= req.assigned_to.name.presence || req.assigned_to.email %></small>
                  <% else %>
                    <span class="text-muted small">Sin asignar</span>
                  <% end %>
                </td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <%= link_to admin_custom_request_path(req), class: "btn btn-outline-info" do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                    <%= link_to admin_custom_request_path(req),
                                data: { turbo_method: :delete, turbo_confirm: "¿Eliminar esta solicitud?" },
                                class: "btn btn-outline-danger" do %>
                      <i class="fas fa-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @custom_requests.empty? %>
        <div class="text-center py-5 text-muted">
          <i class="fas fa-inbox fa-3x mb-3"></i>
          <p>No hay solicitudes para mostrar</p>
        </div>
      <% end %>
    </div>
  </div>

  <% if @pagy && @pagy.pages > 1 %>
    <nav class="d-flex justify-content-center mt-4">
      <%== pagy_nav(@pagy) %>
    </nav>
  <% end %>
</div>
