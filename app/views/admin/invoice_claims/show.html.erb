<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex align-items-center mb-4">
    <%= link_to admin_invoice_claims_path, class: "btn btn-outline-secondary btn-sm me-3" do %>
      <i class="fas fa-arrow-left"></i>
    <% end %>
    <div>
      <h3 class="fw-bold mb-0">Revisión de Factura</h3>
      <p class="text-muted mb-0 small">
        Solicitud de <%= @claim.user.name %> &bull;
        <span class="badge bg-<%= @claim.status_badge %>"><%= @claim.status_label %></span>
      </p>
    </div>
  </div>

  <div class="row g-4">
    <%# ── Columna izquierda: datos ── %>
    <div class="col-12 col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2">
          <h6 class="fw-bold mb-0"><i class="fas fa-user me-2 text-primary"></i> Usuario</h6>
        </div>
        <div class="card-body p-4 pt-2">
          <p class="mb-1 fw-semibold"><%= @claim.user.name %></p>
          <p class="mb-1 text-muted small"><%= @claim.user.email %></p>
          <p class="mb-0">
            <span class="badge <%= @claim.user.membership_badge_class %>">
              <%= @claim.user.membership_display_name %>
            </span>
            <small class="text-muted ms-2">
              <%= @claim.user.calculate_points_for_amount(1).round(2) %> pts por $1
            </small>
          </p>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2">
          <h6 class="fw-bold mb-0"><i class="fas fa-file-invoice me-2 text-primary"></i> Datos de la Factura</h6>
        </div>
        <div class="card-body p-4 pt-2">
          <dl class="row mb-0">
            <dt class="col-5 text-muted small">N° Factura</dt>
            <dd class="col-7 fw-semibold"><%= @claim.invoice_number.presence || "—" %></dd>
            <dt class="col-5 text-muted small">Monto</dt>
            <dd class="col-7 fw-bold text-success">$<%= number_with_precision(@claim.amount, precision: 2) %></dd>
            <dt class="col-5 text-muted small">Descripción</dt>
            <dd class="col-7"><%= @claim.description %></dd>
            <dt class="col-5 text-muted small">Enviada</dt>
            <dd class="col-7 small"><%= @claim.created_at.strftime("%d/%m/%Y %H:%M") %></dd>
            <% if @claim.establishment %>
              <dt class="col-5 text-muted small">Establecimiento</dt>
              <dd class="col-7"><%= @claim.establishment.name %></dd>
            <% end %>
          </dl>
        </div>
      </div>

      <%# Puntos sugeridos según monto y membresía del usuario %>
      <% suggested = @claim.user.calculate_points_for_amount(@claim.amount.to_f).round %>
      <div class="alert rounded-3" style="background: #e8f5e9; border: 1px solid #a5d6a7;">
        <i class="fas fa-calculator me-2 text-success"></i>
        <strong>Puntos sugeridos:</strong> <%= suggested %> pts
        <small class="d-block text-muted mt-1">
          Según el plan <%= @claim.user.membership_display_name %> del usuario para un monto de $<%= number_with_precision(@claim.amount, precision: 2) %>
        </small>
      </div>
    </div>

    <%# ── Columna derecha: archivo + acciones ── %>
    <div class="col-12 col-lg-7">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 p-4 pb-2">
          <h6 class="fw-bold mb-0"><i class="fas fa-paperclip me-2 text-primary"></i> Archivo Adjunto</h6>
        </div>
        <div class="card-body p-4 pt-2">
          <% if @claim.invoice_file.attached? %>
            <% if @claim.invoice_file.content_type.start_with?("image/") %>
              <%= image_tag url_for(@claim.invoice_file), class: "img-fluid rounded-3 shadow-sm", style: "max-height: 500px; width: 100%; object-fit: contain;" %>
            <% else %>
              <div class="text-center py-4">
                <i class="fas fa-file-pdf fa-4x text-danger mb-3"></i>
                <p class="mb-3">Archivo PDF adjunto</p>
              </div>
            <% end %>
            <div class="mt-3">
              <%= link_to url_for(@claim.invoice_file), class: "btn btn-outline-primary rounded-pill btn-sm",
                    target: "_blank", download: true do %>
                <i class="fas fa-download me-1"></i> Descargar factura
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No hay archivo adjunto</p>
          <% end %>
        </div>
      </div>

      <% if @claim.pendiente? %>
        <%# ── Formulario de aprobación ── %>
        <div class="card border-0 shadow-sm rounded-4 border-success mb-3" style="border: 2px solid #28a745 !important;">
          <div class="card-header bg-transparent border-0 p-4 pb-2">
            <h6 class="fw-bold mb-0 text-success"><i class="fas fa-check-circle me-2"></i> Aprobar y Acreditar Puntos</h6>
          </div>
          <div class="card-body p-4 pt-2">
            <%= form_with url: approve_admin_invoice_claim_path(@claim), method: :patch, local: true do |f| %>
              <div class="mb-3">
                <label class="form-label fw-semibold">Puntos a acreditar</label>
                <input type="number" name="points_granted" class="form-control rounded-3"
                       value="<%= suggested %>" min="1" required>
                <small class="text-muted">Puedes ajustar el valor sugerido</small>
              </div>
              <div class="mb-3">
                <label class="form-label fw-semibold">Notas (opcional)</label>
                <textarea name="admin_notes" class="form-control rounded-3" rows="2"
                          placeholder="Observaciones internas..."></textarea>
              </div>
              <button type="submit" class="btn btn-success rounded-pill w-100 fw-bold"
                      onclick="return confirm('¿Confirmar aprobación y acreditación de puntos?')">
                <i class="fas fa-check me-2"></i> Aprobar y Acreditar
              </button>
            <% end %>
          </div>
        </div>

        <%# ── Formulario de rechazo ── %>
        <div class="card border-0 shadow-sm rounded-4" style="border: 2px solid #dc3545 !important;">
          <div class="card-header bg-transparent border-0 p-4 pb-2">
            <h6 class="fw-bold mb-0 text-danger"><i class="fas fa-times-circle me-2"></i> Rechazar Solicitud</h6>
          </div>
          <div class="card-body p-4 pt-2">
            <%= form_with url: reject_admin_invoice_claim_path(@claim), method: :patch, local: true do |f| %>
              <div class="mb-3">
                <label class="form-label fw-semibold">Motivo del rechazo</label>
                <textarea name="admin_notes" class="form-control rounded-3" rows="2"
                          placeholder="Indica el motivo al usuario..." required></textarea>
              </div>
              <button type="submit" class="btn btn-danger rounded-pill w-100 fw-bold"
                      onclick="return confirm('¿Rechazar esta solicitud?')">
                <i class="fas fa-times me-2"></i> Rechazar
              </button>
            <% end %>
          </div>
        </div>

      <% else %>
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4">
            <h6 class="fw-bold mb-3"><i class="fas fa-clipboard-check me-2"></i> Resolución</h6>
            <dl class="row mb-0">
              <dt class="col-5 text-muted small">Estado</dt>
              <dd class="col-7">
                <span class="badge bg-<%= @claim.status_badge %>"><%= @claim.status_label %></span>
              </dd>
              <% if @claim.points_granted %>
                <dt class="col-5 text-muted small">Puntos acreditados</dt>
                <dd class="col-7 fw-bold text-success">+<%= @claim.points_granted %> pts</dd>
              <% end %>
              <% if @claim.admin_notes.present? %>
                <dt class="col-5 text-muted small">Notas</dt>
                <dd class="col-7"><%= @claim.admin_notes %></dd>
              <% end %>
              <% if @claim.reviewed_by %>
                <dt class="col-5 text-muted small">Revisado por</dt>
                <dd class="col-7"><%= @claim.reviewed_by.name %></dd>
              <% end %>
              <dt class="col-5 text-muted small">Fecha</dt>
              <dd class="col-7 small"><%= @claim.reviewed_at&.strftime("%d/%m/%Y %H:%M") %></dd>
            </dl>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
