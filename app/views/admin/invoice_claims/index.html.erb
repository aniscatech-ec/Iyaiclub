<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h3 class="fw-bold mb-1">
        <i class="fas fa-file-invoice-dollar me-2 text-primary"></i>
        Solicitudes de Facturas
      </h3>
      <p class="text-muted mb-0 small">Revisa y acredita puntos por facturas enviadas por turistas</p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to admin_invoice_claims_path, class: "btn btn-sm #{params[:status].blank? ? 'btn-dark' : 'btn-outline-secondary'} rounded-pill" do %>
        Todas
      <% end %>
      <%= link_to admin_invoice_claims_path(status: :pendiente), class: "btn btn-sm #{params[:status] == 'pendiente' ? 'btn-warning' : 'btn-outline-warning'} rounded-pill" do %>
        Pendientes
      <% end %>
      <%= link_to admin_invoice_claims_path(status: :aprobada), class: "btn btn-sm #{params[:status] == 'aprobada' ? 'btn-success' : 'btn-outline-success'} rounded-pill" do %>
        Aprobadas
      <% end %>
      <%= link_to admin_invoice_claims_path(status: :rechazada), class: "btn btn-sm #{params[:status] == 'rechazada' ? 'btn-danger' : 'btn-outline-danger'} rounded-pill" do %>
        Rechazadas
      <% end %>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
      <% if @claims.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Fecha</th>
                <th>Usuario</th>
                <th>N° Factura</th>
                <th>Monto</th>
                <th>Estado</th>
                <th>Puntos</th>
                <th class="text-end pe-4">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @claims.each do |claim| %>
                <tr>
                  <td class="ps-4">
                    <small class="text-muted"><%= claim.created_at.strftime("%d/%m/%Y") %></small>
                  </td>
                  <td>
                    <div class="fw-semibold"><%= claim.user.name %></div>
                    <small class="text-muted"><%= claim.user.email %></small>
                  </td>
                  <td><%= claim.invoice_number.presence || "—" %></td>
                  <td class="fw-bold">$<%= number_with_precision(claim.amount, precision: 2) %></td>
                  <td>
                    <span class="badge bg-<%= claim.status_badge %> rounded-pill">
                      <%= claim.status_label %>
                    </span>
                  </td>
                  <td>
                    <% if claim.points_granted %>
                      <span class="text-success fw-bold">+<%= claim.points_granted %></span>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td class="text-end pe-4">
                    <%= link_to admin_invoice_claim_path(claim), class: "btn btn-sm btn-outline-primary rounded-pill" do %>
                      <i class="fas fa-eye me-1"></i> Revisar
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
          <p class="text-muted mb-0">No hay solicitudes de facturas</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
