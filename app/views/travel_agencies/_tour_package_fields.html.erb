<div class="tour-package-item border rounded-4 mb-3 position-relative"
     style="background: linear-gradient(135deg, #f0f6ff, #e8f0fe);">

  <%= f.hidden_field :id %>
  <%= f.hidden_field :_destroy, class: "destroy-field", value: "false" %>

  <%# Cabecera del paquete — siempre visible %>
  <div class="d-flex align-items-center justify-content-between p-3 package-header" style="cursor: pointer;">
    <h6 class="fw-bold mb-0 text-primary d-flex align-items-center gap-2 flex-wrap"
        data-bs-toggle="collapse" data-bs-target="#pkg-body-<%= f.object.object_id %>" style="flex: 1;">
      <i class="fas fa-suitcase"></i>
      <span class="package-title-preview">
        <%= f.object.name.presence || "Nuevo paquete" %>
      </span>
      <% if f.object.price.present? %>
        <span class="badge bg-success-subtle text-success fw-semibold">$<%= f.object.price %></span>
      <% end %>
      <% if f.object.destination.present? %>
        <span class="badge bg-light text-muted fw-normal"><i class="fas fa-map-marker-alt me-1"></i><%= f.object.destination %></span>
      <% end %>
    </h6>
    <div class="d-flex align-items-center gap-2 ms-2">
      <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill pkg-collapse-btn"
              data-bs-toggle="collapse" data-bs-target="#pkg-body-<%= f.object.object_id %>">
        <i class="fas fa-chevron-up"></i>
      </button>
      <button type="button" class="btn btn-sm btn-outline-danger rounded-pill remove-package">
        <i class="fas fa-trash me-1"></i> Eliminar
      </button>
    </div>
  </div>

  <%# Body colapsable %>
  <div class="collapse show px-3 pb-3" id="pkg-body-<%= f.object.object_id %>">
  <div class="row g-3">

    <%# Nombre y tipo %>
    <div class="col-md-6">
      <%= f.label :name, "Nombre del paquete *", class: "form-label fw-semibold small" %>
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-tag"></i></span>
        <%= f.text_field :name,
              class: "form-control package-name-input",
              placeholder: "Ej: Aventura en el Cajas",
              required: true %>
      </div>
    </div>

    <div class="col-md-3">
      <%= f.label :package_type, "Tipo de paquete", class: "form-label fw-semibold small" %>
      <%= f.select :package_type,
            options_for_select(
              TourPackage::PACKAGE_TYPES.map { |t| [t.humanize, t] },
              f.object.package_type
            ),
            { include_blank: "Seleccione..." },
            class: "form-select" %>
    </div>

    <div class="col-md-3">
      <%= f.label :difficulty, "Dificultad", class: "form-label fw-semibold small" %>
      <%= f.select :difficulty,
            options_for_select(
              [["Fácil", "facil"], ["Moderado", "moderado"], ["Exigente", "exigente"]],
              f.object.difficulty
            ),
            { include_blank: "Seleccione..." },
            class: "form-select" %>
    </div>

    <%# Destino y punto de salida %>
    <div class="col-md-6">
      <%= f.label :destination, "Destino principal", class: "form-label fw-semibold small" %>
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
        <%= f.text_field :destination, class: "form-control", placeholder: "Ej: Cuenca, Galápagos, Amazonia" %>
      </div>
    </div>

    <div class="col-md-6">
      <%= f.label :departure_point, "Punto de salida / encuentro", class: "form-label fw-semibold small" %>
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-flag-checkered"></i></span>
        <%= f.text_field :departure_point, class: "form-control", placeholder: "Ej: Terminal Terrestre Cuenca" %>
      </div>
    </div>

    <%# Duración y grupo %>
    <div class="col-md-3">
      <%= f.label :days, "Días", class: "form-label fw-semibold small" %>
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-sun"></i></span>
        <%= f.number_field :days, class: "form-control", min: 1, placeholder: "3" %>
      </div>
    </div>

    <div class="col-md-3">
      <%= f.label :nights, "Noches", class: "form-label fw-semibold small" %>
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-moon"></i></span>
        <%= f.number_field :nights, class: "form-control", min: 0, placeholder: "2" %>
      </div>
    </div>

    <div class="col-md-3">
      <%= f.label :min_group, "Mín. personas", class: "form-label fw-semibold small" %>
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-user"></i></span>
        <%= f.number_field :min_group, class: "form-control", min: 1, value: f.object.min_group || 1 %>
      </div>
    </div>

    <div class="col-md-3">
      <%= f.label :max_group, "Máx. personas", class: "form-label fw-semibold small" %>
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-users"></i></span>
        <%= f.number_field :max_group, class: "form-control", min: 1, value: f.object.max_group || 15 %>
      </div>
    </div>

    <%# Precios %>
    <div class="col-md-4">
      <%= f.label :price, "Precio por persona *", class: "form-label fw-semibold small" %>
      <div class="input-group">
        <span class="input-group-text">$</span>
        <%= f.number_field :price, class: "form-control", min: 0, step: "0.01", placeholder: "0.00", required: true %>
      </div>
    </div>

    <div class="col-md-4">
      <%= f.label :member_price, "Precio para miembros IyaiClub", class: "form-label fw-semibold small" %>
      <div class="input-group">
        <span class="input-group-text text-warning"><i class="fas fa-crown"></i></span>
        <%= f.number_field :member_price, class: "form-control", min: 0, step: "0.01", placeholder: "0.00" %>
      </div>
      <small class="text-muted">Dejar vacío si no aplica descuento</small>
    </div>

    <div class="col-md-4">
      <%= f.label :season, "Temporada", class: "form-label fw-semibold small" %>
      <%= f.select :season,
            options_for_select(TourPackage::SEASONS, f.object.season),
            { include_blank: "Seleccione..." },
            class: "form-select" %>
    </div>

    <%# Servicios incluidos (checkboxes) %>
    <div class="col-12">
      <label class="form-label fw-semibold small">Servicios incluidos en el paquete</label>
      <div class="d-flex flex-wrap gap-3">
        <div class="form-check">
          <%= f.check_box :includes_transport, class: "form-check-input" %>
          <%= f.label :includes_transport, class: "form-check-label" do %>
            <i class="fas fa-bus me-1 text-primary"></i> Transporte
          <% end %>
        </div>
        <div class="form-check">
          <%= f.check_box :includes_food, class: "form-check-input" %>
          <%= f.label :includes_food, class: "form-check-label" do %>
            <i class="fas fa-utensils me-1 text-warning"></i> Alimentación
          <% end %>
        </div>
        <div class="form-check">
          <%= f.check_box :includes_lodging, class: "form-check-input" %>
          <%= f.label :includes_lodging, class: "form-check-label" do %>
            <i class="fas fa-bed me-1 text-success"></i> Alojamiento
          <% end %>
        </div>
        <div class="form-check">
          <%= f.check_box :includes_guide, class: "form-check-input" %>
          <%= f.label :includes_guide, class: "form-check-label" do %>
            <i class="fas fa-user-tie me-1 text-info"></i> Guía turístico
          <% end %>
        </div>
      </div>
    </div>

    <%# Descripción e itinerario %>
    <div class="col-12">
      <%= f.label :description, "Descripción general del paquete", class: "form-label fw-semibold small" %>
      <%= f.text_area :description, rows: 3, class: "form-control",
            placeholder: "Describe brevemente la experiencia que ofrece este paquete..." %>
    </div>

    <div class="col-12">
      <%= f.label :itinerary, "Itinerario día a día", class: "form-label fw-semibold small" %>
      <%= f.text_area :itinerary, rows: 5, class: "form-control",
            placeholder: "Día 1: Llegada y bienvenida...\nDía 2: Visita al Parque Nacional...\nDía 3: Retorno" %>
      <small class="text-muted">Describe las actividades de cada día del tour.</small>
    </div>

    <%# Incluye / No incluye %>
    <div class="col-md-6">
      <%= f.label :includes, "¿Qué incluye?", class: "form-label fw-semibold small" %>
      <%= f.text_area :includes, rows: 4, class: "form-control",
            placeholder: "Transporte en bus privado\nAlojamiento doble\nDesayunos\nGuía certificado" %>
      <small class="text-muted">Un ítem por línea.</small>
    </div>

    <div class="col-md-6">
      <%= f.label :excludes, "¿Qué NO incluye?", class: "form-label fw-semibold small" %>
      <%= f.text_area :excludes, rows: 4, class: "form-control",
            placeholder: "Vuelos\nGastos personales\nPropinas\nSeguro de viaje" %>
      <small class="text-muted">Un ítem por línea.</small>
    </div>

    <%# Próximas salidas y foto %>
    <div class="col-md-6">
      <%= f.label :next_departures, "Próximas salidas", class: "form-label fw-semibold small" %>
      <%= f.text_area :next_departures, rows: 3, class: "form-control",
            placeholder: "15 de mayo 2026\n10 de junio 2026\nConsultar disponibilidad" %>
      <small class="text-muted">Una fecha por línea.</small>
    </div>

    <div class="col-md-6">
      <%= f.label :cover_photo, "Foto del paquete", class: "form-label fw-semibold small" %>
      <% if f.object.cover_photo.attached? %>
        <div class="mb-2 rounded-3 overflow-hidden" style="height: 80px;">
          <%= image_tag f.object.cover_photo.variant(resize_to_fill: [400, 160]),
                class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
      <% end %>
      <%= f.file_field :cover_photo, class: "form-control", accept: "image/jpeg,image/png,image/webp" %>
      <small class="text-muted">JPG, PNG o WEBP. Recomendado: 800×400 px.</small>
    </div>

    <%# Activo %>
    <div class="col-12">
      <div class="form-check form-switch">
        <%= f.check_box :active, class: "form-check-input", role: "switch" %>
        <%= f.label :active, "Paquete activo (visible para clientes)", class: "form-check-label fw-semibold" %>
      </div>
    </div>

  </div>
  </div><%# fin collapse body %>
</div>
