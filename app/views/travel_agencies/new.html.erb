<!-- app/views/travel_agencies/new.html.erb -->
<div class="container-fluid pt-4 px-4 pb-5">
  <div class="row mb-4 align-items-center">
    <div class="col-auto">
      <%= link_to travel_agencies_path, class: "btn btn-outline-secondary rounded-circle shadow-sm" do %>
        <i class="fas fa-arrow-left"></i>
      <% end %>
    </div>
    <div class="col">
      <h3 class="mb-0 fw-bold" style="color: #2c3e50;">
        <i class="fas fa-suitcase-rolling me-2 text-primary"></i> Registrar Nueva Agencia Turística
      </h3>
      <p class="text-muted mb-0">Completa los datos para registrar tu agencia</p>
    </div>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-10">
      <%= render "form", travel_agency: @travel_agency %>
    </div>
  </div>
</div>
