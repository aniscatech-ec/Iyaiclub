<script>
    (function() {
        const typeSelect = document.getElementById('travel_agency_document_type_select');
        const numberInput = document.getElementById('travel_agency_document_number_input');
        function updateDocumentPattern() {
            if (!typeSelect || !numberInput) return;
            switch (typeSelect.value) {
                case 'ruc':       numberInput.pattern = '[0-9]{13}';      numberInput.maxLength = 13; break;
                case 'cedula':    numberInput.pattern = '[0-9]{10}';      numberInput.maxLength = 10; break;
                case 'pasaporte': numberInput.pattern = '[A-Za-z0-9]{6,15}'; numberInput.maxLength = 15; break;
                default:          numberInput.removeAttribute('pattern');  numberInput.removeAttribute('maxlength'); break;
            }
        }
        function init() {
            if (typeSelect) {
                typeSelect.addEventListener('change', updateDocumentPattern);
                updateDocumentPattern();
            }
        }
        init();
        document.addEventListener('DOMContentLoaded', init);
        document.addEventListener('turbo:load', init);
    })();
</script>
