    // ── Toggle ícono chevron en colapso de paquetes ──
    document.addEventListener("hide.bs.collapse", function(e) {
      if (!e.target.id?.startsWith("pkg-body-")) return;
      const item = e.target.closest(".tour-package-item");
      if (!item) return;
      const btn = item.querySelector(".pkg-collapse-btn i");
      if (btn) { btn.className = "fas fa-chevron-down"; }
    });
    document.addEventListener("show.bs.collapse", function(e) {
      if (!e.target.id?.startsWith("pkg-body-")) return;
      const item = e.target.closest(".tour-package-item");
      if (!item) return;
      const btn = item.querySelector(".pkg-collapse-btn i");
      if (btn) { btn.className = "fas fa-chevron-up"; }
    });
  });
