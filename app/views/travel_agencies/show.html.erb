<!-- app/views/travel_agencies/show.html.erb -->
<div class="container-fluid pt-4 px-4 pb-5">
  <div class="row mb-4 align-items-center">
    <div class="col-auto">
      <%= link_to travel_agencies_path, class: "btn btn-outline-secondary rounded-circle shadow-sm" do %>
        <i class="fas fa-arrow-left"></i>
      <% end %>
    </div>
    <div class="col">
      <h3 class="mb-0 fw-bold" style="color: #2c3e50;">
        <i class="fas fa-suitcase-rolling me-2 text-primary"></i> <%= @travel_agency.establishment.name %>
      </h3>
      <p class="text-muted mb-0">Detalles de la agencia turística</p>
    </div>
    <div class="col-auto">
      <%= link_to edit_travel_agency_path(@travel_agency), class: "btn btn-outline-primary rounded-pill px-4 shadow-sm fw-semibold" do %>
        <i class="fas fa-edit me-1"></i> Editar Agencia
      <% end %>
      <%= link_to travel_agency_path(@travel_agency), data: { turbo_method: :delete, turbo_confirm: "¿Está seguro de eliminar esta agencia?" }, class: "btn btn-outline-danger rounded-pill px-4 shadow-sm fw-semibold ms-2" do %>
        <i class="fas fa-trash me-1"></i> Eliminar
      <% end %>
    </div>
  </div>

  <div class="row g-4">
    <!-- Detalles de la Agencia -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <% if @travel_agency.establishment.images.attached? %>
          <div id="agencyCarouse-<%= @travel_agency.id %>" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner rounded-top-4">
              <% @travel_agency.establishment.images.each_with_index do |img, index| %>
                <div class="carousel-item <%= 'active' if index == 0 %>">
                  <%= image_tag img.variant(resize_to_fill: [600, 400]), class: "d-block w-100", style: "height: 250px; object-fit: cover;" %>
                </div>
              <% end %>
            </div>
            <% if @travel_agency.establishment.images.count > 1 %>
              <button class="carousel-control-prev" type="button" data-bs-target="#agencyCarouse-<%= @travel_agency.id %>" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Anterior</span>
              </button>
              <button class="carousel-control-next" type="button" data-bs-target="#agencyCarouse-<%= @travel_agency.id %>" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Siguiente</span>
              </button>
            <% end %>
          </div>
        <% else %>
          <div class="bg-light rounded-top-4 d-flex align-items-center justify-content-center" style="height: 250px;">
            <i class="fas fa-image fa-4x text-muted opacity-50"></i>
          </div>
        <% end %>
        
        <div class="card-body p-4">
          <div class="mb-4">
            <span class="badge bg-primary px-3 py-2 rounded-pill fw-bold fs-6">
              <%= @travel_agency.subcategory.humanize %>
            </span>
            <span class="badge bg-<%= @travel_agency.establishment.status == 'active' ? 'success' : 'secondary' %> px-3 py-2 rounded-pill ms-2 fw-bold fs-6">
              <%= @travel_agency.establishment.status == 'active' ? 'Activo' : 'Inactivo' %>
            </span>
          </div>

          <p class="mb-4 text-secondary"><%= @travel_agency.establishment.short_description %></p>
          
          <ul class="list-group list-group-flush mb-0">
            <li class="list-group-item bg-transparent px-0 py-3 border-bottom">
              <i class="fas fa-map-marker-alt text-primary rounded-circle bg-light p-2 me-2"></i>
              <span class="fw-semibold"><%= @travel_agency.establishment.address %></span> (<%= @travel_agency.establishment.city&.name %>, <%= @travel_agency.establishment.country&.name %>)
            </li>
            <li class="list-group-item bg-transparent px-0 py-3 border-bottom">
              <i class="fas fa-phone text-primary rounded-circle bg-light p-2 me-2"></i>
              <span class="fw-semibold"><%= @travel_agency.establishment.phone %></span>
            </li>
            <li class="list-group-item bg-transparent px-0 py-3 border-bottom">
              <i class="fab fa-whatsapp text-success rounded-circle bg-light p-2 me-2"></i>
              <span class="fw-semibold"><%= @travel_agency.establishment.whatsapp %></span>
            </li>
            <li class="list-group-item bg-transparent px-0 py-3 border-0">
              <i class="fas fa-envelope text-primary rounded-circle bg-light p-2 me-2"></i>
              <span class="fw-semibold"><%= @travel_agency.establishment.email %></span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Gestión de Paquetes Turísticos -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
          <h4 class="mb-0 fw-bold"><i class="fas fa-box-open me-2 text-warning"></i> Paquetes Turísticos</h4>
          <%= link_to new_travel_agency_tour_package_path(@travel_agency), class: "btn btn-warning text-dark rounded-pill shadow-sm px-4 fw-semibold" do %>
            <i class="fas fa-plus me-1"></i> Crear Paquete
          <% end %>
        </div>
        <div class="card-body p-4">
          <% if @tour_packages.any? %>
            <div class="row g-3">
              <% @tour_packages.each do |package| %>
                <div class="col-md-6">
                  <div class="card border border-light shadow-sm rounded-3 h-100 hover-shadow transition-all">
                    <% if package.photos.attached? %>
                      <%= image_tag package.photos.first.variant(resize_to_fill: [300, 200]), class: "card-img-top", style: "height: 160px; object-fit: cover;" %>
                    <% else %>
                      <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 160px;">
                        <i class="fas fa-image fa-3x text-muted opacity-50"></i>
                      </div>
                    <% end %>

                    <div class="card-body p-3">
                      <div class="d-flex justify-content-between mb-2">
                        <h5 class="fw-bold mb-0 text-truncate"><%= package.name %></h5>
                        <span class="fw-bold text-success fs-5">
                          <%= number_to_currency(package.price, unit: "$") %>
                        </span>
                      </div>
                      <p class="text-muted small mb-2"><i class="fas fa-clock me-1"></i> <%= package.duration %></p>
                      <p class="text-muted small mb-3 text-truncate-2"><%= package.description %></p>
                      
                      <div class="d-flex gap-2">
                        <%= link_to "Ver más", travel_agency_tour_package_path(@travel_agency, package), class: "btn btn-sm btn-outline-primary rounded-pill flex-grow-1" %>
                        <%= link_to edit_travel_agency_tour_package_path(@travel_agency, package), class: "btn btn-sm btn-outline-secondary rounded-pill" do %>
                          <i class="fas fa-edit"></i>
                        <% end %>
                        <%= link_to travel_agency_tour_package_path(@travel_agency, package), data: { turbo_method: :delete, turbo_confirm: "¿Estás seguro?" }, class: "btn btn-sm btn-outline-danger rounded-pill" do %>
                          <i class="fas fa-trash"></i>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-5 border rounded-4 border-dashed bg-light">
              <i class="fas fa-box-open fa-3x text-muted opacity-50 mb-3"></i>
              <h5 class="fw-bold text-dark">No hay paquetes creados</h5>
              <p class="text-muted mb-4">Esta agencia aún no ofrece paquetes turísticos.</p>
              <%= link_to new_travel_agency_tour_package_path(@travel_agency), class: "btn btn-warning rounded-pill px-4 fw-semibold" do %>
                <i class="fas fa-plus me-1"></i> Añadir Paquete
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hover-shadow { transition: all 0.3s ease; }
  .hover-shadow:hover { 
    box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15)!important;
    transform: translateY(-3px);
  }
  .border-dashed { border-style: dashed !important; border-width: 2px !important; }
  .text-truncate-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .transition-all { transition: all 0.3s ease; }
</style>
