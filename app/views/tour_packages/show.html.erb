<!-- app/views/tour_packages/show.html.erb -->
<div class="container-fluid pt-4 px-4 pb-5">
  <div class="row mb-4 align-items-center">
    <div class="col-auto">
      <%= link_to travel_agency_path(@travel_agency), class: "btn btn-outline-secondary rounded-circle shadow-sm" do %>
        <i class="fas fa-arrow-left"></i>
      <% end %>
    </div>
    <div class="col">
      <h3 class="mb-0 fw-bold" style="color: #2c3e50;">
        <i class="fas fa-box-open me-2 text-warning"></i> <%= @tour_package.name %>
      </h3>
      <p class="text-muted mb-0">Agencia: <%= @travel_agency.establishment.name %></p>
    </div>
    <div class="col-auto">
      <%= link_to edit_travel_agency_tour_package_path(@travel_agency, @tour_package), class: "btn btn-outline-primary rounded-pill px-4 shadow-sm fw-semibold" do %>
        <i class="fas fa-edit me-1"></i> Editar
      <% end %>
      <%= link_to travel_agency_tour_package_path(@travel_agency, @tour_package), data: { turbo_method: :delete, turbo_confirm: "¿Eliminar este paquete?" }, class: "btn btn-outline-danger rounded-pill px-4 shadow-sm fw-semibold ms-2" do %>
        <i class="fas fa-trash me-1"></i> Eliminar
      <% end %>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <% if @tour_package.photos.attached? %>
          <div id="packageCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
              <% @tour_package.photos.each_with_index do |img, index| %>
                <div class="carousel-item <%= 'active' if index == 0 %>">
                  <%= image_tag img.variant(resize_to_fill: [800, 500]), class: "d-block w-100", style: "height: 400px; object-fit: cover;" %>
                </div>
              <% end %>
            </div>
            <% if @tour_package.photos.count > 1 %>
              <button class="carousel-control-prev" type="button" data-bs-target="#packageCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Anterior</span>
              </button>
              <button class="carousel-control-next" type="button" data-bs-target="#packageCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Siguiente</span>
              </button>
            <% end %>
          </div>
        <% else %>
          <div class="bg-light d-flex align-items-center justify-content-center" style="height: 400px;">
            <div class="text-center">
              <i class="fas fa-image fa-4x text-muted opacity-50 mb-3 d-block"></i>
              <span class="text-muted">No hay fotos disponibles</span>
            </div>
          </div>
        <% end %>
      </div>
      
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-3"><i class="fas fa-info-circle text-primary me-2"></i> Descripción general</h5>
          <p class="text-secondary mb-0"><%= simple_format(@tour_package.description) %></p>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 mb-4 bg-primary text-white" style="background: linear-gradient(135deg, #f39c12, #e67e22) !important;">
        <div class="card-body p-4 text-center">
          <h6 class="text-white-50 text-uppercase tracking-wide mb-2"><i class="fas fa-tag me-1"></i> Precio del paquete</h6>
          <h2 class="display-5 fw-bold mb-0"><%= number_to_currency(@tour_package.price, unit: "$") %></h2>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="bg-light rounded-circle p-3 me-3">
              <i class="fas fa-clock fa-lg text-primary"></i>
            </div>
            <div>
              <h6 class="text-muted mb-0">Duración del recorrido</h6>
              <h5 class="fw-bold mb-0"><%= @tour_package.duration.presence || "No especificada" %></h5>
            </div>
          </div>
        </div>
      </div>

      <% if @tour_package.itinerary.present? %>
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-header bg-white border-0 p-4 pb-0">
            <h5 class="fw-bold mb-0"><i class="fas fa-map-marked-alt text-success me-2"></i> Itinerario detallado</h5>
          </div>
          <div class="card-body p-4">
            <div class="text-secondary itinerary-text">
              <%= simple_format(@tour_package.itinerary) %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
  .tracking-wide { letter-spacing: 1px; }
  .itinerary-text p {
    margin-bottom: 1rem;
    position: relative;
    padding-left: 1.5rem;
  }
  .itinerary-text p::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--bs-primary);
    font-size: 1.5rem;
    line-height: 1;
    top: -4px;
  }
</style>
