<!-- app/views/tour_packages/edit.html.erb -->
<div class="container-fluid pt-4 px-4 pb-5">
  <div class="row mb-4 align-items-center">
    <div class="col-auto">
      <%= link_to travel_agency_path(@travel_agency), class: "btn btn-outline-secondary rounded-circle shadow-sm" do %>
        <i class="fas fa-arrow-left"></i>
      <% end %>
    </div>
    <div class="col">
      <h3 class="mb-0 fw-bold" style="color: #2c3e50;">
        <i class="fas fa-edit me-2 text-warning"></i> Editar Paquete Turístico
      </h3>
      <p class="text-muted mb-0"><%= @tour_package.name %></p>
    </div>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <%= render "form", tour_package: @tour_package %>
    </div>
  </div>
</div>
