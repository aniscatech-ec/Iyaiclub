<h1>Provinces</h1>
<%= link_to "New Province", new_province_path, class: "btn btn-primary mb-3" %>

<table class="table table-striped">
  <thead>
  <tr>
    <th>Name</th>
    <th>Actions</th>
  </tr>
  </thead>
  <tbody>
  <% @provinces.each do |province| %>
    <tr>
      <td><%= province.name %></td>
      <td>
        <%= link_to "Show", province_path(province), class: "btn btn-info btn-sm" %>
        <%= link_to "Edit", edit_province_path(province), class: "btn btn-warning btn-sm" %>
        <%= link_to "Delete", province_path(province), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
      </td>
    </tr>
  <% end %>
  </tbody>
</table>
