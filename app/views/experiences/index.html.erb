<div class="card mb-4 shadow-sm border-warning">
  <div class="card-header bg-warning text-dark fw-bold d-flex justify-content-between align-items-center">
    <span>
      <i class="bi bi-star me-1"></i> Experiencias
      <% if @establishment %>
        para <%= @establishment.name %>
      <% end %>
    </span>
    <span class="badge bg-light text-warning rounded-pill"><%= @experiences.count %></span>
  </div>
  
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <p class="mb-0 text-muted">Gestione todas las actividades y experiencias.</p>
      <% if @establishment %>
        <%= link_to "Volver al Establecimiento", establishment_path(@establishment), class: "btn btn-outline-secondary btn-sm" %>
      <% else %>
        <%= link_to "Volver", root_path, class: "btn btn-outline-secondary btn-sm" %>
      <% end %>
    </div>

    <% if @experiences.any? %>
      <div class="row">
        <% @experiences.each do |experience| %>
          <div class="col-md-4 mb-3">
            <div class="card h-100 bg-light border-warning-subtle">
              <div class="card-body p-3">
                <h5 class="fw-bold text-dark mb-1"><%= experience.name %></h5>
                <p class="mb-1 fw-bold fs-5 text-success"><%= number_to_currency(experience.price) %></p>
                <div class="small text-muted mb-3">
                  <span class="d-block"><i class="bi bi-clock me-1"></i> <%= experience.duration.presence || "N/A" %></span>
                </div>
                <div class="d-flex justify-content-between mt-auto border-top pt-2">
                  <%= link_to "Detalles", experience_path(experience), class: "btn btn-sm btn-outline-secondary" %>
                  <%= link_to "Editar", edit_experience_path(experience), class: "btn btn-sm btn-outline-warning" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-secondary py-3 text-center">No hay experiencias registradas.</div>
    <% end %>

    <% if @establishment %>
      <hr>
      <div class="text-end">
        <%= link_to "+ Crear Nueva Experiencia", new_establishment_experience_path(@establishment), class: "btn btn-warning fw-bold" %>
      </div>
    <% end %>
  </div>
</div>
