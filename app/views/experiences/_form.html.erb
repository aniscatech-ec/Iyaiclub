<%
  # Determinar la ruta del form según contexto
  form_model = if @getaway
    [@getaway, experience]
  elsif @establishment
    [@establishment, experience]
  else
    experience
  end
%>
<%= form_with(model: form_model, local: true, class: "card shadow-sm border-0", data: { controller: "form-validation" }) do |form| %>
  <div class="card-header text-white fw-bold rounded-top-3" style="background: linear-gradient(135deg, #8e44ad, #6c3483);">
    <i class="fas fa-star me-2"></i>
    <%= experience.persisted? ? "Editar atracción" : "Nueva atracción" %>
    <% if @getaway %>
      <span class="fw-normal opacity-75"> — <%= @getaway.establishment.name %></span>
    <% end %>
  </div>
  <div class="card-body p-4">
    <% if experience.errors.any? %>
      <div class="alert alert-danger">
        <h6 class="alert-heading fw-bold"><%= pluralize(experience.errors.count, "error") %> impidieron guardar:</h6>
        <ul class="mb-0">
          <% experience.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @getaway %>
      <%= form.hidden_field :getaway_id, value: @getaway.id %>
      <%= form.hidden_field :establishment_id, value: @getaway.establishment_id %>
    <% elsif @establishment %>
      <%= form.hidden_field :establishment_id, value: @establishment.id %>
    <% end %>

    <div class="row g-3">
      <div class="col-md-8">
        <%= form.label :name, "Nombre de la atracción", class: "form-label fw-semibold required-field" %>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-star"></i></span>
          <%= form.text_field :name, class: "form-control", placeholder: "Ej. Subida a la cima del monumento", required: true %>
        </div>
      </div>

      <div class="col-md-4">
        <%= form.label :price, "Precio ($)", class: "form-label fw-semibold required-field" %>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
          <%= form.number_field :price, step: 0.01, min: 0.01, class: "form-control", placeholder: "0.00", required: true %>
        </div>
      </div>

      <div class="col-12">
        <%= form.label :description, "Descripción", class: "form-label fw-semibold" %>
        <%= form.text_area :description, rows: 3, class: "form-control",
              placeholder: "Describe qué incluye esta atracción, qué experiencia vivirá el visitante..." %>
      </div>

      <div class="col-md-6">
        <%= form.label :duration, "Duración estimada", class: "form-label fw-semibold" %>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-clock"></i></span>
          <%= form.text_field :duration, class: "form-control", placeholder: "Ej. 30 minutos, 1 hora" %>
        </div>
      </div>

      <div class="col-12">
        <%= form.label :requirements, "Requisitos o condiciones", class: "form-label fw-semibold" %>
        <%= form.text_area :requirements, rows: 2, class: "form-control",
              placeholder: "Edad mínima, restricciones de salud, ropa adecuada..." %>
      </div>
    </div>

    <div class="d-flex gap-3 mt-4">
      <%= form.submit experience.persisted? ? "Guardar cambios" : "Crear atracción",
            class: "btn fw-bold btn-lg px-5",
            style: "background: #8e44ad; color: white; border: none;" %>
      <% back_path = @getaway ? getaway_path(@getaway) : (@establishment ? establishment_path(@establishment) : experiences_path) %>
      <%= link_to "Cancelar", back_path, class: "btn btn-outline-secondary btn-lg" %>
    </div>
  </div>
<% end %>
