<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow border-warning mb-4">
        <div class="card-header bg-warning text-dark fw-bold d-flex justify-content-between align-items-center">
          <span><i class="bi bi-star"></i> Detalles de la Experiencia</span>
          <%= link_to "Volver al Establecimiento", establishment_path(@experience.establishment), class: "btn btn-sm btn-outline-dark" %>
        </div>
        
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h3 class="fw-bold mb-1 border-bottom pb-2"><%= @experience.name %></h3>
            </div>
            <div class="text-end">
              <span class="fs-4 fw-bold text-success"><%= number_to_currency(@experience.price) %></span>
            </div>
          </div>

          <div class="row mb-4 bg-light rounded p-3 mx-0">
            <div class="col-md-6 mb-2">
              <strong class="text-muted d-block"><i class="bi bi-clock me-1"></i> Duración</strong>
              <span class="fs-5"><%= @experience.duration.presence || "No especificada" %></span>
            </div>
          </div>

          <div class="mb-4">
            <strong class="text-muted d-block mb-1"><i class="bi bi-card-text me-1"></i> Descripción</strong>
            <div class="p-3 border rounded bg-light">
              <%= simple_format @experience.description.presence || "Sin descripción detallada." %>
            </div>
          </div>

          <div class="mb-4">
            <strong class="text-muted d-block mb-1"><i class="bi bi-exclamation-triangle me-1"></i> Requisitos</strong>
            <div class="p-3 border rounded bg-light border-warning-subtle">
              <%= simple_format @experience.requirements.presence || "Sin requisitos específicos definidos." %>
            </div>
          </div>

          <div class="d-flex justify-content-between border-top pt-3 mt-4">
            <div>
              <%= link_to edit_experience_path(@experience), class: "btn btn-outline-warning" do %>
                <i class="bi bi-pencil"></i> Editar
              <% end %>
            </div>
            <div>
              <%= button_to experience_path(@experience), method: :delete, data: { turbo_confirm: "¿Estás seguro de que deseas eliminar esta experiencia?" }, class: "btn btn-outline-danger" do %>
                <i class="bi bi-trash"></i> Eliminar
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
