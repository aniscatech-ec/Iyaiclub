<p style="color: green"><%= notice %></p>

<div class="card shadow-sm p-4 mb-3">
  <!--  <h4 class="fw-bold mb-3">Amenidad</h4>-->
  <h4 class="fw-bold mb-3"><%= @amenity.name %></h4>

  <!-- Ícono -->
  <div class="mb-3">
    <%# if @amenity.custom_icon.attached? %>
    <%#= image_tag @amenity.custom_icon, size: "48x48", class: "me-2" %>
    <%# else %>
    <!--      <i class="fa fa-circle-question fa-2x text-muted"></i>-->
    <%# end %>

    <%# if @amenity.custom_icon.attached? %>
      <%# if @amenity.custom_icon.content_type == 'image/svg+xml' %>
        <%#= raw @amenity.custom_icon.download %>
      <%# else %>
        <%#= image_tag @amenity.custom_icon, class: "svg-icon" %>
      <%# end %>
    <%# else %>
<!--      <i class="fa fa-circle-question fa-2x text-muted"></i>-->
    <%# end %>

    <% if @amenity.custom_icon.attached? && @amenity.custom_icon.content_type == 'image/svg+xml' %>
      <% svg_content = @amenity.custom_icon.download %>
      <%= raw svg_content.gsub('<svg', '<svg width="32" height="32"') %>
    <% else %>
      <i class="fa fa-circle-question fa-2x text-muted"></i>
    <% end %>


    <%# if @amenity.custom_icon.attached? %>
    <%#= image_tag url_for(@amenity.custom_icon), size: "48x48" %>
    <%# elsif @amenity.icon.present? %>
    <!--      <i class="fa <%#= @amenity.icon %> fa-2x"></i>-->
    <%# end %>

  </div>

  <!-- Nombre -->
</div>

<div class="mt-3">
  <%= link_to "✏️ Editar", edit_amenity_path(@amenity), class: "btn btn-outline-primary me-2" %>
  <%= link_to "⬅️ Volver", amenities_path, class: "btn btn-secondary me-2" %>
  <%= link_to "🗑️ Eliminar", @amenity, method: :delete,
              data: { confirm: "¿Seguro que deseas eliminar esta amenidad?" },
              class: "btn btn-danger" %>
</div>
