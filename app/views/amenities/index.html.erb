<!--<p style="color: green"><%#= notice %></p>-->
<% content_for :title, "Amenities" %>
<%= link_to new_amenity_path, class: "btn btn-primary btn-lg" do %>
  <i class="fa-solid fa-plus"></i> Nueva comodidad
<% end %>

<table class="table">
  <thead>
  <tr>
    <th>Nombre</th>
    <th>Icon</th>
    <th>Establecimiento</th>
    <th>Acciones</th>
  </tr>
  </thead>
  <tbody>
  <% @amenities.each do |amenity| %>
    <tr>
      <!--      <td><%#= render amenity %></td>-->
      <td><%= amenity.name %></td>
      <td>

        <%# if amenity.custom_icon.attached? %>
          <%#= image_tag amenity.custom_icon, size: "24x24", class: "me-2" %>
        <%# else %>
<!--          --->
        <%# end %>
        <% if amenity.custom_icon.attached? && amenity.custom_icon.content_type == 'image/svg+xml' %>
          <% svg_content = amenity.custom_icon.download %>
          <%= raw svg_content.gsub('<svg', '<svg width="32" height="32"') %>
        <% end %>
        <%# if amenity.custom_icon.attached? %>
          <%# if amenity.custom_icon.content_type == 'image/svg+xml' %>
            <%#= raw amenity.custom_icon.download %>
          <%# else %>
            <%#= image_tag amenity.custom_icon, size: "24x24", class: "svg-icon" %>
          <%# end %>
        <%# end %>
      </td>
      <td>
        <%= amenity.establishment_type.humanize %>
      </td>
      <td>
        <%= link_to amenity_path(amenity), class: "btn btn-info btn-sm" do %>
          <i class="fa-solid fa-eye"></i>
        <% end %>
        <%= link_to edit_amenity_path(amenity), class: "btn btn-warning btn-sm" do %>
          <i class="fa-solid fa-pen-to-square"></i>
        <% end %>
        <%= link_to amenity_path(amenity), data: { turbo_method: :delete, turbo_confirm: "¿Está seguro de eliminar esta comodidad?" }, class: "btn btn-danger btn-sm" do %>
          <i class="fa-solid fa-trash-can"></i>
        <% end %>

      </td>
    </tr>
  <% end %>
  </tbody>
</table>

