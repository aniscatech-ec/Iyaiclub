<% est = @temporary_lodging.establishment %>
<%= render "shared/establishment_show_styles" %>

<div class="est-show-page">

  <!-- HERO -->
  <%
    lodging_icons = {
      "casa" => "fa-home",
      "departamento" => "fa-building",
      "quinta" => "fa-warehouse",
      "habitacion" => "fa-bed"
    }
    icon = lodging_icons[@temporary_lodging.lodging_type] || "fa-house-user"
  %>
  <%= render "shared/establishment_hero",
             establishment: est,
             title: est.name,
             icon: icon,
             badges: [
               { text: lodging_type_label(@temporary_lodging.lodging_type), color: "var(--brand-green, #3FBD02)", icon: icon },
               (est.active? ? { text: "Activo", color: "#27ae60", icon: "fa-check-circle" } : { text: "Inactivo", color: "#6c757d", icon: "fa-pause-circle" })
             ] %>

  <!-- QUICK STATS -->
  <div class="row g-3 mb-4">
    <% if @temporary_lodging.max_guests.present? && @temporary_lodging.max_guests > 0 %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
          <div class="mb-1" style="color: var(--brand-orange, #EB633B);"><i class="fas fa-users fa-2x"></i></div>
          <div class="fw-bold fs-4"><%= @temporary_lodging.max_guests %></div>
          <div class="small text-muted">Huéspedes máx</div>
        </div>
      </div>
    <% end %>
    <% if @temporary_lodging.total_rooms.present? && @temporary_lodging.total_rooms > 0 %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
          <div class="mb-1" style="color: var(--brand-cofee, #88682B);"><i class="fas fa-bed fa-2x"></i></div>
          <div class="fw-bold fs-4"><%= @temporary_lodging.total_rooms %></div>
          <div class="small text-muted">Habitaciones</div>
        </div>
      </div>
    <% end %>
    <% if @temporary_lodging.total_bathrooms.present? && @temporary_lodging.total_bathrooms > 0 %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
          <div class="mb-1" style="color: var(--brand-green, #3FBD02);"><i class="fas fa-bath fa-2x"></i></div>
          <div class="fw-bold fs-4"><%= @temporary_lodging.total_bathrooms %></div>
          <div class="small text-muted">Baños</div>
        </div>
      </div>
    <% end %>
    <% if est.amenities.any? %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
          <div class="text-primary mb-1"><i class="fas fa-concierge-bell fa-2x"></i></div>
          <div class="fw-bold fs-4"><%= est.amenities.size %></div>
          <div class="small text-muted">Servicios</div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="row g-4">
    <!-- COLUMNA PRINCIPAL -->
    <div class="col-12 col-lg-8">

      <!-- PERFIL -->
      <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-orange, #EB633B), #c94a28); color: white; border-radius: 0.5rem 0.5rem 0 0;">
          <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2"></i> Perfil del alojamiento</h5>
        </div>
        <div class="card-body p-4">
          <div class="row g-3 mb-3">
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas fa-tag me-1"></i> Nombre</div>
                <div class="info-value"><%= est.name %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas <%= icon %> me-1"></i> Tipo de alojamiento</div>
                <div class="info-value"><%= lodging_type_label(@temporary_lodging.lodging_type) %></div>
              </div>
            </div>
            <% if @temporary_lodging.max_guests.present? %>
              <div class="col-sm-6">
                <div class="info-item">
                  <div class="info-label"><i class="fas fa-users me-1"></i> Capacidad máxima</div>
                  <div class="info-value"><%= @temporary_lodging.max_guests %> personas</div>
                </div>
              </div>
            <% end %>
            <% if @temporary_lodging.total_rooms.present? %>
              <div class="col-sm-6">
                <div class="info-item">
                  <div class="info-label"><i class="fas fa-bed me-1"></i> Habitaciones</div>
                  <div class="info-value"><%= @temporary_lodging.total_rooms %></div>
                </div>
              </div>
            <% end %>
          </div>

          <% if est.short_description.present? %>
            <div class="mt-3 pt-3 border-top">
              <div class="info-label"><i class="fas fa-align-left me-1"></i> Descripción corta</div>
              <p class="mb-0"><%= est.short_description %></p>
            </div>
          <% end %>

          <% if est.long_description.present? %>
            <div class="mt-3 pt-3 border-top">
              <div class="info-label"><i class="fas fa-file-alt me-1"></i> Descripción detallada</div>
              <div class="long-desc"><%= simple_format(est.long_description) %></div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- UNIDADES -->
      <% if est.respond_to?(:units) && est.units.any? %>
        <div class="card border-0 shadow-sm rounded-3 mb-4">
          <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-green, #3FBD02), #2d8f01); color: white; border-radius: 0.5rem 0.5rem 0 0;">
            <h5 class="mb-0 fw-bold">
              <i class="fas fa-door-open me-2"></i> Unidades disponibles
              <span class="badge bg-light text-dark ms-2"><%= est.units.size %></span>
            </h5>
          </div>
          <div class="card-body p-4">
            <div class="row g-3">
              <% est.units.each do |unit| %>
                <div class="col-12 col-md-6">
                  <div class="card unit-card h-100 rounded-3 border">
                    <div class="card-body p-3">
                      <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title fw-bold mb-0"><%= unit.name %></h6>
                        <% if unit.respond_to?(:price) && unit.price.present? %>
                          <span class="menu-item-price ms-2 text-nowrap">
                            <%= number_to_currency(unit.price) %>
                          </span>
                        <% end %>
                      </div>
                      <% if unit.respond_to?(:description) && unit.description.present? %>
                        <p class="card-text text-muted small mb-0"><%= unit.description %></p>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- GALERÍA -->
      <%= render "shared/establishment_gallery", establishment: est %>

      <!-- COMODIDADES -->
      <% if est.amenities.any? %>
        <div class="card border-0 shadow-sm rounded-3 mb-4">
          <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, #27ae60, #1e8449); color: white; border-radius: 0.5rem 0.5rem 0 0;">
            <h5 class="mb-0 fw-bold"><i class="fas fa-concierge-bell me-2"></i> Servicios y comodidades</h5>
          </div>
          <div class="card-body p-4">
            <div class="row g-2">
              <% est.amenities.each do |amenity| %>
                <div class="col-6 col-md-4">
                  <div class="amenity-pill d-flex align-items-center p-2 rounded-3">
                    <i class="fas fa-check-circle me-2" style="color: var(--brand-green, #3FBD02);"></i>
                    <span class="small"><%= amenity.name %></span>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

    </div>

    <!-- COLUMNA LATERAL -->
    <div class="col-12 col-lg-4">

      <!-- ACCIONES -->
      <div class="card border-0 shadow-sm rounded-3 mb-4 sticky-top-actions">
        <div class="card-body p-3">
          <div class="d-grid gap-2">
            <% if current_user&.administrador? || (current_user&.afiliado? && est.user_id == current_user.id) %>
              <%= link_to edit_temporary_lodging_path(@temporary_lodging), class: "btn btn-primary rounded-pill fw-semibold" do %>
                <i class="fas fa-edit me-1"></i> Editar alojamiento
              <% end %>
            <% end %>

            <% phone = est.whatsapp.presence || est.legal_info&.contact_phone %>
            <% if phone.present? %>
              <a href="https://wa.me/<%= phone.to_s.gsub(/\D/, '') %>?text=<%= CGI.escape("Hola, estoy interesado en #{est.name}") %>"
                 target="_blank"
                 class="btn btn-success rounded-pill fw-semibold">
                <i class="fab fa-whatsapp me-1"></i> Contactar por WhatsApp
              </a>
            <% end %>

            <%= link_to temporary_lodgings_path, class: "btn btn-outline-secondary rounded-pill fw-semibold" do %>
              <i class="fas fa-arrow-left me-1"></i> Volver al listado
            <% end %>
          </div>
        </div>
      </div>

      <%= render "shared/establishment_sidebar", establishment: est %>

    </div>
  </div>
</div>
