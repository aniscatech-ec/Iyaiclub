<%= form_with(model: temporary_lodging, local: true, html: { class: "temporary-lodging-form", multipart: true, data: { controller: "form-validation" } }) do |form| %>
  <%= render_validation_errors(temporary_lodging) %>

  <%= form.fields_for :establishment do |est| %>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header text-white fw-bold rounded-top-3" style="background: var(--brand-green);">
        <i class="fas fa-home me-2"></i> 1. Informacion del alojamiento
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-8">
            <%= est.label :name, "Nombre del alojamiento", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-signature"></i></span>
              <%= est.text_field :name, class: "form-control", placeholder: "Nombre visible para los clientes", required: true %>
            </div>
          </div>

          <div class="col-md-4">
            <%= form.label :lodging_type, "Tipo de alojamiento", class: "form-label fw-semibold required-field" %>
            <%= form.select :lodging_type, lodging_type_options,
                { include_blank: "Selecciona un tipo" }, class: "form-select", required: true %>
          </div>

          <% if current_user.administrador? %>
            <div class="col-md-6">
              <%= est.label :user_id, "Afiliado responsable", class: "form-label fw-semibold" %>
              <%= est.collection_select :user_id, User.where(role: :afiliado).order(:name), :id, :email,
                  { prompt: "Seleccione un afiliado" }, class: "form-select" %>
            </div>
          <% end %>

          <div class="col-md-6">
            <%= est.label :short_description, "Descripcion corta", class: "form-label fw-semibold" %>
            <%= est.text_area :short_description, rows: 2, class: "form-control", placeholder: "Breve descripcion para listados" %>
          </div>

          <div class="col-md-6">
            <%= est.label :long_description, "Descripcion detallada", class: "form-label fw-semibold" %>
            <%= est.text_area :long_description, rows: 2, class: "form-control", placeholder: "Descripcion completa del alojamiento" %>
          </div>

          <div class="col-md-6">
            <%= est.label :video_url, "Video promocional (URL)", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-video"></i></span>
              <%= est.url_field :video_url, class: "form-control", placeholder: "https://youtube.com/..." %>
            </div>
          </div>
        </div>
      </div>
    </div>

  <% end %>

    <!-- ═══════════════ 2. HABITACIONES ═══════════════ -->
    <div class="card shadow-sm border-0 rounded-3 mb-4" data-controller="nested-form">
      <div class="card-header text-white fw-bold rounded-top-3 d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #8e44ad, #6c3483);">
        <h5 class="mb-0 fw-bold"><i class="fas fa-bed me-2"></i> 2. Tipos de habitaciones <small class="opacity-75">(max. 10)</small></h5>
        <button type="button" class="btn btn-sm btn-light fw-semibold rounded-pill px-3" data-action="click->nested-form#add">
          <i class="fas fa-plus me-1"></i> Añadir habitación
        </button>
      </div>
      <div class="card-body p-4">

        <%# ── Template para nueva habitación ── %>
        <template data-nested-form-target="template">
          <div class="nested-fields border rounded-3 p-3 mb-3" style="background: #f5f0ff;" data-new-record="true">
            <%= form.fields_for :rooms, Room.new, child_index: 'NEW_RECORD' do |r| %>
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0 fw-bold"><i class="fas fa-door-open me-2" style="color: #8e44ad;"></i> Nueva habitación</h6>
                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" data-action="click->nested-form#remove">
                  <i class="fas fa-trash me-1"></i> Eliminar
                </button>
              </div>
              <%= r.hidden_field :_destroy %>

              <div class="row g-3">
                <div class="col-md-6">
                  <%= r.label :name, "Nombre de la habitación", class: "form-label fw-semibold required-field" %>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-tag"></i></span>
                    <%= r.text_field :name, class: "form-control", required: true, placeholder: "Ej: Suite Principal, Habitación Doble" %>
                  </div>
                </div>

                <div class="col-md-3">
                  <%= r.label :room_type, "Tipo", class: "form-label fw-semibold" %>
                  <%= r.select :room_type,
                      options_for_select([["Individual", "individual"], ["Doble", "doble"], ["Triple", "triple"], ["Cuádruple", "cuadruple"], ["Suite", "suite"], ["Familiar", "familiar"]]),
                      { include_blank: "Seleccione" },
                      class: "form-select" %>
                </div>

                <div class="col-md-3">
                  <%= r.label :quantity, "Cantidad disponible", class: "form-label fw-semibold" %>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-hashtag"></i></span>
                    <%= r.number_field :quantity, class: "form-control", min: 1, value: 1, placeholder: "Ej: 2" %>
                  </div>
                  <small class="text-muted">¿Cuántas de este tipo?</small>
                </div>

                <div class="col-md-4">
                  <%= r.label :bed_type, "Tipo de cama", class: "form-label fw-semibold" %>
                  <%= r.select :bed_type,
                      options_for_select([["1 Plaza", "1_plaza"], ["Plaza y media", "plaza_y_media"], ["Doble", "doble"], ["Queen", "queen"], ["King", "king"]]),
                      { include_blank: "Seleccione" },
                      class: "form-select" %>
                </div>

                <div class="col-md-2">
                  <%= r.label :num_beds, "N° camas", class: "form-label fw-semibold" %>
                  <%= r.number_field :num_beds, class: "form-control", min: 1, placeholder: "Ej: 2" %>
                </div>

                <div class="col-md-3">
                  <%= r.label :guest_capacity, "Capacidad", class: "form-label fw-semibold" %>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-users"></i></span>
                    <%= r.number_field :guest_capacity, class: "form-control", min: 1, placeholder: "Ej: 2" %>
                  </div>
                  <small class="text-muted">Huéspedes</small>
                </div>

                <div class="col-md-3">
                  <%= r.label :price_per_night, "Precio/noche ($)", class: "form-label fw-semibold" %>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                    <%= r.number_field :price_per_night, step: 0.01, class: "form-control", placeholder: "0.00" %>
                  </div>
                </div>

                <div class="col-12">
                  <%= r.label :description, "Descripción", class: "form-label fw-semibold" %>
                  <%= r.text_area :description, rows: 2, class: "form-control", placeholder: "Descripción de la habitación, características especiales..." %>
                </div>

                <div class="col-md-6">
                  <%= r.label :photo, "Foto de la habitación", class: "form-label fw-semibold" %>
                  <%= r.file_field :photo, class: "form-control", accept: "image/jpeg,image/png,image/webp" %>
                </div>

                <div class="col-12">
                  <label class="form-label fw-semibold">Comodidades de esta habitación</label>
                  <div class="row g-2">
                    <% Amenity.order(:name).each do |amenity| %>
                      <div class="col-6 col-md-4 col-lg-3">
                        <div class="form-check">
                          <%= check_box_tag "temporary_lodging[rooms_attributes][NEW_RECORD][amenity_ids][]", amenity.id, false, class: "form-check-input", id: "room_NEW_RECORD_amenity_#{amenity.id}" %>
                          <label class="form-check-label" for="room_NEW_RECORD_amenity_<%= amenity.id %>"><%= amenity.name %></label>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </template>

        <%# ── Habitaciones existentes ── %>
        <div data-nested-form-target="target">
          <%= form.fields_for :rooms do |r| %>
            <div class="nested-fields border rounded-3 p-3 mb-3" style="background: #f5f0ff;" data-new-record="<%= r.object.new_record? %>">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0 fw-bold"><i class="fas fa-door-open me-2" style="color: #8e44ad;"></i> <%= r.object.name || "Habitación" %></h6>
                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" data-action="click->nested-form#remove">
                  <i class="fas fa-trash me-1"></i> Eliminar
                </button>
              </div>
              <%= r.hidden_field :_destroy %>

              <div class="row g-3">
                <div class="col-md-6">
                  <%= r.label :name, "Nombre de la habitación", class: "form-label fw-semibold required-field" %>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-tag"></i></span>
                    <%= r.text_field :name, class: "form-control", required: true, placeholder: "Ej: Suite Principal, Habitación Doble" %>
                  </div>
                </div>

                <div class="col-md-3">
                  <%= r.label :room_type, "Tipo", class: "form-label fw-semibold" %>
                  <%= r.select :room_type,
                      options_for_select([["Individual", "individual"], ["Doble", "doble"], ["Triple", "triple"], ["Cuádruple", "cuadruple"], ["Suite", "suite"], ["Familiar", "familiar"]], r.object.room_type),
                      { include_blank: "Seleccione" },
                      class: "form-select" %>
                </div>

                <div class="col-md-3">
                  <%= r.label :quantity, "Cantidad disponible", class: "form-label fw-semibold" %>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-hashtag"></i></span>
                    <%= r.number_field :quantity, class: "form-control", min: 1, placeholder: "Ej: 2" %>
                  </div>
                  <small class="text-muted">¿Cuántas de este tipo?</small>
                </div>

                <div class="col-md-4">
                  <%= r.label :bed_type, "Tipo de cama", class: "form-label fw-semibold" %>
                  <%= r.select :bed_type,
                      options_for_select([["1 Plaza", "1_plaza"], ["Plaza y media", "plaza_y_media"], ["Doble", "doble"], ["Queen", "queen"], ["King", "king"]], r.object.bed_type),
                      { include_blank: "Seleccione" },
                      class: "form-select" %>
                </div>

                <div class="col-md-2">
                  <%= r.label :num_beds, "N° camas", class: "form-label fw-semibold" %>
                  <%= r.number_field :num_beds, class: "form-control", min: 1, placeholder: "Ej: 2" %>
                </div>

                <div class="col-md-3">
                  <%= r.label :guest_capacity, "Capacidad", class: "form-label fw-semibold" %>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-users"></i></span>
                    <%= r.number_field :guest_capacity, class: "form-control", min: 1, placeholder: "Ej: 2" %>
                  </div>
                  <small class="text-muted">Huéspedes</small>
                </div>

                <div class="col-md-3">
                  <%= r.label :price_per_night, "Precio/noche ($)", class: "form-label fw-semibold" %>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                    <%= r.number_field :price_per_night, step: 0.01, class: "form-control", placeholder: "0.00" %>
                  </div>
                </div>

                <div class="col-12">
                  <%= r.label :description, "Descripción", class: "form-label fw-semibold" %>
                  <%= r.text_area :description, rows: 2, class: "form-control", placeholder: "Descripción de la habitación, características especiales..." %>
                </div>

                <div class="col-md-6">
                  <%= r.label :photo, "Foto de la habitación", class: "form-label fw-semibold" %>
                  <% if r.object.persisted? && r.object.photo.attached? %>
                    <div class="mb-2">
                      <%= image_tag r.object.photo.variant(resize_to_limit: [200, 120]), class: "img-thumbnail rounded shadow-sm", loading: "lazy" %>
                    </div>
                  <% end %>
                  <%= r.file_field :photo, class: "form-control", accept: "image/jpeg,image/png,image/webp" %>
                </div>

                <div class="col-12">
                  <label class="form-label fw-semibold">Comodidades de esta habitación</label>
                  <div class="row g-2">
                    <% Amenity.order(:name).each do |amenity| %>
                      <div class="col-6 col-md-4 col-lg-3">
                        <div class="form-check">
                          <%= r.check_box :amenity_ids, { multiple: true, checked: r.object.amenity_ids.include?(amenity.id), class: "form-check-input", id: "room_#{r.object.id || r.index}_amenity_#{amenity.id}" }, amenity.id, nil %>
                          <label class="form-check-label" for="room_<%= r.object.id || r.index %>_amenity_<%= amenity.id %>"><%= amenity.name %></label>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <% if temporary_lodging.rooms.empty? %>
          <p class="text-muted text-center py-3 mb-0">
            <i class="fas fa-info-circle me-1"></i> Aún no has agregado tipos de habitaciones. Haz click en "Añadir habitación" para comenzar.
          </p>
        <% end %>
      </div>
    </div>

  <%= form.fields_for :establishment do |est| %>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header bg-dark text-white fw-bold rounded-top-3">
        <i class="fas fa-file-contract me-2"></i> 3. Datos legales
      </div>
      <div class="card-body">
        <%= est.fields_for :legal_info do |li| %>
          <div class="row g-3">
            <div class="col-md-6">
              <%= li.label :business_name, "Razon social", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-building"></i></span>
                <%= li.text_field :business_name, class: "form-control", placeholder: "Nombre legal de la empresa", required: true %>
              </div>
            </div>
            <div class="col-md-6">
              <%= li.label :legal_representative, "Representante legal", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-user-tie"></i></span>
                <%= li.text_field :legal_representative, class: "form-control", placeholder: "Nombre completo", required: true %>
              </div>
            </div>
            <div class="col-md-6">
              <%= li.label :document_type, "Tipo de documento", class: "form-label fw-semibold required-field" %>
              <%= li.select :document_type, [["RUC", "RUC"], ["Cedula", "Cedula"], ["Pasaporte", "Pasaporte"]],
                  { prompt: "Seleccione" }, class: "form-select", required: true %>
            </div>
            <div class="col-md-6">
              <%= li.label :document_number, "Numero de documento", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                <%= li.text_field :document_number, class: "form-control", placeholder: "Ej: 0102030405001", required: true %>
              </div>
            </div>
            <div class="col-md-6">
              <%= li.label :contact_email, "Email de contacto", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                <%= li.email_field :contact_email, class: "form-control", placeholder: "legal@empresa.com", required: true %>
              </div>
            </div>
            <div class="col-md-6">
              <%= li.label :contact_phone, "Telefono de contacto", class: "form-label fw-semibold required-field" %>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                <%= li.telephone_field :contact_phone, class: "form-control", placeholder: "0991234567", required: true %>
              </div>
              <small class="text-success">10 digitos numericos</small>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header text-white fw-bold rounded-top-3" style="background: var(--brand-orange);">
        <i class="fas fa-address-book me-2"></i> 4. Contacto
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <%= est.label :phone, "Telefono", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-phone"></i></span>
              <%= est.telephone_field :phone, class: "form-control", placeholder: "Ej: 072123456", required: true %>
            </div>
          </div>
          <div class="col-md-6">
            <%= est.label :whatsapp, "WhatsApp", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fab fa-whatsapp text-success"></i></span>
              <%= est.telephone_field :whatsapp, class: "form-control", placeholder: "593991234567", required: true %>
            </div>
            <small class="text-muted">Con codigo de pais, sin + ni espacios</small>
          </div>
          <div class="col-md-6">
            <%= est.label :email, "Correo electronico", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-envelope"></i></span>
              <%= est.email_field :email, class: "form-control", placeholder: "correo@ejemplo.com", required: true %>
            </div>
          </div>
          <div class="col-md-6">
            <%= est.label :website, "Sitio web", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-globe"></i></span>
              <%= est.url_field :website, class: "form-control", placeholder: "https://www.ejemplo.com" %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header text-white fw-bold rounded-top-3" style="background: var(--brand-cofee);">
        <i class="fas fa-map-marker-alt me-2"></i> 5. Ubicacion
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-12">
            <%= est.label :address, "Direccion", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-road"></i></span>
              <%= est.text_field :address, class: "form-control", placeholder: "Calle principal y secundaria", required: true %>
            </div>
          </div>
          <div class="col-md-4">
            <%= est.label :country_id, "Pais", class: "form-label fw-semibold required-field" %>
            <%= est.collection_select :country_id, Country.order(:name), :id, :name,
                { prompt: "Seleccione pais" }, class: "form-select", required: true %>
          </div>
          <div class="col-md-4">
            <%= est.label :province_id, "Provincia", class: "form-label fw-semibold required-field" %>
            <%= est.collection_select :province_id, Province.order(:name), :id, :name,
                { prompt: "Seleccione provincia" }, class: "form-select", required: true %>
          </div>
          <div class="col-md-4">
            <%= est.label :city_id, "Ciudad", class: "form-label fw-semibold required-field" %>
            <%= est.collection_select :city_id, City.order(:name), :id, :name,
                { prompt: "Seleccione ciudad" }, class: "form-select", required: true %>
          </div>
          <div class="col-12">
            <%= est.label :arrival_instructions, "Instrucciones de llegada", class: "form-label fw-semibold" %>
            <%= est.text_area :arrival_instructions, class: "form-control", rows: 2, placeholder: "Como llegar al alojamiento" %>
          </div>
          <div class="col-md-6">
            <%= est.label :latitude, "Latitud", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-map-pin"></i></span>
              <%= est.number_field :latitude, step: 0.000001, class: "form-control", placeholder: "Ej: -2.897086", required: true %>
            </div>
          </div>
          <div class="col-md-6">
            <%= est.label :longitude, "Longitud", class: "form-label fw-semibold required-field" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-map-pin"></i></span>
              <%= est.number_field :longitude, step: 0.000001, class: "form-control", placeholder: "Ej: -79.004653", required: true %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
      <div class="card-header bg-info text-white fw-bold rounded-top-3">
        <i class="fas fa-clock me-2"></i> 6. Horarios
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <%= est.label :check_in_time, "Hora de entrada (Check-in)", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-door-open"></i></span>
              <%= est.time_field :check_in_time, class: "form-control" %>
            </div>
          </div>
          <div class="col-md-6">
            <%= est.label :check_out_time, "Hora de salida (Check-out)", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-door-closed"></i></span>
              <%= est.time_field :check_out_time, class: "form-control" %>
            </div>
          </div>
          <div class="col-12">
            <%= est.label :policies, "Politicas del alojamiento", class: "form-label fw-semibold" %>
            <%= est.text_area :policies, class: "form-control", rows: 3, placeholder: "Politicas de cancelacion, normas de convivencia..." %>
          </div>
        </div>
      </div>
    </div>

  <% end %>

  <div class="card shadow-sm border-0 rounded-3 mb-4">
    <div class="card-header bg-dark text-white fw-bold rounded-top-3">
      <i class="fas fa-images me-2"></i> 7. Galeria de fotos
    </div>
    <div class="card-body">
      <%= form.fields_for :establishment do |est2| %>
        <% temporary_lodging.establishment&.galleries&.each_with_index do |gallery, gi| %>
          <%= est2.fields_for :galleries, gallery do |gf| %>
            <div class="mb-3">
              <%= gf.hidden_field :id %>
              <%= gf.label :name, "Nombre de la galeria", class: "form-label fw-semibold" %>
              <%= gf.text_field :name, class: "form-control mb-2", placeholder: "Ej: Fotos del interior" %>

              <% gallery.gallery_images.each_with_index do |img, ii| %>
                <%= gf.fields_for :gallery_images, img do |gif| %>
                  <div class="d-inline-block me-2 mb-2">
                    <%= gif.hidden_field :id %>
                    <% if img.persisted? && img.file.attached? %>
                      <%= image_tag img.file.variant(resize_to_limit: [120, 80]),
                          class: "img-thumbnail rounded shadow-sm",
                          style: "width: 120px; height: 80px; object-fit: cover;",
                          loading: "lazy" %>
                    <% end %>
                    <%= gif.file_field :file, class: "form-control form-control-sm mt-1",
                        accept: "image/jpeg,image/png,image/webp" %>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>
      <small class="text-muted">Sube las fotos del alojamiento (JPG, PNG, WEBP)</small>
    </div>
  </div>

  <div class="card shadow-sm border-0 rounded-3 mb-4">
    <div class="card-header fw-bold rounded-top-3" style="background: var(--brand-green); color: white;">
      <i class="fas fa-concierge-bell me-2"></i> 8. Comodidades
    </div>
    <div class="card-body">
      <div class="row g-2">
        <% Amenity.with_attached_custom_icon.each do |amenity| %>
          <div class="col-6 col-md-4 col-lg-3">
            <div class="form-check p-3 border rounded-3 h-100 d-flex align-items-center"
                 style="cursor: pointer; transition: all 0.2s ease;"
                 onmouseover="this.style.borderColor='var(--brand-green)'; this.style.background='#f0fdf0';"
                 onmouseout="this.style.borderColor=''; this.style.background='';">
              <%= check_box_tag "temporary_lodging[establishment_attributes][amenity_ids][]", amenity.id,
                  temporary_lodging.establishment&.amenity_ids&.include?(amenity.id),
                  id: "amenity_#{amenity.id}",
                  class: "form-check-input me-2 flex-shrink-0" %>
              <%= label_tag "amenity_#{amenity.id}", amenity.name,
                  class: "form-check-label w-100",
                  style: "cursor: pointer;" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="d-flex flex-column flex-sm-row gap-3 mb-5">
    <button type="submit" class="gradient-btn btn-lg flex-grow-1 order-1 order-sm-1">
      <i class="fas fa-save me-2"></i> Guardar alojamiento
    </button>
    <%= link_to temporary_lodging.persisted? ? temporary_lodging_path(temporary_lodging) : temporary_lodgings_path,
        class: "btn btn-outline-secondary btn-lg flex-grow-0 order-2 order-sm-2" do %>
      <i class="fas fa-times me-2"></i> Cancelar
    <% end %>
  </div>
<% end %>

<script>
    // Intentar múltiples eventos para asegurar que el script se ejecute
    function initLocationScript() {
        console.log("Inicializando script de ubicación para alojamiento temporal");
        
        // ═══════════════ UBICACIÓN DINÁMICA ═══════════════
        const countrySelect = document.getElementById('establishment_country_id');
        const provinceSelect = document.getElementById('establishment_province_id');
        const citySelect = document.getElementById('establishment_city_id');

        console.log('Elementos encontrados:', { countrySelect, provinceSelect, citySelect });

        // Función para cargar provincias
        function loadProvinces(countryId) {
            console.log('Cargando provincias para país:', countryId);
            
            if (!countryId) {
                console.log('No hay país seleccionado');
                provinceSelect.innerHTML = '<option value="">Seleccione provincia</option>';
                citySelect.innerHTML = '<option value="">Seleccione ciudad</option>';
                return;
            }

            fetch(`/locations/provinces/${countryId}`)
                .then(response => {
                    console.log('Response status:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('Provincias recibidas:', data);
                    provinceSelect.innerHTML = '<option value="">Seleccione provincia</option>';
                    data.forEach(province => {
                        provinceSelect.innerHTML += `<option value="${province.id}">${province.name}</option>`;
                    });
                    citySelect.innerHTML = '<option value="">Seleccione ciudad</option>';
                })
                .catch(error => {
                    console.error('Error loading provinces:', error);
                    provinceSelect.innerHTML = '<option value="">Error al cargar provincias</option>';
                });
        }

        // Función para cargar ciudades
        function loadCities(provinceId) {
            console.log('Cargando ciudades para provincia:', provinceId);
            
            if (!provinceId) {
                citySelect.innerHTML = '<option value="">Seleccione ciudad</option>';
                return;
            }

            fetch(`/locations/cities/${provinceId}`)
                .then(response => {
                    console.log('Cities response status:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('Ciudades recibidas:', data);
                    citySelect.innerHTML = '<option value="">Seleccione ciudad</option>';
                    data.forEach(city => {
                        citySelect.innerHTML += `<option value="${city.id}">${city.name}</option>`;
                    });
                })
                .catch(error => {
                    console.error('Error loading cities:', error);
                    citySelect.innerHTML = '<option value="">Error al cargar ciudades</option>';
                });
        }

        // Event listeners
        if (countrySelect) {
            console.log('Country select encontrado:', countrySelect);
            countrySelect.addEventListener('change', function() {
                console.log('Cambio en país seleccionado:', this.value);
                loadProvinces(this.value);
            });

            // Cargar provincias si hay un país preseleccionado
            if (countrySelect.value) {
                console.log('País preseleccionado:', countrySelect.value);
                loadProvinces(countrySelect.value);
            }
        } else {
            console.log('No se encontró el select de país');
        }

        if (provinceSelect) {
            console.log('Province select encontrado:', provinceSelect);
            provinceSelect.addEventListener('change', function() {
                console.log('Cambio en provincia seleccionada:', this.value);
                loadCities(this.value);
            });
        } else {
            console.log('No se encontró el select de provincia');
        }
    }

    // Múltiples intentos para asegurar que el script se ejecute
    
    // Intentar inmediatamente
    initLocationScript();
    
    // Intentar con DOMContentLoaded
    document.addEventListener('DOMContentLoaded', initLocationScript);
    
    // Intentar con turbo:load
    document.addEventListener('turbo:load', initLocationScript);
    
    // Intentar después de un pequeño delay
    setTimeout(initLocationScript, 500);
</script>
