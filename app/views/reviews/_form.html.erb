<%= form_with(model: [@establishment, Review.new], local: true, class: "needs-validation") do |form| %>
  <% if form.object.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h4><%= pluralize(form.object.errors.count, "error") %> impidió guardar esta reseña:</h4>
      <ul>
        <% form.object.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group mb-3">
    <%= form.label :user_name, "Nombre de Usuario", class: "form-label" %>
    <%= form.text_field :user_name, class: "form-control", required: true %>
  </div>

  <div class="form-group mb-3">
    <%= form.label :rating, "Calificación (1 a 5)", class: "form-label" %>
    <%= form.number_field :rating, in: 1..5, class: "form-control", required: true %>
  </div>

  <div class="form-group mb-3">
    <%= form.label :comment, "Comentario", class: "form-label" %>
    <%= form.text_area :comment, rows: 4, class: "form-control", required: true %>
  </div>

  <div class="form-group mt-3">
    <%= form.submit "Publicar Reseña", class: "btn btn-primary" %>
  </div>
<% end %>
