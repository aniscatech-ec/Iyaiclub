<div class="container my-5">
  <!-- Mensaje introductorio -->
  <div class="row mb-5">
    <div class="col text-center">
      <h2 class="fw-bold text-dark">Por favor seleccione el usuario</h2>
      <p class="text-muted">Elija si desea gestionar a un <strong>afiliado</strong> o un <strong>turista</strong>.</p>
    </div>
  </div>

  <div class="row justify-content-center">
    <!-- Tarjeta Afiliados -->
    <div class="col-md-5 mb-4">
      <%= link_to admin_users_path(role: "afiliado"), class: "text-decoration-none" do %>
        <div class="card shadow-sm border-0 rounded-4 hover-card">
          <div class="card-body text-center">
            <h3 class="card-title mb-3 text-dark">Afiliados</h3>
            <p class="card-text mb-4 text-dark">
              Accede a las funciones exclusivas para afiliados, promociones y beneficios especiales.
            </p>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Tarjeta Turistas -->
    <div class="col-md-5 mb-4">
      <%= link_to admin_users_path(role: "turista"), class: "text-decoration-none" do %>
        <div class="card shadow-sm border-0 rounded-4 hover-card">
          <div class="card-body text-center">
            <h3 class="card-title mb-3 text-dark">Turistas</h3>
            <p class="card-text mb-4 text-dark">
              Descubre los servicios y planes disponibles para turistas, con acceso rápido y sencillo.
            </p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Mejora visual al hover -->
<style>
    .hover-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }
</style>
