<div class="plans-container" style="display: flex; gap: 20px; justify-content: center; margin-top: 40px;">

  <% @plans.each do |plan| %>
    <div class="plan-card" style="border: 1px solid #ddd; border-radius: 12px; padding: 24px; width: 280px; text-align: center; box-shadow: 0 2px 6px rgba(0,0,0,0.1);">

      <!-- Nombre del plan -->
      <h2 style="font-size: 22px; font-weight: bold; margin-bottom: 10px;">
        <%= plan.plan_type %>
      </h2>

      <!-- Precio -->
      <p style="font-size: 20px; margin: 10px 0; color: #333;">
<!--        $<%#= plan.price %>-->
        $<%= number_to_currency(plan.price, unit: "", separator: ".", delimiter: ",") %>

      </p>

      <!-- Beneficios -->
      <ul style="list-style: none; padding: 0; margin: 15px 0; text-align: left; font-size: 14px;">
        <% if plan.features.nil? %>
        <% else %>
          <% plan.features.each do |feature| %>
            <li style="margin-bottom: 8px;">✅ <%= feature %></li>
          <% end %>
        <% end %>

      </ul>

      <!-- Botón de acción -->
      <%= link_to "Suscribirme", new_subscription_path(plan_id: plan.id, establishment_id: @establishment.id),
                  class: "subscribe-btn",
                  style: "display:inline-block; background:#4f46e5; color:white; padding:10px 20px; border-radius:8px; text-decoration:none;" %>
    </div>
  <% end %>

</div>

