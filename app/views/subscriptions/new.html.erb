<h1>Nueva Suscripción</h1>

<%#= render 'form', subscription: @subscription %>
<%= form_with(model: @subscription, local: true) do |form| %>
  <% if @subscription.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% @subscription.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div data-controller="subscriptions">

<%# -------------------- Usuario (solo admin) -------------------- %>
    <% if current_user.administrador? %>


      <div class="mb-3">
        <%= form.label :user_id, "Usuario", class: "form-label fw-bold" %>
        <%= form.text :user_id, "Usuario" %>


      </div>
    <% else %>
      <div class="mb-3">
        <strong><%= "#{current_user.role.humanize}:" %></strong>
        <%= form.label :user_name, current_user.name %>
        <%#= form.hidden_field :user_id, value: current_user.id %>
        <% if current_user.turista? %>
          <%= form.hidden_field :subscribable_type, value: "User" %>
          <%= form.hidden_field :subscribable_id, value: current_user.id %>
        <% end %>


      </div>

    <% end %>

<%# -------------------- Establecimiento -------------------- %>
    <div class="mb-3">

      <% if current_user.administrador? %>


      <% elsif current_user.afiliado? %>
        <strong>Establecimiento: </strong>

        <%= @establishment.name %>
        <%#= form.hidden_field :establishment_id, value: @establishment.id %>

        <%= form.hidden_field :subscribable_type, value: "Establishment" %>
        <%= form.hidden_field :subscribable_id, value: @establishment.id %>
      <% end %>
    </div>

    <%# -------------------- Plan -------------------- %>
    <div class="mb-3">
      <strong>Plan:</strong>
      <%= @plan_price.plan_type %>
      <%= form.hidden_field :plan_type, value: @plan_price.id %>
    </div>
    <div class="mb-3">

      <strong>Precio:</strong>
      $<%= number_to_currency(@plan_price.price, unit: "", separator: ".", delimiter: ",") %> USD/mes
    </div>

    <%# -------------------- Estado -------------------- %>
    <div class="mb-3">
      <%#= form.label :status, "Estado", class: "form-label fw-bold" %>
      <%#= form.select :status, Subscription.statuses.keys.map { |s| [s.humanize, s] }, { prompt: "Seleccione estado" }, class: "form-select" %>
      <strong>Estado:</strong>
      <%= Subscription.statuses.first[0].humanize %>
      <%= form.hidden_field :status, value: Subscription.statuses.first[0] %>

    </div>

<%# -------------------- Fecha de inicio -------------------- %>
    <div class="mb-3">
      <%#= form.label :start_date, "Fecha de inicio", class: "form-label fw-bold" %>
      <%#= form.date_field :start_date, class: "form-control" %>
    </div>

<%# -------------------- Fecha de fin -------------------- %>
    <div class="mb-3">
      <%#= form.label :end_date, "Fecha de fin", class: "form-label fw-bold" %>
      <%#= form.date_field :end_date, class: "form-control" %>
    </div>

    <%# -------------------- Método de pago -------------------- %>
    <div class="mb-3">
      <%= form.label :payment_method, "Método de pago", class: "form-label fw-bold" %>
      <%= form.select :payment_method,
                      Subscription.payment_methods.keys.map { |p| [p.humanize, p] },
                      { prompt: "Seleccione método" },
                      class: "form-select",
                      data: { subscriptions_target: "paymentMethod", action: "change->subscriptions#updatePaymentInstructions" } %>
    </div>

    <%# -------------------- Instrucciones de pago -------------------- %>
    <div class="mb-3">
      <%= form.label :payment_instructions, "Instrucciones de pago", class: "form-label fw-bold" %>
      <%= form.text_area :payment_instructions, rows: 4,
                         class: "form-control",
                         data: { subscriptions_target: "paymentInstructions" } %>
    </div>
  </div>


  <%# -------------------- Botones -------------------- %>
  <div class="mb-3 d-flex gap-2">
    <%= form.submit "Guardar Suscripción", class: "btn btn-primary" %>
    <%= link_to "Cancelar", subscriptions_path, class: "btn btn-secondary" %>
  </div>
<% end %>


<%= link_to 'Volver', subscriptions_path, class: 'btn btn-secondary mt-3' %>
