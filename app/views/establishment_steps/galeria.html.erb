<h2>Paso 4 – Galería</h2>

<h2>Galerías</h2>
<% @establishment.galleries.each do |gallery| %>
  <div class="mb-4 p-3 border rounded">
    <p class="fw-bold">
      <%= gallery.name %>
      <span class="text-muted">(<%= gallery.gallery_images.count %> imágenes)</span>
    </p>

    <% if gallery.gallery_images.any? %>
      <div class="d-flex flex-wrap gap-3">
        <% gallery.gallery_images.each do |gi| %>
          <% if gi.file.attached? %>
            <div class="position-relative">
              <%= image_tag gi.file.variant(resize_to_limit: [200, 200]), class: "img-thumbnail #{'border border-3 border-success' if gi.is_cover?}" %>

              <% if gi.is_cover? %>
                <span class="badge bg-success position-absolute top-0 start-0 m-1">Portada</span>
              <% else %>

                <%= button_to "Marcar como portada",
                              wizard_path(:galeria, gallery_image_id: gi.id, make_cover: true, establishment_id: @establishment.id),
                              method: :put, class: "btn btn-sm btn-outline-success mt-1 w-100" %>


            <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted">No hay imágenes aún en esta galería.</p>
    <% end %>

    <h5 class="mt-3">Agregar imágenes:</h5>
    <%= form_with model: gallery.gallery_images.build,
                  url: wizard_path,
                  method: :put,
                  local: true do |form| %>
      <%= form.hidden_field :gallery_id, value: gallery.id %>
      <%= form.file_field :file, multiple: true, class: "form-control" %>
      <%= form.submit "Subir imágenes", name: "stay_in_gallery", class: "btn btn-primary btn-sm mt-2" %>
    <% end %>
  </div>
<% end %>

<h2>Agregar Galería:</h2>
<%= form_with model: [@establishment, @establishment.galleries.build], url: wizard_path, method: :put, local: true do |form| %>
  <p>
    <%= form.label :name, "Nombre de la galería (ej: Fachada, Piscina)" %>
    <%= form.text_field :name, class: "form-control" %>
  </p>
  <p>
    <%= form.submit "Guardar galería", name: "stay_in_gallery", class: "btn btn-secondary" %>
    <%#= link_to "Continuar", next_wizard_path(establishment_id: @establishment.id), class: "btn btn-primary mx-2" %>

    <%= hidden_field_tag :edit_mode, @edit_mode %>
    <%= form.submit @edit_mode ? "Guardar cambios" : "Continuar", class: "btn #{@edit_mode ? 'btn-warning' : 'btn-primary'}" %>

  </p>
<% end %>

<h2>Video del establecimiento</h2>
<% if @establishment.video.attached? %>
  <h5>Video de presentación</h5>
  <%= video_tag url_for(@establishment.video),
                controls: true,
                preload: "metadata",
                class: "w-100 rounded shadow mb-3" %>
  <%#= link_to est, data: { turbo_method: :delete, turbo_confirm: "¿Está seguro de eliminar este establecimiento?" }, class: "btn btn-danger btn-sm" do %>

  <%= button_to "Eliminar video",
                wizard_path(:galeria, establishment_id: @establishment.id, remove_video: true),
                method: :put,
                data: { turbo_confirm: "¿Estás seguro de que deseas eliminar este video?" },
                class: "btn btn-danger mb-4" %>
<% elsif @establishment.video_url.present? %>

  <%= embed_video_tag_from_url(@establishment.video_url) %>

  <%= button_to "Eliminar enlace",
                wizard_path(:galeria, establishment_id: @establishment.id, remove_video_url: true),
                method: :put,
                data: { turbo_confirm: "¿Quieres eliminar este enlace de video?" },
                class: "btn btn-danger mb-4" %>
<% end %>


<%= form_with model: @establishment,
              url: wizard_path,
              method: :put,
              local: true,
              html: { multipart: true } do |form| %>

  <div class="mb-3">
    <%= form.label :video, "Subir video de presentación" %>
    <%= form.file_field :video, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :video_url, "O pegar un enlace de YouTube/Vimeo" %>
    <%= form.text_field :video_url, class: "form-control" %>
  </div>

  <div class="mt-3">
    <%= form.submit "Guardar video", name: "stay_in_gallery", class: "btn btn-success" %>
  </div>
<% end %>
