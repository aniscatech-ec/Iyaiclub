<hr>
<h3 class="mt-4">Unidades existentes (<%= @establishment.units.count %>)</h3>
<% @establishment.units.where.not(id: nil).each do |unit| %>
  <%#= unit.unit_availabilities.count %>

  <p>
    – <strong><%= unit.unit_type.presence || "Sin tipo" %></strong>
    – Capacidad: <%= unit.capacity || "No especificada" %> personas
    –
    Camas: <%= unit.bed_configuration.present? ? unit.bed_configuration.map { |k, v| "#{v} #{k}" }.join(", ") : "No especificado" %>
    – Precio base: $<%= unit.base_price || "No definido" %>

  </p>

  <p>
    Temporadas
  </p>
  <ul>
    <% unit.unit_prices.each do |unit_price| %>
      <li>
        <% if unit_price.season == "low"  %>
          Baja -
        <% end %>
        <% if unit_price.season == "high"  %>
          Alta -
        <% end %>
        <%= unit_price.price %>
      </li>
    <% end %>
  </ul>

  <% if unit.unit_availabilities.any? %>
    <p>– Disponibilidad guardada:</p>
    <ul>
      <% unit.unit_availabilities.order(:date).each do |avail| %>
        <li>
          <%= avail.date.strftime("%d/%m/%Y") %> –
          <%= avail.available ? "✅ Disponible" : "❌ No disponible" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>– Disponibilidad: ❌ No definido</p>
  <% end %>
<% end %>
