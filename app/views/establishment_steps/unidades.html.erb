<h2>Paso 5 – Unidades / Habitaciones</h2>

<%= form_with model: [@establishment, @establishment.units.build], url: wizard_path, method: :put, local: true do |f| %>
  <div class="mb-3">
    <%= f.label :unit_type, "Tipo de unidad" %>
    <%= f.text_field :unit_type, class: "form-control", placeholder: "Ej: Simple, Doble, Suite" %>
  </div>

  <div class="mb-3">
    <%= f.label :capacity, "Capacidad de personas" %>
    <%= f.number_field :capacity, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :beds, "Número de camas" %>
    <%= f.number_field :beds, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :base_price, "Precio base por noche" %>
    <%= f.number_field :base_price, step: 0.01, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :seasonal_prices, "Precios por temporada (JSON: {high: 120, low: 80})" %>
    <%= f.text_area :seasonal_prices, class: "form-control", placeholder: '{ "high": 120.0, "low": 80.0 }' %>
  </div>

  <div class="mb-3 form-check">
    <%= f.check_box :available, class: "form-check-input" %>
    <%= f.label :available, "Disponible", class: "form-check-label" %>
  </div>
  <%= f.submit "Guardar y quedarse", name: "stay_in_unit", class: "btn btn-warning" %>
  <%#= f.submit "Guardar unidad", class: "btn btn-primary" %>
  <%= link_to "Continuar", next_wizard_path(establishment_id: @establishment.id), class: "btn btn-primary" %>

<% end %>

<hr>
<h3>Unidades existentes</h3>
<% @establishment.units.each do |unit| %>
  <p>
    <strong><%= unit.unit_type %></strong> - Capacidad: <%= unit.capacity %> personas -
    Camas: <%= unit.beds %> - Precio: $<%= unit.base_price %> -
    Disponibilidad: <%= unit.available ? "Sí" : "No" %>
  </p>
<% end %>
