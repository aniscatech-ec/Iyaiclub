<div class="container-fluid px-3 px-md-4 py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <% if @event.image.attached? %>
          <%= image_tag @event.image, class: "card-img-top", style: "max-height: 300px; object-fit: cover; border-radius: 16px 16px 0 0;" %>
        <% end %>
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <h2 class="fw-bold mb-0"><%= @event.name %></h2>
            <% if @event.ticket_price.to_f == 0 %>
              <span class="badge bg-success fs-6">GRATIS</span>
            <% else %>
              <span class="badge bg-primary fs-6">$<%= number_with_precision(@event.ticket_price, precision: 2) %></span>
            <% end %>
          </div>

          <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
              <div class="text-center p-2 bg-light rounded-3">
                <i class="fas fa-calendar text-primary mb-1"></i>
                <small class="d-block text-muted">Fecha</small>
                <strong class="small"><%= @event.event_date&.strftime('%d/%m/%Y') || 'Por definir' %></strong>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="text-center p-2 bg-light rounded-3">
                <i class="fas fa-clock text-info mb-1"></i>
                <small class="d-block text-muted">Hora</small>
                <strong class="small"><%= @event.event_date&.strftime('%H:%M') || 'Por definir' %></strong>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="text-center p-2 bg-light rounded-3">
                <i class="fas fa-map-marker-alt text-danger mb-1"></i>
                <small class="d-block text-muted">Lugar</small>
                <strong class="small"><%= @event.location.presence || 'Por definir' %></strong>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="text-center p-2 bg-light rounded-3">
                <i class="fas fa-ticket-alt text-success mb-1"></i>
                <small class="d-block text-muted">Disponibles</small>
                <strong class="small"><%= @event.available_tickets || 'Ilimitado' %></strong>
              </div>
            </div>
          </div>

          <% if @event.description.present? %>
            <div class="mb-4">
              <h6 class="fw-bold">Descripción</h6>
              <p class="text-muted"><%= @event.description %></p>
            </div>
          <% end %>

          <% if @event.maps_url.present? %>
            <div class="mb-4">
              <%= link_to @event.maps_url, target: "_blank", class: "btn btn-outline-info" do %>
                <i class="fas fa-map-marked-alt me-1"></i> Ver en Google Maps
              <% end %>
            </div>
          <% end %>

          <div class="d-flex flex-column flex-md-row gap-2">
            <% if user_signed_in? %>
              <% if @event.ticket_price.to_f == 0 %>
                <% if @event.sold_out? %>
                  <button class="btn btn-secondary btn-lg" disabled>
                    <i class="fas fa-times-circle me-1"></i> Agotado
                  </button>
                <% else %>
                  <%= link_to new_free_turista_event_tickets_path(@event), class: "btn btn-success btn-lg" do %>
                    <i class="fas fa-ticket-alt me-1"></i> Adquirir Ticket Gratuito
                  <% end %>
                <% end %>
              <% else %>
                <button class="btn btn-primary btn-lg" disabled>
                  <i class="fas fa-credit-card me-1"></i> Comprar Ticket (Próximamente)
                </button>
              <% end %>

              <% if @ticket_count.to_i > 0 %>
                <%= link_to turista_tickets_path, class: "btn btn-outline-success" do %>
                  <i class="fas fa-check-circle me-1"></i> Ya tienes <%= @ticket_count %> ticket(s)
                <% end %>
              <% end %>
            <% else %>
              <%= link_to new_user_session_path, class: "btn btn-primary btn-lg" do %>
                <i class="fas fa-sign-in-alt me-1"></i> Inicia sesión para adquirir ticket
              <% end %>
            <% end %>

            <%= link_to events_path, class: "btn btn-outline-secondary" do %>
              <i class="fas fa-arrow-left me-1"></i> Volver a eventos
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
