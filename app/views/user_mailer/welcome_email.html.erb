        <i class="fas fa-envelope"></i> portal@iyaiclub.com
      </a>
    </div>
    <div>
      <p style="margin-bottom: 5px; font-size: 14px; color: #666;">Información general</p>
      <a href="mailto:info@iyaiclub.com" style="color: #34c759; font-weight: 500; text-decoration: none;">
