<%= form_with(model: city, local: true) do |form| %>
  <div class="mb-3">
    <%= form.label :name %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :province_id, "Province" %>
    <%= form.collection_select :province_id, provinces, :id, :name, { prompt: "Select Province" }, { class: "form-select" } %>
  </div>

  <%= form.submit class: "btn btn-primary" %>
<% end %>
