<%= form_with(model: city, local: true, data: { controller: "location" }) do |form| %>

  <div class="mb-3">
    <%= form.label :country_id, "País" %>
    <%= form.collection_select :country_id, countries, :id, :name, { prompt: "Seleccionar país" },
                               { class: "form-select",
                                 data: { action: "change->location#updateProvinces", location_target: "country" } } %>
  </div>

  <div class="mb-3">
    <%= form.label :province_id, "Provincia" %>
    <%= form.collection_select :province_id, provinces || [], :id, :name, { prompt: "Seleccionar provincia" },
                               { class: "form-select", data: { location_target: "province" } } %>
  </div>

  <div class="mb-3">
    <%= form.label :name, "Nombre" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <%= form.submit class: "btn btn-primary" %>
<% end %>
