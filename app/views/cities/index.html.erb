<h1>Cities</h1>
<%= link_to "New City", new_city_path, class: "btn btn-primary mb-3" %>

<table class="table table-striped">
  <thead>
  <tr>
    <th>Name</th>
    <th>Province</th>
    <th>Actions</th>
  </tr>
  </thead>
  <tbody>
  <% @cities.each do |city| %>
    <tr>
      <td><%= city.name %></td>
      <td><%= city.province.name %></td>
      <td>
        <%= link_to "Show", city_path(city), class: "btn btn-info btn-sm" %>
        <%= link_to "Edit", edit_city_path(city), class: "btn btn-warning btn-sm" %>
        <%= link_to "Delete", city_path(city), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
      </td>
    </tr>
  <% end %>
  </tbody>
</table>
