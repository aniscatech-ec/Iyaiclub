<% est = @getaway.establishment %>
<%= render "shared/establishment_show_styles" %>

<%
  getaway_icons = {
    "museo" => "fa-landmark",
    "parque_mirador" => "fa-mountain",
    "piscina" => "fa-swimming-pool",
    "balneario" => "fa-umbrella-beach",
    "centro_recreacional" => "fa-child",
    "parque_extremo" => "fa-hiking",
    "senderismo" => "fa-shoe-prints",
    "camping" => "fa-campground"
  }
  getaway_labels = {
    "museo" => "Museo",
    "parque_mirador" => "Parque y Mirador",
    "piscina" => "Piscina",
    "balneario" => "Balneario",
    "centro_recreacional" => "Centro Recreacional",
    "parque_extremo" => "Parque Extremo",
    "senderismo" => "Senderismo",
    "camping" => "Camping"
  }
  icon = getaway_icons[@getaway.subcategory] || "fa-map-marked-alt"
  subcategory_label = getaway_labels[@getaway.subcategory] || @getaway.subcategory&.humanize&.titleize
%>

<div class="est-show-page">

  <!-- HERO -->
  <%= render "shared/establishment_hero",
             establishment: est,
             title: est.name,
             icon: icon,
             badges: [
               { text: subcategory_label, color: "var(--brand-green, #3FBD02)", icon: icon },
               { text: "Escapada", color: "var(--brand-orange, #EB633B)", icon: "fa-map-marked-alt" }
             ] %>

  <!-- QUICK STATS -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
        <div class="mb-1" style="color: var(--brand-orange, #EB633B);"><i class="fas fa-ticket-alt fa-2x"></i></div>
        <div class="fw-bold fs-5"><%= number_to_currency(@getaway.entry_price) %></div>
        <div class="small text-muted">Precio de entrada</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
        <div class="mb-1" style="color: var(--brand-cofee, #88682B);"><i class="fas <%= icon %> fa-2x"></i></div>
        <div class="fw-bold fs-6"><%= subcategory_label %></div>
        <div class="small text-muted">Categoría</div>
      </div>
    </div>
    <% if est.amenities.any? %>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
          <div class="mb-1" style="color: var(--brand-green, #3FBD02);"><i class="fas fa-concierge-bell fa-2x"></i></div>
          <div class="fw-bold fs-4"><%= est.amenities.size %></div>
          <div class="small text-muted">Servicios</div>
        </div>
      </div>
    <% end %>
    <div class="col-6 col-md-3">
      <div class="card border-0 shadow-sm rounded-3 h-100 text-center p-3">
        <div class="text-primary mb-1">
          <i class="fas <%= est.active? ? 'fa-check-circle' : 'fa-pause-circle' %> fa-2x"></i>
        </div>
        <div class="fw-bold fs-6"><%= est.active? ? "Activa" : "Inactiva" %></div>
        <div class="small text-muted">Estado</div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- COLUMNA PRINCIPAL -->
    <div class="col-12 col-lg-8">

      <!-- PERFIL -->
      <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-orange, #EB633B), #c94a28); color: white; border-radius: 0.5rem 0.5rem 0 0;">
          <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2"></i> Perfil de la escapada</h5>
        </div>
        <div class="card-body p-4">
          <div class="row g-3 mb-3">
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas fa-tag me-1"></i> Nombre</div>
                <div class="info-value"><%= est.name %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas <%= icon %> me-1"></i> Tipo de escapada</div>
                <div class="info-value"><%= subcategory_label %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas fa-dollar-sign me-1"></i> Precio de entrada</div>
                <div class="info-value"><%= number_to_currency(@getaway.entry_price) %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="info-item">
                <div class="info-label"><i class="fas fa-circle me-1"></i> Estado</div>
                <div class="info-value"><%= est.active? ? "Activa" : "Inactiva" %></div>
              </div>
            </div>
          </div>

          <% if est.short_description.present? %>
            <div class="mt-3 pt-3 border-top">
              <div class="info-label"><i class="fas fa-align-left me-1"></i> Descripción corta</div>
              <p class="mb-0"><%= est.short_description %></p>
            </div>
          <% end %>

          <% if est.long_description.present? %>
            <div class="mt-3 pt-3 border-top">
              <div class="info-label"><i class="fas fa-file-alt me-1"></i> Descripción detallada</div>
              <div class="long-desc"><%= simple_format(est.long_description) %></div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- RECOMENDACIONES -->
      <% if @getaway.recommendations.present? %>
        <div class="card border-0 shadow-sm rounded-3 mb-4">
          <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-green, #3FBD02), #2d8f01); color: white; border-radius: 0.5rem 0.5rem 0 0;">
            <h5 class="mb-0 fw-bold"><i class="fas fa-lightbulb me-2"></i> Recomendaciones</h5>
          </div>
          <div class="card-body p-4">
            <div class="long-desc"><%= simple_format(@getaway.recommendations) %></div>
          </div>
        </div>
      <% end %>

      <!-- REGLAS -->
      <% if @getaway.rules.present? %>
        <div class="card border-0 shadow-sm rounded-3 mb-4">
          <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-cofee, #88682B), #5d4717); color: white; border-radius: 0.5rem 0.5rem 0 0;">
            <h5 class="mb-0 fw-bold"><i class="fas fa-gavel me-2"></i> Reglas</h5>
          </div>
          <div class="card-body p-4">
            <div class="long-desc"><%= simple_format(@getaway.rules) %></div>
          </div>
        </div>
      <% end %>

      <!-- GALERÍA -->
      <%= render "shared/establishment_gallery", establishment: est %>

      <!-- COMODIDADES -->
      <% if est.amenities.any? %>
        <div class="card border-0 shadow-sm rounded-3 mb-4">
          <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, #27ae60, #1e8449); color: white; border-radius: 0.5rem 0.5rem 0 0;">
            <h5 class="mb-0 fw-bold"><i class="fas fa-concierge-bell me-2"></i> Servicios y comodidades</h5>
          </div>
          <div class="card-body p-4">
            <div class="row g-2">
              <% est.amenities.each do |amenity| %>
                <div class="col-6 col-md-4">
                  <div class="amenity-pill d-flex align-items-center p-2 rounded-3">
                    <i class="fas fa-check-circle me-2" style="color: var(--brand-green, #3FBD02);"></i>
                    <span class="small"><%= amenity.name %></span>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

    </div>

    <!-- COLUMNA LATERAL -->
    <div class="col-12 col-lg-4">

      <!-- ACCIONES -->
      <div class="card border-0 shadow-sm rounded-3 mb-4 sticky-top-actions">
        <div class="card-body p-3">
          <div class="d-grid gap-2">
            <% can_edit = current_user&.administrador? || (current_user&.afiliado? && est.user_id == current_user.id) %>
            <% if can_edit %>
              <%= link_to edit_getaway_path(@getaway), class: "btn btn-primary rounded-pill fw-semibold" do %>
                <i class="fas fa-edit me-1"></i> Editar escapada
              <% end %>
            <% end %>

            <%# Botón de beneficio exclusivo para piscinas %>
            <% if user_signed_in? && current_user.turista? && @getaway.piscina? && current_user.can_request_pool_benefit? %>
              <div class="border border-warning rounded-3 p-3 text-center mb-1" style="background: rgba(255,193,7,0.08);">
                <div class="small text-warning fw-semibold mb-2">
                  <i class="fas fa-crown me-1"></i>
                  Beneficio <%= current_user.membership_display_name %>
                  <span class="badge bg-warning text-dark ms-1"><%= current_user.remaining_pool_visits %> visita(s) disponible(s)</span>
                </div>
                <%= link_to new_turista_getaway_benefit_request_path(@getaway, benefit_type: "pool"),
                      class: "btn btn-warning rounded-pill fw-bold w-100" do %>
                  <i class="fas fa-swimming-pool me-1"></i> Reservar con mi beneficio
                <% end %>
              </div>
            <% elsif user_signed_in? && current_user.turista? && @getaway.piscina? && current_user.can_access_pool_visits? && !current_user.can_request_pool_benefit? %>
              <div class="border rounded-3 p-2 text-center mb-1 bg-light">
                <small class="text-muted">
                  <i class="fas fa-info-circle me-1"></i>
                  Ya usaste todas tus visitas de piscina este año (<%= current_user.pool_visits_per_year %> de <%= current_user.pool_visits_per_year %>)
                </small>
              </div>
            <% end %>

            <%= link_to getaway_bookings_path(@getaway), class: "btn btn-primary rounded-pill fw-semibold" do %>
              <i class="fas fa-calendar-check me-1"></i> Reservar ahora
            <% end %>

            <% phone = est.whatsapp.presence || est.legal_info&.contact_phone %>
            <% if phone.present? %>
              <a href="https://wa.me/<%= phone.to_s.gsub(/\D/, '') %>?text=<%= CGI.escape("Hola, me interesa la escapada #{est.name}") %>"
                 target="_blank"
                 class="btn btn-success rounded-pill fw-semibold">
                <i class="fab fa-whatsapp me-1"></i> Contactar por WhatsApp
              </a>
            <% end %>

            <%= link_to getaways_path, class: "btn btn-outline-secondary rounded-pill fw-semibold" do %>
              <i class="fas fa-arrow-left me-1"></i> Volver a escapadas
            <% end %>
          </div>
        </div>
      </div>

      <%= render "shared/establishment_sidebar", establishment: est %>

    </div>
  </div>
</div>
