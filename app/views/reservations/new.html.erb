<h1>Nueva reserva</h1>

<div
  data-controller="reservation-calendar"
  data-reservation-calendar-disabled-ranges-value="<%= @reserved_ranges.to_json %>"
  data-reservation-calendar-hotel-id-value="<%= @unit.hotel.id %>"
  data-reservation-calendar-unit-id-value="<%= @unit.id %>">

  <div id="calendar"></div>

  <p id="selection-message" class="mt-3 text-muted">
    📅 Por favor selecciona la fecha de inicio de la estadía.
  </p>

  <%= form_with(model: [@unit.hotel, @unit, @reservation], local: true) do |f| %>
    <div class="mt-4">
      <div class="mb-3">
        <%= f.label :user_id, "Turista:" %>
        <%= f.collection_select :user_id, User.where(role: "turista"), :id, :email,
                                { prompt: "Selecciona un turista" },
                                class: "form-select" %>
      </div>

      <!-- ✅ Estos son los campos correctos, vinculados al modelo -->
      <%= f.hidden_field :start_date, id: "start_date" %>
      <%= f.hidden_field :end_date, id: "end_date" %>

      <div class="mt-3">
        <%= f.submit "Guardar reserva",
                     id: "submit-btn",
                     class: "btn btn-success",
                     disabled: true %>
      </div>
    </div>
  <% end %>
</div>
