<h2 class="mb-4 text-center fw-bold">Mis Reservas</h2>

<% if @reservations.any? %>
  <div class="row g-4">
    <% @reservations.each do |reservation| %>
      <% unit = reservation.unit %>
      <% hotel = unit.hotel %>
      <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm border-0 h-100">
          <div class="position-relative">
            <% if hotel.establishment.galleries.any? && hotel.establishment.galleries.first.gallery_images.any? %>
              <%= image_tag hotel.establishment.galleries.first.gallery_images.first.file,
                            class: "card-img-top", style: "height:200px; object-fit:cover;" %>
            <% else %>
              <%= image_tag "hotel-placeholder.jpg",
                            class: "card-img-top", style: "height:200px; object-fit:cover;" %>
            <% end %>
          </div>

          <div class="card-body">
            <h5 class="fw-bold"><%= hotel.establishment.name %></h5>
            <p class="text-muted mb-1">
              <i class="bi bi-geo-alt"></i>
              <%= hotel.establishment.city&.name || "Ubicación no disponible" %>
            </p>

            <div class="small text-muted mb-2">
              Habitación: <%= unit.unit_type %><br>
              Fechas: <%= reservation.start_date.strftime("%d/%m/%Y") %> → <%= reservation.end_date.strftime("%d/%m/%Y") %>
            </div>

            <!-- Estado visual -->
            <span class="badge
              <%= case reservation.status
                  when 'confirmed' then 'bg-success'
                  when 'pending' then 'bg-warning text-dark'
                  when 'cancelled' then 'bg-danger'
                  else 'bg-secondary' end %>">
              <%#= reservation.status.humanize %>
            </span>

            <div class="d-grid gap-2 mt-3">
              <%= link_to "Ver Detalles", hotel_unit_reservation_path(hotel, unit, reservation),
                          class: "btn btn-outline-primary btn-sm" %>
              <%# if reservation.pending? %>
                <%= link_to "Cancelar", hotel_unit_reservation_path(hotel, unit, reservation),
                            method: :delete, data: { confirm: "¿Deseas cancelar esta reserva?" },
                            class: "btn btn-outline-danger btn-sm" %>
              <%# end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-calendar-x display-4 mb-3"></i>
    <h5>No tienes reservas registradas</h5>
    <p>Explora hoteles y realiza tu primera reserva</p>
    <%= link_to "Ver hoteles", hotels_path, class: "btn btn-primary mt-2" %>
  </div>
<% end %>
