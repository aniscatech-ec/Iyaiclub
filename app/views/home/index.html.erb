<style>
    .badge-custom {
        background: rgba(255, 255, 255, 0.2);
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.9rem;
        display: inline-block;
    }

    .search-box {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        padding: 10px;
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .search-box input {
        border: none;
        outline: none;
    }

    .stats h4 {
        font-weight: bold;
    }

    .category-card {
        background: white;
        border: 1px solid #21C188;
        border-radius: 15px;
        padding: 20px;
        transition: transform 0.2s ease;
    }

    .category-card:hover {
        transform: translateY(-5px);
    }

    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin: 0 auto 10px;
    }
</style>
<% content_for :search_bar do %>
  <%= render "shared/search_hotels" %>
<% end %>

<!-- Fragmento dentro del body -->
<div class="container-fluid py-5"
     style="background: linear-gradient(90deg, #21C188, #FF9800); color: white;">
  <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">

      <!-- Slide 1 -->
      <div class="carousel-item active" style="height: 60vh;">
        <div class="position-absolute top-0 start-0 w-100 h-100">
          <%= image_tag "quito.jpg", class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
        <div class="d-flex flex-column justify-content-center align-items-center text-center text-white h-100 position-relative" style="background: rgba(0,0,0,0.5);">
          <h1 class="fw-bold">Bienvenido a IyaiClub</h1>
          <h4>Visita <span class="text-success">Quito</span></h4>
          <p>Atrévete a viajar sin límites</p>
        </div>
      </div>

      <!-- Slide 2 -->
      <div class="carousel-item" style="height: 60vh;">
        <div class="position-absolute top-0 start-0 w-100 h-100">
          <%= image_tag "cuenca.jpg", class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
        <div class="d-flex flex-column justify-content-center align-items-center text-center text-white h-100 position-relative" style="background: rgba(0,0,0,0.5);">
          <h1 class="fw-bold">Bienvenido a IyaiClub</h1>
          <h4>Visita <span class="text-success">Cuenca</span></h4>
          <p>Descubre la cultura y tradición</p>
        </div>
      </div>

      <!-- Slide 3 -->
      <div class="carousel-item" style="height: 60vh;">
        <div class="position-absolute top-0 start-0 w-100 h-100">
          <%= image_tag "guayaquil.webp", class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
        <div class="d-flex flex-column justify-content-center align-items-center text-center text-white h-100 position-relative" style="background: rgba(0,0,0,0.5);">
          <h1 class="fw-bold">Bienvenido a IyaiClub</h1>
          <h4>Visita <span class="text-success">Galápagos</span></h4>
          <p>Un paraíso natural único</p>
        </div>
      </div>

    </div>

    <!-- Controles -->
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>
  </div>

</div>

<% if @upcoming_events.any? %>
<div class="container-fluid py-4" style="background: linear-gradient(135deg, #FFF8E1 0%, #FFE082 100%);">
  <div class="container">
    <h3 class="fw-bold text-center mb-4" style="color: #E65100;">
      <i class="fas fa-calendar-star me-2"></i>
      Eventos Próximos
    </h3>

    <div id="eventsCarousel" class="carousel slide" data-bs-ride="carousel">
      <div class="carousel-inner">
        <% @upcoming_events.each_with_index do |event, index| %>
          <div class="carousel-item <%= 'active' if index == 0 %>">
            <div class="row justify-content-center">
              <div class="col-md-8 col-lg-6">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                  <% if event.image.attached? %>
                    <%= image_tag event.image, class: "card-img-top", style: "height: 250px; object-fit: cover;" %>
                  <% else %>
                    <div class="card-img-top d-flex align-items-center justify-content-center" style="height: 250px; background: linear-gradient(135deg, #21C188, #FF9800);">
                      <i class="fas fa-calendar-alt fa-5x text-white"></i>
                    </div>
                  <% end %>
                  <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="badge bg-warning text-dark">
                        <i class="fas fa-calendar me-1"></i>
                        <%= event.event_date&.strftime('%d/%m/%Y') || 'Próximamente' %>
                      </span>
                      <span class="badge <%= event.ticket_price.to_f > 0 ? 'bg-success' : 'bg-info' %>">
                        <%= event.ticket_price.to_f > 0 ? "$#{number_with_precision(event.ticket_price, precision: 2)}" : 'GRATIS' %>
                      </span>
                    </div>
                    <h4 class="card-title fw-bold" style="color: #7B3F00;"><%= event.name %></h4>
                    <p class="card-text text-muted"><%= truncate(event.description, length: 100) %></p>

                    <% if event.location.present? %>
                      <p class="text-muted small mb-3">
                        <i class="fas fa-map-marker-alt me-1 text-danger"></i>
                        <%= event.location %>
                      </p>
                    <% end %>

                    <div class="d-grid">
                      <% if user_signed_in? %>
                        <%= link_to event_path(event), class: "btn btn-primary rounded-pill" do %>
                          <i class="fas fa-eye me-1"></i> Ver Detalles
                        <% end %>
                      <% else %>
                        <%= link_to new_user_registration_path, class: "btn btn-outline-primary rounded-pill",
                            data: { turbo: false, confirm: "¡Hazte socio de IyaiClub para acceder a eventos exclusivos!" } do %>
                          <i class="fas fa-user-plus me-1"></i> Hazte Socio
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @upcoming_events.count > 1 %>
        <button class="carousel-control-prev" type="button" data-bs-target="#eventsCarousel" data-bs-slide="prev" style="width: 5%;">
          <span class="carousel-control-prev-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
          <span class="visually-hidden">Anterior</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#eventsCarousel" data-bs-slide="next" style="width: 5%;">
          <span class="carousel-control-next-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
          <span class="visually-hidden">Siguiente</span>
        </button>
      <% end %>
    </div>
  </div>
</div>
<% end %>

<div class="container py-4">
  <%= render "shared/custom_experience_cta" %>
</div>

<div class="container-fluid py-5" style="background-color: #f2f7f8;">
  <div class="container-fluid text-center">


    <!-- Título -->
    <h2 class="fw-bold" style="color: #7B3F00;">Explora por Categorías</h2>
    <p style="color: #7B3F00;">Encuentra exactamente lo que buscas para tu próxima aventura</p>

    <!-- Grid de categorías -->
    <section class="categories py-5">
      <div class="container-fluid ms-2 me-2">
        <div class="row row-cols-1 row-cols-md-6 g-4">
          <% category_catalog.each do |cat| %>
            <div class="col-6 col-md-2">
              <%= render "shared/category_card_with_dropdown", category: cat %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  </div>
</div>
