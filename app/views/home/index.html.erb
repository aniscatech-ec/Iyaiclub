<style>


    .search-box input {
        border: none;
        outline: none;
    }

    .stats h4 {
        font-weight: bold;
    }


    /* DESTINOS POPULARES */
    .destinos .card {
        overflow: hidden;
        border-radius: 15px;
        cursor: pointer;
        transition: transform 0.3s;
    }

    .destinos .card:hover {
        transform: scale(1.05);
    }

    .destinos .card-img-overlay {
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    }


    /* RECOMENDADOS */


    /* BENEFICIOS */
    .beneficios i {
        font-size: 48px;
        color: var(--green-500);
        transition: transform 0.3s, color 0.3s;
    }

    .beneficios i:hover {
        transform: scale(1.2);
        color: var(--green-700);
    }

    /* DESTINOS POPULARES */
    .sabores .card {
        overflow: hidden;
        border-radius: 15px;
        cursor: pointer;
        transition: transform 0.3s;
    }

    .sabores .card:hover {
        transform: scale(1.05);
    }

    .sabores .card-img-overlay {
        /*background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));*/
    }

    /*CARROUSEL*/
    .carousel-item {
        transition: transform 0.8s ease, opacity 0.8s ease;
    }

    .card:hover {
        transform: scale(1.03);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    }

    @media (max-width: 768px) {
        .col-md-4 {
            flex: 0 0 80%;
            max-width: 80%;
        }
    }


</style>
<%# content_for :search_bar do %>
<%#= render "shared/search_hotels" %>
<%# end %>

<!-- Fragmento dentro del body -->
<section class="hero position-relative">
  <!-- Carrusel -->
  <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
      <div class="carousel-item active">
        <%= image_tag "quito.jpg", class: "d-block w-100", style: "height: 70vh; object-fit: cover;" %>
        <div class="overlay position-absolute top-0 start-0 w-100 h-100" style="background: rgba(0,0,0,0.55);"></div>
      </div>

      <div class="carousel-item">
        <%= image_tag "cuenca.jpg", class: "d-block w-100", style: "height: 70vh; object-fit: cover;" %>
        <div class="overlay position-absolute top-0 start-0 w-100 h-100" style="background: rgba(0,0,0,0.55);"></div>
      </div>

      <div class="carousel-item">
        <%= image_tag "guayaquil.webp", class: "d-block w-100", style: "height: 70vh; object-fit: cover;" %>
        <div class="overlay position-absolute top-0 start-0 w-100 h-100" style="background: rgba(0,0,0,0.55);"></div>
      </div>
    </div>

    <!-- Controles -->
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>
  </div>

  <!-- Contenido fijo sobre el carrusel -->
  <div class="hero-content position-absolute top-50 start-50 translate-middle text-center w-100 px-3" style="max-width: 900px; z-index: 10;">
    <h1 class="fw-bold display-5 mb-3 text-white text-shadow">Bienvenido a IyaiClub 🇪🇨</h1>
    <!--    <h2 class="text-white mb-4 fw-normal fs-5">Descubre hoteles y restaurantes en todo Ecuador 🇪🇨</h2>-->

    <div class="search-bar-wrapper bg-white p-4 rounded-4 shadow-lg">
      <%= render "shared/search_hotels" %>
    </div>
  </div>
</section>

<!-- Modal Comodidades -->
<!-- Aquí termina tu hero, así que ahora colocamos el modal -->
<%= render "shared/amenities_modal" %>
<div class="container-fluid py-5" style="background-color: #f2f7f8;">
  <div class="container-fluid text-center">

    <!-- Título -->
    <h2 class="text-center fw-bold mb-4">Encuentra exactamente lo que buscas para tu próxima aventura</h2>

    <!-- Grid de categorías -->
    <section class="categories py-5">
      <div class="container-fluid ms-2 me-2">
        <div class="row row-cols-1 row-cols-md-6 g-4">

          <div class="col-6 col-md-2">
            <%= link_to hotels_path, class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
              <i class="bi bi-building icon"></i>
              <h5 class="mt-3">Hospedajes</h5>
            <% end %>
          </div>

          <div class="col-6 col-md-2">
            <%= link_to "#", class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
              <i class="bi bi-building icon"></i>
              <h5 class="mt-3">Alojamientos Temporales</h5>
            <% end %>
          </div>

          <div class="col-6 col-md-2">
            <%= link_to "#", class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
              <i class="bi bi-bus-front icon"></i>
              <h5 class="mt-3">Transporte</h5>
            <% end %>
          </div>

          <div class="col-6 col-md-2">
            <%= link_to "#", class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
              <i class="bi bi-balloon-heart icon"></i>
              <h5 class="mt-3">Escapadas de Momento</h5>
            <% end %>
          </div>

          <div class="col-6 col-md-2">
            <%= link_to "#", class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
              <i class="bi bi-geo-alt icon"></i>
              <h5 class="mt-3">Agencias de Viaje</h5>
            <% end %>
          </div>

          <div class="col-6 col-md-2">
            <%= link_to restaurants_path, class: "category-card text-center p-4 h-100 d-block text-decoration-none text-dark" do %>
              <i class="bi bi-building icon"></i>
              <h5 class="mt-3">Restaurantes</h5>
            <% end %>
          </div>

        </div>
      </div>
    </section>

  </div>
</div>


<!-- DESTINOS POPULARES -->
<section class="destinos py-5">
  <div class="container">
    <h2 class="text-center fw-bold mb-4">Destinos Populares</h2>
    <div class="row g-4">
      <% ["Quito", "Cuenca", "Guayaquil", "Galapagos"].each do |city| %>
        <div class="col-md-3">
          <div class="card text-white overflow-hidden shadow-sm">
            <%= image_tag "#{city.downcase}.jpg", class: "card-img", style: "height:200px; object-fit:cover;" %>
            <div class="card-img-overlay d-flex flex-column justify-content-end p-3">
              <h5 class="card-title fw-bold"><%= city %></h5>
              <p class="card-text">+<%= Establishment.where(city: City.find_by(name: city)).count %> lugares</p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- RECOMENDADOS -->
<section class="recomendados py-5 bg-light">
  <div class="container">
    <h2 class="fw-bold text-center mb-4">Recomendados para ti</h2>

    <div id="recommendedCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
      <div class="carousel-inner">

        <% establishments = Establishment.order("RAND()").limit(12).to_a %>
        <% establishments.each_slice(3).with_index do |group, index| %>
          <div class="carousel-item <%= 'active' if index.zero? %>">
            <div class="row justify-content-center g-4">
              <% group.each do |est| %>
                <div class="col-md-4">
                  <%= link_to establishment_path(est), class: "text-decoration-none text-dark" do %>
                    <div class="card shadow-sm rounded-4 overflow-hidden h-100" style="transition: transform 0.2s, box-shadow 0.2s;">
                      <% image_src = if est.galleries.any? && est.galleries.first.gallery_images.any? && est.galleries.first.gallery_images.first.file.attached?
                                       est.galleries.first.gallery_images.first.file
                                     else
                                       "logo.jpeg"
                                     end %>
                      <%= image_tag image_src, class: "card-img-top", height: 200, alt: est.name %>
                      <div class="card-body">
                        <h5 class="card-title fw-bold mb-1"><%= est.name %></h5>
                        <p class="text-muted mb-1"><%= est.category.humanize %></p>
                        <p class="text-muted mb-2">
                          <i class="bi bi-geo-alt"></i> <%= est.city&.name || "Ubicación desconocida" %></p>
                        <p class="mb-0 text-warning">⭐⭐⭐⭐☆</p>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

      </div>

      <!-- Controles -->
      <button class="carousel-control-prev" type="button" data-bs-target="#recommendedCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
        <span class="visually-hidden">Anterior</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#recommendedCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
        <span class="visually-hidden">Siguiente</span>
      </button>
    </div>
  </div>
</section>

<style>

</style>


<!-- SABORES Y EXPERIENCIAS -->
<section class="sabores py-5">
  <div class="container text-center">
    <h2 class="fw-bold mb-4">Sabores y Experiencias</h2>
    <p class="text-muted mb-5">Descubre los mejores restaurantes y actividades locales</p>
    <div class="row g-4">
      <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100 mx-2">
          <%= image_tag "restaurante.jpg", class: "card-img-top", style: "height:200px; object-fit:cover;" %>
          <div class="card-body">
            <h5 class="fw-bold">Gastronomía ecuatoriana</h5>
            <p>Los mejores sabores en cada rincón del país</p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100 mx-2">
          <%= image_tag "aventura.jpg", class: "card-img-top", style: "height:200px; object-fit:cover;" %>
          <div class="card-body">
            <h5 class="fw-bold">Experiencias únicas</h5>
            <p>Vive momentos inolvidables en la naturaleza y la ciudad</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- BENEFICIOS -->
<section class="beneficios py-5">
  <div class="container">
    <h2 class="fw-bold text-center mb-5">Por qué elegirnos</h2>
    <div class="row text-center g-4">
      <div class="col-md-4">
        <i class="bi bi-lock-fill mb-3"></i>
        <h5 class="fw-bold">Reservas seguras</h5>
        <p class="text-muted">Tu información y pagos siempre protegidos.</p>
      </div>
      <div class="col-md-4">
        <i class="bi bi-clock-fill mb-3"></i>
        <h5 class="fw-bold">Disponibilidad en tiempo real</h5>
        <p class="text-muted">Consulta y reserva al instante sin complicaciones.</p>
      </div>
      <div class="col-md-4">
        <i class="bi bi-chat-dots-fill mb-3"></i>
        <h5 class="fw-bold">Opiniones verificadas</h5>
        <p class="text-muted">Reseñas reales de clientes como tú.</p>
      </div>
    </div>
  </div>
</section>
