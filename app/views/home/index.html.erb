<style>
    .badge-custom {
        background: rgba(255, 255, 255, 0.2);
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.9rem;
        display: inline-block;
    }

    .search-box {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        padding: 10px;
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .search-box input {
        border: none;
        outline: none;
    }

    .stats h4 {
        font-weight: bold;
    }

    .category-card {
        background: white;
        border: 1px solid #21C188;
        border-radius: 15px;
        padding: 20px;
        transition: transform 0.2s ease;
    }

    .category-card:hover {
        transform: translateY(-5px);
    }

    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin: 0 auto 10px;
    }
</style>
<% content_for :search_bar do %>
  <%= render "shared/search_hotels" %>
<% end %>

<div class="d-flex flex-column">

<!-- Explora por Categorías - Arriba de todo -->
<div class="container-fluid py-2 order-3 order-md-1" style="background-color: #f2f7f8;">
  <div class="container-fluid text-center">
    <!-- Título -->
    <h6 class="fw-bold mb-0" style="color: #7B3F00; font-size: 0.85rem;">Explora por Categorías</h6>
    <p class="mb-1" style="color: #7B3F00; font-size: 0.7rem;">Encuentra lo que buscas para tu próxima aventura</p>

    <!-- Grid de categorías -->
    <section class="categories">
      <div class="container-fluid px-2">
        <div class="row row-cols-2 row-cols-md-6 g-2">
          <% category_catalog.each do |cat| %>
            <div class="col">
              <%= render "shared/category_card_with_dropdown", category: cat %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  </div>
</div>

<!-- Banner publicitario -->
<div class="order-1 order-md-2">
<% if @advertisements.any? %>
<div id="adsBanner" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
  <div class="carousel-inner">
    <% @advertisements.each_with_index do |ad, index| %>
      <div class="carousel-item <%= 'active' if index == 0 %>">
        <% wrapper_tag = ad.link_url.present? ? :a : :div %>
        <%= content_tag wrapper_tag,
              href: ad.link_url,
              target: "_blank",
              rel: "noopener noreferrer",
              class: "text-decoration-none d-block" do %>
          <div class="position-relative" style="height: 220px; overflow: hidden;">
            <% if ad.image.attached? %>
              <%= image_tag ad.image,
                    class: "position-absolute top-0 start-0 w-100 h-100",
                    style: "object-fit: fill; width: 100%; height: 100%;" %>
            <% else %>
              <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, #1a1a2e, #16213e);"></div>
            <% end %>
            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center px-4"
                 style="background: linear-gradient(90deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.45) 55%, rgba(0,0,0,0.05) 100%);">
              <div class="text-white">
                <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                  <span class="badge bg-warning text-dark">
                    <i class="fas fa-bullhorn me-1"></i> PUBLICIDAD
                  </span>
                  <% ad.tags_array.first(3).each do |tag| %>
                    <span class="badge bg-white text-dark"><%= tag %></span>
                  <% end %>
                </div>
                <h4 class="fw-bold mb-1"><%= ad.title %></h4>
                <% if ad.description.present? %>
                  <p class="mb-0 small opacity-90"><%= ad.description %></p>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @advertisements.count > 1 %>
    <button class="carousel-control-prev" type="button" data-bs-target="#adsBanner" data-bs-slide="prev" style="width: 30px; opacity: 0.7;">
      <span class="carousel-control-prev-icon" style="width: 15px; height: 15px;" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#adsBanner" data-bs-slide="next" style="width: 30px; opacity: 0.7;">
      <span class="carousel-control-next-icon" style="width: 15px; height: 15px;" aria-hidden="true"></span>
    </button>
    <div class="carousel-indicators" style="bottom: 6px;">
      <% @advertisements.each_with_index do |_, i| %>
        <button type="button" data-bs-target="#adsBanner" data-bs-slide-to="<%= i %>"
                class="<%= 'active' if i == 0 %>"
                style="width: 8px; height: 8px; border-radius: 50%;"></button>
      <% end %>
    </div>
  <% end %>
</div>
<script>
  document.addEventListener("turbo:load", function() {
    var el = document.getElementById("adsBanner");
    if (el && typeof bootstrap !== "undefined") {
      new bootstrap.Carousel(el, { interval: 5000, ride: "carousel" });
    }
  });
</script>
<% end %>
</div><%# /order-1 order-md-2 %>

<!-- Buscador solo en móvil (en desktop ya se muestra desde el layout) -->
<div class="d-block d-md-none order-2">
  <%= render "shared/search_hotels" %>
</div>

<!-- Fragmento dentro del body -->
<div class="container-fluid py-3 order-1 order-md-3"
     style="background: linear-gradient(90deg, #21C188, #FF9800); color: white;">
  <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">

      <!-- Slide 1 -->
      <div class="carousel-item active" style="height: 35vh;">
        <div class="position-absolute top-0 start-0 w-100 h-100">
          <%= image_tag "quito.jpg", class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
        <div class="d-flex flex-column justify-content-center align-items-center text-center text-white h-100 position-relative" style="background: rgba(0,0,0,0.5);">
          <h1 class="fw-bold">Bienvenido a IyaiClub</h1>
          <h4>Visita <span class="text-success">Quito</span></h4>
          <p>Atrévete a viajar sin límites</p>
        </div>
      </div>

      <!-- Slide 2 -->
      <div class="carousel-item" style="height: 35vh;">
        <div class="position-absolute top-0 start-0 w-100 h-100">
          <%= image_tag "cuenca.jpg", class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
        <div class="d-flex flex-column justify-content-center align-items-center text-center text-white h-100 position-relative" style="background: rgba(0,0,0,0.5);">
          <h1 class="fw-bold">Bienvenido a IyaiClub</h1>
          <h4>Visita <span class="text-success">Cuenca</span></h4>
          <p>Descubre la cultura y tradición</p>
        </div>
      </div>

      <!-- Slide 3 -->
      <div class="carousel-item" style="height: 35vh;">
        <div class="position-absolute top-0 start-0 w-100 h-100">
          <%= image_tag "guayaquil.webp", class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
        <div class="d-flex flex-column justify-content-center align-items-center text-center text-white h-100 position-relative" style="background: rgba(0,0,0,0.5);">
          <h1 class="fw-bold">Bienvenido a IyaiClub</h1>
          <h4>Visita <span class="text-success">Galápagos</span></h4>
          <p>Un paraíso natural único</p>
        </div>
      </div>

    </div>

    <!-- Controles -->
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>
  </div>

</div><%# /hero container-fluid %>

</div><%# /d-flex flex-column wrapper %>

<div class="container py-4">
  <%= render "shared/custom_experience_cta" %>
</div>

<% if @upcoming_events.any? %>
<div class="py-4" style="background: #f8f9fa;">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h4 class="fw-bold mb-0">Eventos Próximos</h4>
        <p class="text-muted small mb-0">No te pierdas lo que se viene</p>
      </div>
      <%= link_to events_path, class: "btn btn-outline-primary btn-sm rounded-pill" do %>
        Ver todos <i class="fas fa-arrow-right ms-1"></i>
      <% end %>
    </div>

    <div class="row g-3">
      <% @upcoming_events.each do |event| %>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">

            <%# Imagen %>
            <div class="position-relative" style="height: 160px; overflow: hidden;">
              <% if event.image.attached? %>
                <%= image_tag event.image.variant(resize_to_fill: [600, 320]),
                      class: "w-100 h-100", style: "object-fit: cover;" %>
              <% else %>
                <div class="w-100 h-100 d-flex align-items-center justify-content-center"
                     style="background: linear-gradient(135deg, #1a1a2e, #16213e);">
                  <i class="fas fa-calendar-alt fa-3x text-white opacity-50"></i>
                </div>
              <% end %>

              <%# Fecha flotante %>
              <% if event.event_date.present? %>
                <div class="position-absolute top-0 start-0 m-2">
                  <div class="bg-white rounded-3 text-center px-2 py-1 shadow-sm" style="min-width: 40px;">
                    <div class="fw-bold lh-1" style="font-size: 1.1rem; color: var(--brand-orange, #EB633B);">
                      <%= event.event_date.strftime("%d") %>
                    </div>
                    <div class="text-muted text-uppercase" style="font-size: 0.6rem;">
                      <%= event.event_date.strftime("%b") %>
                    </div>
                  </div>
                </div>
              <% end %>

              <%# Badge precio %>
              <% price = event.price_for(current_user) %>
              <div class="position-absolute top-0 end-0 m-2">
                <span class="badge rounded-pill <%= price > 0 ? 'bg-success' : 'bg-info' %> px-2 py-1">
                  <%= price > 0 ? "$#{number_with_precision(price, precision: 2)}" : "GRATIS" %>
                </span>
              </div>
            </div>

            <%# Contenido %>
            <div class="card-body p-3 d-flex flex-column">
              <h6 class="fw-bold mb-1 lh-sm"><%= event.name %></h6>
              <% if event.location.present? %>
                <p class="text-muted small mb-2">
                  <i class="fas fa-map-marker-alt me-1"></i><%= event.location %>
                </p>
              <% end %>
              <div class="mt-auto pt-2">
                <%= link_to event_path(event), class: "btn btn-sm w-100 rounded-pill fw-semibold",
                      style: "background: var(--brand-orange, #EB633B); color: white; border: none;" do %>
                  <i class="fas fa-ticket-alt me-1"></i> Compra tickets aquí
                <% end %>
              </div>
            </div>

          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>

