<style>
    .badge-custom {
        background: rgba(255, 255, 255, 0.2);
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.9rem;
        display: inline-block;
    }

    .search-box {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        padding: 10px;
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .search-box input {
        border: none;
        outline: none;
    }

    .stats h4 {
        font-weight: bold;
    }

    .category-card {
        background: white;
        border: 1px solid #21C188;
        border-radius: 15px;
        padding: 20px;
        transition: transform 0.2s ease;
    }

    .category-card:hover {
        transform: translateY(-5px);
    }

    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin: 0 auto 10px;
    }
</style>
<% content_for :search_bar do %>
  <%= render "shared/search_hotels" %>
<% end %>

<!-- Fragmento dentro del body -->
<div class="container-fluid py-5"
     style="background: linear-gradient(90deg, #21C188, #FF9800); color: white;">
  <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">

      <!-- Slide 1 -->
      <div class="carousel-item active" style="height: 60vh;">
        <div class="position-absolute top-0 start-0 w-100 h-100">
          <%= image_tag "quito.jpg", class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
        <div class="d-flex flex-column justify-content-center align-items-center text-center text-white h-100 position-relative" style="background: rgba(0,0,0,0.5);">
          <h1 class="fw-bold">Bienvenido a IyaiClub</h1>
          <h4>Visita <span class="text-success">Quito</span></h4>
          <p>Atrévete a viajar sin límites</p>
        </div>
      </div>

      <!-- Slide 2 -->
      <div class="carousel-item" style="height: 60vh;">
        <div class="position-absolute top-0 start-0 w-100 h-100">
          <%= image_tag "cuenca.jpg", class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
        <div class="d-flex flex-column justify-content-center align-items-center text-center text-white h-100 position-relative" style="background: rgba(0,0,0,0.5);">
          <h1 class="fw-bold">Bienvenido a IyaiClub</h1>
          <h4>Visita <span class="text-success">Cuenca</span></h4>
          <p>Descubre la cultura y tradición</p>
        </div>
      </div>

      <!-- Slide 3 -->
      <div class="carousel-item" style="height: 60vh;">
        <div class="position-absolute top-0 start-0 w-100 h-100">
          <%= image_tag "guayaquil.webp", class: "w-100 h-100", style: "object-fit: cover;" %>
        </div>
        <div class="d-flex flex-column justify-content-center align-items-center text-center text-white h-100 position-relative" style="background: rgba(0,0,0,0.5);">
          <h1 class="fw-bold">Bienvenido a IyaiClub</h1>
          <h4>Visita <span class="text-success">Galápagos</span></h4>
          <p>Un paraíso natural único</p>
        </div>
      </div>

    </div>

    <!-- Controles -->
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>
  </div>

</div>

<div class="container-fluid py-5" style="background-color: #f2f7f8;">
  <div class="container-fluid text-center">

    <!-- Banner de Emergencia / Asistencia -->
    <div class="emergency-banner mb-4 mx-auto" style="max-width: 700px;">
      <div class="emergency-banner__info">
        <span class="emergency-banner__icon"><i class="fas fa-kit-medical"></i></span>
        <div>
          <p class="emergency-banner__title">Asistencia de Emergencia</p>
          <p class="emergency-banner__subtitle">Farmacias, talleres, centros medicos cerca de ti</p>
        </div>
      </div>
      <a href="#" class="emergency-banner__btn"><i class="fas fa-arrow-right me-1"></i> Buscar ayuda</a>
    </div>

    <!-- Título -->
    <h2 class="fw-bold" style="color: #7B3F00;">Explora por Categorías</h2>
    <p style="color: #7B3F00;">Encuentra exactamente lo que buscas para tu próxima aventura</p>

    <!-- Grid de categorías -->
    <section class="categories py-5">
      <div class="container-fluid ms-2 me-2">
        <div class="row row-cols-1 row-cols-md-6 g-4">
          <% category_catalog.each do |cat| %>
            <div class="col-6 col-md-2">
              <%= render "shared/category_card_with_dropdown", category: cat %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  </div>
</div>
