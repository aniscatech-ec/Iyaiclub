<div class="container-fluid px-3 px-md-4 py-4">
  <div class="d-flex align-items-center mb-4">
    <%= link_to afiliado_profile_path, class: "btn btn-outline-secondary btn-sm me-3" do %>
      <i class="fas fa-arrow-left"></i>
    <% end %>
    <h3 class="fw-bold mb-0">Editar Perfil</h3>
  </div>

  <div class="row justify-content-center">
    <div class="col-12 col-lg-6">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">
          <%= form_with model: @user, url: afiliado_profile_path, method: :patch, local: true, multipart: true do |f| %>
            <% if @user.errors.any? %>
              <div class="alert alert-danger rounded-3 mb-4">
                <ul class="mb-0">
                  <% @user.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <%# ── Foto de portada ── %>
            <div class="mb-4">
              <%= f.label :cover_photo, "Foto de portada", class: "form-label fw-semibold" %>
              <% if @user.cover_photo.attached? %>
                <div class="mb-2 rounded-3 overflow-hidden" style="height:100px;">
                  <%= image_tag @user.cover_photo.variant(resize_to_fill: [600, 100]),
                        class: "w-100 h-100", style: "object-fit:cover;" %>
                </div>
              <% end %>
              <%= f.file_field :cover_photo, class: "form-control rounded-3",
                    accept: "image/jpeg,image/png,image/webp" %>
              <small class="text-muted">Imagen horizontal (JPG, PNG, WEBP). Recomendado: 1200×300 px.</small>
            </div>

            <%# ── Foto de perfil ── %>
            <div class="mb-4">
              <%= f.label :avatar, "Foto de perfil", class: "form-label fw-semibold" %>
              <div class="d-flex align-items-center gap-3 mb-2">
                <% if @user.avatar.attached? %>
                  <%= image_tag @user.avatar.variant(resize_to_fill: [72, 72]),
                        class: "rounded-circle border border-3 shadow-sm",
                        style: "width:72px; height:72px; object-fit:cover;" %>
                <% else %>
                  <div class="rounded-circle d-flex align-items-center justify-content-center border border-3 shadow-sm flex-shrink-0"
                       style="width:72px; height:72px; background:var(--brand-cofee,#88682B); color:white; font-size:1.8rem; font-weight:700;">
                    <%= @user.name&.first&.upcase || "?" %>
                  </div>
                <% end %>
                <%= f.file_field :avatar, class: "form-control rounded-3",
                      accept: "image/jpeg,image/png,image/webp" %>
              </div>
              <small class="text-muted">Imagen cuadrada (JPG, PNG, WEBP). Recomendado: 300×300 px.</small>
            </div>

            <hr class="my-3">

            <div class="mb-4">
              <%= f.label :name, "Nombre completo", class: "form-label fw-semibold" %>
              <%= f.text_field :name, class: "form-control rounded-3", placeholder: "Tu nombre completo" %>
            </div>

            <div class="mb-4">
              <%= f.label :phone, "Teléfono", class: "form-label fw-semibold" %>
              <%= f.text_field :phone, class: "form-control rounded-3", placeholder: "+593..." %>
            </div>

            <div class="mb-4">
              <%= f.label :birth_date, "Fecha de nacimiento", class: "form-label fw-semibold" %>
              <%= f.date_field :birth_date, class: "form-control rounded-3" %>
            </div>

            <div class="d-grid">
              <%= f.submit "Guardar cambios", class: "btn btn-primary rounded-pill fw-bold" %>
            </div>
          <% end %>

          <hr class="my-4">
          <div class="text-center">
            <%= link_to edit_user_registration_path, class: "btn btn-sm btn-outline-secondary rounded-pill" do %>
              <i class="fas fa-lock me-1"></i> Cambiar contraseña o correo
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
