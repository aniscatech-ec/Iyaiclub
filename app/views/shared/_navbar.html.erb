<nav class="navbar navbar-expand-lg navbar-iyai">
  <div class="container">
    <!-- Logo -->
    <a class="navbar-brand d-flex align-items-center" href="/">
      <%= image_tag "logo.jpeg", size: "160x60", class: "rounded" %>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse justify-content-end" id="navbarSupportedContent">
      <ul class="navbar-nav mb-2 mb-lg-0">
        <li class="nav-item mx-2">
          <%= link_to "Inicio", root_path, class: "nav-link nav-link-iyai", "aria-current": "page" %>
        </li>
        <li class="nav-item mx-2">
          <%= link_to "Club Iyai", "#", class: "nav-link nav-link-iyai" %>
        </li>

        <% if user_signed_in? %>
        <%else %>
          <li class="nav-item mx-2">
            <%= link_to "Suscribirse", new_user_registration_path, class: "nav-link nav-link-iyai" %>
          </li>
        <% end %>

        <% if user_signed_in? %>
          <% if current_user.administrador? %>
            <li class="nav-item mx-2">
              <%= link_to current_user.name, admin_dashboard_index_path, class: "nav-link nav-link-iyai"  %>
            </li>
          <% elsif current_user.afiliado?%>
            <li class="nav-item mx-2">
              <%= link_to current_user.name, afiliado_dashboard_index_path, class: "nav-link nav-link-iyai"  %>
            </li>
          <% elsif current_user.turista?%>
            <li class="nav-item mx-2">
              <%= link_to current_user.name, turista_dashboard_index_path, class: "nav-link nav-link-iyai"  %>
            </li>
          <% end %>

          <li class="nav-item mx-2">
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-iyai-danger" do %>
              Cerrar Sesión
            <% end %>
          </li>
        <% else %>
          <li class="nav-item mx-2">
            <%= link_to "Iniciar sesión", new_user_session_path, class: "btn btn-iyai-primary" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>

<style>
    .navbar-iyai {
        background: var(--white);
        box-shadow: 0 2px 10px rgba(15, 107, 58, 0.1);
        padding: 1rem 0;
    }

    .nav-link-iyai {
        color: var(--brown-700) !important;
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .nav-link-iyai:hover,
    .nav-link-iyai.active {
        color: var(--green-700) !important;
    }

    .btn-iyai-primary {
        background: var(--green-700);
        color: var(--white);
        border: none;
        padding: 8px 20px;
        border-radius: 6px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .btn-iyai-primary:hover {
        background: var(--green-500);
        transform: translateY(-1px);
    }

    .btn-iyai-danger {
        background: var(--red-500);
        color: var(--white);
        border: none;
        padding: 8px 20px;
        border-radius: 6px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .btn-iyai-danger:hover {
        background: #c62828;
        transform: translateY(-1px);
    }
</style>