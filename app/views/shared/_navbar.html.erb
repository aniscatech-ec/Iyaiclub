<nav class="navbar navbar-expand-lg">
  <div class="container-fluid">
    <!-- Logo -->
    <a class="navbar-brand d-flex align-items-center" href="/">
      <%= image_tag "logo.jpeg", size: "160x60", class: "rounded" %>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse justify-content-end" id="navbarSupportedContent">
      <ul class="navbar-nav mb-2 mb-lg-0">
        <li class="nav-item mx-2">
          <%= link_to "Inicio", root_path, class: "nav-link", "aria-current": "page" %>
          <%#= link_to "Inicio", root_path, class: "nav-link"%>

        </li>
        <li class="nav-item mx-2">
          <%= link_to "Club Iyai", "#", class: "nav-link" %>

        </li>

        <% if user_signed_in? %>
        <%else %>
          <li class="nav-item mx-2">
            <%= link_to "Suscribirse", new_user_registration_path, class: "nav-link" %>
          </li>
        <% end %>

        <% if user_signed_in? %>
          <% if current_user.administrador? %>
            <li class="nav-item mx-2">
              <%= link_to current_user.name, admin_dashboard_index_path, class: "nav-link"  %>
            </li>
          <% elsif current_user.afiliado?%>
            <li class="nav-item mx-2">
              <%= link_to current_user.name, afiliado_dashboard_index_path, class: "nav-link"  %>
            </li>
          <% elsif current_user.turista?%>
            <li class="nav-item mx-2">
              <%= link_to current_user.name, turista_dashboard_index_path, class: "nav-link"  %>
            </li>
          <% end %>

          <li class="nav-item mx-2">
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-danger" do %>
              <i class="bi bi-box-arrow-right"></i>
            <% end %>
          </li>
        <% else %>
          <li class="nav-item mx-2">
            <%= link_to "Iniciar sesion", new_user_session_path, class: "btn btn-primary" %>
          </li>
        <% end %>


      </ul>
    </div>
  </div>
