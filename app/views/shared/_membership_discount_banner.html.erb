<% if current_user&.can_access_discounts? %>
  <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" role="alert">
    <i class="fas fa-crown text-warning"></i>
    <div class="small mb-0">
      <strong>Eres miembro IyaiClub.</strong>
      Coordina tu descuento directamente con el establecimiento al momento de reservar.
    </div>
  </div>
<% else %>
  <div class="alert alert-info d-flex align-items-center gap-2 py-2 mb-3" role="alert">
    <i class="fas fa-tag"></i>
    <div class="small mb-0">
      <strong>Obtén hasta un 50% de descuento</strong> contratando una
      <%= link_to "membresía IyaiClub", turista_memberships_path, class: "alert-link fw-semibold" %>.
    </div>
  </div>
<% end %>
