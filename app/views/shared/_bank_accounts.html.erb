<%
  accounts = BankAccount.active.ordered
  return if accounts.empty?
%>

<div class="mt-3 mb-2">

  <div class="d-flex align-items-center gap-2 mb-3">
    <i class="fas fa-university" style="color:var(--brand-green,#3FBD02); font-size:1rem;"></i>
    <span class="fw-bold" style="font-size:0.95rem;">Cuentas para transferencia</span>
  </div>

  <div class="d-flex flex-column gap-3">
    <% accounts.each do |account| %>
      <div class="rounded-4 overflow-hidden" style="border:1.5px solid #e2e8f0; background:#fff; box-shadow:0 2px 8px rgba(0,0,0,0.05);">

        <%# Header banco %>
        <div class="d-flex align-items-center justify-content-between px-3 py-2"
             style="background:linear-gradient(90deg,#f0fdf4,#f8fafc); border-bottom:1px solid #e2e8f0;">
          <div class="d-flex align-items-center gap-2">
            <span class="d-inline-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                  style="width:32px;height:32px;background:rgba(63,189,2,0.12);">
              <i class="fas fa-university" style="color:var(--brand-green,#3FBD02);font-size:0.75rem;"></i>
            </span>
            <span class="fw-bold" style="font-size:0.9rem;"><%= account.institution %></span>
          </div>
          <span class="badge rounded-pill fw-semibold"
                style="background:#dcfce7;color:#15803d;font-size:0.7rem;padding:3px 10px;">
            Cta. <%= account.account_type_label %>
          </span>
        </div>

        <%# Filas de datos %>
        <div class="px-3 py-2">

          <%# Número de cuenta %>
          <div class="d-flex justify-content-between align-items-center py-2"
               style="border-bottom:1px dashed #f1f5f9;">
            <span style="font-size:0.78rem; color:#64748b; font-weight:500;">N° de cuenta</span>
            <div class="d-flex align-items-center gap-2">
              <span class="font-monospace fw-bold" style="font-size:0.9rem; letter-spacing:.04em; color:#1e293b;">
                <%= account.account_number %>
              </span>
              <button type="button"
                      onclick="copyBankField(this, '<%= account.account_number %>')"
                      title="Copiar número de cuenta"
                      style="background:none;border:none;padding:3px 5px;cursor:pointer;color:#94a3b8;line-height:1;border-radius:6px;transition:all .15s;"
                      onmouseenter="this.style.background='#f1f5f9';this.style.color='#475569';"
                      onmouseleave="this.style.background='none';this.style.color='#94a3b8';">
                <i class="fas fa-copy" style="font-size:0.75rem;"></i>
              </button>
            </div>
          </div>

          <%# Propietario %>
          <div class="d-flex justify-content-between align-items-center py-2"
               style="border-bottom:1px dashed #f1f5f9;">
            <span style="font-size:0.78rem; color:#64748b; font-weight:500;">Propietario</span>
            <span style="font-size:0.875rem; font-weight:600; color:#1e293b;"><%= account.owner_name %></span>
          </div>

          <%# Identificador %>
          <div class="d-flex justify-content-between align-items-center py-2">
            <span style="font-size:0.78rem; color:#64748b; font-weight:500;"><%= account.identifier_type_label %></span>
            <div class="d-flex align-items-center gap-2">
              <span class="font-monospace" style="font-size:0.875rem; color:#1e293b;">
                <%= account.identifier %>
              </span>
              <button type="button"
                      onclick="copyBankField(this, '<%= account.identifier %>')"
                      title="Copiar <%= account.identifier_type_label %>"
                      style="background:none;border:none;padding:3px 5px;cursor:pointer;color:#94a3b8;line-height:1;border-radius:6px;transition:all .15s;"
                      onmouseenter="this.style.background='#f1f5f9';this.style.color='#475569';"
                      onmouseleave="this.style.background='none';this.style.color='#94a3b8';">
                <i class="fas fa-copy" style="font-size:0.75rem;"></i>
              </button>
            </div>
          </div>

          <% if account.notes.present? %>
            <div class="d-flex align-items-start gap-2 mt-2 rounded-3 px-2 py-2"
                 style="background:#f0fdf4; font-size:0.78rem; color:#15803d;">
              <i class="fas fa-circle-info mt-1 flex-shrink-0"></i>
              <span><%= account.notes %></span>
            </div>
          <% end %>

        </div>
      </div>
    <% end %>
  </div>

</div>

<script>
  function copyBankField(btn, text) {
    navigator.clipboard.writeText(text).then(function() {
      var icon = btn.querySelector('i');
      icon.className = 'fas fa-check';
      btn.style.color = 'var(--brand-green,#3FBD02)';
      setTimeout(function() {
        icon.className = 'fas fa-copy';
        btn.style.color = '#94a3b8';
      }, 1800);
    });
  }
</script>
