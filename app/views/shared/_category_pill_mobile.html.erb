<%
  has_subtypes = category[:subtypes].present?
  cat_path     = category[:path]
  cat_color    = category[:color]
  cat_icon     = category[:icon]
  cat_name     = category[:name]
  is_grouped   = category[:grouped]
  pill_id      = "pill-sheet-#{cat_name.parameterize}"
%>

<div class="category-pill-item" data-controller="dropdown-hover">

  <% if has_subtypes %>
    <%# Ícono circular — abre el bottom sheet %>
    <button type="button"
            class="category-pill-btn"
            style="--pill-color: <%= cat_color %>;"
            data-action="click->dropdown-hover#toggle"
            aria-label="<%= cat_name %>">
      <span class="category-pill-circle">
        <i class="fas <%= cat_icon %>"></i>
      </span>
      <span class="category-pill-label"><%= cat_name %></span>
    </button>

    <%# Bottom sheet reutilizado %>
    <div class="category-dropdown">
      <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom"
           style="background:#fff; flex-shrink:0;">
        <span class="fw-bold" style="color:<%= cat_color %>;">
          <i class="fas <%= cat_icon %> me-2"></i><%= cat_name %>
        </span>
        <button type="button"
                class="btn-close btn-sm"
                data-action="click->dropdown-hover#closeSheet"
                aria-label="Cerrar"></button>
      </div>
      <div class="list-group list-group-flush rounded-3">
        <%= link_to cat_path, class: "list-group-item list-group-item-action px-3 py-2 fw-semibold",
            style: "font-size: 0.8rem; color: #{cat_color};" do %>
          <i class="fas fa-th-list me-2"></i> Ver todos
        <% end %>

        <% if is_grouped %>
          <% category[:subtypes].each do |group| %>
            <div class="dropdown-section-header px-3 py-1" style="background: <%= cat_color %>10;">
              <small class="fw-bold text-uppercase" style="font-size: 0.7rem; color: <%= cat_color %>; letter-spacing: 0.5px;">
                <%= group[:group] %>
              </small>
            </div>
            <% group[:items].each do |sub| %>
              <%= link_to sub[:path], class: "list-group-item list-group-item-action px-3 py-2",
                  style: "font-size: 0.8rem; padding-left: 1.5rem !important;" do %>
                <i class="fas fa-angle-right me-2" style="color: <%= cat_color %>;"></i>
                <%= sub[:label] %>
              <% end %>
            <% end %>
          <% end %>
        <% else %>
          <% category[:subtypes].each do |sub| %>
            <%= link_to sub[:path], class: "list-group-item list-group-item-action px-3 py-2",
                style: "font-size: 0.8rem;" do %>
              <i class="fas fa-angle-right me-2" style="color: <%= cat_color %>;"></i>
              <%= sub[:label] %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

  <% else %>
    <%# Sin subtypes: link directo %>
    <%= link_to cat_path,
          class: "category-pill-btn",
          style: "--pill-color: #{cat_color};",
          aria: { label: cat_name } do %>
      <span class="category-pill-circle">
        <i class="fas <%= cat_icon %>"></i>
      </span>
      <span class="category-pill-label"><%= cat_name %></span>
    <% end %>
  <% end %>

</div>
