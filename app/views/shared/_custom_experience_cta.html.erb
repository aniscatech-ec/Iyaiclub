<%#
  CTA: "Quiero una experiencia personalizada"
  Locales opcionales:
    variant:  :full (default) | :compact | :inline
%>
<% variant ||= :full %>

<% case variant %>
<% when :compact %>
  <div class="text-center my-3">
    <%= link_to new_custom_request_path,
                class: "btn btn-warning btn-lg rounded-pill fw-semibold shadow-sm" do %>
      <i class="fas fa-star me-2"></i> Quiero una experiencia personalizada
    <% end %>
  </div>

<% when :inline %>
  <%= link_to new_custom_request_path,
              class: "btn btn-warning rounded-pill fw-semibold" do %>
    <i class="fas fa-star me-1"></i> Experiencia personalizada
  <% end %>

<% else %>
  <div class="custom-experience-cta card border-0 shadow-sm rounded-4 my-4 overflow-hidden">
    <div class="card-body p-4 p-md-5 text-white"
         style="background: linear-gradient(135deg, var(--brand-orange, #EB633B), #c94a28);">
      <div class="row align-items-center g-3">
        <div class="col-12 col-md-8">
          <h3 class="fw-bold mb-2">
            <i class="fas fa-magic me-2"></i> ¿Buscas algo único?
          </h3>
          <p class="mb-0 lead">
            Nuestro equipo Iyaiclub diseña experiencias a tu medida: hospedaje, gastronomía,
            transporte y actividades. Dinos qué sueñas y lo organizamos por ti.
          </p>
        </div>
        <div class="col-12 col-md-4 text-md-end">
          <%= link_to new_custom_request_path,
                      class: "btn btn-light btn-lg rounded-pill fw-bold w-100 w-md-auto" do %>
            <i class="fas fa-star me-2"></i> Quiero una experiencia personalizada
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
