
<section class="search-hotels mb-4" data-controller="modal">
<!--  <form action="/establishments" method="get" class="row g-2 align-items-end">-->
  <form action="/establishments/search_results" method="get" class="row g-2 align-items-end">

    <!-- Ciudad -->
    <!-- Ciudad -->
    <div class="col-md-4 col-12 position-relative" data-controller="autocomplete">
      <label class="form-label fw-semibold">¿A dónde quieres ir?</label>
      <div class="input-group">
        <span class="input-group-text bg-white"><i class="bi bi-geo-alt text-muted"></i></span>
        <input type="text"
               name="city"
               class="form-control"
               placeholder="Ej: Quito, Cuenca..."
               data-autocomplete-target="input"
               data-action="input->autocomplete#search">
      </div>
      <div class="list-group position-absolute w-100 z-3" data-autocomplete-target="results"></div>
    </div>


    <!-- Establecimientos -->
    <!-- Establecimientos -->
    <div class="col-md-3">
      <label class="form-label fw-semibold">Tipo de establecimiento</label>
      <select name="establishment_type" class="form-select">
        <option value="todos">Todos</option>
        <option value="hotel">Hoteles</option>
        <option value="restaurante">Restaurantes</option>
      </select>
    </div>
    <!-- Comodidades -->
    <div class="col-md-3">
      <label class="form-label fw-semibold d-block">Comodidades</label>
      <button id="amenitiesSummaryBtn" type="button" class="btn btn-outline-primary w-100 text-start" data-bs-toggle="modal" data-bs-target="#amenitiesModal">
        <i class="bi bi-star me-2"></i> Seleccionar
      </button>
    </div>
    <div id="selectedAmenities" hidden></div>

    <!-- Botón Buscar -->
    <div class="col-md-2 d-grid">
      <button type="submit" class="btn btn-primary btn-lg">Buscar</button>
    </div>

  </form>
</section>

<script>

    // Huéspedes
    function updateGuests(type, change) {
        const input = document.getElementById(type);
        let value = parseInt(input.value) + change;
        if (type === 'adults' || type === 'rooms') {
            if (value < 1) value = 1;
        } else if (value < 0) value = 0;
        input.value = value;
    }

    function applyGuests() {
        const adults = document.getElementById("adults").value;
        const children = document.getElementById("children").value;
        const rooms = document.getElementById("rooms").value;

        let summary = `${adults} adulto${adults != 1 ? "s" : ""}`;
        if (children > 0) summary += ` · ${children} niño${children != 1 ? "s" : ""}`;
        summary += ` · ${rooms} habitación${rooms != 1 ? "es" : ""}`;

        document.getElementById("guestsSummaryBtn").innerHTML = `<i class="bi bi-people me-2"></i> ${summary}`;
    }

    function applyAmenities() {
        const checkboxes = document.querySelectorAll('.amenity:checked');
        const selected = Array.from(checkboxes).map(cb => ({
            id: cb.value,
            name: cb.nextElementSibling.textContent.trim() // 👈 toma el texto del label
        }));

        // Limpiar los hidden inputs anteriores
        const container = document.getElementById("selectedAmenities");
        container.innerHTML = "";

        // Crear un hidden input por cada amenity seleccionado
        selected.forEach(item => {
            const hidden = document.createElement("input");
            hidden.type = "hidden";
            hidden.name = "amenities[]";   // Rails lo recibe como array de IDs
            hidden.value = item.id;
            container.appendChild(hidden);
        });

        // Actualizar el botón resumen
        let summary = `<i class="bi bi-star me-2"></i> Seleccionar`;
        if (selected.length > 0) {
            if (selected.length <= 3) {
                summary = `<i class="bi bi-star me-2"></i> ${selected.map(i => i.name).join(" · ")}`;
            } else {
                summary = `<i class="bi bi-star me-2"></i> ${selected.length} comodidades seleccionadas`;
            }
        }

        document.getElementById("amenitiesSummaryBtn").innerHTML = summary;
    }

</script>
