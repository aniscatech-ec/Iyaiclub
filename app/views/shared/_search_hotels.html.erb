<%# ── Desktop: layout horizontal original ── %>
<section class="search-hotels bg-white p-2 rounded-3 shadow-sm d-none d-md-block" data-controller="modal">
  <form action="/establishments" method="get" class="row g-2 align-items-end">
    <div class="col-md-2" data-controller="autocomplete">
      <label class="form-label fw-semibold small mb-1">¿A dónde quieres ir?</label>
      <input type="text" name="city" class="form-control" placeholder="Ej: Quito, Cuenca..."
             data-autocomplete-target="input" data-action="input->autocomplete#search">
      <div class="list-group position-absolute" data-autocomplete-target="results"></div>
    </div>
    <div class="col-md-2">
      <label class="form-label fw-semibold small mb-1">Check-in</label>
      <input type="date" name="checkin" class="form-control">
    </div>
    <div class="col-md-2">
      <label class="form-label fw-semibold small mb-1">Check-out</label>
      <input type="date" name="checkout" class="form-control">
    </div>
    <div class="col-md-2">
      <label class="form-label fw-semibold small mb-1 d-block">Huéspedes</label>
      <button id="guestsSummaryBtnDesktop" type="button" class="btn btn-outline-primary w-100 text-start" data-bs-toggle="modal" data-bs-target="#guestsModal">
        <i class="bi bi-people me-2"></i> Seleccionar
      </button>
    </div>
    <div class="col-md-2">
      <label class="form-label fw-semibold small mb-1 d-block">Comodidades</label>
      <button id="amenitiesSummaryBtnDesktop" type="button" class="btn btn-outline-primary w-100 text-start" data-bs-toggle="modal" data-bs-target="#amenitiesModal">
        <i class="bi bi-star me-2"></i> Seleccionar
      </button>
    </div>
    <div id="selectedAmenitiesDesktop" hidden></div>
    <div class="col-md-2 d-grid">
      <button type="submit" class="btn btn-primary">Buscar</button>
    </div>
  </form>
</section>

<%# ── Móvil: tarjeta compacta ── %>
<section class="search-compact d-md-none mx-3 my-2" data-controller="modal">
  <form action="/establishments" method="get">

    <%# Tarjeta unificada %>
    <div class="search-compact__card">

      <%# Fila 1: Destino %>
      <div class="search-compact__row" data-controller="autocomplete">
        <i class="fas fa-map-marker-alt search-compact__icon" style="color: var(--brand-green);"></i>
        <input type="text" name="city" class="search-compact__input"
               placeholder="¿A dónde vas?"
               data-autocomplete-target="input"
               data-action="input->autocomplete#search">
        <div class="list-group position-absolute" style="top:100%;left:0;right:0;z-index:200;"
             data-autocomplete-target="results"></div>
      </div>

      <div class="search-compact__divider"></div>

      <%# Fila 2: Fechas (check-in y check-out en la misma fila) %>
      <div class="search-compact__row search-compact__row--split">
        <div class="search-compact__half">
          <i class="fas fa-calendar search-compact__icon" style="color:#888;"></i>
          <div class="search-compact__field">
            <span class="search-compact__label">Entrada</span>
            <input type="date" name="checkin" class="search-compact__input search-compact__input--date">
          </div>
        </div>
        <div class="search-compact__split-divider"></div>
        <div class="search-compact__half">
          <i class="fas fa-calendar-check search-compact__icon" style="color:#888;"></i>
          <div class="search-compact__field">
            <span class="search-compact__label">Salida</span>
            <input type="date" name="checkout" class="search-compact__input search-compact__input--date">
          </div>
        </div>
      </div>

      <div class="search-compact__divider"></div>

      <%# Fila 3: Huéspedes %>
      <button id="guestsSummaryBtn" type="button"
              class="search-compact__row search-compact__row--btn"
              data-bs-toggle="modal" data-bs-target="#guestsModal">
        <i class="fas fa-user-friends search-compact__icon" style="color:#888;"></i>
        <div class="search-compact__field">
          <span class="search-compact__label">Huéspedes</span>
          <span class="search-compact__value" id="guestsSummaryText">1 adulto · 1 habitación</span>
        </div>
        <i class="fas fa-chevron-right search-compact__chevron"></i>
      </button>

      <div class="search-compact__divider"></div>

      <%# Fila 4: Comodidades %>
      <button id="amenitiesSummaryBtn" type="button"
              class="search-compact__row search-compact__row--btn"
              data-bs-toggle="modal" data-bs-target="#amenitiesModal">
        <i class="fas fa-star search-compact__icon" style="color:#888;"></i>
        <div class="search-compact__field">
          <span class="search-compact__label">Comodidades</span>
          <span class="search-compact__value" id="amenitiesSummaryText">Cualquiera</span>
        </div>
        <i class="fas fa-chevron-right search-compact__chevron"></i>
      </button>

    </div><%# /card %>

    <div id="selectedAmenities" hidden></div>

    <%# Botón buscar %>
    <button type="submit" class="search-compact__submit">
      <i class="fas fa-search me-2"></i>Buscar
    </button>

  </form>
</section>

<!-- Modal Huéspedes -->
<div class="modal fade" id="guestsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 shadow">
      <div class="modal-header">
        <h5 class="modal-title fw-bold">Selecciona los huéspedes</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
          <span>Adultos</span>
          <div class="input-group" style="width: 140px;">
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('adults', -1)">-</button>
            <input type="text" id="adults" name="adults" class="form-control text-center" value="2" readonly>
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('adults', 1)">+</button>
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <span>Niños</span>
          <div class="input-group" style="width: 140px;">
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('children', -1)">-</button>
            <input type="text" id="children" name="children" class="form-control text-center" value="0" readonly>
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('children', 1)">+</button>
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center">
          <span>Habitaciones</span>
          <div class="input-group" style="width: 140px;">
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('rooms', -1)">-</button>
            <input type="text" id="rooms" name="rooms" class="form-control text-center" value="1" readonly>
            <button type="button" class="btn btn-outline-primary" onclick="updateGuests('rooms', 1)">+</button>
          </div>
        </div>

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cerrar</button>
        <button type="button" class="btn btn-primary rounded-pill" data-bs-dismiss="modal" onclick="applyGuests()">Aplicar</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Comodidades -->
<!-- Modal Comodidades -->
<div class="modal fade" id="amenitiesModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content rounded-4 shadow">
      <div class="modal-header">
        <h5 class="modal-title fw-bold">Elige las comodidades</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row row-cols-2 row-cols-md-3 g-3">
          <% Amenity.with_attached_custom_icon.each do |amenity| %>
            <div class="col">
              <div class="form-check">
                <%= check_box_tag "amenities[]", amenity.name, false, class: "form-check-input amenity", id: "amenity_#{amenity.id}" %>
                <%= label_tag "amenity_#{amenity.id}", amenity.name, class: "form-check-label" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cerrar</button>
        <button type="button" class="btn btn-primary rounded-pill" data-bs-dismiss="modal" onclick="applyAmenities()">Aplicar</button>
      </div>
    </div>
  </div>
</div>

<script>
  function updateGuests(type, change) {
    const input = document.getElementById(type);
    let value = parseInt(input.value) + change;
    if (type === 'adults' || type === 'rooms') { if (value < 1) value = 1; }
    else if (value < 0) value = 0;
    input.value = value;
  }

  function applyGuests() {
    const adults   = document.getElementById("adults").value;
    const children = document.getElementById("children").value;
    const rooms    = document.getElementById("rooms").value;

    let summary = `${adults} adulto${adults != 1 ? "s" : ""}`;
    if (children > 0) summary += ` · ${children} niño${children != 1 ? "s" : ""}`;
    summary += ` · ${rooms} habitación${rooms != 1 ? "es" : ""}`;

    // Desktop
    const desktopBtn = document.getElementById("guestsSummaryBtnDesktop");
    if (desktopBtn) desktopBtn.innerHTML = `<i class="bi bi-people me-2"></i> ${summary}`;

    // Móvil
    const mobileText = document.getElementById("guestsSummaryText");
    if (mobileText) mobileText.textContent = summary;
  }

  function applyAmenities() {
    const checkboxes = document.querySelectorAll('.amenity:checked');
    const selected   = Array.from(checkboxes).map(cb => cb.value);

    // Hidden inputs (móvil y desktop comparten el mismo form en cada versión)
    ['selectedAmenities', 'selectedAmenitiesDesktop'].forEach(id => {
      const container = document.getElementById(id);
      if (!container) return;
      container.innerHTML = "";
      selected.forEach(value => {
        const hidden = document.createElement("input");
        hidden.type  = "hidden";
        hidden.name  = "amenities[]";
        hidden.value = value;
        container.appendChild(hidden);
      });
    });

    const label = selected.length === 0       ? "Cualquiera"
                : selected.length <= 2        ? selected.join(" · ")
                : `${selected.length} seleccionadas`;

    // Desktop
    const desktopBtn = document.getElementById("amenitiesSummaryBtnDesktop");
    if (desktopBtn) desktopBtn.innerHTML = `<i class="bi bi-star me-2"></i> ${selected.length > 0 ? label : "Seleccionar"}`;

    // Móvil
    const mobileText = document.getElementById("amenitiesSummaryText");
    if (mobileText) mobileText.textContent = label;
  }
</script>
