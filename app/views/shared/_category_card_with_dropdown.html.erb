<%
  has_subtypes = category[:subtypes].present?
  cat_path     = category[:path]
  cat_color    = category[:color]
  cat_icon     = category[:icon]
  cat_name     = category[:name]
  is_grouped   = category[:grouped]
%>

<div class="category-card-wrapper" data-controller="dropdown-hover">
  <% if has_subtypes %>
    <%= link_to cat_path, class: "text-decoration-none category-card-link",
        data: { action: "click->dropdown-hover#toggle" } do %>
      <div class="card border-0 shadow-sm d-flex flex-row align-items-center p-2 rounded-3 category-card-hover" style="min-height: 45px;">
        <div class="d-flex align-items-center justify-content-center rounded-2 me-2 flex-shrink-0"
             style="width: 32px; height: 32px; background: <%= cat_color %>15;">
          <i class="fas <%= cat_icon %>" style="color: <%= cat_color %>; font-size: 0.9rem;"></i>
        </div>
        <span class="fw-semibold text-dark" style="font-size: 0.75rem; line-height: 1.2;">
          <%= cat_name %>
          <i class="fas fa-chevron-down ms-1 dropdown-chevron" style="font-size: 0.5rem; opacity: 0.5;"></i>
        </span>
      </div>
    <% end %>

    <div class="category-dropdown">
      <div class="list-group list-group-flush rounded-3 shadow overflow-hidden">
        <%= link_to cat_path, class: "list-group-item list-group-item-action px-3 py-2 fw-semibold",
            style: "font-size: 0.8rem; color: #{cat_color};" do %>
          <i class="fas fa-th-list me-2"></i> Ver todos
        <% end %>

        <% if is_grouped %>
          <% category[:subtypes].each do |group| %>
            <div class="dropdown-section-header px-3 py-1" style="background: <%= cat_color %>10;">
              <small class="fw-bold text-uppercase" style="font-size: 0.7rem; color: <%= cat_color %>; letter-spacing: 0.5px;">
                <%= group[:group] %>
              </small>
            </div>
            <% group[:items].each do |sub| %>
              <%= link_to sub[:path], class: "list-group-item list-group-item-action px-3 py-2",
                  style: "font-size: 0.8rem; padding-left: 1.5rem !important;" do %>
                <i class="fas fa-angle-right me-2" style="color: <%= cat_color %>;"></i>
                <%= sub[:label] %>
              <% end %>
            <% end %>
          <% end %>
        <% else %>
          <% category[:subtypes].each do |sub| %>
            <%= link_to sub[:path], class: "list-group-item list-group-item-action px-3 py-2",
                style: "font-size: 0.8rem;" do %>
              <i class="fas fa-angle-right me-2" style="color: <%= cat_color %>;"></i>
              <%= sub[:label] %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

  <% else %>
    <%= link_to cat_path, class: "text-decoration-none" do %>
      <div class="card border-0 shadow-sm d-flex flex-row align-items-center p-2 rounded-3 category-card-hover" style="min-height: 45px;">
        <div class="d-flex align-items-center justify-content-center rounded-2 me-2 flex-shrink-0"
             style="width: 32px; height: 32px; background: <%= cat_color %>15;">
          <i class="fas <%= cat_icon %>" style="color: <%= cat_color %>; font-size: 0.9rem;"></i>
        </div>
        <span class="fw-semibold text-dark" style="font-size: 0.75rem; line-height: 1.2;">
          <%= cat_name %>
        </span>
      </div>
    <% end %>
  <% end %>
</div>
