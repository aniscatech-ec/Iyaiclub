<%#
  Partial DRY para mostrar errores de validación de forma específica y agrupada.

  Uso:
    render "shared/validation_errors", errors_list: collect_nested_errors(@hotel)

  o más fácilmente desde un form:
    render_validation_errors(@hotel)

  `errors_list` es un array de hashes:
    [{ section:, field:, message:, full: }, ...]
%>
<% if errors_list.present? %>
  <% grouped = errors_list.group_by { |e| e[:section] } %>
  <% total = errors_list.size %>

  <div id="validation-errors-toaster"
       class="alert alert-danger border-0 shadow-lg rounded-3 mb-4 fade show"
       role="alert"
       data-controller="scroll-into-view"
       style="border-left: 6px solid #dc3545 !important;">

    <!-- Cabecera -->
    <div class="d-flex align-items-start justify-content-between mb-3">
      <div class="d-flex align-items-center">
        <div class="flex-shrink-0 me-3">
          <div class="rounded-circle d-flex align-items-center justify-content-center"
               style="width: 44px; height: 44px; background: #dc3545; color: white;">
            <i class="fas fa-exclamation-triangle fa-lg"></i>
          </div>
        </div>
        <div>
          <h5 class="mb-1 fw-bold text-danger">
            <%= total == 1 ? "Falta 1 dato obligatorio" : "Faltan #{total} datos obligatorios" %>
          </h5>
          <p class="mb-0 small text-muted">
            Por favor revisa y completa los siguientes campos antes de continuar:
          </p>
        </div>
      </div>
      <button type="button"
              class="btn-close flex-shrink-0"
              data-bs-dismiss="alert"
              aria-label="Cerrar"></button>
    </div>

    <!-- Lista de errores agrupados por sección -->
    <div class="row g-2">
      <% grouped.each do |section, section_errors| %>
        <div class="col-12 col-md-6">
          <div class="bg-white rounded-3 p-3 h-100 border border-danger-subtle">
            <div class="d-flex align-items-center mb-2 pb-2 border-bottom">
              <i class="fas fa-folder-open text-danger me-2"></i>
              <h6 class="mb-0 fw-bold text-dark"><%= section %></h6>
              <span class="badge bg-danger ms-auto rounded-pill"><%= section_errors.size %></span>
            </div>
            <ul class="mb-0 ps-0 list-unstyled small">
              <% section_errors.each do |err| %>
                <li class="d-flex align-items-start mb-1">
                  <i class="fas fa-angle-right text-danger me-2 mt-1 flex-shrink-0"></i>
                  <div>
                    <span class="fw-semibold text-dark"><%= err[:field] %>:</span>
                    <span class="text-muted"><%= err[:message] %></span>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Ayuda visual final -->
    <div class="mt-3 pt-2 border-top border-danger-subtle text-center">
      <small class="text-muted">
        <i class="fas fa-info-circle me-1"></i>
        Los campos obligatorios están marcados con asterisco en el formulario.
      </small>
    </div>
  </div>

  <script>
    (function () {
      function scrollToErrors() {
        var el = document.getElementById('validation-errors-toaster');
        if (el) {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scrollToErrors);
      } else {
        setTimeout(scrollToErrors, 100);
      }
      document.addEventListener('turbo:load', scrollToErrors);
    })();
  </script>
<% end %>
