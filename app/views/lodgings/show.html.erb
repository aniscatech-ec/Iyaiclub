<div class="container mt-4">
  <div class="card shadow-sm mb-4 border-info">
    <div class="card-header bg-info text-dark d-flex justify-content-between align-items-center">
      <h3 class="mb-0 fw-bold">Hospedaje: <%= @lodging.lodging_type.titleize %></h3>
      <span class="badge bg-white text-info fs-5 border border-info"><%= number_to_currency(@lodging.price_per_night) %> / noche</span>
    </div>
    
    <div class="card-body">
      <h5 class="fw-bold">Establecimiento:</h5>
      <p><%= link_to @lodging.establishment.name, establishment_path(@lodging.establishment), class: "text-decoration-none" %></p>

      <div class="row mt-4 mb-4 bg-light p-3 rounded">
        <div class="col-md-6 border-end">
          <h5 class="fw-bold text-success"><i class="bi bi-box-arrow-in-right"></i> Check-in</h5>
          <p class="fs-5 mb-0"><%= @lodging.check_in_time&.strftime("%H:%M") || 'No especificado' %></p>
        </div>
        <div class="col-md-6 pl-md-4">
          <h5 class="fw-bold text-danger"><i class="bi bi-box-arrow-right"></i> Check-out</h5>
          <p class="fs-5 mb-0"><%= @lodging.check_out_time&.strftime("%H:%M") || 'No especificado' %></p>
        </div>
      </div>

      <h5 class="fw-bold mt-4 border-bottom pb-2">Reglas del Hospedaje:</h5>
      <div class="bg-light p-3 rounded text-secondary">
        <%= simple_format(@lodging.rules.presence || 'Sin reglas registradas.') %>
      </div>
    </div>
    
    <div class="card-footer d-flex gap-2 bg-white border-top-0">
      <%= link_to 'Editar hospedaje', edit_lodging_path(@lodging), class: 'btn btn-warning' %>
      <%= link_to 'Volver a Hospedajes', establishment_lodgings_path(@lodging.establishment), class: 'btn btn-secondary' %>
    </div>
  </div>
</div>
