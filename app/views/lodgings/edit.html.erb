<div class="container mt-4">
  <h2 class="mb-4">Editar Hospedaje: <%= @lodging.lodging_type.titleize %></h2>
  <%= render 'form', lodging: @lodging %>
  <div class="mt-3">
    <%= link_to 'Volver al detalle', lodging_path(@lodging), class: 'btn btn-info' %>
    <%= link_to 'Volver a Hospedajes', establishment_lodgings_path(@lodging.establishment), class: 'btn btn-secondary' %>
  </div>
</div>
